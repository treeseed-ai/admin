---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import MarkdownField from '@treeseed/ui/components/astro/app/controls/MarkdownField.astro';
import ContentFieldHelp from '@treeseed/ui/components/astro/app/controls/ContentFieldHelp.astro';
import { QUESTION_STATUS_OPTIONS, QUESTION_TYPE_OPTIONS } from '../../capabilities/questions.js';
import { contentFieldHelp } from '../../lib/market/content-form-help.js';
import type { QuestionFormViewModel } from '../../view-models/ui-foundation/questions.vm.js';

interface Props {
	viewModel: QuestionFormViewModel;
}

const { viewModel } = Astro.props as Props;
const question = viewModel.question;
const formId = viewModel.mode === 'create' ? 'question-create-form' : 'question-edit-form';
const dataId = viewModel.mode === 'create' ? 'question-create-data' : 'question-edit-data';
const submitLabel = viewModel.mode === 'create' ? 'Create question' : 'Save question';
const typeOptions = QUESTION_TYPE_OPTIONS.filter((option) => option.value);
const statusOptions = QUESTION_STATUS_OPTIONS.filter((option) => option.value);
const fieldHelp = (fieldName: string) => contentFieldHelp(fieldName) ?? { label: fieldName, purpose: '' };
const operationData = JSON.stringify({
	collection: 'questions',
	selectedProjectId: viewModel.selectedProjectId,
	slug: question?.slug ?? '',
	mode: viewModel.mode,
}).replace(/</gu, '\\u003c');
---

<form id={formId} class="ts-form-stack">
	<input type="hidden" name="id" value={question?.id ?? ''} />
	<input type="hidden" name="overwrite" value={viewModel.mode === 'edit' ? 'true' : 'false'} />
	<div class="ts-form-grid">
		<Field label="Project" name="projectId" required>
			<div class="ts-help-row">
				<Select name="projectId" required value={viewModel.selectedProjectId} options={viewModel.projectOptions} />
				<ContentFieldHelp {...fieldHelp('projectId')} />
			</div>
		</Field>
		<Field label="Title" name="title" required>
			<div class="ts-help-row">
				<TextInput name="title" required value={question?.title ?? ''} />
				<ContentFieldHelp {...fieldHelp('title')} />
			</div>
		</Field>
		<Field label="Slug" name="slug">
			<div class="ts-help-row">
				<TextInput name="slug" value={question?.slug ?? ''} placeholder="Generated from title if empty" />
				<ContentFieldHelp {...fieldHelp('slug')} />
			</div>
		</Field>
		<Field label="Status" name="status">
			<div class="ts-help-row">
				<Select name="status" value={question?.status ?? 'planned'} options={statusOptions} />
				<ContentFieldHelp {...fieldHelp('status')} />
			</div>
		</Field>
		<Field label="Question type" name="questionType">
			<div class="ts-help-row">
				<Select name="questionType" value={question?.questionType ?? 'strategy'} options={typeOptions} />
				<ContentFieldHelp {...fieldHelp('questionType')} />
			</div>
		</Field>
	</div>
	<MarkdownField label="Description" name="description" rows={3} required value={question?.description ?? ''} help={fieldHelp('description').purpose} />
	<MarkdownField label="Summary" name="summary" rows={3} value={question?.summary ?? ''} help={fieldHelp('summary').purpose} />
	<Field label="Contributor" name="primaryContributor">
		<div class="ts-help-row">
			<TextInput name="primaryContributor" value={question?.primaryContributor ?? ''} />
			<ContentFieldHelp {...fieldHelp('primaryContributor')} />
		</div>
	</Field>
	<MarkdownField label="Motivation" name="motivation" rows={4} value={question?.motivation ?? ''} help={fieldHelp('motivation').purpose} />
	<div class="ts-form-grid">
		<Field label="Related objectives" name="relatedObjectives">
			<div class="ts-help-row">
				<Textarea name="relatedObjectives" rows={3} value={question?.relatedObjectives.join('\n') ?? ''} />
				<ContentFieldHelp {...fieldHelp('relatedObjectives')} />
			</div>
		</Field>
		<Field label="Related books" name="relatedBooks">
			<div class="ts-help-row">
				<Textarea name="relatedBooks" rows={3} value={question?.relatedBooks.join('\n') ?? ''} />
				<ContentFieldHelp {...fieldHelp('relatedBooks')} />
			</div>
		</Field>
	</div>
	<MarkdownField label="Body" name="body" rows={10} value={question?.body ?? ''} help={fieldHelp('body').purpose} />
	<FormActions align="start">
		<Button type="submit" disabled={viewModel.policy.save !== 'allowed' && viewModel.policy.create !== 'allowed'}>{submitLabel}</Button>
		<Button href={question?.href ?? '/app/work/questions'} variant="secondary">Cancel</Button>
		<span class="ts-subtle" id={viewModel.statusMessageId} role="status"></span>
	</FormActions>
</form>
<script is:inline type="application/json" id={dataId} set:html={operationData}></script>

<script>
	import '@treeseed/ui/lib/app/markdown-field';
	import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

	const dataElement = document.getElementById(document.getElementById('question-edit-data') ? 'question-edit-data' : 'question-create-data');
	const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : {};
	const form = document.getElementById(pageData.mode === 'edit' ? 'question-edit-form' : 'question-create-form') as HTMLFormElement | null;
	const status = document.getElementById(pageData.mode === 'edit' ? 'question-edit-status' : 'question-create-status');
	function value(formData: FormData, key: string) { return String(formData.get(key) ?? '').trim(); }
	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const formData = new FormData(form);
		const projectId = value(formData, 'projectId') || pageData.selectedProjectId;
		const body: any = Object.fromEntries(formData.entries());
		body.overwrite = pageData.mode === 'edit';
		try {
			await submitPlatformOperationForm({
				url: `/v1/projects/${encodeURIComponent(projectId)}/local-content/questions`,
				body,
				statusElement: status,
				fallbackHref: pageData.slug ? `/app/work/questions/${encodeURIComponent(pageData.slug)}` : '/app/work/questions',
				initialMessage: pageData.mode === 'edit' ? 'Queuing question save...' : 'Queuing question creation...',
			});
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'Question could not be saved.';
		}
	});
</script>
