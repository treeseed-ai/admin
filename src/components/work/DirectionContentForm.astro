---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import MarkdownField from '@treeseed/ui/components/astro/app/controls/MarkdownField.astro';
import type { DirectionCollection } from '../../view-models/operating-loop.vm.js';

interface ProjectOption {
	label: string;
	value: string;
}

interface Props {
	collection: DirectionCollection;
	mode: 'create' | 'edit';
	projectOptions: ProjectOption[];
	selectedProjectId: string;
	initialData?: Record<string, any>;
	body?: string;
	slug?: string;
	fallbackHref: string;
}

const {
	collection,
	mode,
	projectOptions,
	selectedProjectId,
	initialData = {},
	body = '',
	slug = '',
	fallbackHref,
} = Astro.props as Props;

const labels: Record<DirectionCollection, { singular: string; typeLabel: string; typeName?: string; options?: Array<{ label: string; value: string }> }> = {
	objectives: { singular: 'objective', typeLabel: 'Horizon', typeName: 'timeHorizon', options: [{ label: 'Near-term', value: 'near-term' }, { label: 'Mid-term', value: 'mid-term' }, { label: 'Long-term', value: 'long-term' }] },
	notes: { singular: 'note', typeLabel: 'Type' },
	proposals: { singular: 'proposal', typeLabel: 'Proposal type', typeName: 'proposalType', options: [{ label: 'Implementation', value: 'implementation' }, { label: 'Strategy', value: 'strategy' }, { label: 'Policy', value: 'policy' }, { label: 'Research', value: 'research' }] },
	decisions: { singular: 'decision', typeLabel: 'Decision type', typeName: 'decisionType', options: [{ label: 'Approved', value: 'approved' }, { label: 'Rejected', value: 'rejected' }, { label: 'Deferred', value: 'deferred' }, { label: 'Request changes', value: 'request_changes' }, { label: 'Superseded', value: 'superseded' }] },
};
const label = labels[collection];
const dataId = `${collection}-${mode}-data`;
const formId = `${collection}-${mode}-form`;
const statusId = `${collection}-${mode}-status`;
const serialized = JSON.stringify({ collection, projectId: selectedProjectId }).replace(/</gu, '\\u003c');
---

<form id={formId} class="ts-form-stack" data-direction-content-form data-direction-data-id={dataId} data-direction-status-id={statusId} data-direction-fallback-href={fallbackHref}>
	{mode === 'edit' ? (
		<>
			<input type="hidden" name="slug" value={slug} />
			<input type="hidden" name="id" value={initialData.id ?? `${label.singular}:${slug}`} />
			<input type="hidden" name="overwrite" value="true" />
		</>
	) : null}
	<div class="ts-form-grid">
		<Field label="Project" name="projectId" required>
			<Select name="projectId" required value={selectedProjectId} options={projectOptions} />
		</Field>
		<Field label="Title" name="title" required>
			<TextInput name="title" required value={initialData.title ?? ''} />
		</Field>
		{mode === 'create' ? (
			<Field label="Slug" name="slug">
				<TextInput name="slug" placeholder="Generated from title if empty" />
			</Field>
		) : null}
		<Field label="Status" name="status">
			<Select name="status" value={initialData.status ?? 'planned'} options={[{ label: 'Planned', value: 'planned' }, { label: 'Live', value: 'live' }, { label: 'In progress', value: 'in progress' }, { label: 'Exploratory', value: 'exploratory' }, { label: 'Speculative', value: 'speculative' }, { label: 'Recorded', value: 'recorded' }]} />
		</Field>
		{label.typeName && label.options ? (
			<Field label={label.typeLabel} name={label.typeName}>
				<Select name={label.typeName} value={initialData[label.typeName] ?? label.options[0]?.value} options={label.options} />
			</Field>
		) : null}
		{collection === 'decisions' ? (
			<Field label="Authority" name="authority">
				<TextInput name="authority" value={initialData.authority ?? 'TreeSeed Market Team'} />
			</Field>
		) : null}
		{collection === 'notes' ? (
			<Field label="Author" name="author">
				<TextInput name="author" value={initialData.author ?? ''} />
			</Field>
		) : collection !== 'decisions' ? (
			<Field label="Contributor" name="primaryContributor">
				<TextInput name="primaryContributor" value={initialData.primaryContributor ?? ''} />
			</Field>
		) : null}
	</div>
	<MarkdownField label="Description" name="description" rows={3} required value={initialData.description ?? ''} />
	<MarkdownField label="Summary" name="summary" rows={3} value={initialData.summary ?? ''} />
	{collection === 'decisions' ? (
		<MarkdownField label="Rationale" name="rationale" rows={4} value={initialData.rationale ?? ''} />
	) : collection !== 'notes' ? (
		<MarkdownField label="Motivation" name="motivation" rows={4} value={initialData.motivation ?? ''} />
	) : null}
	{collection === 'proposals' ? (
		<div class="ts-form-grid">
			<Field label="Related objectives" name="relatedObjectives"><Textarea name="relatedObjectives" rows={3} value={(initialData.relatedObjectives ?? []).join?.('\n') ?? ''} /></Field>
			<Field label="Related questions" name="relatedQuestions"><Textarea name="relatedQuestions" rows={3} value={(initialData.relatedQuestions ?? []).join?.('\n') ?? ''} /></Field>
			<Field label="Related notes" name="relatedNotes"><Textarea name="relatedNotes" rows={3} value={(initialData.relatedNotes ?? []).join?.('\n') ?? ''} /></Field>
		</div>
	) : null}
	{collection === 'decisions' ? (
		<Field label="Related proposals" name="relatedProposals"><Textarea name="relatedProposals" rows={3} value={(initialData.relatedProposals ?? []).join?.('\n') ?? ''} /></Field>
	) : null}
	<MarkdownField label="Body" name="body" rows={10} value={body} />
	<FormActions align="start">
		<Button type="submit">{mode === 'create' ? `Create ${label.singular}` : `Save ${label.singular}`}</Button>
		<Button href={fallbackHref} variant="secondary">Cancel</Button>
		<span class="ts-subtle" id={statusId} role="status"></span>
	</FormActions>
</form>
<script is:inline type="application/json" id={dataId} set:html={serialized}></script>

<script>
	import '@treeseed/ui/lib/app/markdown-field';
	import { bindDirectionContentForms } from '../../lib/market/operating-loop-client';

	bindDirectionContentForms();
</script>
