---
import '@treeseed/ui/styles/tokens.css';
import '@treeseed/ui/styles/theme.css';
import '@treeseed/ui/styles/ui.css';
import '@treeseed/ui/styles/forms.css';
import '@treeseed/ui/styles/app-shell.css';
import '@treeseed/ui/styles/app-controls.css';
import '@treeseed/ui/styles/auth.css';
import ProductShell from '@treeseed/ui/components/astro/shell/ProductShell.astro';
import { resolveAuthenticatedThemePreference } from '../lib/auth/appearance';
import { compileGuidedThemePalette } from '@treeseed/ui/theme';
import { createApiFacade } from '../lib/market/api-client';
import { ensureCsrfToken } from '../lib/auth/csrf';

interface TeamEntry {
	id: string;
	name: string;
	slug?: string;
	displayName?: string | null;
}

interface Props {
	title: string;
	description?: string;
	currentPath: string;
	teams: TeamEntry[];
	activeTeam?: TeamEntry | null;
}

const {
	title,
	description = 'Manage your account, teams, and active team.',
	currentPath,
	teams,
	activeTeam = null,
} = Astro.props as Props;

const appearance = await resolveAuthenticatedThemePreference(Astro);
const api = createApiFacade(Astro);
const [personalThemes, notifications] = await Promise.all([
	api.personalThemes().catch(() => []),
	api.accountNotifications(8).catch(() => []),
]);
const customSchemes = Object.fromEntries(personalThemes.flatMap((theme) => {
	try { return [[theme.schemeId, compileGuidedThemePalette(theme.palette, theme.baseScheme)]]; } catch { return []; }
}));
const themeConfig = { schemes: customSchemes };
const csrfToken = ensureCsrfToken(Astro);
const teamOptions = teams.map((team) => ({
	id: team.id,
	label: team.displayName ?? team.name ?? team.slug ?? team.id,
}));
---

<ProductShell
	title={title}
	description={description}
	currentPath={currentPath}
	appearance={appearance}
	themeConfig={themeConfig}
	notifications={notifications}
	notificationCsrfToken={csrfToken}
	brand={{
		name: 'TreeSeed',
		tag: 'Identity and teams',
		href: '/app/',
		logoSrc: '/logo.svg',
		logoAlt: '',
	}}
	navItems={[
		{ label: 'Start', href: '/app/' },
		{ label: 'Teams', href: '/app/teams' },
	]}
	siteItems={[{ label: 'Home', href: '/' }]}
	quickActions={[
		activeTeam
			? { label: 'Manage team', href: `/app/teams/${encodeURIComponent(activeTeam.id)}/edit`, variant: 'primary' as const }
			: { label: 'Create team', href: '/app/teams/new', variant: 'primary' as const },
	]}
	accountActions={[
		{ label: 'Account', href: '/app/account', variant: 'secondary' as const },
		{ label: 'Sign out', action: '/auth/logout', method: 'post' as const, hiddenFields: { csrfToken }, variant: 'secondary' as const },
	]}
>
	<div slot="railContext" class="ts-team-switcher">
		<div class="ts-section__eyebrow">Active team</div>
		{teams.length > 0 ? (
			<form class="ts-team-selector" aria-label="Active team" data-team-switcher>
				<label class="ts-field ts-team-selector__label">
					<select class="ts-control" name="teamId" aria-label="Active team">
						{teamOptions.map((team) => (
							<option value={team.id} selected={team.id === activeTeam?.id}>{team.label}</option>
						))}
					</select>
				</label>
				<a class="ts-icon-button" href="/app/teams" aria-label="Manage teams">Manage</a>
			</form>
		) : (
			<a class="ts-create-team-button" href="/app/teams/new">Create team</a>
		)}
	</div>
	<slot />
</ProductShell>

<script>
	document.querySelectorAll('[data-team-switcher]').forEach((form) => {
		const select = (form as HTMLFormElement).elements.namedItem('teamId') as HTMLSelectElement | null;
		select?.addEventListener('change', () => {
			const url = new URL(window.location.href);
			url.searchParams.delete('teamId');
			document.cookie = `treeseed_active_team=${encodeURIComponent(select.value)}; path=/app; max-age=31536000; SameSite=Lax`;
			window.location.href = url.toString();
		});
	});
</script>

<script is:inline data-astro-rerun>
	(() => {
		const bindingKey = '__treeseedAuthenticatedAppearanceSyncBound';
		if (window[bindingKey]) return;
		window[bindingKey] = true;
		window.addEventListener('treeseed:theme-change', (event) => {
			const detail = event.detail || {};
			if (detail.persist !== true || !detail.scheme || !detail.mode) return;
			fetch('/v1/auth/web/appearance', {
				method: 'PATCH',
				headers: { accept: 'application/json', 'content-type': 'application/json', 'x-treeseed-csrf': document.cookie.split('; ').find((entry) => entry.startsWith('ts_csrf='))?.split('=').slice(1).join('=') || '' },
				body: JSON.stringify({ colorScheme: detail.scheme, themeMode: detail.mode }),
				keepalive: true,
			}).catch(() => {});
		});
	})();
</script>
