---
import '@treeseed/ui/styles/tokens.css';
import '@treeseed/ui/styles/theme.css';
import '@treeseed/ui/styles/ui.css';
import '@treeseed/ui/styles/forms.css';
import '@treeseed/ui/styles/app-shell.css';
import '@treeseed/ui/styles/site.css';
import '@treeseed/ui/styles/market.css';
import PublicShell from '@treeseed/ui/components/astro/shell/PublicShell.astro';
import ShellIconLink from '@treeseed/ui/components/astro/shell/ShellIconLink.astro';
import { resolveAnonymousThemePreference, resolveAuthenticatedThemePreference } from '../lib/auth/appearance';

interface NavItem {
	label: string;
	href: string;
}

interface Props {
	title?: string;
	description?: string;
	currentPath?: string;
}

const {
	title = 'TreeSeed',
	description = 'Launch, guide, release, and publish knowledge hubs with your team and your agents.',
	currentPath = '/',
} = Astro.props as Props;

const navItems: NavItem[] = [
	{ label: 'Home', href: '/' },
	{ label: 'Resources', href: '/market/' },
	{ label: 'Workflow Imports', href: '/market/templates/' },
	{ label: 'Knowledge Imports', href: '/market/knowledge-packs/' },
];

const isSignedIn = Boolean(Astro.locals.auth?.principal);
const appearance = isSignedIn
	? await resolveAuthenticatedThemePreference(Astro)
	: resolveAnonymousThemePreference(Astro);
const actions = isSignedIn
	? []
	: [
		{ label: 'Sign in', href: '/auth/sign-in', variant: 'ghost' as const },
	];
---

<PublicShell
	title={title}
	description={description}
	currentPath={currentPath}
	appearance={appearance}
	brand={{
		name: 'TreeSeed',
		tag: 'Governable AI Infrastructure for Organizational Continuity',
		href: '/',
		logoSrc: '/logo.svg',
		logoAlt: '',
	}}
	navItems={navItems}
	actions={actions}
	showAppearanceControl
	preferServerAppearance={isSignedIn}
>
	<Fragment slot="actions">
		<ShellIconLink href="/app/" label="Manager" icon="manager" />
	</Fragment>
	<slot />
</PublicShell>
