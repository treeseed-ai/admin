---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import { WEB_SESSION_COOKIE } from '../../lib/auth/config';
import { apiServiceHeaders, clearApiAccessTokenCookie, resolveApiBaseUrl } from '../../lib/market/api-client';
import { resolveAnonymousThemePreference } from '../../lib/auth/appearance';

export const prerender = false;

if (!Astro.locals.auth?.principal) {
	return Astro.redirect('/auth/sign-in?signedOut=1', 303);
}

if (Astro.request.method === 'POST') {
	await fetch(`${resolveApiBaseUrl(Astro.locals)}/v1/auth/logout`, {
		method: 'POST',
		headers: apiServiceHeaders(Astro),
	}).catch(() => null);

	Astro.cookies.delete(WEB_SESSION_COOKIE, {
		path: '/',
		secure: Astro.url.protocol === 'https:',
	});
	clearApiAccessTokenCookie(Astro);

	return Astro.redirect('/auth/sign-in?signedOut=1', 303);
}

const appearance = resolveAnonymousThemePreference(Astro);
---

<AuthShell title="Sign Out | TreeSeed" description="Sign out of TreeSeed Market." appearance={appearance}>
	<AuthCard
		title="Sign out"
		description="End this browser session and return to the anonymous sign-in surface."
		appearance={appearance}
	>
		<form class="auth-form" method="POST" action="/auth/logout" data-scene="logout-form">
			<FormActions>
				<Button type="submit">Sign out</Button>
			</FormActions>
		</form>
	</AuthCard>
</AuthShell>
