---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import AuthDivider from '@treeseed/ui/components/astro/auth/AuthDivider.astro';
import ProviderButtonList from '@treeseed/ui/components/astro/auth/ProviderButtonList.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import {
	authProviderCapabilities,
	isSupportedAuthProvider,
	normalizeReturnTo,
	providerSignInPath,
	redirectAuthenticatedToApp,
	submitMarketEmailAuthFlow,
} from '../../lib/auth/flow';
import { resolveAnonymousThemePreference } from '../../lib/auth/appearance';

export const prerender = false;

const authenticatedRedirect = redirectAuthenticatedToApp(Astro);
if (authenticatedRedirect) {
	return authenticatedRedirect;
}

const returnTo = normalizeReturnTo(Astro);
const capabilities = authProviderCapabilities(Astro);
const provider = Astro.url.searchParams.get('provider');
let error = Astro.url.searchParams.get('error') ?? '';
let submittedIdentifier = '';
const notice = Astro.url.searchParams.get('reset') === 'complete'
	? 'Password reset complete. You can sign in with your new password.'
	: Astro.url.searchParams.get('verified')
		? 'Email verified. Sign in to continue.'
		: Astro.url.searchParams.get('signedOut')
			? 'You have been signed out.'
		: '';
let oauthRedirectPath = '';

if (Astro.request.method === 'GET' && provider) {
	if (!isSupportedAuthProvider(provider)) {
		error = 'Unsupported provider.';
	} else {
		const providerEntry = capabilities.providers.find((entry) => entry.id === provider);
		if (!providerEntry?.enabled) {
			error = 'That provider is not configured for this environment.';
		} else {
			oauthRedirectPath = providerSignInPath(Astro, provider, returnTo);
		}
	}
}

if (oauthRedirectPath) {
	return Astro.redirect(oauthRedirectPath, 302);
}

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	const identifier = String(form.get('login') ?? form.get('email') ?? '').trim();
	const password = String(form.get('password') ?? '');
	submittedIdentifier = identifier;
	if (!identifier || !password) {
		error = 'Email or username and password are required.';
	} else {
		const result = await submitMarketEmailAuthFlow(Astro, 'sign-in/email', {
			login: identifier,
			password,
			rememberMe: true,
		});
		if (result.ok) {
			const response = Astro.redirect(returnTo, 303);
			for (const cookie of Astro.cookies.headers()) {
				response.headers.append('set-cookie', cookie);
			}
			return response;
		}
		error = result.error;
	}
}

const enabledProviders = capabilities.providers.filter((entry) => entry.enabled);
const appearance = resolveAnonymousThemePreference(Astro);
---

<AuthShell title="Sign In | TreeSeed" description="Sign in to TreeSeed Market." appearance={appearance}>
	<AuthCard
		title="Sign in"
		description="Use your account email or username and password, or continue with a configured provider."
		error={error}
		notice={notice}
		appearance={appearance}
	>
		<Fragment slot="sidebarLinks">
			{capabilities.internal.enabled ? (
				<a href={`/auth/forgot-password?returnTo=${encodeURIComponent(returnTo)}`}>Forgot password?</a>
			) : null}
			{capabilities.internal.signupEnabled ? (
				<a href={`/auth/register?returnTo=${encodeURIComponent(returnTo)}`}>Create account</a>
			) : null}
		</Fragment>
		{capabilities.internal.enabled ? (
			<form class="auth-form" method="POST" action={`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`}>
				<Field label="Email or username" name="login" required>
					<TextInput name="login" type="text" autocomplete="username" value={submittedIdentifier} required />
				</Field>
				<Field label="Password" name="password" required>
					<TextInput name="password" type="password" autocomplete="current-password" required minlength={8} />
				</Field>
				<FormActions>
					<Button type="submit">Sign in</Button>
				</FormActions>
			</form>
		) : null}
		{enabledProviders.length > 0 ? (
			<>
				<AuthDivider />
				<ProviderButtonList providers={enabledProviders} returnTo={returnTo} />
			</>
		) : null}
	</AuthCard>
</AuthShell>
