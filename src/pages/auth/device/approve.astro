---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import { resolveAnonymousThemePreference } from '../../../lib/auth/appearance';

export const prerender = false;

const principal = Astro.locals.auth?.principal;

if (!principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`, 302);
}

const activePrincipal = principal;
const appearance = resolveAnonymousThemePreference(Astro);
let userCode = String(Astro.url.searchParams.get('user_code') ?? '').trim().toUpperCase();
let error = '';
let notice = Astro.url.searchParams.get('approved') === '1' ? 'CLI login approved. You can return to your terminal.' : '';
let approved = Astro.url.searchParams.get('approved') === '1';

function runtimeApiBaseUrl() {
	const env = (Astro.locals.runtime?.env ?? {}) as Record<string, unknown>;
	const value = env.TREESEED_API_BASE_URL ?? env.TREESEED_MARKET_API_BASE_URL;
	if (Astro.url.hostname === '127.0.0.1' || Astro.url.hostname === 'localhost') {
		if (typeof value === 'string' && value.trim()) {
			return value.trim().replace(/\/+$/u, '');
		}
		return 'http://127.0.0.1:3000';
	}
	return '';
}

function approvalEndpoints() {
	const localApiBaseUrl = runtimeApiBaseUrl();
	if (localApiBaseUrl) {
		return {
			formAction: `${Astro.url.pathname}${Astro.url.search}`,
			serverUrls: [
				`${localApiBaseUrl}/auth/device/approve`,
				`${localApiBaseUrl}/v1/auth/device/approve`,
			],
		};
	}
	return {
		formAction: `${Astro.url.pathname}${Astro.url.search}`,
		serverUrls: [`${Astro.url.origin}/v1/auth/device/approve`],
	};
}

async function approveThroughApi() {
	const payload = {
		userCode,
		principalId: activePrincipal.id,
		displayName: activePrincipal.displayName ?? activePrincipal.id,
		metadata: activePrincipal.metadata ?? {},
	};
	const errors: string[] = [];
	for (const url of approvalEndpoints().serverUrls) {
		const response = await fetch(url, {
			method: 'POST',
			headers: { 'content-type': 'application/json' },
			body: JSON.stringify(payload),
		});
		if (response.ok) return true;
		const body = await response.json().catch(() => null);
		const message = typeof body?.error === 'string'
			? body.error
			: `Device login approval failed with status ${response.status}.`;
		if (response.status !== 404) {
			errors.push(message);
		}
	}
	throw new Error(errors[0] ?? 'Device login approval endpoint was not found.');
}

const directApprovalAction = approvalEndpoints().formAction;
const approvalRedirectTo = `${Astro.url.origin}/auth/device/approve?approved=1`;
const principalMetadata = JSON.stringify(activePrincipal.metadata ?? {});

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	userCode = String(form.get('userCode') ?? '').trim().toUpperCase();
	if (!userCode) {
		error = 'Enter the CLI login code to approve this session.';
	} else {
		try {
			const approvedByApi = await approveThroughApi();
			if (!approvedByApi) throw new Error('Device login approval endpoint was not found.');
			approved = true;
			notice = 'CLI login approved. You can return to your terminal.';
		} catch (approvalError) {
			error = approvalError instanceof Error
				? approvalError.message
				: 'CLI login approval failed.';
		}
	}
}
---

<AuthShell title="Approve CLI Login | TreeSeed" description="Approve a TreeSeed CLI device login." appearance={appearance}>
	<AuthCard
		title={approved ? 'CLI login approved' : 'Approve CLI login'}
		description={approved
			? 'The terminal session can now finish signing in.'
			: 'Confirm the code shown by the TreeSeed CLI to connect this account.'}
		error={error}
		notice={notice}
		appearance={appearance}
	>
		{approved ? (
			<p class="auth-card__footer">
				You may close this tab.
			</p>
		) : (
			<form class="auth-form" method="POST" action={directApprovalAction}>
				<input type="hidden" name="principalId" value={activePrincipal.id} />
				<input type="hidden" name="displayName" value={activePrincipal.displayName ?? activePrincipal.id} />
				<input type="hidden" name="metadata" value={principalMetadata} />
				<input type="hidden" name="redirectTo" value={approvalRedirectTo} />
				<Field label="CLI login code" name="userCode" required>
					<TextInput name="userCode" type="text" value={userCode} autocomplete="one-time-code" required />
				</Field>
				<FormActions>
					<Button type="submit">Approve login</Button>
				</FormActions>
			</form>
		)}
	</AuthCard>
</AuthShell>
