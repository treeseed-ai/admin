---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import { resolveAnonymousThemePreference } from '../../../lib/auth/appearance';
import { createApiFacade } from '../../../lib/market/api-client';
import { ensureCsrfToken, requireCsrf } from '../../../lib/auth/csrf';

export const prerender = false;

const principal = Astro.locals.auth?.principal;

if (!principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(`${Astro.url.pathname}${Astro.url.search}`)}`, 302);
}

const appearance = resolveAnonymousThemePreference(Astro);
const api = createApiFacade(Astro);
const csrfToken = ensureCsrfToken(Astro);
let userCode = String(Astro.url.searchParams.get('user_code') ?? '').trim().toUpperCase();
let error = '';
let notice = Astro.url.searchParams.get('approved') === '1' ? 'CLI login approved. You can return to your terminal.' : '';
let approved = Astro.url.searchParams.get('approved') === '1';

async function approveThroughApi() {
	await api.approveDevice(userCode);
	return true;
}

const directApprovalAction = `${Astro.url.pathname}${Astro.url.search}`;

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	requireCsrf(Astro, form.get('csrfToken'));
	userCode = String(form.get('userCode') ?? '').trim().toUpperCase();
	if (!userCode) {
		error = 'Enter the CLI login code to approve this session.';
	} else {
		try {
			const approvedByApi = await approveThroughApi();
			if (!approvedByApi) throw new Error('Device login approval endpoint was not found.');
			approved = true;
			notice = 'CLI login approved. You can return to your terminal.';
		} catch (approvalError) {
			error = approvalError instanceof Error
				? approvalError.message
				: 'CLI login approval failed.';
		}
	}
}
---

<AuthShell title="Approve CLI Login | TreeSeed" description="Approve a TreeSeed CLI device login." appearance={appearance}>
	<AuthCard
		title={approved ? 'CLI login approved' : 'Approve CLI login'}
		description={approved
			? 'The terminal session can now finish signing in.'
			: 'Confirm the code shown by the TreeSeed CLI to connect this account.'}
		error={error}
		notice={notice}
		appearance={appearance}
	>
		{approved ? (
			<p class="auth-card__footer">
				You may close this tab.
			</p>
		) : (
			<form class="auth-form" method="POST" action={directApprovalAction}>
				<input type="hidden" name="csrfToken" value={csrfToken} />
				<Field label="CLI login code" name="userCode" required>
					<TextInput name="userCode" type="text" value={userCode} autocomplete="one-time-code" required />
				</Field>
				<FormActions>
					<Button type="submit">Approve login</Button>
				</FormActions>
			</form>
		)}
	</AuthCard>
</AuthShell>
