---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import RegistrationForm from '@treeseed/ui/components/astro/auth/RegistrationForm.astro';
import { authProviderCapabilities, normalizeReturnTo, redirectAuthenticatedToApp, submitMarketEmailAuthFlow } from '../../lib/auth/flow';
import { composeDisplayNameFromParts, normalizeUsername, validateUsername } from '../../lib/auth/profile-validation';
import { passwordMeetsPolicy, passwordPolicyMessage } from '../../lib/auth/password-policy';
import { resolveAnonymousThemePreference, setAnonymousThemeCookies } from '../../lib/auth/appearance';

export const prerender = false;

const authenticatedRedirect = redirectAuthenticatedToApp(Astro);
if (authenticatedRedirect) {
	return authenticatedRedirect;
}

const returnTo = normalizeReturnTo(Astro);
const inviteToken = Astro.url.searchParams.get('inviteToken') ?? '';
const invitedEmail = Astro.url.searchParams.get('email') ?? '';
const capabilities = authProviderCapabilities(Astro);
let error = Astro.url.searchParams.get('error') ?? '';
let appearance = resolveAnonymousThemePreference(Astro);
let submittedFirstName = '';
let submittedLastName = '';
let submittedUsername = '';
let submittedEmail = invitedEmail;

if (!capabilities.internal.signupEnabled) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}&error=${encodeURIComponent('Registration is not open in this environment.')}`, 302);
}

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	appearance = resolveAnonymousThemePreference(Astro, form);
	const firstName = String(form.get('firstName') ?? '').trim();
	const lastName = String(form.get('lastName') ?? '').trim();
	const name = composeDisplayNameFromParts(firstName, lastName);
	const username = normalizeUsername(String(form.get('username') ?? ''));
	const email = String(form.get('email') ?? '').trim();
	const password = String(form.get('password') ?? '');
	const confirmPassword = String(form.get('confirmPassword') ?? '');
	const submittedInviteToken = String(form.get('inviteToken') ?? inviteToken).trim();
	submittedFirstName = firstName;
	submittedLastName = lastName;
	submittedUsername = username;
	submittedEmail = email;
	const usernameValidation = validateUsername(username);
	if (!firstName || !lastName || !username || !email || !password || !confirmPassword) {
		error = 'First name, last name, username, email, password, and password confirmation are required.';
	} else if (!usernameValidation.ok) {
		error = usernameValidation.message;
	} else if (password !== confirmPassword) {
		error = 'Passwords do not match.';
	} else if (!passwordMeetsPolicy(password)) {
		error = passwordPolicyMessage();
	} else {
		const result = await submitMarketEmailAuthFlow(Astro, 'sign-up/email', {
			name,
			displayName: name,
			firstName,
			lastName,
			username: usernameValidation.username,
			email,
			password,
			...(submittedInviteToken ? { inviteToken: submittedInviteToken } : {}),
			appearance,
			rememberMe: true,
			returnTo,
		});
		if (result.ok) {
			setAnonymousThemeCookies(Astro, appearance);
			if (result.confirmationRequired) {
				return Astro.redirect(`/auth/check-email?kind=verify&email=${encodeURIComponent(email)}&returnTo=${encodeURIComponent(returnTo)}`, 303);
			}
			const response = Astro.redirect(returnTo, 303);
			for (const cookie of Astro.cookies.headers()) {
				response.headers.append('set-cookie', cookie);
			}
			return response;
		}
		error = result.error;
	}
}
---

<AuthShell title="Create Account | TreeSeed" description="Create an internal login for the market control plane." appearance={appearance}>
	<AuthCard
		title="Create account"
		description="Create an internal login for the market control plane."
		error={error}
		appearance={appearance}
		showAppearance={false}
	>
		<Fragment slot="sidebarLinks">
			<a href={`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`}>Sign in</a>
		</Fragment>
		<RegistrationForm
			action={`/auth/register?returnTo=${encodeURIComponent(returnTo)}${inviteToken ? `&inviteToken=${encodeURIComponent(inviteToken)}` : ''}${invitedEmail ? `&email=${encodeURIComponent(invitedEmail)}` : ''}`}
			values={{ firstName: submittedFirstName, lastName: submittedLastName, username: submittedUsername, email: submittedEmail }}
			appearance={appearance}
			inviteToken={inviteToken}
			invitedEmailReadonly={Boolean(inviteToken && invitedEmail)}
		/>
	</AuthCard>
</AuthShell>
