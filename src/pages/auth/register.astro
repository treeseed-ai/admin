---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import PasswordMeter from '@treeseed/ui/components/astro/forms/PasswordMeter.astro';
import { authProviderCapabilities, normalizeReturnTo, redirectAuthenticatedToApp, submitMarketEmailAuthFlow } from '../../lib/auth/flow';
import { composeDisplayNameFromParts, normalizeUsername, validateUsername } from '../../lib/auth/profile-validation';
import { passwordMeetsPolicy, passwordPolicyMessage } from '../../lib/auth/password-policy';
import { resolveAnonymousThemePreference, setAnonymousThemeCookies } from '../../lib/auth/appearance';

export const prerender = false;

const authenticatedRedirect = redirectAuthenticatedToApp(Astro);
if (authenticatedRedirect) {
	return authenticatedRedirect;
}

const returnTo = normalizeReturnTo(Astro);
const inviteToken = Astro.url.searchParams.get('inviteToken') ?? '';
const invitedEmail = Astro.url.searchParams.get('email') ?? '';
const capabilities = authProviderCapabilities(Astro);
let error = Astro.url.searchParams.get('error') ?? '';
let appearance = resolveAnonymousThemePreference(Astro);
let submittedFirstName = '';
let submittedLastName = '';
let submittedUsername = '';
let submittedEmail = invitedEmail;

if (!capabilities.internal.signupEnabled) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}&error=${encodeURIComponent('Registration is not open in this environment.')}`, 302);
}

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	appearance = resolveAnonymousThemePreference(Astro, form);
	const firstName = String(form.get('firstName') ?? '').trim();
	const lastName = String(form.get('lastName') ?? '').trim();
	const name = composeDisplayNameFromParts(firstName, lastName);
	const username = normalizeUsername(String(form.get('username') ?? ''));
	const email = String(form.get('email') ?? '').trim();
	const password = String(form.get('password') ?? '');
	const confirmPassword = String(form.get('confirmPassword') ?? '');
	const submittedInviteToken = String(form.get('inviteToken') ?? inviteToken).trim();
	submittedFirstName = firstName;
	submittedLastName = lastName;
	submittedUsername = username;
	submittedEmail = email;
	const usernameValidation = validateUsername(username);
	if (!firstName || !lastName || !username || !email || !password || !confirmPassword) {
		error = 'First name, last name, username, email, password, and password confirmation are required.';
	} else if (!usernameValidation.ok) {
		error = usernameValidation.message;
	} else if (password !== confirmPassword) {
		error = 'Passwords do not match.';
	} else if (!passwordMeetsPolicy(password)) {
		error = passwordPolicyMessage();
	} else {
		const result = await submitMarketEmailAuthFlow(Astro, 'sign-up/email', {
			name,
			displayName: name,
			firstName,
			lastName,
			username: usernameValidation.username,
			email,
			password,
			...(submittedInviteToken ? { inviteToken: submittedInviteToken } : {}),
			appearance,
			rememberMe: true,
			returnTo,
		});
		if (result.ok) {
			setAnonymousThemeCookies(Astro, appearance);
			if (result.confirmationRequired) {
				return Astro.redirect(`/auth/check-email?kind=verify&email=${encodeURIComponent(email)}&returnTo=${encodeURIComponent(returnTo)}`, 303);
			}
			const response = Astro.redirect(returnTo, 303);
			for (const cookie of Astro.cookies.headers()) {
				response.headers.append('set-cookie', cookie);
			}
			return response;
		}
		error = result.error;
	}
}
---

<AuthShell title="Create Account | TreeSeed" description="Create an internal login for the market control plane." appearance={appearance}>
	<AuthCard
		title="Create account"
		description="Create an internal login for the market control plane."
		error={error}
		appearance={appearance}
		showAppearance={false}
	>
		<Fragment slot="sidebarLinks">
			<a href={`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`}>Sign in</a>
		</Fragment>
		<form class="auth-form" method="POST" action={`/auth/register?returnTo=${encodeURIComponent(returnTo)}${inviteToken ? `&inviteToken=${encodeURIComponent(inviteToken)}` : ''}${invitedEmail ? `&email=${encodeURIComponent(invitedEmail)}` : ''}`}>
			<input type="hidden" name="colorScheme" value={appearance.scheme} data-auth-theme-scheme-field />
			<input type="hidden" name="themeMode" value={appearance.mode} data-auth-theme-mode-field />
			{inviteToken && <input type="hidden" name="inviteToken" value={inviteToken} />}
			<div class="auth-form-grid">
				<Field label="First name" name="firstName" required>
					<TextInput name="firstName" type="text" autocomplete="given-name" value={submittedFirstName} required />
				</Field>
				<Field label="Last name" name="lastName" required>
					<TextInput name="lastName" type="text" autocomplete="family-name" value={submittedLastName} required />
				</Field>
			</div>
			<Field label="Username" name="username" required>
				<TextInput
					data-username-input
					name="username"
					type="text"
					autocomplete="username"
					value={submittedUsername}
					required
					minlength={1}
					maxlength={39}
					pattern="[A-Za-z0-9](?:[A-Za-z0-9\-]{0,37}[A-Za-z0-9])?"
					aria-describedby="username-status"
				/>
				<span id="username-status" data-username-status class="auth-field-help">Username is public and cannot be changed after registration.</span>
			</Field>
			<Field label="Email" name="email" required>
				<TextInput name="email" type="email" autocomplete="email" value={submittedEmail} required readonly={Boolean(inviteToken && invitedEmail)} />
			</Field>
			<Field label="Password" name="password" required>
				<TextInput id="registerPassword" data-password-input name="password" type="password" autocomplete="new-password" required minlength={12} />
			</Field>
			<Field label="Confirm password" name="confirmPassword" required>
				<TextInput data-confirm-password-input name="confirmPassword" type="password" autocomplete="new-password" required minlength={12} />
			</Field>
			<PasswordMeter inputId="registerPassword" />
			<FormActions>
				<Button type="submit">Create account</Button>
			</FormActions>
		</form>
	</AuthCard>
	<script is:inline data-astro-rerun>
		const input = document.querySelector('[data-password-input]');
		const confirmInput = document.querySelector('[data-confirm-password-input]');
		const usernameInput = document.querySelector('[data-username-input]');
		const usernameStatus = document.querySelector('[data-username-status]');
		const schemeField = document.querySelector('[data-auth-theme-scheme-field]');
		const modeField = document.querySelector('[data-auth-theme-mode-field]');
		const submitButton = document.querySelector('form.auth-form button[type="submit"]');

		function currentThemePreference() {
			const root = document.documentElement;
			return {
				scheme: root.dataset.tsScheme || schemeField?.value || 'fern',
				mode: root.dataset.tsModeSource === 'system' ? 'system' : (root.dataset.tsMode || modeField?.value || 'system'),
			};
		}

		function syncThemeFields(event) {
			const detail = event?.detail || currentThemePreference();
			if (schemeField) schemeField.value = detail.scheme || currentThemePreference().scheme;
			if (modeField) modeField.value = detail.mode || currentThemePreference().mode;
		}

		function setUsernameState(status, message) {
			if (!usernameInput || !usernameStatus) return;
			if (!status || status === 'empty') {
				usernameInput.removeAttribute('data-username-state');
				usernameStatus.removeAttribute('data-tone');
				usernameStatus.textContent = message || 'Username is public and cannot be changed after registration.';
				return;
			}
			usernameInput.setAttribute('data-username-state', status);
			if (status === 'checking') {
				usernameStatus.removeAttribute('data-tone');
			} else {
				usernameStatus.setAttribute('data-tone', status === 'available' ? 'success' : 'danger');
			}
			usernameStatus.textContent = message;
			if (submitButton) submitButton.disabled = status === 'taken' || status === 'invalid' || status === 'reserved' || status === 'error';
		}

		let usernameCheckSequence = 0;
		let usernameCheckTimer = 0;
		async function updateUsernameAvailability() {
			if (!usernameInput) return;
			const value = usernameInput.value.trim();
			const sequence = ++usernameCheckSequence;
			if (!value) {
				setUsernameState('empty', 'Username is public and cannot be changed after registration.');
				if (submitButton) submitButton.disabled = false;
				return;
			}
			setUsernameState('checking', 'Checking username availability...');
			try {
				const response = await fetch(`/v1/auth/web/username/check?username=${encodeURIComponent(value)}`, {
					headers: { accept: 'application/json' },
				});
				const result = await response.json();
				if (sequence !== usernameCheckSequence || usernameInput.value.trim() !== value) return;
				const payload = result?.payload || result;
				setUsernameState(payload.status, payload.message);
			} catch {
				if (sequence !== usernameCheckSequence) return;
				setUsernameState('error', 'Username availability could not be checked.');
			}
		}

		function scheduleUsernameAvailability() {
			clearTimeout(usernameCheckTimer);
			usernameCheckTimer = setTimeout(updateUsernameAvailability, 250);
		}

		function updateConfirmState() {
			const password = input?.value ?? '';
			const confirmPassword = confirmInput?.value ?? '';
			if (!confirmInput) return;
			if (!confirmPassword) {
				confirmInput.removeAttribute('data-match-state');
				return;
			}
			confirmInput.setAttribute('data-match-state', password && password === confirmPassword ? 'match' : 'mismatch');
		}

		input?.addEventListener('input', updateConfirmState);
		usernameInput?.addEventListener('input', scheduleUsernameAvailability);
		usernameInput?.addEventListener('change', updateUsernameAvailability);
		confirmInput?.addEventListener('input', updateConfirmState);
		window.addEventListener('treeseed:theme-change', syncThemeFields);
		document.querySelector('form.auth-form')?.addEventListener('submit', () => syncThemeFields());
		updateConfirmState();
		updateUsernameAvailability();
		syncThemeFields();
	</script>
</AuthShell>
