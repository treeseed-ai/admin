---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import PasswordMeter from '@treeseed/ui/components/astro/forms/PasswordMeter.astro';
import { resolveAnonymousThemePreference } from '../../lib/auth/appearance';
import { normalizeReturnTo, redirectAuthenticatedToApp } from '../../lib/auth/flow';
import { passwordMeetsPolicy, passwordPolicyMessage } from '../../lib/auth/password-policy';
import { createApiFacade } from '../../lib/market/api-client';

export const prerender = false;

const authenticatedRedirect = redirectAuthenticatedToApp(Astro);
if (authenticatedRedirect) {
	return authenticatedRedirect;
}

const returnTo = normalizeReturnTo(Astro);
let token = Astro.url.searchParams.get('token') ?? '';
let error = Astro.url.searchParams.get('error') ? 'This password reset link is invalid or expired.' : '';
const appearance = resolveAnonymousThemePreference(Astro);
const api = createApiFacade(Astro);

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	token = String(form.get('token') ?? '').trim();
	const password = String(form.get('password') ?? '');
	const confirmPassword = String(form.get('confirmPassword') ?? '');
	if (!token) {
		error = 'This password reset link is invalid or expired.';
	} else if (!password || !confirmPassword) {
		error = 'Password and password confirmation are required.';
	} else if (password !== confirmPassword) {
		error = 'Passwords do not match.';
	} else if (!passwordMeetsPolicy(password)) {
		error = passwordPolicyMessage();
	} else {
		try {
			await api.completePasswordReset(token, password);
			return Astro.redirect(`/auth/sign-in?reset=complete&returnTo=${encodeURIComponent(returnTo)}`, 303);
		} catch (resetError) {
			error = resetError instanceof Error ? resetError.message : 'Unable to reset password.';
		}
	}
}
---

<AuthShell title="Reset Password | TreeSeed" description="Set a new TreeSeed Market password." appearance={appearance}>
	<AuthCard
		title="Choose a new password"
		description="Set a strong password for your internal Treeseed Market login."
		error={error}
		appearance={appearance}
	>
		<Fragment slot="sidebarLinks">
			<a href={`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`}>Back to sign in</a>
		</Fragment>
		<form class="auth-form" method="POST" action={`/auth/reset-password?returnTo=${encodeURIComponent(returnTo)}`}>
			<input type="hidden" name="token" value={token} />
			<Field label="New password" name="password" required>
				<TextInput id="resetPassword" name="password" type="password" autocomplete="new-password" required minlength={12} />
			</Field>
			<Field label="Confirm new password" name="confirmPassword" required>
				<TextInput name="confirmPassword" type="password" autocomplete="new-password" required minlength={12} />
			</Field>
			<PasswordMeter inputId="resetPassword" />
			<FormActions>
				<Button type="submit">Reset password</Button>
			</FormActions>
		</form>
	</AuthCard>
</AuthShell>
