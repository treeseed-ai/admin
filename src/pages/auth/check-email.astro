---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import { resolveAnonymousThemePreference } from '../../lib/auth/appearance';
import { normalizeReturnTo, redirectAuthenticatedToApp } from '../../lib/auth/flow';

export const prerender = false;

const authenticatedRedirect = redirectAuthenticatedToApp(Astro);
if (authenticatedRedirect) {
	return authenticatedRedirect;
}

const returnTo = normalizeReturnTo(Astro);
const kind = Astro.url.searchParams.get('kind') ?? 'verify';
const email = Astro.url.searchParams.get('email') ?? '';
const isReset = kind === 'reset';
const appearance = resolveAnonymousThemePreference(Astro);
const description = `${isReset
	? 'If that account exists, a password reset link is on its way.'
	: 'Open the verification link to finish creating your account.'}${email ? ` We sent it to ${email}.` : ''}`;
---

<AuthShell title="Check Email | TreeSeed" description="Check your email to continue." appearance={appearance}>
	<AuthCard
		title="Check your email"
		description={description}
		appearance={appearance}
	>
		<Fragment slot="sidebarLinks">
			<a href={`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`}>
				{isReset ? 'Back to sign in' : 'I verified my email'}
			</a>
		</Fragment>
	</AuthCard>
</AuthShell>
