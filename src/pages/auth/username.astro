---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import { resolveAnonymousThemePreference } from '../../lib/auth/appearance';
import { normalizeReturnTo } from '../../lib/auth/flow';

export const prerender = false;

const returnTo = normalizeReturnTo(Astro);
const appearance = resolveAnonymousThemePreference(Astro);
---

<AuthShell title="Username Managed | TreeSeed" description="Usernames are managed by the API." appearance={appearance}>
	<AuthCard
		title="Username already configured"
		description="TreeSeed Market usernames are now assigned during account creation by the backend API."
		appearance={appearance}
	>
		<FormActions>
			<Button href={returnTo}>Continue</Button>
		</FormActions>
	</AuthCard>
</AuthShell>
