---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import { resolveAnonymousThemePreference } from '../../lib/auth/appearance';
import { normalizeReturnTo, redirectAuthenticatedToApp } from '../../lib/auth/flow';
import { resolveApiBaseUrl } from '../../lib/market/api-client';

export const prerender = false;

const authenticatedRedirect = redirectAuthenticatedToApp(Astro);
if (authenticatedRedirect) {
	return authenticatedRedirect;
}

const returnTo = normalizeReturnTo(Astro);
let error = '';
let submittedEmail = '';
const appearance = resolveAnonymousThemePreference(Astro);

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	const email = String(form.get('email') ?? '').trim();
	submittedEmail = email;
	if (!email) {
		error = 'Email is required.';
	} else {
		const response = await fetch(`${resolveApiBaseUrl(Astro.locals)}/v1/auth/web/password-reset/request`, {
			method: 'POST',
			headers: { accept: 'application/json', 'content-type': 'application/json' },
			body: JSON.stringify({ email }),
		});
		if (response.ok) {
			return Astro.redirect(`/auth/check-email?kind=reset&email=${encodeURIComponent(email)}&returnTo=${encodeURIComponent(returnTo)}`, 303);
		}
		const result = await response.json().catch(() => null);
		error = result?.error ?? 'Password reset could not be requested.';
	}
}
---

<AuthShell title="Forgot Password | TreeSeed" description="Send a password reset link." appearance={appearance}>
	<AuthCard
		title="Reset password"
		description="Enter your account email and we will send a reset link."
		error={error}
		appearance={appearance}
	>
		<Fragment slot="sidebarLinks">
			<a href={`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`}>Back to sign in</a>
		</Fragment>
		<form class="auth-form" method="POST" action={`/auth/forgot-password?returnTo=${encodeURIComponent(returnTo)}`}>
			<Field label="Email" name="email" required>
				<TextInput name="email" type="email" autocomplete="email" value={submittedEmail} required />
			</Field>
			<FormActions>
				<Button type="submit">Send reset link</Button>
			</FormActions>
		</form>
	</AuthCard>
</AuthShell>
