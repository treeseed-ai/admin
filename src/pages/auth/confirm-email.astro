---
import AuthShell from '@treeseed/ui/components/astro/auth/AuthShell.astro';
import AuthCard from '@treeseed/ui/components/astro/auth/AuthCard.astro';
import { resolveApiBaseUrl, setApiAccessTokenCookie } from '../../lib/market/api-client';
import { resolveAnonymousThemePreference, setAnonymousThemeCookies, setPrincipalThemeCookies } from '../../lib/auth/appearance';
import { authApiJsonHeaders, normalizeReturnTo, redirectAuthenticatedToApp } from '../../lib/auth/flow';

export const prerender = false;

const returnTo = normalizeReturnTo(Astro);
const token = Astro.url.searchParams.get('token') ?? '';
const appearance = resolveAnonymousThemePreference(Astro);
let error = '';

if (token) {
	const response = await fetch(`${resolveApiBaseUrl(Astro.locals)}/v1/auth/web/confirm-email`, {
		method: 'POST',
		headers: authApiJsonHeaders(Astro),
		body: JSON.stringify({ token }),
	});
	const envelope = await response.json().catch(() => null);
	if (response.ok && envelope?.ok && envelope?.payload?.accessToken) {
		setApiAccessTokenCookie(Astro, envelope.payload.accessToken, Number(envelope.payload.expiresInSeconds ?? 900));
		if (!setPrincipalThemeCookies(Astro, envelope.payload.principal)) {
			setAnonymousThemeCookies(Astro, appearance);
		}
		const redirect = Astro.redirect(returnTo, 303);
		for (const cookie of Astro.cookies.headers()) {
			redirect.headers.append('set-cookie', cookie);
		}
		return redirect;
	}
	error = envelope?.error ?? 'Email confirmation failed.';
} else {
	const authenticatedRedirect = redirectAuthenticatedToApp(Astro);
	if (authenticatedRedirect) {
		return authenticatedRedirect;
	}
	error = 'Email confirmation token is missing.';
}
---

<AuthShell title="Confirm Email | TreeSeed" description="Confirm your email to continue." appearance={appearance}>
	<AuthCard
		title="Email confirmation failed"
		description="The confirmation link is invalid or expired. Try registering again or contact support if this keeps happening."
		error={error}
		appearance={appearance}
	>
		<Fragment slot="sidebarLinks">
			<a href={`/auth/register?returnTo=${encodeURIComponent(returnTo)}`}>Create account</a>
			<a href={`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`}>Sign in</a>
		</Fragment>
	</AuthCard>
</AuthShell>
