---
import TreeseedAppLayout from '../../layouts/TreeseedAppLayout.astro';
import '@treeseed/ui/styles/ui.css';
import '@treeseed/ui/styles/forms.css';
import '@treeseed/ui/styles/auth.css';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import PasswordMeter from '@treeseed/ui/components/astro/forms/PasswordMeter.astro';
import Badge from '@treeseed/ui/components/astro/data/Badge.astro';
import StatusPill from '@treeseed/ui/components/astro/data/StatusPill.astro';
import KeyValueList from '@treeseed/ui/components/astro/data/KeyValueList.astro';
import { DELETE_ACCOUNT_CONFIRMATION } from '../../lib/auth/delete-confirmation';
import { loadAppContext } from '../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/account')}`);
}

const context = await loadAppContext(Astro);
const api = context.store;
const requestAccountList = async (path: string) => api ? await api.request('GET', path).catch(() => []) : [];
const [emailAddresses, webSessions] = await Promise.all([
	requestAccountList('/v1/auth/web/emails'),
	requestAccountList('/v1/auth/web/sessions'),
]);
const accounts: any[] = [];
const principal = Astro.locals.auth.principal;
const currentSessionId = Astro.locals.auth?.session?.id ?? (typeof principal.metadata?.sessionId === 'string' ? principal.metadata.sessionId : null);
const fallbackCurrentSession = currentSessionId
	? {
		id: currentSessionId,
		provider: 'market_api',
		email: Astro.locals.auth?.session?.email ?? null,
		displayName: Astro.locals.auth?.session?.displayName ?? null,
		ipAddress: null,
		userAgent: null,
		authenticatedAt: null,
		lastSeenAt: null,
		expiresAt: Astro.locals.auth?.session?.expiresAt ?? null,
		revokedAt: null,
		current: true,
	}
	: null;
const sessionMap = new Map<string, any>();
for (const session of webSessions) {
	if (!session?.id) continue;
	sessionMap.set(session.id, {
		provider: 'web',
		userAgent: null,
		authenticatedAt: null,
		lastSeenAt: null,
		...session,
		current: Boolean(session.current || session.id === currentSessionId),
	});
}
if (fallbackCurrentSession && !sessionMap.has(fallbackCurrentSession.id)) {
	sessionMap.set(fallbackCurrentSession.id, fallbackCurrentSession);
}
const sessions = Array.from(sessionMap.values());
const passwordStatus = Astro.url.searchParams.get('password') ?? '';
const profileStatus = Astro.url.searchParams.get('profile') ?? '';
const emailStatus = Astro.url.searchParams.get('email') ?? '';
const deleteStatus = Astro.url.searchParams.get('delete') ?? '';
const statusMessage = Astro.url.searchParams.get('message') ?? '';
const hasCredential = accounts.some((account: any) => account.providerId === 'credential');
const roles = principal.roles ?? [];
const permissions = principal.permissions ?? [];
const isPlatformAdmin = roles.includes('platform_admin') || permissions.includes('*:*:*');
const verifiedEmailCount = emailAddresses.filter((email: any) => email.verified).length;
const emailItems = emailAddresses.map((email: any) => ({
	...email,
	deleteDisabled: email.verified && verifiedEmailCount <= 1,
}));
const currentName = principal.displayName ?? '';
const currentImage = typeof principal.metadata?.image === 'string' ? principal.metadata.image : '';
const currentUsername = typeof principal.metadata?.username === 'string' ? principal.metadata.username : '';
const deletionBlockers: any[] = [];
const profileStatusLabels: Record<string, string> = {
	updated: 'Profile updated',
	missing_name: 'Display name is required',
	invalid_image: 'Profile image must be an HTTPS URL',
	failed: 'Profile update failed',
};
const emailStatusLabels: Record<string, string> = {
	sent: 'Verification email sent. Open the link to finish adding this email.',
	verified: 'Email verified',
	primary: 'Primary email updated',
	deleted: 'Email removed',
	missing: 'Email is required',
	confirm: 'At least one verified email is required',
	last_verified_email: 'At least one verified email is required',
	not_configured: statusMessage || 'Auth email is not configured',
	failed: statusMessage || 'Email update failed',
};
const deleteStatusLabels: Record<string, string> = {
	confirm: `Type "${DELETE_ACCOUNT_CONFIRMATION}" to delete this account.`,
	blocked: 'Account deletion is blocked until the items below are resolved',
	password_required: 'Current password is required to delete this account',
	invalid_password: 'Current password was not accepted',
	reauth_required: 'Sign in again before deleting this provider-only account',
	failed: 'Account deletion failed',
};
const passwordStatusLabels: Record<string, string> = {
	updated: 'Password updated',
	missing: 'Password and confirmation are required',
	mismatch: 'Passwords do not match',
	weak: 'Password does not meet the strength rules',
	change_failed: 'Password change failed',
	set_failed: 'Password update failed',
};
const permissionSummary = isPlatformAdmin
	? 'This account has every global permission through the platform_admin role.'
	: 'This account is limited to assigned global roles and market team membership.';
const activeAccountTab: string = deleteStatus
	? 'danger'
	: (passwordStatus ? 'security' : 'profile');
const accountTabs = [
	{ id: 'profile', label: 'Profile' },
	{ id: 'security', label: 'Security' },
	{ id: 'sessions', label: 'Sessions' },
	{ id: 'danger', label: 'Delete' },
];
---

<TreeseedAppLayout
	title="Account"
	description="Manage your sign-in methods and active sessions."
	currentPath={Astro.url.pathname}
	teams={context.teams}
	activeTeam={context.activeTeam}
>
	<section class="account-tabs-shell" data-account-tabs-root data-default-tab={activeAccountTab}>
		<nav class="ts-tabs account-tabs" role="tablist" aria-label="Account sections">
			{accountTabs.map((tab) => (
				<button
					class="ts-tab"
					type="button"
					role="tab"
					id={`account-tab-${tab.id}`}
					aria-controls={`account-panel-${tab.id}`}
					aria-selected={activeAccountTab === tab.id ? 'true' : 'false'}
					tabindex={activeAccountTab === tab.id ? '0' : '-1'}
					data-account-tab={tab.id}
				>
					{tab.label}
				</button>
			))}
		</nav>

		<div class="account-tab-panels">
			<section id="account-panel-profile" class="account-tab-panel" role="tabpanel" aria-labelledby="account-tab-profile" data-account-panel="profile" hidden={activeAccountTab !== 'profile'}>
				<div class="account-two-column">
					<form method="POST" action="/v1/auth/web/profile" data-account-api-form="profile" data-method="PATCH" data-success="updated" data-failure="failed" data-redirect="/app/account">
						<Panel eyebrow="Profile" title="Public account details">
							<div class="account-form">
								{profileStatus ? <Badge tone={profileStatus === 'updated' ? 'success' : 'danger'}>{profileStatusLabels[profileStatus] ?? 'Profile update failed'}</Badge> : null}
								<div class="account-list-item">
									<strong>Username</strong>
									{currentUsername ? (
										<a href={`/u/${currentUsername}`}>@{currentUsername}</a>
									) : (
										<a href="/auth/username?returnTo=/app/account">Choose username</a>
									)}
									<span>Username is public and cannot be changed after registration.</span>
								</div>
								<Field label="Display name" name="name" required>
									<TextInput name="name" type="text" autocomplete="name" value={currentName} required />
								</Field>
								<Field label="Profile image URL" name="image">
									<TextInput name="image" type="url" inputmode="url" placeholder="https://example.com/avatar.png" value={currentImage} />
								</Field>
								<FormActions>
									<Button type="submit">Update profile</Button>
								</FormActions>
							</div>
						</Panel>
					</form>

					<Panel eyebrow="Email" title="Attached email addresses">
						<div class="account-form">
							{emailStatus ? <Badge tone={['sent', 'verified', 'primary', 'deleted'].includes(emailStatus) ? 'success' : 'danger'}>{emailStatusLabels[emailStatus] ?? 'Email update failed'}</Badge> : null}
								<div class="account-list">
									{emailItems.map((email: any) => (
										<div class="account-list-item">
											<div class="account-email-row">
												<div class="account-list-heading">
													<strong>{email.email}</strong>
													<div class="account-badges">
														{email.isPrimary ? <Badge tone="success">Primary</Badge> : null}
														<StatusPill tone={email.verified ? 'success' : 'warning'}>{email.verified ? 'verified' : 'pending'}</StatusPill>
													</div>
												</div>
												<div class="account-list-actions">
													{email.verified ? (
														email.isPrimary ? null : (
															<form method="POST" action={`/v1/auth/web/emails/${email.id}/primary`} data-account-api-form="email" data-email-action="primary" data-method="POST" data-success="primary" data-failure="failed" data-redirect="/app/account">
																<Button class="account-email-action" variant="secondary" size="sm" type="submit">Make primary</Button>
															</form>
														)
													) : (
														<form method="POST" action={`/v1/auth/web/emails/${email.id}/verify`} data-account-api-form="email" data-email-action="verify" data-method="POST" data-success="sent" data-failure="failed" data-redirect="/app/account">
															<Button class="account-email-action" variant="secondary" size="sm" type="submit">Verify</Button>
														</form>
													)}
													<form method="POST" action={`/v1/auth/web/emails/${email.id}`} data-account-api-form="email" data-email-action="delete" data-method="DELETE" data-success="deleted" data-failure={email.deleteDisabled ? 'last_verified_email' : 'failed'} data-redirect="/app/account">
														<Button class="account-email-action" variant="danger" size="sm" type="submit" disabled={email.deleteDisabled}>Delete</Button>
													</form>
												</div>
											</div>
										</div>
									))}
							</div>
								<form class="account-form account-email-add-form" method="POST" action="/v1/auth/web/emails" data-account-api-form="email" data-email-action="add" data-method="POST" data-success="sent" data-failure="failed" data-redirect="/app/account">
								<Field label="Add email address" name="email" required>
									<TextInput name="email" type="email" autocomplete="email" required />
								</Field>
								<FormActions>
									<Button type="submit">Add email</Button>
								</FormActions>
							</form>
						</div>
					</Panel>

					<Panel eyebrow="Platform access" title={isPlatformAdmin ? 'Root user' : 'Standard user'}>
						<Fragment slot="actions">
							<StatusPill tone={isPlatformAdmin ? 'success' : 'info'}>
								{isPlatformAdmin ? 'platform_admin' : 'member'}
							</StatusPill>
						</Fragment>
						<div class="account-form">
							<KeyValueList items={[{ key: 'Permission model', value: permissionSummary }]} />
							<div class="account-list-item">
								<strong>Roles</strong>
								<div class="account-badges">
									{roles.length > 0 ? roles.map((role: string) => <Badge>{role}</Badge>) : <Badge>none</Badge>}
								</div>
							</div>
						</div>
					</Panel>
				</div>
			</section>

			<section id="account-panel-security" class="account-tab-panel" role="tabpanel" aria-labelledby="account-tab-security" data-account-panel="security" hidden={activeAccountTab !== 'security'}>
				<div class="account-two-column">
					<form method="POST" action="/v1/auth/web/password" data-account-api-form="password" data-method="PATCH" data-success="updated" data-failure="change_failed" data-redirect="/app/account">
						<Panel eyebrow="Password" title={hasCredential ? 'Change password' : 'Set password'}>
							<div class="account-form">
								{passwordStatus === 'updated' ? <Badge tone="success">Password updated</Badge> : null}
								{passwordStatus && passwordStatus !== 'updated' ? <Badge tone="danger">{passwordStatusLabels[passwordStatus] ?? 'Password update failed'}</Badge> : null}
								{hasCredential ? (
									<Field label="Current password" name="currentPassword">
										<TextInput name="currentPassword" type="password" autocomplete="current-password" />
									</Field>
								) : null}
								<Field label="New password" name="newPassword" required>
									<TextInput id="accountNewPassword" name="newPassword" type="password" autocomplete="new-password" required minlength={12} />
								</Field>
								<Field label="Confirm new password" name="confirmPassword" required>
									<TextInput name="confirmPassword" type="password" autocomplete="new-password" required minlength={12} />
								</Field>
								<PasswordMeter inputId="accountNewPassword" />
								<FormActions>
									<Button type="submit">{hasCredential ? 'Change password' : 'Set password'}</Button>
								</FormActions>
							</div>
						</Panel>
					</form>

					<Panel eyebrow="Sign-in methods" title="Connected accounts">
						<div class="account-list">
							{accounts.map((account: any) => (
								<div class="account-list-item">
									<strong>{account.providerId === 'credential' ? 'Email and password' : account.providerId}</strong>
									<span>{account.accountId}</span>
								</div>
							))}
						</div>
					</Panel>
				</div>
			</section>

			<section id="account-panel-sessions" class="account-tab-panel" role="tabpanel" aria-labelledby="account-tab-sessions" data-account-panel="sessions" hidden={activeAccountTab !== 'sessions'}>
				<Panel eyebrow="Sessions" title="Active and recent sessions" class="account-stack">
					<div class="account-list">
						{sessions.length > 0 ? sessions.map((session: any) => (
								<div class="account-list-item">
									<strong>{session.current ? 'Current session' : session.provider}</strong>
									<span>{session.userAgent ?? 'Unknown device'}</span>
									{session.ipAddress ? <span>IP address {session.ipAddress}</span> : null}
									{session.lastSeenAt || session.authenticatedAt ? <span>Last seen {session.lastSeenAt ?? session.authenticatedAt}</span> : null}
									{!session.lastSeenAt && !session.authenticatedAt && session.expiresAt ? <span>Expires {session.expiresAt}</span> : null}
								{session.revokedAt ? <span>Revoked {session.revokedAt}</span> : null}
								{!session.revokedAt ? (
									<form method="POST" action={`/v1/auth/web/sessions/${session.id}/revoke`} data-account-api-form="sessions" data-method="POST" data-success="revoked" data-failure="failed" data-redirect="/app/account#sessions">
										<Button variant={session.current ? 'danger' : 'secondary'} type="submit">{session.current ? 'Sign out this session' : 'Revoke session'}</Button>
									</form>
								) : null}
							</div>
						)) : <p class="ts-empty-inline">No web sessions are available.</p>}
					</div>
				</Panel>
			</section>

			<section id="account-panel-danger" class="account-tab-panel" role="tabpanel" aria-labelledby="account-tab-danger" data-account-panel="danger" hidden={activeAccountTab !== 'danger'}>
					<Panel class="account-danger-panel" eyebrow="Delete account" title="Remove your personal account" description="This action is permanent and cannot be undone.">
					<div class="account-form">
						{deleteStatus ? <Badge tone="danger">{deleteStatusLabels[deleteStatus] ?? 'Account deletion failed'}</Badge> : null}
						{deletionBlockers.length > 0 ? (
							<div class="account-list">
								{deletionBlockers.map((blocker) => (
									<div class="account-list-item">
										<strong>{blocker.code === 'platform_admin' ? 'Platform administrator' : blocker.teamName}</strong>
										<span>{blocker.message}</span>
									</div>
								))}
							</div>
						) : null}
								<form class="account-form" method="POST" action="/v1/auth/web/account" data-account-api-form="delete" data-method="DELETE" data-success="deleted" data-failure="failed" data-redirect="/" data-delete-confirmation={DELETE_ACCOUNT_CONFIRMATION} data-delete-blocked={deletionBlockers.length > 0 ? 'true' : 'false'}>
									<Field label={`Type "${DELETE_ACCOUNT_CONFIRMATION}"`} name="confirmation" required>
										<TextInput name="confirmation" type="text" autocomplete="off" data-delete-confirmation-input />
									</Field>
							{hasCredential ? (
								<Field label="Current password" name="password">
									<TextInput name="password" type="password" autocomplete="current-password" />
								</Field>
							) : null}
								<FormActions>
									<Button variant="danger" type="submit" disabled={true}>Delete account</Button>
								</FormActions>
							</form>
					</div>
				</Panel>
			</section>
		</div>
	</section>

	<script is:inline data-astro-rerun>
		(() => {
			const root = document.querySelector('[data-account-tabs-root]');
			if (!root) return;
			if (root.dataset.accountTabsReady === 'true') return;
			root.dataset.accountTabsReady = 'true';
			const tabs = Array.from(root.querySelectorAll('[data-account-tab]'));
			const panels = Array.from(root.querySelectorAll('[data-account-panel]'));
			const ids = new Set(tabs.map((tab) => tab.getAttribute('data-account-tab')));
			const defaultTab = root.getAttribute('data-default-tab') || 'profile';

			function activate(id, updateHash = true) {
				const next = ids.has(id) ? id : defaultTab;
				tabs.forEach((tab) => {
					const selected = tab.getAttribute('data-account-tab') === next;
					tab.setAttribute('aria-selected', selected ? 'true' : 'false');
					tab.setAttribute('tabindex', selected ? '0' : '-1');
				});
				panels.forEach((panel) => {
					panel.hidden = panel.getAttribute('data-account-panel') !== next;
				});
				if (updateHash) {
					history.replaceState(null, '', `${location.pathname}${location.search}#${next}`);
				}
			}

			tabs.forEach((tab) => {
				tab.addEventListener('click', (event) => {
					event.preventDefault();
					activate(tab.getAttribute('data-account-tab'));
				});
				tab.addEventListener('keydown', (event) => {
					if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
					event.preventDefault();
					const currentIndex = tabs.indexOf(tab);
					const nextIndex = event.key === 'Home'
						? 0
						: event.key === 'End'
							? tabs.length - 1
							: event.key === 'ArrowLeft'
								? (currentIndex - 1 + tabs.length) % tabs.length
								: (currentIndex + 1) % tabs.length;
					const nextTab = tabs[nextIndex];
					nextTab?.focus();
					activate(nextTab?.getAttribute('data-account-tab'));
				});
			});
			if (location.hash.length > 1) {
				activate(location.hash.slice(1), false);
			}

			function accountRedirect(form, status) {
				const base = form.getAttribute('data-redirect') || '/app/account';
				const kind = form.getAttribute('data-account-api-form') || 'profile';
				if (base === '/') {
					location.href = status === 'deleted' ? '/?account=deleted' : `/app/account?delete=${encodeURIComponent(status)}#danger`;
					return;
				}
				const [path, hash = ''] = base.split('#');
				const url = new URL(path || '/app/account', location.origin);
				if (kind !== 'sessions') url.searchParams.set(kind, status);
				const panel = kind === 'email' ? 'profile' : kind;
				location.href = `${url.pathname}${url.search}${hash ? `#${hash}` : `#${panel}`}`;
			}

			function bodyFor(kind, formData, form) {
				if (kind === 'profile') {
					return {
						displayName: String(formData.get('name') || '').trim(),
						image: String(formData.get('image') || '').trim() || null,
					};
				}
				if (kind === 'email') {
					const emailAction = form.getAttribute('data-email-action') || 'add';
					if (emailAction === 'add') {
						const email = String(formData.get('email') || '').trim();
						if (!email) throw new Error('missing');
						return { email };
					}
					return {};
				}
				if (kind === 'password') {
					const newPassword = String(formData.get('newPassword') || '');
					const confirmPassword = String(formData.get('confirmPassword') || '');
					if (!newPassword || !confirmPassword) throw new Error('missing');
					if (newPassword !== confirmPassword) throw new Error('mismatch');
					if (newPassword.length < 12) throw new Error('weak');
					return {
						currentPassword: String(formData.get('currentPassword') || ''),
						newPassword,
					};
				}
				if (kind === 'delete') {
					const confirmation = String(formData.get('confirmation') || '').trim();
					const required = form.getAttribute('data-delete-confirmation') || '';
					if (confirmation !== required) throw new Error('confirm');
					return { confirmation };
				}
				return {};
			}

				async function hasDeletionBlockers() {
					const response = await fetch('/v1/auth/web/account/deletion-blockers', { headers: { accept: 'application/json' } });
					const envelope = await response.json().catch(() => null);
					return Array.isArray(envelope?.payload) && envelope.payload.length > 0;
				}

				root.querySelectorAll('[data-account-api-form="delete"]').forEach((form) => {
					const input = form.querySelector('[data-delete-confirmation-input]');
					const submit = form.querySelector('button[type="submit"]');
					const required = form.getAttribute('data-delete-confirmation') || '';
					const blocked = form.getAttribute('data-delete-blocked') === 'true';
					function updateDeleteButton() {
						if (!submit) return;
						submit.disabled = blocked || input?.value !== required;
					}
					input?.addEventListener('input', updateDeleteButton);
					updateDeleteButton();
				});

				root.querySelectorAll('[data-account-api-form]').forEach((form) => {
				form.addEventListener('submit', async (event) => {
					event.preventDefault();
					const kind = form.getAttribute('data-account-api-form') || '';
					const failure = form.getAttribute('data-failure') || 'failed';
					try {
						const formData = new FormData(form);
						if (kind === 'delete' && await hasDeletionBlockers()) {
							accountRedirect(form, 'blocked');
							return;
						}
						const response = await fetch(form.action, {
							method: form.getAttribute('data-method') || form.method || 'POST',
							headers: { accept: 'application/json', 'content-type': 'application/json' },
							body: JSON.stringify(bodyFor(kind, formData, form)),
						});
						const envelope = await response.json().catch(() => null);
						if (!response.ok || envelope?.ok === false) {
							accountRedirect(form, envelope?.error ? failure : failure);
							return;
						}
						accountRedirect(form, form.getAttribute('data-success') || 'updated');
					} catch (error) {
						accountRedirect(form, error instanceof Error ? error.message : failure);
					}
				});
			});
		})();
	</script>
</TreeseedAppLayout>
