---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc, providerLabel } from '../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/hosts/knowledge-library')}`);
}

const context = await loadAppContext(Astro);
const team = context.activeTeam;
const treeDx = team && context.store ? await context.store.getTeamTreeDx(team.id).catch(() => null) : null;
const instance = treeDx?.instance ?? null;
const mirrors = Array.isArray(treeDx?.mirrors) ? treeDx.mirrors : [];
const shares = Array.isArray(treeDx?.shares) ? treeDx.shares : [];
const deployments = Array.isArray(treeDx?.deployments) ? treeDx.deployments : [];

const instanceRows = instance ? [{
	id: instance.id,
	name: `<strong>${esc(instance.name ?? 'TreeDX Knowledge Library')}</strong><span>${esc(instance.baseUrl ?? 'Waiting for deployment URL')}</span>`,
	provider: esc(providerLabel(instance.provider ?? 'treedx')),
	status: esc(instance.status ?? 'pending'),
	scope: esc(instance.publicRead ? 'Public federation' : 'Private team library'),
	image: esc(instance.imageRef ?? 'treeseed/treedx:latest'),
	volume: esc(instance.volumeMountPath ?? 'managed externally'),
}] : [];

const mirrorRows = mirrors.map((mirror: any) => ({
	id: mirror.id,
	name: `<strong>${esc(mirror.name)}</strong><span>${esc(mirror.targetUrl ?? mirror.targetKind ?? 'mirror target')}</span>`,
	direction: esc(mirror.direction ?? 'bidirectional'),
	status: esc(mirror.status ?? 'pending'),
	lastSync: esc(mirror.lastSyncAt ?? 'not synced'),
	instructions: esc(mirror.instructions ?? 'Use TreeDX mirror credentials stored outside seed exports.'),
}));

const shareRows = shares.map((share: any) => ({
	id: share.id,
	scope: `<strong>${esc(share.scope)}</strong><span>${esc(share.libraryId ?? share.projectId ?? 'team library')}</span>`,
	target: esc(share.targetTeamId ?? (share.publicRead ? 'public federation' : 'team scoped')),
	status: esc(share.status ?? 'active'),
	publicRead: esc(share.publicRead ? 'yes' : 'no'),
	expires: esc(share.expiresAt ?? 'no expiry'),
}));

const deploymentRows = deployments.map((deployment: any) => ({
	id: deployment.id,
	status: `<strong>${esc(deployment.status)}</strong><span>${esc(deployment.completedAt ?? deployment.updatedAt ?? deployment.createdAt)}</span>`,
	provider: esc(providerLabel(deployment.provider)),
	image: esc(deployment.imageRef ?? 'treeseed/treedx:latest'),
	volume: esc(deployment.volumeMountPath ?? 'n/a'),
	result: esc(deployment.result?.nextAction ?? deployment.error?.message ?? 'recorded'),
}));

const pageData = JSON.stringify({ teamId: team?.id ?? null }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title="Knowledge Library" description="Manage the team TreeDX binding, mirrors, and shares." currentPath={Astro.url.pathname} teams={context.teams} activeTeam={team}>
	<section class="ts-control-page" aria-label="Knowledge Library">
		<Panel eyebrow="Knowledge Library" title="Team TreeDX" description="TreeDX is the canonical data plane for project content libraries. Site and parent project repositories remain filesystem worktrees on capacity provider volumes.">
			<Button slot="actions" href="/app/hosts" size="sm" variant="secondary">Back to Hosts</Button>
			{team ? (
				<div class="ts-form-note">
					<strong>{instance ? 'Primary binding active.' : 'No primary binding yet.'}</strong>
					<span>{instance ? 'Use mirrors and shares to connect this team library to other TreeDX libraries or customer-managed copies.' : 'Provision a private managed TreeDX for private teams, or attach public teams to the shared TreeSeed federation.'}</span>
				</div>
			) : (
				<EmptyState title="No team selected" description="Create or switch to a team before configuring TreeDX." actions={[{ label: 'Open Team', href: '/app/teams' }]} />
			)}
			{team ? (
				<div class="ts-button-row" data-treedx-actions>
					<button class="ts-link-button ts-link-button--primary" type="button" data-provision-kind="private">Provision private TreeDX</button>
					<button class="ts-link-button" type="button" data-provision-kind="public">Attach public federation</button>
					<span class="ts-subtle" role="status" data-treedx-status></span>
				</div>
			) : null}
		</Panel>

		{team ? (
			<>
				<Panel eyebrow="Primary" title="Active knowledge-library host" description="One active primary TreeDX binding is allowed per team. Private bindings use a dedicated managed service with a persistent /data volume.">
					<PlainTable columns={[
						{ key: 'name', label: 'Instance' },
						{ key: 'status', label: 'Status' },
						{ key: 'provider', label: 'Provider' },
						{ key: 'scope', label: 'Scope' },
						{ key: 'image', label: 'Image' },
						{ key: 'volume', label: 'Volume' },
					]} rows={instanceRows} emptyTitle="No TreeDX instance" emptyDescription="Provision or attach a TreeDX binding to begin storing project content libraries." />
				</Panel>

				<Panel eyebrow="Mirrors" title="Mirror instructions" description="Mirrors keep customer-owned TreeDX instances and Git identities connected without exposing secrets in the Market UI or seed exports.">
					<PlainTable columns={[
						{ key: 'name', label: 'Mirror' },
						{ key: 'direction', label: 'Direction' },
						{ key: 'status', label: 'Status' },
						{ key: 'lastSync', label: 'Last sync' },
						{ key: 'instructions', label: 'Instructions' },
					]} rows={mirrorRows} emptyTitle="No mirrors" emptyDescription="Add mirrors through the API or CLI when a customer wants a self-hosted copy or linked Git mirror." />
				</Panel>

				<Panel eyebrow="Sharing" title="Federation sharing" description="Sharing links describe trust grants between teams, libraries, and the public federation.">
					<PlainTable columns={[
						{ key: 'scope', label: 'Scope' },
						{ key: 'target', label: 'Target' },
						{ key: 'status', label: 'Status' },
						{ key: 'publicRead', label: 'Public read' },
						{ key: 'expires', label: 'Expires' },
					]} rows={shareRows} emptyTitle="No shares" emptyDescription="Private teams start closed; public federation teams publish read access by policy." />
				</Panel>

				<Panel eyebrow="Deployments" title="Managed deployment records" description="Provisioning records track Railway service, image, volume, and federation attachment attempts.">
					<PlainTable columns={[
						{ key: 'status', label: 'Status' },
						{ key: 'provider', label: 'Provider' },
						{ key: 'image', label: 'Image' },
						{ key: 'volume', label: 'Volume' },
						{ key: 'result', label: 'Result' },
					]} rows={deploymentRows} emptyTitle="No deployments" emptyDescription="Provisioning creates a deployment record even before the hosted service is fully attached." />
				</Panel>
			</>
		) : null}
	</section>
	<script is:inline type="application/json" id="treedx-page-data" set:html={pageData}></script>
</TreeseedAppLayout>

<script>
	const dataElement = document.getElementById('treedx-page-data');
	const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : {};
	const status = document.querySelector<HTMLElement>('[data-treedx-status]');

	document.addEventListener('click', async (event) => {
		const button = event.target instanceof Element ? event.target.closest<HTMLButtonElement>('[data-provision-kind]') : null;
		if (!button || !pageData.teamId) return;
		button.disabled = true;
		if (status) status.textContent = 'Saving TreeDX binding...';
		try {
			const kind = button.dataset.provisionKind;
			const response = await fetch(`/v1/teams/${encodeURIComponent(pageData.teamId)}/treedx/provision`, {
				method: 'POST',
				headers: { 'content-type': 'application/json' },
				body: JSON.stringify({
					publicRead: kind === 'public',
					status: kind === 'public' ? 'active' : 'pending',
				}),
			});
			const payload = await response.json().catch(() => null);
			if (!response.ok || payload?.ok === false) throw new Error(payload?.error ?? 'TreeDX binding could not be saved.');
			if (status) status.textContent = 'TreeDX binding saved. Refreshing...';
			window.location.reload();
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'TreeDX binding could not be saved.';
		} finally {
			button.disabled = false;
		}
	});
</script>
