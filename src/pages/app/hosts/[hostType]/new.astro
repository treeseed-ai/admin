---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import HostCredentialPermissionNote from '@treeseed/ui/components/astro/app/controls/HostCredentialPermissionNote.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { hostProviderFor, hostTypeLabel } from '../../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../../view-models/app-access.js';

const hostType = String(Astro.params.hostType ?? '');
const validTypes = new Set(['repository', 'web', 'capacity-provider', 'email', 'ai']);
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}
const context = await loadAppContext(Astro);
if (!validTypes.has(hostType)) Astro.response.status = 404;
const team = context.activeTeam;
const provider = hostProviderFor(hostType);
const hostTypeName = hostTypeLabel(hostType);
const title = `Create ${hostTypeName} host`;
const data = JSON.stringify({ teamId: team?.id ?? null, hostType, provider }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={title} description="Create one host configuration." currentPath="/app/hosts" teams={context.teams} activeTeam={team}>
	{validTypes.has(hostType) && team ? (
		<section class="ts-control-page" aria-label={title}>
			<Panel eyebrow="Hosts" title={title} description="Sensitive values are encrypted in the browser using the unlock passphrase.">
				<form id="host-create-form" class="ts-form-stack" autocomplete="off">
					<div class="ts-form-grid">
						<Field label="Host display name" name="name" required help="A friendly name shown in TreeSeed when people choose this host.">
							<TextInput name="name" required placeholder={`${hostTypeName} host`} autocomplete="off" />
						</Field>
						<Field label="Connected account" name="accountLabel" help="Optional label for the external account, organization, workspace, or provider account behind this host.">
							<TextInput name="accountLabel" placeholder="Production provider account" autocomplete="off" />
						</Field>
						{hostType === 'repository' && (
							<>
								<Field label="GitHub owner or organization" name="organizationOrOwner" required>
									<TextInput name="organizationOrOwner" required placeholder="example-org" />
								</Field>
								<Field label="Default visibility" name="defaultVisibility">
									<Select name="defaultVisibility" options={[{ label: 'Private', value: 'private' }, { label: 'Public', value: 'public' }]} />
								</Field>
								<Field label="Software repository name template" name="softwareRepositoryNameTemplate">
									<TextInput name="softwareRepositoryNameTemplate" value="{hub}-site" />
								</Field>
								<Field label="Content repository name template" name="contentRepositoryNameTemplate">
									<TextInput name="contentRepositoryNameTemplate" value="{hub}-content" />
								</Field>
								<Field label="Default branch" name="defaultBranch">
									<TextInput name="defaultBranch" value="main" />
								</Field>
								<Field label="GitHub token" name="githubToken" required>
									<TextInput name="githubToken" type="password" required autocomplete="new-password" />
								</Field>
							</>
						)}
						{hostType !== 'repository' && (
							<>
								<Field label="Provider" name="provider" required>
									<Select name="provider" required options={hostType === 'ai'
										? [
												{ label: 'OpenAI', value: 'openai' },
												{ label: 'GitHub Copilot', value: 'github_copilot' },
												{ label: 'OpenRouter', value: 'openrouter' },
												{ label: 'Custom', value: 'custom' },
											]
										: [{ label: provider, value: provider }]} />
								</Field>
								<Field label="Status" name="status">
									<Select name="status" options={[{ label: 'Active', value: 'active' }, { label: 'Paused', value: 'paused' }]} />
								</Field>
							</>
						)}
						{hostType === 'web' && (
							<>
								<Field label="Cloudflare account ID" name="cloudflareAccountId" required><TextInput name="cloudflareAccountId" required /></Field>
								<Field label="Cloudflare API token" name="cloudflareApiToken" required><TextInput name="cloudflareApiToken" type="password" required autocomplete="new-password" /></Field>
								<Field label="Root domain" name="cloudflareZoneName" help="Domain this web host can use for project addresses, such as treeseed.ai. Projects can use the root domain or subdomains for production and staging."><TextInput name="cloudflareZoneName" placeholder="example.com" /></Field>
							</>
						)}
						{hostType === 'capacity-provider' && (
							<>
								<Field label="Railway API token" name="railwayApiToken" required><TextInput name="railwayApiToken" type="password" required autocomplete="new-password" /></Field>
								<Field label="Railway workspace" name="railwayWorkspace"><TextInput name="railwayWorkspace" /></Field>
							</>
						)}
						{hostType === 'email' && (
							<>
								<Field label="SMTP host" name="smtpHost" required><TextInput name="smtpHost" required /></Field>
								<Field label="SMTP port" name="smtpPort" required><TextInput name="smtpPort" type="number" required value="587" /></Field>
								<Field label="SMTP username" name="smtpUsername" required><TextInput name="smtpUsername" required /></Field>
								<Field label="SMTP password" name="smtpPassword" required><TextInput name="smtpPassword" type="password" required autocomplete="new-password" /></Field>
								<Field label="From email" name="smtpFromEmail"><TextInput name="smtpFromEmail" type="email" /></Field>
								<Field label="Reply-to email" name="smtpReplyTo"><TextInput name="smtpReplyTo" type="email" /></Field>
								<Field label="Secure mode" name="smtpSecure"><Select name="smtpSecure" options={[{ label: 'STARTTLS', value: 'false' }, { label: 'TLS', value: 'true' }]} /></Field>
							</>
						)}
						{hostType === 'ai' && (
							<>
								<Field label="API key" name="aiApiKey" required><TextInput name="aiApiKey" type="password" required autocomplete="new-password" /></Field>
								<Field label="Base URL" name="aiBaseUrl"><TextInput name="aiBaseUrl" type="url" /></Field>
								<Field label="Default model" name="aiDefaultModel"><TextInput name="aiDefaultModel" /></Field>
							</>
						)}
						<div class="ts-field--full">
							<HostCredentialPermissionNote hostType={hostType} />
						</div>
					</div>
					<FormActions align="start">
						<Button type="submit">Create host</Button>
						<Button href="/app/hosts" variant="secondary">Cancel</Button>
						<span class="ts-subtle" id="host-create-status" role="status"></span>
					</FormActions>
				</form>
			</Panel>
		</section>
	) : (
		<EmptyState title={team ? 'Unknown host type' : 'No active team'} description={team ? 'Choose a supported host type.' : 'Create or switch to a team before adding hosts.'} actions={[{ label: 'Back to hosts', href: '/app/hosts' }]} />
	)}
	<script is:inline type="application/json" id="host-create-data" set:html={data}></script>
</TreeseedAppLayout>

<script>
	import { bindHostCreateCredentialForm } from '../../../../lib/market/host-credential-form-client.ts';

	function initHostCreateForm() {
		const dataElement = document.getElementById('host-create-data');
		const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : {};
		bindHostCreateCredentialForm(pageData);
	}
	(window as any).treeseedInitHostCreateForm = initHostCreateForm;
	initHostCreateForm();
</script>

<script is:inline data-astro-rerun>
	window.treeseedInitHostCreateForm?.();
</script>
