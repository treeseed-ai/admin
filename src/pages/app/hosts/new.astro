---
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc, hostPurposeFor } from '../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/hosts/new')}`);
}
const context = await loadAppContext(Astro);
const rows = [
	{ name: `<strong>Repository host</strong><span>${esc(hostPurposeFor('repository'))}</span>`, usedBy: 'Project creation', provider: 'GitHub', action: '<a class="ts-link-button" href="/app/hosts/repository/new">Create repository host</a>' },
	{ name: `<strong>Web host</strong><span>${esc(hostPurposeFor('web'))}</span>`, usedBy: 'Project deployment', provider: 'Cloudflare', action: '<a class="ts-link-button" href="/app/hosts/web/new">Create web host</a>' },
	{ name: `<strong>Email host</strong><span>${esc(hostPurposeFor('email'))}</span>`, usedBy: 'Project notifications', provider: 'SMTP', action: '<a class="ts-link-button" href="/app/hosts/email/new">Create email host</a>' },
	{ name: `<strong>Capacity provider host</strong><span>${esc(hostPurposeFor('capacity-provider'))}</span>`, usedBy: 'Capacity provider deployment', provider: 'Railway', action: '<a class="ts-link-button" href="/app/hosts/capacity-provider/new">Create capacity provider host</a>' },
	{ name: `<strong>AI host</strong><span>${esc(hostPurposeFor('ai'))}</span>`, usedBy: 'Agent and content workflows', provider: 'OpenAI, Copilot, OpenRouter', action: '<a class="ts-link-button" href="/app/hosts/ai/new">Create AI host</a>' },
];
---

<TreeseedAppLayout title="New host" description="Choose the workflow this host will support." currentPath="/app/hosts" teams={context.teams} activeTeam={context.activeTeam}>
	<section class="ts-control-page" aria-label="New host">
		<Panel eyebrow="Hosts" title="Create a host by workflow" description="Most operators can start from Projects or Capacity and create hosts inline. Use this page when you already know which reusable team credential you want to add.">
			<PlainTable columns={[
				{ key: 'name', label: 'Host' },
				{ key: 'usedBy', label: 'Used by' },
				{ key: 'provider', label: 'Provider' },
				{ key: 'action', label: 'Action' },
			]} rows={rows} />
		</Panel>
	</section>
</TreeseedAppLayout>
