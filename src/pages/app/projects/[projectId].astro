---
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import ReadinessSummary from '@treeseed/ui/components/astro/service/ReadinessSummary.astro';
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../view-models/app-access.js';
import { buildProjectDashboard } from '../../../view-models/contextual-dashboard.vm.js';
import { buildServicesDashboard, loadServiceInventory } from '../../../view-models/service-readiness.vm.js';

const projectParam = String(Astro.params.projectId ?? '');
const returnTo = `/app/projects/${encodeURIComponent(projectParam)}`;
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`);
}

const context = await loadAppContext(Astro);
const runtime = (Astro.locals as any).runtime ?? Astro.locals;
const resolution = await resolveAppProject(context, projectParam);
if (resolution.status === 'found') {
	persistActiveTeamSelection(Astro, resolution.team);
}
const projectContext = resolution.status === 'found' ? { ...context, activeTeam: resolution.team } : context;
const [dashboard, serviceBundle] = resolution.status === 'found'
	? await Promise.all([
			buildProjectDashboard(projectContext, resolution.resource, resolution.details, resolution.team, Astro.url),
			loadServiceInventory(projectContext, runtime).then((inventory) => buildServicesDashboard(projectContext, inventory, Astro.url)),
		])
	: [null, null];
---

<TreeseedAppLayout
	title={dashboard?.viewModel.title ?? 'Project dashboard'}
	description={dashboard?.viewModel.description ?? 'Project context is unavailable.'}
	currentPath={Astro.url.pathname}
	teams={context.teams}
	activeTeam={resolution.team ?? context.activeTeam}
	helpContext={dashboard?.helpContext}
	feedbackContext={dashboard?.feedbackContext}
>
	{dashboard ? (
		<>
			<ProjectControlNav projectId={dashboard.feedbackContext.projectId ?? projectParam} current="overview" />
			<DashboardTemplate viewModel={dashboard.viewModel} actions={dashboard.actions} />
			{serviceBundle ? <ReadinessSummary viewModel={serviceBundle.readiness} showAdvanced={false} /> : null}
		</>
	) : (
		<EmptyState
			title={resolution.status === 'forbidden' ? 'Project access unavailable' : 'Project not found'}
			description={resolution.status === 'forbidden' ? 'Your current account cannot open this project dashboard.' : 'Choose a project from the project portfolio.'}
			actions={[{ label: 'Open projects', href: '/app/projects' }]}
		/>
	)}
</TreeseedAppLayout>
