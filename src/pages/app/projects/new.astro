	async function submitJson(url: string, method: string, body: any) {
		const response = await fetch(url, { method, headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) });
		const payload = await response.json().catch(() => null);
		if (!response.ok || payload?.ok === false) {
			const error: Error & { payload?: any; providerCredentialUnlock?: boolean } = new Error(payload?.error ?? 'Request failed.');
			error.payload = payload;
			error.providerCredentialUnlock = payload?.error === 'Unable to unlock provider credentials for this host.';
			throw error;
		}
		return payload.payload ?? payload;
	}
	async function submitLaunchRequest(request: any) {
