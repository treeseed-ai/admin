---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import HostCredentialPermissionNote from '@treeseed/ui/components/astro/app/controls/HostCredentialPermissionNote.astro';
import LaunchRequirementSummary from '@treeseed/ui/components/astro/app/controls/LaunchRequirementSummary.astro';
import TemplateHostRequirementPicker from '@treeseed/ui/components/astro/app/controls/TemplateHostRequirementPicker.astro';
import TemplateResourceRequirementPicker from '@treeseed/ui/components/astro/app/controls/TemplateResourceRequirementPicker.astro';
import TemplateSecretRequirementPanel from '@treeseed/ui/components/astro/app/controls/TemplateSecretRequirementPanel.astro';
import type { TemplateSiteCard } from '@treeseed/core/templates';
import { deriveProjectLaunchRequirementsViewModel } from '@treeseed/sdk/template-launch-ui';
import type { ProjectLaunchHostRequirementViewModel } from '@treeseed/sdk/template-launch-ui';
import { TREESEED_DEFAULT_STARTER_TEMPLATE_ID } from '@treeseed/sdk/types';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { listTreeseedManagedHostsFromConfig } from '../../../lib/market/managed-hosts.js';
import { hostPurposeFor } from '../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../view-models/app-access.js';
import { listMarketplaceSiteTemplates } from '../../../lib/market/public-access.js';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/projects/new')}`);
}
const context = await loadAppContext(Astro);
const runtime = (Astro.locals as any).runtime ?? Astro.locals;
const team = context.activeTeam;
const [managedHosts, customHosts, repositoryHosts] = team && context.store
	? await Promise.all([
			listTreeseedManagedHostsFromConfig(team.id, runtime).catch(() => []),
			context.store.listTeamWebHosts(team.id).catch(() => []),
			context.store.listRepositoryHosts(team.id).catch(() => []),
		])
	: [[], [], []];
const templateListing = await listMarketplaceSiteTemplates(Astro).catch(() => ({ rendered: true, items: [] as TemplateSiteCard[] }));
const marketplaceTemplateItems = templateListing.items as TemplateSiteCard[];
const activeStarterTemplateIds = new Set([
	'research',
	'engineering',
	'information-hub',
]);
const templateSourceRef = (template: TemplateSiteCard) => template.sourceRef ?? template.slug;
const launchableTemplates = marketplaceTemplateItems.filter((template) => activeStarterTemplateIds.has(templateSourceRef(template)));
const templateCards = [
	...launchableTemplates.filter((template) => templateSourceRef(template) === TREESEED_DEFAULT_STARTER_TEMPLATE_ID),
	...launchableTemplates.filter((template) => templateSourceRef(template) !== TREESEED_DEFAULT_STARTER_TEMPLATE_ID),
];
const defaultCoreObjective = `# Core Objective

Describe the enduring outcome this project should help the team achieve. Keep it concrete enough that TreeSeed agents can use it as their first source of context when planning, writing, and reviewing work.
`;
const defaultHosts = team?.metadata?.defaultHosts && typeof team.metadata.defaultHosts === 'object'
	? team.metadata.defaultHosts
	: {};
const templateRequirementModels = templateCards.map((template) => ({
	slug: template.slug,
	sourceRef: templateSourceRef(template),
	title: template.title,
	launchRequirements: template.launchRequirements,
	requirementsView: deriveProjectLaunchRequirementsViewModel({
		launchRequirements: template.launchRequirements,
		repositoryHosts: repositoryHosts as any,
		teamHosts: customHosts as any,
		managedHosts: managedHosts as any,
		defaultHosts,
	}),
}));
const defaultTemplateRequirementModel = templateRequirementModels.find((template) => template.sourceRef === TREESEED_DEFAULT_STARTER_TEMPLATE_ID) ?? templateRequirementModels[0];
const defaultRequirementsView = defaultTemplateRequirementModel?.requirementsView ?? deriveProjectLaunchRequirementsViewModel({});
const defaultRequirementByKey = new Map(defaultRequirementsView.hosts.map((requirement) => [requirement.key, requirement]));
const fallbackHostRequirement = (key: string, type: string, displayName: string, purpose: string, required: boolean, provider: string, selectValue: string): ProjectLaunchHostRequirementViewModel => ({
	kind: 'host',
	key,
	type,
	displayName,
	purpose,
	required,
	compatibleProviders: [provider],
	defaultSelection: required ? 'managed' : 'none',
	environmentScopes: ['staging', 'prod'],
	configWritePreviews: [],
	environmentWritePreviews: [],
	choices: [
		{
			value: selectValue,
			label: displayName,
			mode: selectValue.startsWith('none:') ? 'none' : 'treeseed_managed',
			hostId: type === 'repository' ? 'platform:github:hosted-hubs' : null,
			managedHostKey: type === 'repository' ? 'platform:github:hosted-hubs' : selectValue.split(':').slice(1).join(':'),
			provider,
			type,
			selected: true,
			readiness: selectValue.startsWith('none:') ? 'none' : 'ready',
			rootDomain: null,
		},
		{
			value: `new:${type}`,
			label: `Create new ${type} host...`,
			mode: 'new',
			hostId: null,
			managedHostKey: null,
			provider,
			type,
			selected: false,
			readiness: 'new',
			rootDomain: null,
		},
	],
});
const sourceRepositoryRequirement = defaultRequirementByKey.get('sourceRepository') ?? fallbackHostRequirement('sourceRepository', 'repository', 'Repository', hostPurposeFor('repository'), true, 'github', 'treeseed_managed:platform:github:hosted-hubs');
const publicWebRequirement = defaultRequirementByKey.get('publicWeb') ?? fallbackHostRequirement('publicWeb', 'web', 'Web', hostPurposeFor('web'), true, 'cloudflare', 'treeseed_managed:treeseed-managed-web');
const transactionalEmailRequirement = defaultRequirementByKey.get('transactionalEmail') ?? fallbackHostRequirement('transactionalEmail', 'email', 'Email', hostPurposeFor('email'), false, 'smtp', 'none:transactionalEmail');
const launchJson = JSON.stringify({
	teamId: team?.id ?? null,
	defaultTemplateId: TREESEED_DEFAULT_STARTER_TEMPLATE_ID,
	templates: templateRequirementModels,
	hosts: [...managedHosts, ...customHosts],
	managedHosts,
	customHosts,
	repositoryHosts,
	defaultHosts,
}).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title="New project" description="Create one hosted project." currentPath="/app/projects" teams={context.teams} activeTeam={team}>
	{team ? (
		<section class="ts-control-page" aria-label="New project">
			<form id="project-launch-form" class="ts-form-stack">
				<Panel eyebrow="Projects" title="Create hosted project" description="Start with the project, then choose the hosts it needs. TreeSeed managed hosts are preselected.">
					<div class="ts-form-grid">
						<Field label="Project name" name="name" required help="The readable name people see in TreeSeed, project headings, and generated project content."><TextInput name="name" required placeholder="Use a clear project name" /></Field>
						<Field label="Project web address" name="slug" required help="The short lowercase address used in project links, repository names, and hosted resources."><TextInput name="slug" required placeholder="lowercase letters and hyphens" pattern="[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?" /></Field>
						<div class="ts-domain-fields" data-domain-fields hidden>
							<Field label="Production domain" name="productionDomain" help="Public address for the live project, scoped to the selected web host."><TextInput name="productionDomain" disabled placeholder="project.example.com" data-production-domain /></Field>
							<Field label="Staging domain" name="stagingDomain" help="Address for staging deployments. Keep it distinct from production."><TextInput name="stagingDomain" disabled placeholder="project-staging.example.com" data-staging-domain /></Field>
						</div>
						<input type="hidden" name="manageDns" value="true" />
					</div>
					<div class="ts-rich-markdown-field ts-field--full">
						<div class="ts-markdown-field__title">
							<label class="ts-field__label" for="coreObjective">
								<span>Core objective</span>
								<span class="ts-field__required" aria-hidden="true">*</span>
							</label>
							<p class="ts-field__help" id="coreObjective-help">This becomes the project repository's <code>src/content/objectives/core.md</code> file and is loaded into AI agent context everywhere.</p>
						</div>
						<div class="ts-rich-markdown-editor" data-rich-markdown-editor>
							<textarea
								class="ts-rich-markdown-editor__textarea"
								id="coreObjective"
								name="coreObjective"
								required
								rows="10"
								aria-describedby="coreObjective-help"
								data-rich-markdown-input
							>{defaultCoreObjective}</textarea>
							<div class="ts-rich-markdown-editor__mount" data-rich-markdown-mount></div>
							<p class="ts-markdown-field__error" hidden data-rich-markdown-error>Core objective is required.</p>
						</div>
					</div>
				</Panel>

				<Panel eyebrow="Template" title="Choose project template" description="Every hosted project starts from a first-party starter or marketplace template.">
					<input type="hidden" name="sourceKind" value="template" />
					<input type="hidden" name="sourceRef" value="" data-template-source-ref />
					<Field label="Search templates" name="templateSearch">
						<TextInput name="templateSearch" type="search" placeholder="Search by name, publisher, category, or summary" data-template-search />
					</Field>
					<div class="ts-template-choice-grid" role="radiogroup" aria-label="Project template">
						{templateCards.map((template) => {
							const sourceRef = templateSourceRef(template);
							const templateInputId = `template-${sourceRef.replace(/[^a-zA-Z0-9_-]/gu, '-')}`;
							const details = [
								template.category,
								template.publisherName,
								template.templateVersion ? `v${template.templateVersion}` : '',
								template.priceModel ? String(template.priceModel) : '',
							].filter(Boolean).join(' · ');
							const searchable = `${template.title} ${template.summary} ${template.category} ${template.publisherName} ${template.priceModel ?? ''}`.toLowerCase();
							return (
								<div class="ts-template-choice" data-template-card data-template-search-text={searchable}>
									<input id={templateInputId} type="radio" name="templateSlug" value={sourceRef} required />
									<label class="ts-template-choice__body" for={templateInputId}>
										<span class="ts-template-choice__title">
											<strong>{template.title}</strong>
											{template.featured ? <span>Featured</span> : null}
										</span>
										<span class="ts-template-choice__summary">{template.summary}</span>
										<span class="ts-template-choice__meta">{details}</span>
									</label>
									<a class="ts-template-choice__details" href={`/market/templates/${template.slug}/`} target="_blank" rel="noreferrer" aria-label={`Open details for ${template.title} in a new tab`}>
										<span>View template details</span>
										<span aria-hidden="true">Open in new tab</span>
									</a>
								</div>
							);
						})}
					</div>
					<p class="ts-subtle" data-template-empty hidden>No matching templates.</p>
					<LaunchRequirementSummary templates={templateRequirementModels} defaultTemplateId={TREESEED_DEFAULT_STARTER_TEMPLATE_ID} />
				</Panel>

				<Panel eyebrow="Project hosts" title="Choose project hosts" description="Use managed defaults, select an existing team host, or create the needed host before launch.">
					<div class="ts-host-setup-grid">
						<TemplateHostRequirementPicker requirement={sourceRepositoryRequirement} selectName="repositoryHostChoice" label="Repository host">
							<div class="ts-inline-host-fields" data-inline-host="repository" hidden>
								<div class="ts-form-grid">
									<Field label="Host display name" name="repositoryNewName" required help="A friendly name shown in TreeSeed when people choose this repository host."><TextInput name="repositoryNewName" required disabled data-inline-control placeholder="Main GitHub connection" /></Field>
									<Field label="Connected account" name="repositoryNewAccountLabel" help="Optional label for the GitHub organization or account behind this host."><TextInput name="repositoryNewAccountLabel" disabled data-inline-control placeholder="Acme GitHub organization" /></Field>
									<Field label="GitHub owner or organization" name="repositoryNewOwner" required><TextInput name="repositoryNewOwner" required disabled data-inline-control placeholder="example-org" /></Field>
									<Field label="Default visibility" name="repositoryNewVisibility"><Select name="repositoryNewVisibility" disabled options={[{ label: 'Private', value: 'private' }, { label: 'Public', value: 'public' }]} /></Field>
									<Field label="Default branch" name="repositoryNewDefaultBranch"><TextInput name="repositoryNewDefaultBranch" disabled data-inline-control value="main" /></Field>
									<Field label="GitHub token" name="repositoryNewToken" required><TextInput name="repositoryNewToken" type="password" required disabled data-inline-control autocomplete="new-password" /></Field>
								</div>
								<HostCredentialPermissionNote hostType="repository" />
							</div>
						</TemplateHostRequirementPicker>

						<TemplateHostRequirementPicker requirement={publicWebRequirement} selectName="cloudflareHostChoice" label="Web host">
							<div class="ts-inline-host-fields" data-inline-host="web" hidden>
								<div class="ts-form-grid">
									<Field label="Host display name" name="webNewName" required help="A friendly name shown in TreeSeed when people choose this web host."><TextInput name="webNewName" required disabled data-inline-control placeholder="Production web hosting" /></Field>
									<Field label="Connected account" name="webNewAccountLabel" help="Optional label for the Cloudflare account behind this host."><TextInput name="webNewAccountLabel" disabled data-inline-control placeholder="Acme Cloudflare account" /></Field>
									<Field label="Root domain" name="webNewRootDomain" required help="The domain this web host can use for project addresses, such as example.com."><TextInput name="webNewRootDomain" required disabled data-inline-control placeholder="example.com" autocomplete="off" /></Field>
									<Field label="Cloudflare account ID" name="webNewAccountId" required><TextInput name="webNewAccountId" required disabled data-inline-control /></Field>
									<Field label="Cloudflare API token" name="webNewApiToken" required><TextInput name="webNewApiToken" type="password" required disabled data-inline-control autocomplete="new-password" /></Field>
								</div>
								<HostCredentialPermissionNote hostType="web" />
							</div>
						</TemplateHostRequirementPicker>

						<TemplateHostRequirementPicker requirement={transactionalEmailRequirement} selectName="emailHostChoice" label="Email host">
							<div class="ts-inline-host-fields" data-inline-host="email" hidden>
								<div class="ts-form-grid">
									<Field label="Host display name" name="emailNewName" required help="A friendly name shown in TreeSeed when people choose this email host."><TextInput name="emailNewName" required disabled data-inline-control placeholder="Transactional email" /></Field>
									<Field label="Connected account" name="emailNewAccountLabel" help="Optional label for the email provider account behind this host."><TextInput name="emailNewAccountLabel" disabled data-inline-control placeholder="Acme SMTP account" /></Field>
									<Field label="SMTP host" name="emailNewSmtpHost" required><TextInput name="emailNewSmtpHost" required disabled data-inline-control /></Field>
									<Field label="SMTP port" name="emailNewSmtpPort" required><TextInput name="emailNewSmtpPort" type="number" required value="587" disabled data-inline-control /></Field>
									<Field label="SMTP username" name="emailNewSmtpUsername" required><TextInput name="emailNewSmtpUsername" required disabled data-inline-control /></Field>
									<Field label="SMTP password" name="emailNewSmtpPassword" required><TextInput name="emailNewSmtpPassword" type="password" required disabled data-inline-control autocomplete="new-password" /></Field>
									<Field label="From email" name="emailNewFromEmail"><TextInput name="emailNewFromEmail" type="email" disabled data-inline-control /></Field>
									<Field label="Reply-to email" name="emailNewReplyTo"><TextInput name="emailNewReplyTo" type="email" disabled data-inline-control /></Field>
									<Field label="Secure mode" name="emailNewSecure"><Select name="emailNewSecure" disabled options={[{ label: 'STARTTLS', value: 'false' }, { label: 'TLS', value: 'true' }]} /></Field>
								</div>
								<HostCredentialPermissionNote hostType="email" />
							</div>
						</TemplateHostRequirementPicker>
						{defaultRequirementsView.resources.map((requirement) => <TemplateResourceRequirementPicker requirement={requirement} />)}
						{defaultRequirementsView.secrets.map((requirement) => <TemplateSecretRequirementPanel requirement={requirement} />)}
					</div>
					<div class="ts-form-note ts-form-note--warning ts-launch-sensitive-notice" id="launch-sensitive-notice" hidden>
						<strong>Sensitive data unlock required.</strong>
						<span>Unlock sensitive data before launching with team-owned or newly created hosts.</span>
						<button class="ts-button-secondary" type="button" data-launch-sensitive-unlock>Unlock sensitive data</button>
					</div>
				</Panel>

				<Panel eyebrow="Launch" title="Create and deploy" description="TreeSeed creates any inline hosts first, unlocks team-owned credentials for this launch, then queues deployment.">
					<FormActions align="start" class="ts-project-launch-actions">
						<span data-project-launch-submit-wrap>
							<Button type="submit" data-project-launch-submit>Create project</Button>
						</span>
						<Button href="/app/projects" variant="secondary">Cancel</Button>
						<span class="ts-subtle" id="project-launch-message" role="status"></span>
					</FormActions>
				</Panel>
			</form>
		</section>
	) : (
		<EmptyState title="No active team" description="Create or switch to a team before creating projects." actions={[{ label: 'Open Team', href: '/app/teams' }]} />
	)}
	<script is:inline type="application/json" id="project-launch-data" set:html={launchJson}></script>
</TreeseedAppLayout>

<script>
	import { encryptHostConfig } from '../../../lib/host-crypto.ts';

	function initProjectLaunchForm() {
		const dataElement = document.getElementById('project-launch-data');
		const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : { hosts: [], repositoryHosts: [] };
		const launchForm = document.getElementById('project-launch-form') as HTMLFormElement | null;
		if (!launchForm || launchForm.dataset.projectLaunchBound === 'true') return;
		launchForm.dataset.projectLaunchBound = 'true';
		const repositoryHostSelect = launchForm.elements.namedItem('repositoryHostChoice') as HTMLSelectElement | null;
		const webHostSelect = launchForm.elements.namedItem('cloudflareHostChoice') as HTMLSelectElement | null;
		const emailHostSelect = launchForm.elements.namedItem('emailHostChoice') as HTMLSelectElement | null;
		const templateSourceRef = launchForm.querySelector('[data-template-source-ref]') as HTMLInputElement | null;
		const templateSearch = launchForm.querySelector('[data-template-search]') as HTMLInputElement | null;
		const templateCards = [...document.querySelectorAll<HTMLElement>('[data-template-card]')];
		const templateEmpty = document.querySelector('[data-template-empty]') as HTMLElement | null;
		const projectSlugInput = launchForm.elements.namedItem('slug') as HTMLInputElement | null;
		const domainFields = launchForm.querySelector('[data-domain-fields]') as HTMLElement | null;
		const productionDomainInput = launchForm.querySelector('[data-production-domain]') as HTMLInputElement | null;
		const stagingDomainInput = launchForm.querySelector('[data-staging-domain]') as HTMLInputElement | null;
		const webNewRootDomainInput = launchForm.elements.namedItem('webNewRootDomain') as HTMLInputElement | null;
		const sensitiveNotice = document.getElementById('launch-sensitive-notice');
		const sensitiveUnlockButton = launchForm.querySelector('[data-launch-sensitive-unlock]') as HTMLButtonElement | null;
		const launchSubmitButton = launchForm.querySelector('[data-project-launch-submit]') as HTMLButtonElement | null;
		const launchSubmitWrap = launchForm.querySelector('[data-project-launch-submit-wrap]') as HTMLElement | null;
		const statusElement = document.getElementById('project-launch-message');
		let validatedLaunchUnlock: { signature: string; passphrase: string } | null = null;
		const templateModels = Array.isArray(pageData.templates) ? pageData.templates : [];
		function value(formData: FormData, key: string) { return String(formData.get(key) ?? '').trim(); }
		function setStatus(message: string) {
			if (!statusElement) return;
			statusElement.style.whiteSpace = '';
			statusElement.textContent = message;
		}
		function renderLaunchError(error: unknown) {
			const payload = (error as any)?.payload;
			const message = error instanceof Error ? error.message : String(error);
			const blockers = [
				...(Array.isArray(payload?.audit?.blockers) ? payload.audit.blockers : []),
				...(Array.isArray(payload?.details?.blockers) ? payload.details.blockers : []),
			].map((entry: any) => typeof entry === 'string' ? entry : String(entry?.message ?? entry?.code ?? 'Launch blocker'));
			const missing = [
				...(Array.isArray(payload?.audit?.missingConfig) ? payload.audit.missingConfig : []),
				...(Array.isArray(payload?.details?.missingConfig) ? payload.details.missingConfig : []),
			].map((entry: any) => `Missing configuration: ${String(entry)}`);
			const details = [...blockers, ...missing].filter(Boolean);
			if (!statusElement || details.length === 0) {
				setStatus(message);
				return;
			}
			statusElement.style.whiteSpace = 'pre-wrap';
			statusElement.textContent = `${message}\n${details.map((entry) => `- ${entry}`).join('\n')}`;
		}
		async function safeInitializeCoreObjectiveEditors() {
			try {
				const editor = await import('@treeseed/ui/react');
				editor.initializeRichMarkdownEditors?.();
			} catch (error) {
				console.error('Core objective editor failed to load.', error);
			}
		}
		function hostType(host: any) {
			const metadataType = String(host.metadata?.hostType ?? '').trim();
			if (metadataType === 'capacity_provider' || metadataType === 'capacity_provider_host') return 'capacity-provider';
			if (metadataType === 'web_host' || metadataType === 'cloudflare' || metadataType === 'web') return 'web';
			if (metadataType === 'email_host' || metadataType === 'smtp' || metadataType === 'email') return 'email';
			if (metadataType === 'ai_host' || metadataType === 'ai') return 'ai';
			if (host.provider === 'railway') return 'capacity-provider';
			if (host.provider === 'smtp') return 'email';
			if (['openai', 'github_copilot', 'openrouter', 'custom'].includes(String(host.provider))) return 'ai';
			if (host.provider === 'cloudflare') return 'web';
			return metadataType || 'web';
		}
	function hostLabel(host: any, fallback: string) {
		const ownership = host.ownership === 'treeseed_managed' ? 'managed' : host.accountLabel ?? host.organizationOrOwner ?? host.provider ?? 'team-owned';
		return `${host.name || fallback} (${ownership})`;
	}
	function option(select: HTMLSelectElement | null, label: string, value: string, data: Record<string, string> = {}) {
		if (!select) return;
		const item = new Option(label, value);
		for (const [key, entry] of Object.entries(data)) {
			if (entry) item.dataset[key] = entry;
		}
		select.append(item);
	}
	function activeTemplateId() {
		return String(launchForm?.querySelector<HTMLInputElement>('input[name="templateSlug"]:checked')?.value ?? templateSourceRef?.value ?? '');
	}
	function activeTemplateModel() {
		return templateModels.find((template: any) => (template.sourceRef ?? template.slug) === activeTemplateId())
			?? templateModels.find((template: any) => (template.sourceRef ?? template.slug) === pageData.defaultTemplateId)
			?? templateModels[0]
			?? null;
	}
	function activeRequirementsView() {
		return activeTemplateModel()?.requirementsView ?? { hosts: [], resources: [], secrets: [] };
	}
	function activeHostRequirement(key: string) {
		return (activeRequirementsView().hosts ?? []).find((requirement: any) => requirement.key === key) ?? null;
	}
	function requirementForSelect(select: HTMLSelectElement | null) {
		if (!select) return null;
		if (select.name === 'repositoryHostChoice') return activeHostRequirement('sourceRepository');
		if (select.name === 'cloudflareHostChoice') return activeHostRequirement('publicWeb');
		if (select.name === 'emailHostChoice') return activeHostRequirement('transactionalEmail');
		return null;
	}
	function choiceDataset(choice: any) {
		return {
			mode: String(choice.mode ?? ''),
			hostId: String(choice.hostId ?? ''),
			managedHostKey: String(choice.managedHostKey ?? ''),
			provider: String(choice.provider ?? ''),
			hostType: String(choice.type ?? ''),
			readiness: String(choice.readiness ?? ''),
			rootDomain: String(choice.rootDomain ?? ''),
		};
	}
	function hostsFor(hostKind: string, provider: string) {
		return (pageData.hosts ?? []).filter((host: any) => host.provider === provider && hostType(host) === hostKind);
	}
	function hostIdFromOptionValue(optionValue: string) {
		if (String(optionValue ?? '').startsWith('platform:')) return optionValue;
		const parts = String(optionValue ?? '').split(':');
		return parts.length > 1 ? parts.slice(1).join(':') : optionValue;
	}
	function selectDefaultHost(select: HTMLSelectElement | null, type: string) {
		if (!select) return;
		const defaultHostId = String(pageData.defaultHosts?.[type] ?? '');
		if (!defaultHostId) return;
		const defaultOption = [...select.options].find((option) => hostIdFromOptionValue(option.value) === defaultHostId);
		if (defaultOption) select.value = defaultOption.value;
	}
	function refreshRepositories(requirement = activeHostRequirement('sourceRepository')) {
		if (!repositoryHostSelect) return;
		repositoryHostSelect.replaceChildren();
		if (requirement?.choices?.length) {
			for (const choice of requirement.choices) {
				option(repositoryHostSelect, choice.label, choice.value, choiceDataset(choice));
			}
			const selected = requirement.choices.find((choice: any) => choice.selected)?.value ?? requirement.choices[0]?.value ?? '';
			if (selected) repositoryHostSelect.value = selected;
