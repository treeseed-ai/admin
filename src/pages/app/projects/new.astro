			}

			let emailHostMode: string | null = selectedMode(emailHostSelect) === 'team_owned' || selectedMode(emailHostSelect) === 'new' ? 'team_owned' : selectedMode(emailHostSelect) === 'none' ? null : 'treeseed_managed';
			let emailHostId = selectedMode(emailHostSelect) === 'team_owned' ? selectedHostId(emailHostSelect) : null;
			if (selectedMode(emailHostSelect) === 'new') {
				const host = await createEmailHost(formData, String(passphrase));
				emailHostId = host.id;
				hostIdOverrides.transactionalEmail = host.id;
			} else if (emailHostMode === 'team_owned') {
				const host = selectedTeamHost(emailHostSelect, 'email', 'smtp');
				if (!host) throw new Error('Selected email host is not available.');
				if (!passphrase) throw new Error('Unlock sensitive data before launching with this email host.');
			}

			setStatus('Creating durable deployment record...');
			const slug = value(formData, 'slug');
			const launchRequestId = globalThis.crypto?.randomUUID?.() ?? String(Date.now());
			const hostBindings = buildHostBindings(hostIdOverrides);
			const publicWebBinding = hostBindings.publicWeb;
			const transactionalEmailBinding = hostBindings.transactionalEmail;
			cloudflareHostMode = bindingHostMode(publicWebBinding);
			cloudflareHostId = cloudflareHostMode === 'team_owned' ? publicWebBinding?.hostId ?? cloudflareHostId : null;
			emailHostMode = bindingHostMode(transactionalEmailBinding);
			emailHostId = emailHostMode === 'team_owned' ? transactionalEmailBinding?.hostId ?? emailHostId : null;
			const launchRequest = {
				action: `/v1/teams/${encodeURIComponent(pageData.teamId)}/projects/launch`,
				method: 'POST',
				createdAt: new Date().toISOString(),
				projectName: value(formData, 'name'),
				projectSlug: slug,
				body: {
					slug,
					launchRequestId,
					name: value(formData, 'name'),
					summary: value(formData, 'coreObjective'),
					coreObjective: value(formData, 'coreObjective'),
					sourceKind: 'template',
					sourceRef: selectedSourceRef,
					hostingMode: 'managed',
					repoProvider: 'github',
					repoVisibility: 'private',
					repositoryHostId,
					cloudflareHostMode,
					cloudflareHostId,
					emailHostMode,
					emailHostId,
					hostBindings,
					sensitivePassphrase: passphrase,
					domains: {
						productionDomain: value(formData, 'productionDomain'),
						stagingDomain: value(formData, 'stagingDomain'),
						manageDns: formData.get('manageDns') === 'true',
					},
					publicSite: true,
				},
			};
			const launchResponse = await submitLaunchRequest(launchRequest);
			const projectId = launchResponse?.projectId ?? launchResponse?.payload?.project?.id ?? launchResponse?.payload?.project?.project?.id ?? null;
			const deployHref = launchResponse?.deploymentHref ?? launchResponse?.deployHref ?? (launchResponse?.deploymentId ? `/app/projects/deployment/${encodeURIComponent(launchResponse.deploymentId)}` : null);
			if (!deployHref) throw new Error(projectId ? 'Project was created, but no deployment status link was returned.' : 'Project launch did not return a deployment status link.');
			setStatus('Deployment record created. Opening deployment status...');
			window.location.href = deployHref;
		} catch (error) {
			renderLaunchError(error);
		}
	});
	}
	(window as any).treeseedInitProjectLaunchForm = initProjectLaunchForm;
	initProjectLaunchForm();
</script>

<script is:inline data-astro-rerun>
	window.treeseedInitProjectLaunchForm?.();
</script>
