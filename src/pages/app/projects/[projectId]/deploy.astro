---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import StatusPill from '@treeseed/ui/components/astro/data/StatusPill.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import DeploymentTimeline from '@treeseed/ui/components/astro/app/operations/DeploymentTimeline.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { buildProjectDeploymentState } from '../../../../lib/market/deployment-projection.ts';
import { buildDeploymentViewModel } from '../../../../view-models/deployment.vm.ts';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../view-models/app-access.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const resolvedProject = await resolveAppProject(context, projectParam);
const projectEntry = resolvedProject.resource;
const projectId = projectEntry?.id ?? projectParam;
const details = resolvedProject.details;
if (!projectEntry || !details) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
let deploymentStateError: unknown = null;
const state = projectEntry && details && context.store
	? await buildProjectDeploymentState({ store: context.store, projectId, details }).catch((error) => {
			deploymentStateError = error;
			return null;
		})
	: null;
const fallbackState = projectEntry && details && !state ? {
	ok: false,
	project: details.project ?? projectEntry,
	launch: details.latestLaunch ? {
		...details.latestLaunch,
		events: details.latestLaunchEvents ?? [],
	} : null,
	environments: details.environments ?? [],
	repositories: details.repositories ?? [],
	hosts: [],
	runner: { status: 'unknown', capabilities: [] },
	latestDeployments: {
		staging: null,
		prod: null,
	},
	latestMonitors: {
		staging: null,
		prod: null,
	},
	activeOperations: [],
	recentDeployments: details.deployments ?? [],
	readiness: {
		ready: false,
		blockers: [{
			code: 'deployment_state_unavailable',
			message: deploymentStateError instanceof Error
				? `Deployment state could not be loaded: ${deploymentStateError.message}`
				: 'Deployment state could not be loaded.',
		}],
		checks: [],
	},
	actions: [],
	target: null,
	nextAction: {
		code: 'deployment_state_unavailable',
		label: 'Deployment state unavailable',
		description: 'The project was found, but deployment controls could not load their state.',
		action: null,
		environment: null,
	},
} : null;
const displayState = state ?? fallbackState;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
const timelineDeployment = displayState?.activeOperations?.[0] ?? displayState?.recentDeployments?.[0] ?? null;
const timelineEvents = timelineDeployment && context.store?.listProjectDeploymentEvents
	? await context.store.listProjectDeploymentEvents(timelineDeployment.id, { limit: 200 }).catch(() => [])
	: [];
const vm = displayState ? buildDeploymentViewModel(displayState, timelineEvents) : null;
const activeOperationLabel = vm?.activeDeployment ? String(vm.activeDeployment.status ?? 'Active') : 'None';
const activeOperationDescription = vm?.activeDeployment
	? String(vm.activeDeployment.summary ?? `${vm.activeDeployment.action ?? 'Deployment'} for ${vm.activeDeployment.environment ?? 'environment'}.`)
	: 'No deployment operation is active.';
const readinessTone = vm?.readiness.ready ? 'success' : vm?.readiness.blockers.length ? 'danger' : 'warning';
const readinessAttentionCount = vm
	? vm.readiness.blockers.length || vm.readiness.checks.filter((check) => !check.ready).length
	: 0;
const needsSetupAttention = Boolean(vm?.launch.inspect || vm?.launch.actions.length || vm?.showSensitiveUnlock);
const uniqueReadinessBlockers = vm
	? Array.from(new Map(vm.readiness.blockers.map((blocker) => [`${blocker.code}:${blocker.message}:${blocker.href ?? ''}`, blocker])).values())
	: [];
const overviewAttentionCount = vm
	? uniqueReadinessBlockers.length
		+ vm.readiness.checks.filter((check) => !check.ready).length
		+ vm.troubleshooting.filter((hint) => hint.tone === 'danger' || hint.tone === 'warning').length
		+ (needsSetupAttention ? 1 : 0)
	: 0;
const deploymentActionUrl = `/v1/projects/${encodeURIComponent(projectId)}/deployments/web`;
const deploymentStateUrl = `/v1/projects/${encodeURIComponent(projectId)}/deployment-state`;
const historyRows = vm?.historyRows.map((row) => ({
	id: `deployment-${esc(row.id)}`,
	name: `<strong>${esc(row.environment)}</strong><span>${esc(row.action)}</span>`,
	status: esc(row.status),
	started: esc(row.startedAt),
	completed: esc(row.completedAt),
	workflow: row.workflowUrl ? `<a class="ts-link-button" href="${esc(row.workflowUrl)}">Workflow</a>` : 'Not recorded',
	url: row.url ? `<a class="ts-link-button" href="${esc(row.url)}">Open URL</a>` : 'Not recorded',
	requestedBy: esc(row.requestedBy),
	actions: `<a class="ts-link-button ts-link-button--primary" href="/app/projects/deployment/${encodeURIComponent(row.id)}">Status</a>`,
})) ?? [];
---

<TreeseedAppLayout title="Project deploy" description="Queue and monitor project web deployments." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{projectEntry && details && vm ? (
		<section
			class="ts-control-page ts-project-deploy-page"
			aria-label="Project deploy"
			data-deploy-page
			data-state-url={deploymentStateUrl}
			data-has-active={vm.activeDeployment ? 'true' : 'false'}
		>
			<ProjectControlNav projectId={vm.project.id} current="deploy" />

			<section class="ts-deploy-command-surface" data-tone={vm.nextAction.tone} data-next-action={vm.nextAction.code} aria-label="Deployment command state">
				<div class="ts-deploy-command-surface__main">
					<p class="ts-deploy-command-surface__eyebrow">Project deployment</p>
					<h1>{vm.project.name}</h1>
					<div class="ts-deploy-command-surface__state">
						<StatusPill tone={vm.nextAction.tone} label={vm.nextAction.label} />
					</div>
					<p>{vm.nextAction.description}</p>
					<div class="ts-deploy-command-surface__actions">
						{vm.nextAction.code === 'deploy_staging' ? (
							<a class="ts-link-button ts-link-button--primary" href="#deploy-staging-title">Open staging actions</a>
						) : vm.nextAction.code === 'launch_recovery' && vm.launch.actions.length > 0 ? (
							<a class="ts-link-button ts-link-button--primary" href="#launch-recovery-actions">Open launch recovery</a>
						) : vm.launch.deployHref ? (
							<a class="ts-link-button ts-link-button--primary" href={vm.launch.deployHref}>Open deployment status</a>
						) : null}
						<p class="ts-subtle" id="deployment-action-status" role="status" aria-live="polite"></p>
					</div>
				</div>
				<div class="ts-deploy-signal-grid" aria-label="Deployment signals">
					<div class="ts-deploy-signal" data-tone={readinessTone}>
						<span>Readiness</span>
						<strong>{vm.readiness.label}</strong>
						<p>{vm.readiness.ready ? 'Deployment actions can run.' : `${readinessAttentionCount} blocker${readinessAttentionCount === 1 ? '' : 's'} need attention.`}</p>
					</div>
					<div class="ts-deploy-signal" data-tone={vm.launch.tone}>
						<span>Launch</span>
						<strong>{vm.launch.label}</strong>
						<p>{vm.launch.description}</p>
					</div>
					<div class="ts-deploy-signal" data-tone={vm.runner.tone}>
						<span>Runner</span>
						<strong>{vm.runner.label}</strong>
						<p>{vm.runner.activeJobCount} active jobs.</p>
					</div>
					<div class="ts-deploy-signal" data-tone={vm.activeDeployment ? 'warning' : 'default'}>
						<span>Active operation</span>
						<strong>{activeOperationLabel}</strong>
						<p>{activeOperationDescription}</p>
					</div>
				</div>
			</section>

			<section class="ts-deploy-tabs-shell" data-deploy-tabs-root data-default-tab="overview" aria-label="Deployment sections">
				<nav class="ts-tabs ts-deploy-subtabs" role="tablist" aria-label="Deployment sections">
					<button class="ts-tab" type="button" role="tab" id="deploy-tab-overview" aria-controls="deploy-panel-overview" aria-selected="true" data-deploy-tab="overview">
						Overview {overviewAttentionCount > 0 ? (
							<span class="ts-tab__count" title={`${overviewAttentionCount} overview item${overviewAttentionCount === 1 ? '' : 's'} need attention`} aria-label={`${overviewAttentionCount} overview item${overviewAttentionCount === 1 ? '' : 's'} need attention`}>{overviewAttentionCount}</span>
						) : null}
					</button>
					<button class="ts-tab" type="button" role="tab" id="deploy-tab-environments" aria-controls="deploy-panel-environments" aria-selected="false" tabindex="-1" data-deploy-tab="environments">
						Environments
					</button>
					<button class="ts-tab" type="button" role="tab" id="deploy-tab-activity" aria-controls="deploy-panel-activity" aria-selected="false" tabindex="-1" data-deploy-tab="activity">
						Activity <span class="ts-tab__count" title={`${vm.timeline.length} deployment timeline event${vm.timeline.length === 1 ? '' : 's'}`} aria-label={`${vm.timeline.length} deployment timeline event${vm.timeline.length === 1 ? '' : 's'}`}>{vm.timeline.length}</span>
					</button>
					<button class="ts-tab" type="button" role="tab" id="deploy-tab-history" aria-controls="deploy-panel-history" aria-selected="false" tabindex="-1" data-deploy-tab="history">
						History <span class="ts-tab__count" title={`${historyRows.length} deployment record${historyRows.length === 1 ? '' : 's'}`} aria-label={`${historyRows.length} deployment record${historyRows.length === 1 ? '' : 's'}`}>{historyRows.length}</span>
					</button>
				</nav>

				<div class="ts-deploy-tab-panels">
					<section id="deploy-panel-overview" class="ts-deploy-tab-panel" role="tabpanel" aria-labelledby="deploy-tab-overview" data-deploy-panel="overview">
						{needsSetupAttention ? (
							<Panel class="ts-deploy-status-panel" eyebrow="Setup" title="Setup attention" description="Only recovery actions and setup blockers appear here. Routine launch progress stays in the timeline.">
								<div class="ts-deploy-launch">
									{vm.launch.inspect ? (
										<ul class="ts-deploy-attention-list" aria-label="Setup failure details">
											<li data-tone="danger">
												<StatusPill tone="danger" label="Failure" />
												<div>
													<strong>Inspect failure</strong>
													<p>{vm.launch.inspect.summary}</p>
													{vm.launch.inspect.command ? <code>{vm.launch.inspect.command}</code> : null}
												</div>
											</li>
										</ul>
									) : null}
									{vm.launch.actions.length > 0 ? (
										<div class="ts-deploy-actions" id="launch-recovery-actions" aria-label="Launch recovery actions">
											{vm.launch.actions.map((action) => (
												<form
													class="ts-deploy-action"
													method={action.method}
													action={action.url}
													data-launch-recovery-action
												>
													<label class="ts-deploy-action__field">
														<span>Host passphrase</span>
														<input type="password" name="sensitivePassphrase" autocomplete="current-password" placeholder="Required for team-owned hosts" />
													</label>
													<Button type="submit" size="sm" variant="secondary">{action.label}</Button>
													<p class="ts-deploy-action__message">{action.description}</p>
												</form>
											))}
										</div>
									) : null}
									{vm.showSensitiveUnlock ? (
										<ul class="ts-deploy-attention-list" aria-label="Sensitive data requirement">
											<li data-tone="warning">
												<StatusPill tone="warning" label="Required" />
												<div>
													<strong>Unlock sensitive data</strong>
													<p>Unlock sensitive provider access before queueing deployment work.</p>
												</div>
											</li>
										</ul>
									) : null}
								</div>
							</Panel>
						) : null}

						<Panel class="ts-deploy-readiness-panel" eyebrow="Readiness" title="Deployment readiness" description="Checks that must pass before the runner can safely dispatch web deployment work.">
							<ul class="ts-deploy-checklist" aria-label="Deployment readiness checklist">
								{vm.readiness.checks.map((check) => (
									<li data-tone={check.tone} data-ready={check.ready ? 'true' : 'false'}>
										<StatusPill tone={check.tone} label={check.ready ? 'Ready' : 'Blocked'} />
										<div>
											<div class="ts-deploy-check-title">
												<strong>{check.label}</strong>
												<span class="ts-info-popover">
													<button class="ts-info-popover__trigger" type="button" aria-label={`What ${check.label} means`} aria-describedby={`readiness-help-${check.code}`}>
														i
													</button>
													<span class="ts-info-popover__content" id={`readiness-help-${check.code}`} role="tooltip">
														{check.help}
													</span>
												</span>
											</div>
											<p>{check.message}</p>
											{check.href ? <a href={check.href}>Open related settings</a> : null}
										</div>
									</li>
								))}
							</ul>
							{uniqueReadinessBlockers.length > 0 ? (
								<ul class="ts-deploy-blocker-list" aria-label="Deployment blockers">
									{uniqueReadinessBlockers.map((blocker) => (
										<li data-tone="danger">
											<StatusPill tone="danger" label="Blocked" />
											<div>
												<strong>{blocker.code.replaceAll('_', ' ')}</strong>
												<p>{blocker.message}</p>
												{blocker.href ? <a href={blocker.href}>Open related settings</a> : null}
											</div>
										</li>
									))}
								</ul>
							) : null}
							{vm.troubleshooting.length > 0 ? (
								<section class="ts-deploy-support-group" aria-labelledby="deployment-support-heading">
									<div class="ts-deploy-support-group__header">
										<h3 id="deployment-support-heading">Recent failure context</h3>
										<p>These rows summarize launch or deployment failures already recorded by the system. They are separate from the readiness checklist above.</p>
									</div>
									<ul class="ts-deploy-attention-list" aria-label="Deployment support hints">
										{vm.troubleshooting.map((hint) => (
											<li data-tone={hint.tone}>
												<StatusPill tone={hint.tone} label={hint.tone === 'danger' ? 'Failure' : hint.tone === 'warning' ? 'Warning' : 'Info'} />
												<div>
													<strong>{hint.title}</strong>
													<p>{hint.description}</p>
													{hint.href ? <a href={hint.href}>Open related settings</a> : null}
												</div>
											</li>
										))}
									</ul>
								</section>
							) : null}
						</Panel>
					</section>

					<section id="deploy-panel-environments" class="ts-deploy-tab-panel" role="tabpanel" aria-labelledby="deploy-tab-environments" data-deploy-panel="environments" hidden>
						<Panel class="ts-deploy-environment-panel" eyebrow="Environments" title="Staging and production" description="Latest deployment state, target URL, workflow run, monitor result, and available actions.">
							<div class="ts-deploy-environments">
								{vm.environments.map((environment) => (
									<article class="ts-deploy-environment" data-tone={environment.tone} aria-labelledby={`deploy-${environment.environment}-title`}>
										<header class="ts-deploy-environment__header">
											<div>
												<h3 id={`deploy-${environment.environment}-title`}>{environment.label}</h3>
												<p>{environment.latestSummary}</p>
											</div>
											<StatusPill tone={environment.tone} label={environment.status} />
										</header>
										<dl class="ts-deploy-definition-list">
											<div>
												<dt>Target URL</dt>
												<dd>{environment.url ? <a href={environment.url}>{environment.url}</a> : 'Not recorded'}</dd>
											</div>
											<div>
												<dt>Completed</dt>
												<dd>{environment.latestCompletedAt ?? 'Not recorded'}</dd>
											</div>
											<div>
												<dt>Workflow</dt>
												<dd>{environment.workflowUrl ? <a href={environment.workflowUrl}>Open workflow run</a> : 'Not recorded'}</dd>
											</div>
											<div>
												<dt>Monitor</dt>
												<dd>
													<div class="ts-deploy-monitor-summary">
														<StatusPill tone={environment.monitor.tone} label={environment.monitor.label} />
														<span>{environment.monitorSummary}</span>
														{environment.monitor.checkedAt ? <time datetime={environment.monitor.checkedAt}>{environment.monitor.checkedAt}</time> : null}
													</div>
												</dd>
											</div>
										</dl>
										{environment.monitor.checks.length > 0 ? (
											<ul class="ts-deploy-monitor-checks" aria-label={`${environment.label} monitor checks`}>
												<li><strong>{environment.monitor.counts.passed}</strong><span>Passed</span></li>
												<li><strong>{environment.monitor.counts.warnings}</strong><span>Warnings</span></li>
												<li><strong>{environment.monitor.counts.failed}</strong><span>Failed</span></li>
												<li><strong>{environment.monitor.counts.skipped}</strong><span>Skipped</span></li>
											</ul>
										) : null}
										{environment.monitor.checks.length > 0 ? (
											<ol class="ts-deploy-compact-list" aria-label={`${environment.label} monitor details`}>
												{environment.monitor.checks.slice(0, 4).map((check) => (
													<li>
														<strong>{check.label}</strong>
														<span>{check.summary}</span>
														{check.url ? <a href={check.url}>Inspect link</a> : null}
														{check.inspectCommand ? <code>{check.inspectCommand}</code> : null}
													</li>
												))}
											</ol>
										) : null}
										<div class="ts-deploy-actions" aria-label={`${environment.label} deployment actions`}>
											{environment.actions.map((action) => (
												<form
													class="ts-deploy-action"
													method="post"
													action={deploymentActionUrl}
													data-deployment-action
													data-state-url={deploymentStateUrl}
												>
													<input type="hidden" name="environment" value={action.environment} />
													<input type="hidden" name="action" value={action.action} />
													{action.requiresProductionConfirmation ? (
														<label class="ts-checkbox-label">
															<input type="checkbox" name="confirmProduction" required />
															<span>I confirm this production {action.label.toLowerCase()} request.</span>
														</label>
													) : null}
													<Button type="submit" size="sm" variant={action.disabled ? 'secondary' : 'primary'} disabled={action.disabled}>
														{action.label}
													</Button>
													<p class="ts-deploy-action__message">
														{action.disabled && action.blockers[0] ? action.blockers[0].message : action.description}
													</p>
												</form>
											))}
										</div>
									</article>
								))}
							</div>
						</Panel>
					</section>

					<section id="deploy-panel-activity" class="ts-deploy-tab-panel" role="tabpanel" aria-labelledby="deploy-tab-activity" data-deploy-panel="activity" hidden>
						<Panel eyebrow="Timeline" title={vm.activeDeployment ? 'Active operation timeline' : 'Latest deployment timeline'} description="Deployment-scoped events linked with the platform operation when one exists.">
							<DeploymentTimeline items={vm.timeline} />
						</Panel>
					</section>

					<section id="deploy-panel-history" class="ts-deploy-tab-panel" role="tabpanel" aria-labelledby="deploy-tab-history" data-deploy-panel="history" hidden>
						<Panel eyebrow="History" title="Deployment history" description="Recent deployment and monitor records for this project.">
							<PlainTable
								columns={[
									{ key: 'name', label: 'Environment' },
									{ key: 'status', label: 'Status' },
									{ key: 'started', label: 'Started' },
									{ key: 'completed', label: 'Completed' },
									{ key: 'workflow', label: 'Workflow' },
									{ key: 'url', label: 'URL' },
									{ key: 'requestedBy', label: 'Requested by' },
									{ key: 'actions', label: 'Status page' },
								]}
								rows={historyRows}
								emptyTitle="No deployment history"
								emptyDescription="Deployment records appear after staging or production work is queued."
								interactive={true}
								pageSize={10}
								searchLabel="Filter deployments"
							/>
						</Panel>
					</section>
				</div>
			</section>
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>

<script>
	import { submitDeploymentActionForm, submitLaunchRecoveryForm, watchDeploymentState } from '@treeseed/ui/lib/app/deployment-action-status';

	function initializeProjectDeployPage() {
	const page = document.querySelector('[data-deploy-page]') as HTMLElement | null;
	if (!page || page.dataset.deployInitialized === 'true') return;
	page.dataset.deployInitialized = 'true';
		const status = document.getElementById('deployment-action-status');
		const forms = [...document.querySelectorAll('[data-deployment-action]')] as HTMLFormElement[];
		const launchForms = [...document.querySelectorAll('[data-launch-recovery-action]')] as HTMLFormElement[];
		const tabsRoot = document.querySelector('[data-deploy-tabs-root]') as HTMLElement | null;
		if (tabsRoot) {
			const tabs = [...tabsRoot.querySelectorAll('[data-deploy-tab]')] as HTMLButtonElement[];
			const panels = [...tabsRoot.querySelectorAll('[data-deploy-panel]')] as HTMLElement[];
			const ids = new Set(tabs.map((tab) => tab.dataset.deployTab ?? ''));
			const defaultTab = tabsRoot.dataset.defaultTab ?? 'overview';
			const activateTab = (next: string, updateHash = false) => {
				const id = ids.has(next) ? next : defaultTab;
				for (const tab of tabs) {
					const selected = tab.dataset.deployTab === id;
					tab.setAttribute('aria-selected', selected ? 'true' : 'false');
					tab.tabIndex = selected ? 0 : -1;
				}
				for (const panel of panels) {
					panel.hidden = panel.dataset.deployPanel !== id;
				}
				if (updateHash) history.replaceState(null, '', `${window.location.pathname}${window.location.search}#${id}`);
			};
			for (const tab of tabs) {
				tab.addEventListener('click', () => activateTab(tab.dataset.deployTab ?? defaultTab, true));
				tab.addEventListener('keydown', (event) => {
					if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(event.key)) return;
					event.preventDefault();
					const currentIndex = tabs.indexOf(tab);
					const nextIndex = event.key === 'Home'
						? 0
						: event.key === 'End'
							? tabs.length - 1
							: event.key === 'ArrowLeft'
								? (currentIndex - 1 + tabs.length) % tabs.length
								: (currentIndex + 1) % tabs.length;
					const nextTab = tabs[nextIndex];
					activateTab(nextTab?.dataset.deployTab ?? defaultTab, true);
					nextTab?.focus();
				});
			}
			activateTab(window.location.hash.replace('#', '') || defaultTab);
		}
		for (const form of forms) {
			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				try {
					await submitDeploymentActionForm({
						form,
						statusElement: status,
						fallbackHref: `${window.location.pathname}?deployment=${Date.now()}`,
					});
				} catch (error) {
					if (status) status.textContent = error instanceof Error ? error.message : 'Deployment operation could not be queued.';
				}
			});
		}
		for (const form of launchForms) {
			form.addEventListener('submit', async (event) => {
				event.preventDefault();
				try {
					await submitLaunchRecoveryForm({
						form,
						statusElement: status,
						fallbackHref: `${window.location.pathname}?launch=${Date.now()}`,
					});
				} catch (error) {
					if (status) status.textContent = error instanceof Error ? error.message : 'Launch recovery could not be queued.';
				}
			});
		}
		watchDeploymentState({
			stateUrl: page?.dataset.stateUrl ?? '',
			statusElement: status,
			initialActive: page?.dataset.hasActive === 'true',
			intervalMs: 12_000,
		});
	}
	initializeProjectDeployPage();
	document.addEventListener('astro:page-load', initializeProjectDeployPage);
</script>
