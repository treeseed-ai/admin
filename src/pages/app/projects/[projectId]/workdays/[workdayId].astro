---
import WorkspaceTemplate from '@treeseed/ui/components/astro/templates/WorkspaceTemplate.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { loadProjectWorkdayWorkspace } from '../../../../../view-models/operating-loop.vm.js';

const projectParam = String(Astro.params.projectId ?? '');
const workdayId = String(Astro.params.workdayId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadProjectWorkdayWorkspace(Astro, projectParam, workdayId, Astro.url);
if (!vm.project || !vm.workspace) Astro.response.status = vm.resolution.status === 'forbidden' ? 403 : 404;
const pageJson = JSON.stringify({ projectId: vm.project?.id ?? '', requestType: 'follow_up', reason: 'Requested from workday workspace', source: 'workday_workspace_ui' }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={vm.workspace?.title ?? 'Workday'} description={vm.workspace?.description} currentPath="/app/projects" teams={vm.context.teams} activeTeam={vm.resolution.team ?? vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.workspace ? (
		<WorkspaceTemplate viewModel={vm.workspace} actions={vm.actions}>
			<button class="ts-button" data-size="sm" type="button" id="request-workday-button">Request follow-up</button>
			<span class="ts-subtle" id="workday-request-status" role="status"></span>
		</WorkspaceTemplate>
	) : (
		<EmptyState title="Workday not found" description="This workday is not available for the selected project." actions={[{ label: 'Back to Workdays', href: vm.project ? `/app/projects/${vm.project.id}/workdays` : '/app/projects' }]} />
	)}
	<script is:inline type="application/json" id="workday-request-data" set:html={pageJson}></script>
</TreeseedAppLayout>

<script>
	import { bindWorkdayRequest } from '../../../../../lib/market/operating-loop-client';

	bindWorkdayRequest({ dataId: 'workday-request-data', buttonId: 'request-workday-button', statusId: 'workday-request-status' });
</script>
