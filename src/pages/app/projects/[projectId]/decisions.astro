---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../view-models/app-access.js';
import { loadWorkContentEntries, workContentEntriesFor } from '../../../../view-models/work-content.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const [context, contentEntries] = await Promise.all([
	loadAppContext(Astro),
	loadWorkContentEntries(),
]);
const resolvedProject = await resolveAppProject(context, projectParam);
const project = resolvedProject.resource;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
if (!project) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
function entrySlug(entry: any) {
	return String(entry.id ?? '').replace(/\.(mdx|md)$/u, '').replace(/^[^:]+:/u, '');
}
function relationHref(reference: string) {
	const [prefix, ...rest] = String(reference ?? '').split(':');
	const slug = rest.join(':').trim();
	const collection = {
		objective: 'objectives',
		question: 'questions',
		note: 'notes',
		proposal: 'proposals',
		decision: 'decisions',
	}[prefix] ?? '';
	if (prefix === 'book' && slug) return `/books/${encodeURIComponent(slug)}`;
	if (!collection || !slug) return '';
	return `/app/work/${collection}/${encodeURIComponent(slug)}`;
}
function relationTypeLabel(reference: string) {
	const prefix = String(reference ?? '').split(':')[0] ?? '';
	return {
		objective: 'Objective',
		question: 'Question',
		note: 'Note',
		proposal: 'Proposal',
		decision: 'Decision',
		book: 'Book',
	}[prefix] ?? 'Link';
}
function relationLabel(reference: string) {
	return String(reference ?? '').replace(/^[^:]+:/u, '').replace(/[-_]+/gu, ' ');
}
function relationLinks(entry: any) {
	const relations = Array.isArray(entry.relations) ? entry.relations : [];
	if (relations.length === 0) return `<span class="ts-record-card__relation-empty">No linked records</span>`;
	return relations.map((reference: string) => {
		const href = relationHref(reference);
		const label = relationLabel(reference);
		const typeLabel = relationTypeLabel(reference);
		return href
			? `<a class="ts-record-card__relation-link" href="${esc(href)}"><span>${esc(typeLabel)}</span><strong>${esc(label)}</strong></a>`
			: `<span class="ts-record-card__relation-empty">${esc(reference)}</span>`;
	}).join('');
}
function contentRow(entry: any, actionLabel = 'Open') {
	return {
		id: `content-${esc(entry.id)}`,
		name: `<strong>${esc(entry.title)}</strong><span>${esc(entry.summary || entry.description)}</span>`,
		type: esc(entry.type),
		state: esc(entry.status),
		related: relationLinks(entry),
		action: `<a class="ts-link-button" href="${esc(entry.href)}">${actionLabel}</a>`,
	};
}
const proposals = workContentEntriesFor(contentEntries, 'proposals');
const votingRows = proposals
	.filter((entry: any) => String(entry.governanceStatus ?? entry.status ?? '').toLowerCase() === 'voting')
	.map((entry: any) => contentRow(entry, 'Vote'));
const proposalRows = proposals
	.filter((entry: any) => String(entry.governanceStatus ?? entry.status ?? '').toLowerCase() !== 'voting')
	.map((entry: any) => contentRow(entry, 'Open'));
const decisionRows = workContentEntriesFor(contentEntries, 'decisions').map((entry: any) => contentRow(entry));
const timelineRows = [...proposals, ...workContentEntriesFor(contentEntries, 'decisions')]
	.sort((left: any, right: any) => String(right.date ?? '').localeCompare(String(left.date ?? '')))
	.map((entry: any) => contentRow(entry, 'Open'));
const activeTabParam = String(Astro.url.searchParams.get('tab') ?? 'proposals');
const activeTab = ['proposals', 'voting', 'decisions', 'timeline'].includes(activeTabParam) ? activeTabParam : 'proposals';
const tabBase = `/app/projects/${encodeURIComponent(project?.id ?? projectParam)}/decisions`;
const decisionTabs = [
	{ key: 'proposals', label: 'Proposals', count: proposalRows.length, href: `${tabBase}?tab=proposals` },
	{ key: 'voting', label: 'Voting', count: votingRows.length, href: `${tabBase}?tab=voting` },
	{ key: 'decisions', label: 'Decisions', count: decisionRows.length, href: `${tabBase}?tab=decisions` },
	{ key: 'timeline', label: 'Timeline', count: timelineRows.length, href: `${tabBase}?tab=timeline` },
];
---

<TreeseedAppLayout title="Project decisions" description="Evaluate proposals and preserve decisions for this project." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{project ? (
		<section class="ts-control-page" aria-label="Project decisions">
			<ProjectControlNav projectId={project.id} current="decisions" />
			<nav class="ts-tabs" aria-label="Decision sections">
				{decisionTabs.map((tab) => (
					<a class="ts-tab" href={tab.href} aria-current={activeTab === tab.key ? 'page' : undefined}>
						{tab.label}
						<span class="ts-tab__count">{tab.count}</span>
					</a>
				))}
			</nav>
			{activeTab === 'proposals' ? (
				<Panel eyebrow="Proposal governance" title="Proposals" description="Open proposal records that can move into voting under the active governance provider.">
					<div slot="actions" class="ts-action-row">
						<Button href={`/app/work/proposals/new?projectId=${encodeURIComponent(project.id)}`} size="sm">New proposal</Button>
					</div>
					<PlainTable columns={[{ key: 'name', label: 'Proposal' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]} rows={proposalRows} emptyTitle="No proposals" emptyDescription="Create a proposal before asking for a decision." interactive={true} pageSize={10} searchLabel="Search proposals" controlMode="filter" filterColumns={['type', 'state']} />
				</Panel>
			) : null}
			{activeTab === 'voting' ? (
				<Panel eyebrow="Active voting" title="Voting" description="Proposals currently collecting votes or approvals under governance.">
					<PlainTable columns={[{ key: 'name', label: 'Proposal' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]} rows={votingRows} emptyTitle="No active voting" emptyDescription="Voting proposals appear here after governance starts." interactive={true} pageSize={10} searchLabel="Search voting proposals" controlMode="filter" filterColumns={['type', 'state']} />
				</Panel>
			) : null}
			{activeTab === 'decisions' ? (
				<Panel eyebrow="Immutable decisions" title="Decisions" description="Accepted decisions generated from approved proposal snapshots.">
					<PlainTable columns={[{ key: 'name', label: 'Decision' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]} rows={decisionRows} emptyTitle="No decisions" emptyDescription="Decision content appears from src/content/decisions." interactive={true} pageSize={10} searchLabel="Search decisions" controlMode="filter" filterColumns={['type', 'state']} />
				</Panel>
			) : null}
			{activeTab === 'timeline' ? (
				<Panel eyebrow="Governance timeline" title="Timeline" description="Proposal and decision records in one audit-oriented timeline.">
					<PlainTable columns={[{ key: 'name', label: 'Record' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]} rows={timelineRows} emptyTitle="No governance records" emptyDescription="Proposal and decision records appear here as the project deliberates." interactive={true} pageSize={10} searchLabel="Search timeline" controlMode="filter" filterColumns={['type', 'state']} />
				</Panel>
			) : null}
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>
