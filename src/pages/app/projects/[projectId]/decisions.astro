---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../view-models/app-access.js';
import { loadWorkContentEntries, workContentEntriesFor } from '../../../../view-models/work-content.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const [context, contentEntries] = await Promise.all([
	loadAppContext(Astro),
	loadWorkContentEntries(),
]);
const resolvedProject = await resolveAppProject(context, projectParam);
const project = resolvedProject.resource;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
const approvals = project && context.store && typeof context.store.listApprovalRequestsForProject === 'function'
	? await context.store.listApprovalRequestsForProject(project.id, 100).catch(() => [])
	: [];
if (!project) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
const principalPermissions = new Set((Astro.locals.auth?.principal?.permissions ?? []) as string[]);
const canManageProject = ['*', '*:*:*', 'projects:*:team', 'projects:manage:team'].some((permission) => principalPermissions.has(permission));
function entrySlug(entry: any) {
	return String(entry.id ?? '').replace(/\.(mdx|md)$/u, '').replace(/^[^:]+:/u, '');
}
function relationHref(reference: string) {
	const [prefix, ...rest] = String(reference ?? '').split(':');
	const slug = rest.join(':').trim();
	const collection = {
		objective: 'objectives',
		question: 'questions',
		note: 'notes',
		proposal: 'proposals',
		decision: 'decisions',
	}[prefix] ?? '';
	if (prefix === 'book' && slug) return `/books/${encodeURIComponent(slug)}`;
	if (!collection || !slug) return '';
	return `/app/work/${collection}/${encodeURIComponent(slug)}`;
}
function relationTypeLabel(reference: string) {
	const prefix = String(reference ?? '').split(':')[0] ?? '';
	return {
		objective: 'Objective',
		question: 'Question',
		note: 'Note',
		proposal: 'Proposal',
		decision: 'Decision',
		book: 'Book',
	}[prefix] ?? 'Link';
}
function relationLabel(reference: string) {
	return String(reference ?? '').replace(/^[^:]+:/u, '').replace(/[-_]+/gu, ' ');
}
function relationLinks(entry: any) {
	const relations = Array.isArray(entry.relations) ? entry.relations : [];
	if (relations.length === 0) return `<span class="ts-record-card__relation-empty">No linked records</span>`;
	return relations.map((reference: string) => {
		const href = relationHref(reference);
		const label = relationLabel(reference);
		const typeLabel = relationTypeLabel(reference);
		return href
			? `<a class="ts-record-card__relation-link" href="${esc(href)}"><span>${esc(typeLabel)}</span><strong>${esc(label)}</strong></a>`
			: `<span class="ts-record-card__relation-empty">${esc(reference)}</span>`;
	}).join('');
}
function contentRow(entry: any, actionLabel = 'Open', mode: 'proposal' | 'decision' = 'decision') {
	const slug = entrySlug(entry);
	const manageActions = mode === 'proposal' && canManageProject
		? `<button class="ts-link-button" type="button" data-proposal-decide data-proposal-slug="${esc(slug)}" data-proposal-title="${esc(entry.title)}">Decide</button>`
		: '';
	return {
		id: `content-${esc(entry.id)}`,
		name: `<strong>${esc(entry.title)}</strong><span>${esc(entry.summary || entry.description)}</span>`,
		type: esc(entry.type),
		state: esc(entry.status),
		related: relationLinks(entry),
		select: mode === 'proposal' && canManageProject ? `<label class="ts-card-select"><input type="checkbox" data-proposal-select value="${esc(slug)}" data-proposal-title="${esc(entry.title)}" /> Select</label>` : '',
		action: `<a class="ts-link-button" href="${esc(entry.href)}">${actionLabel}</a>${manageActions}`,
	};
}
const proposals = workContentEntriesFor(contentEntries, 'proposals');
const proposalRows = proposals.map((entry: any) => contentRow(entry, 'Review', 'proposal'));
const decisionRows = workContentEntriesFor(contentEntries, 'decisions').map((entry: any) => contentRow(entry));
const approvalRows = approvals.map((approval: any) => ({
	id: `decision-${esc(approval.id)}`,
	name: `<strong>${esc(approval.title ?? approval.kind ?? 'Proposal review')}</strong><span>${esc(approval.summary ?? approval.description ?? '')}</span>`,
	state: esc(approval.state ?? 'pending'),
	action: `<a class="ts-link-button" href="/app/work/decisions/${encodeURIComponent(approval.id)}">Review</a>`,
}));
const activeTabParam = String(Astro.url.searchParams.get('tab') ?? 'proposals');
const activeTab = ['proposals', 'decisions', 'review'].includes(activeTabParam) ? activeTabParam : 'proposals';
const tabBase = `/app/projects/${encodeURIComponent(project?.id ?? projectParam)}/decisions`;
const decisionTabs = [
	{ key: 'proposals', label: 'Proposals', count: proposalRows.length, href: `${tabBase}?tab=proposals` },
	{ key: 'decisions', label: 'Decisions', count: decisionRows.length, href: `${tabBase}?tab=decisions` },
	{ key: 'review', label: 'Review', count: approvalRows.length, href: `${tabBase}?tab=review` },
];
const verdictData = JSON.stringify({ projectId: project?.id ?? projectParam }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title="Project decisions" description="Evaluate proposals and preserve decisions for this project." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{project ? (
		<section class="ts-control-page" aria-label="Project decisions">
			<ProjectControlNav projectId={project.id} current="decisions" />
			<nav class="ts-tabs" aria-label="Decision sections">
				{decisionTabs.map((tab) => (
					<a class="ts-tab" href={tab.href} aria-current={activeTab === tab.key ? 'page' : undefined}>
						{tab.label}
						<span class="ts-tab__count">{tab.count}</span>
					</a>
				))}
			</nav>
			{activeTab === 'proposals' ? (
				<Panel eyebrow="Proposal review" title="Proposals" description="Suggested changes that can become one decision or be combined into a final verdict.">
					<div slot="actions" class="ts-action-row">
						{canManageProject ? <button class="ts-link-button" type="button" data-final-verdict-open>Final verdict</button> : null}
						<Button href={`/app/work/proposals/new?projectId=${encodeURIComponent(project.id)}`} size="sm">New proposal</Button>
					</div>
					<PlainTable columns={[{ key: 'select', label: 'Select' }, { key: 'name', label: 'Proposal' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]} rows={proposalRows} emptyTitle="No proposals" emptyDescription="Create a proposal before asking for a decision." interactive={true} pageSize={10} searchLabel="Search proposals" controlMode="filter" filterColumns={['type', 'state']} />
				</Panel>
			) : null}
			{activeTab === 'decisions' ? (
				<Panel eyebrow="Decision memory" title="Decisions" description="Previous decisions and the proposals, objectives, questions, or notes they cite.">
					<Button slot="actions" href={`/app/work/decisions/new?projectId=${encodeURIComponent(project.id)}`} size="sm">New decision</Button>
					<PlainTable columns={[{ key: 'name', label: 'Decision' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]} rows={decisionRows} emptyTitle="No decisions" emptyDescription="Decision content appears from src/content/decisions." interactive={true} pageSize={10} searchLabel="Search decisions" controlMode="filter" filterColumns={['type', 'state']} />
				</Panel>
			) : null}
			{activeTab === 'review' ? (
				<Panel eyebrow="Operational governance" title="Pending review" description="Automation-created proposal review tasks that need a human decision.">
					<PlainTable columns={[{ key: 'name', label: 'Review item' }, { key: 'state', label: 'State' }, { key: 'action', label: 'Action' }]} rows={approvalRows} emptyTitle="No pending review" emptyDescription="Approval requests appear here when agents need a decision." interactive={true} pageSize={10} searchLabel="Search review items" controlMode="filter" filterColumns={['state']} />
				</Panel>
			) : null}
			{canManageProject ? (
				<section class="ts-proposal-verdict" hidden data-proposal-verdict data-verdict-context={verdictData} aria-label="Proposal verdict">
					<div class="ts-proposal-verdict__header">
						<div>
							<h3>Record decision</h3>
							<p>Select one or more proposals, choose a verdict, and write the reason that should be preserved.</p>
						</div>
						<button class="ts-link-button" type="button" data-verdict-close>Cancel</button>
					</div>
					<form id="proposal-verdict-form" class="ts-form-stack">
						<ul class="ts-proposal-verdict__selected" data-selected-proposals></ul>
						<Field label="Decision title" name="title" required>
							<TextInput name="title" required data-verdict-title />
						</Field>
						<Field label="Verdict" name="decisionType" required>
							<Select name="decisionType" required value="approved" options={[{ label: 'Approved', value: 'approved' }, { label: 'Rejected', value: 'rejected' }, { label: 'Deferred', value: 'deferred' }, { label: 'Request changes', value: 'request_changes' }]} />
						</Field>
						<Field label="Reason" name="reason" required>
							<Textarea name="reason" required rows={5} placeholder="Why is this the right verdict?" />
						</Field>
						<Field label="Summary" name="summary">
							<Textarea name="summary" rows={3} placeholder="Optional shorter summary for lists and cards." />
						</Field>
						<Field label="Body" name="body">
							<Textarea name="body" rows={6} placeholder="Optional full decision body. Leave blank to generate one from the reason." />
						</Field>
						<p class="ts-proposal-verdict__status" data-verdict-status aria-live="polite"></p>
						<FormActions>
							<Button type="submit">Save decision</Button>
							<button class="ts-link-button" type="button" data-verdict-close>Cancel</button>
						</FormActions>
					</form>
				</section>
			) : null}
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>

{canManageProject ? (
	<script>
		import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

		(() => {
			const panel = document.querySelector<HTMLElement>('[data-proposal-verdict]');
			if (!panel || panel.dataset.ready === 'true') return;
			const panelEl = panel;
			panelEl.dataset.ready = 'true';
			const form = panelEl.querySelector<HTMLFormElement>('#proposal-verdict-form');
			const selectedList = panelEl.querySelector<HTMLElement>('[data-selected-proposals]');
			const status = panelEl.querySelector<HTMLElement>('[data-verdict-status]');
			const titleInput = panelEl.querySelector<HTMLInputElement>('[data-verdict-title]');
			const context = JSON.parse(panelEl.getAttribute('data-verdict-context') || '{}');
			type SelectedProposal = { slug: string; title: string };
			let selected: SelectedProposal[] = [];
			function selectedFromChecks(): SelectedProposal[] {
				return [...document.querySelectorAll<HTMLInputElement>('[data-proposal-select]:checked')].map((input) => ({
					slug: input.value,
					title: input.getAttribute('data-proposal-title') || input.value,
				}));
			}
			function setStatus(message: string, error = false) {
				if (!status) return;
				status.textContent = message;
				status.dataset.error = error ? 'true' : 'false';
			}
			function renderSelected() {
				if (!selectedList) return;
				selectedList.innerHTML = '';
				for (const proposal of selected) {
					const item = document.createElement('li');
					item.textContent = proposal.title || proposal.slug;
					selectedList.append(item);
				}
			}
			function openPanel(proposals: SelectedProposal[]) {
				selected = proposals.filter((proposal) => proposal.slug);
				if (selected.length === 0) {
					setStatus('Select at least one proposal before recording a verdict.', true);
					return;
				}
				renderSelected();
				if (titleInput) {
					titleInput.value = selected.length === 1 ? `Decision for ${selected[0].title}` : `Final verdict for ${selected.length} proposals`;
				}
				setStatus('');
				panelEl.hidden = false;
				titleInput?.focus();
			}
			document.addEventListener('click', (event) => {
				const target = event.target instanceof Element ? event.target : null;
				const decide = target?.closest('[data-proposal-decide]');
				if (decide) {
					openPanel([{ slug: decide.getAttribute('data-proposal-slug') || '', title: decide.getAttribute('data-proposal-title') || '' }]);
				}
				if (target?.closest('[data-final-verdict-open]')) {
					openPanel(selectedFromChecks());
				}
				if (target?.closest('[data-verdict-close]')) {
					panelEl.hidden = true;
				}
			});
			form?.addEventListener('submit', async (event) => {
				event.preventDefault();
				if (selected.length === 0) {
					setStatus('Select at least one proposal before recording a verdict.', true);
					return;
				}
				const formData = new FormData(event.currentTarget as HTMLFormElement);
				const reason = String(formData.get('reason') || '').trim();
				if (!reason) {
					setStatus('A reason is required before saving a decision.', true);
					return;
				}
				try {
					await submitPlatformOperationForm({
						url: `/v1/projects/${encodeURIComponent(context.projectId)}/local-content/decisions/from-proposals`,
						statusElement: status,
						fallbackHref: `/app/projects/${encodeURIComponent(context.projectId)}/decisions?tab=decisions`,
						initialMessage: 'Queuing decision operation...',
						body: {
						proposalSlugs: selected.map((proposal) => proposal.slug),
						decisionType: formData.get('decisionType'),
						title: formData.get('title'),
						reason,
						summary: formData.get('summary'),
						body: formData.get('body'),
						},
					});
				} catch (error) {
					setStatus(error instanceof Error ? error.message : 'Decision could not be saved.', true);
				}
			});
		})();
	</script>
) : null}
