---
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { deriveProjectHostBindingsView } from '@treeseed/sdk/operations/project-host-operations';
import { TREESEED_DEFAULT_STARTER_TEMPLATE_ID, normalizeTreeseedTemplateId } from '@treeseed/sdk/types';
import { deriveProjectLaunchRequirementsViewModel } from '@treeseed/sdk/template-launch-ui';
import { escapeHtml as esc, hostTypeLabel, ownershipLabel, providerLabel } from '../../../../lib/market/control-ui.ts';
import { listTreeseedManagedHostsFromConfig } from '../../../../lib/market/managed-hosts.js';
import { listMarketplaceSiteTemplates } from '../../../../lib/market/public-access.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../view-models/app-access.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const runtime = (Astro.locals as any).runtime ?? Astro.locals;
const resolvedProject = await resolveAppProject(context, projectParam);
const projectEntry = resolvedProject.resource;
const details = resolvedProject.details;
if (!projectEntry || !details) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
const project = details?.project ?? projectEntry;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);

const metadata = {
	...(details?.connection?.metadata ?? {}),
	...(details?.hosting?.metadata ?? {}),
	...(project?.metadata ?? {}),
};
const sourceRef = normalizeTreeseedTemplateId(String(metadata.sourceRef ?? TREESEED_DEFAULT_STARTER_TEMPLATE_ID));
const templateListing = await listMarketplaceSiteTemplates(Astro).catch(() => ({ items: [] as any[] }));
const template = templateListing.items.find((item: any) => (item.sourceRef ?? item.slug) === sourceRef)
	?? templateListing.items.find((item: any) => (item.sourceRef ?? item.slug) === TREESEED_DEFAULT_STARTER_TEMPLATE_ID)
	?? null;
const launchRequirements = template?.launchRequirements ?? metadata.launchRequirements ?? null;
const teamId = project?.teamId ?? layoutActiveTeam?.id ?? null;
const [managedHosts, teamHosts, repositoryHosts, repositoryTopology] = teamId && context.store
	? await Promise.all([
		listTreeseedManagedHostsFromConfig(teamId, runtime).catch(() => []),
		context.store.listTeamWebHosts(teamId).catch(() => []),
		context.store.listRepositoryHosts(teamId).catch(() => []),
		project?.id ? context.store.getProjectRepositoryTopology(project.id).catch(() => null) : null,
	])
	: [[], [], [], null];
const defaultHosts = layoutActiveTeam?.metadata?.defaultHosts && typeof layoutActiveTeam.metadata.defaultHosts === 'object'
	? layoutActiveTeam.metadata.defaultHosts
	: {};
const hostBindings = metadata.hostBindings && typeof metadata.hostBindings === 'object' ? metadata.hostBindings : {};
const hostBindingPlans = metadata.hostBindingPlans ?? { configWrites: [], secretDeployment: { items: [] } };
const hostView = deriveProjectHostBindingsView({
	launchRequirements,
	hostBindings,
	hostBindingPlans,
});
const requirementsView = deriveProjectLaunchRequirementsViewModel({
	launchRequirements,
	repositoryHosts: repositoryHosts as any,
	teamHosts: teamHosts as any,
	managedHosts: managedHosts as any,
	defaultHosts,
});
const requirementChoicesByKey = new Map(requirementsView.hosts.map((requirement) => [requirement.key, requirement.choices]));
const operationRows = Array.isArray(metadata.hostBindingOperations) ? metadata.hostBindingOperations : [];
const architecture = details?.architecture && typeof details.architecture === 'object'
	? details.architecture as Record<string, any>
	: metadata.architecture && typeof metadata.architecture === 'object'
		? metadata.architecture as Record<string, any>
		: null;
const contentSource = details?.contentSource && typeof details.contentSource === 'object'
	? details.contentSource as Record<string, any>
	: null;
const contentPublishTarget = architecture?.contentPublishTarget && typeof architecture.contentPublishTarget === 'object'
	? architecture.contentPublishTarget as Record<string, any>
	: null;
const docsReadiness = metadata.docsSiteReadiness ?? metadata.projectArchitectureReadiness ?? null;
const topologyRows = architecture ? [
	{
		id: 'architecture',
		location: '<strong>Project architecture</strong><span>Repository plus logical paths</span>',
		access: esc(architecture.topology ?? 'unknown'),
		source: esc(`root ${architecture.rootPath ?? '.'}`),
		workspace: esc(`site ${architecture.sitePath ?? '.'}`),
		notes: esc('Canonical model for template creation and live repository import without restructuring.'),
	},
	{
		id: 'content-runtime',
		location: '<strong>Content runtime</strong><span>Hosted and local content source</span>',
		access: esc(architecture.contentRuntimeSource ?? 'unknown'),
		source: esc(contentSource?.source ?? contentSource?.runtimeSource ?? 'TreeDX/R2 metadata'),
		workspace: esc(architecture.contentPath ? `content ${architecture.contentPath}` : 'no local content path'),
		notes: esc(`Local materialization: ${architecture.localContentMaterialization ?? 'none'}`),
	},
	{
		id: 'content-publish',
		location: '<strong>Content publish</strong><span>Independent of software deploy</span>',
		access: esc(contentPublishTarget?.kind ?? 'not configured'),
		source: esc(contentPublishTarget?.prefix ?? contentSource?.manifestKey ?? contentSource?.manifestPath ?? 'R2 manifest when published'),
		workspace: esc(repositoryTopology?.contentRepository?.treeDx?.libraryId ?? contentSource?.treeDxLibraryId ?? 'TreeDX/API/R2 backed'),
		notes: esc('Software deploy can proceed without checking out the full content repository.'),
	},
	...(docsReadiness ? [{
		id: 'docs-readiness',
		location: '<strong>Docs readiness</strong><span>Package site preparation</span>',
		access: esc(docsReadiness),
		source: esc(architecture.sitePath ?? 'docs'),
		workspace: esc('Does not block package release unless a docs build opts in.'),
		notes: esc(docsReadiness === 'site_not_prepared' ? 'The docs site path is reserved but not runnable yet.' : 'Docs site structure has been recorded.'),
	}] : []),
] : repositoryTopology ? [
	{
		id: 'content',
		location: '<strong>Content repository</strong><span>src/content canonical library</span>',
		access: esc(repositoryTopology.contentRepository?.accessMode ?? 'treedx'),
		source: esc(repositoryTopology.contentRepository?.treeDx?.libraryId ?? 'TreeDX library'),
		workspace: esc(repositoryTopology.contentRepository?.githubUrl ?? 'Git mirror/source identity'),
		notes: esc('TreeDX canonical; publishes snapshots to R2 without GitHub Actions.'),
	},
	{
		id: 'site',
		location: '<strong>Site repository</strong><span>Knowledge Hub code outside src/content</span>',
		access: esc(repositoryTopology.siteRepository?.accessMode ?? 'filesystem'),
		source: esc(repositoryTopology.siteRepository?.url ?? repositoryTopology.siteRepository?.name ?? 'site repository'),
		workspace: esc(repositoryTopology.siteRepository?.volumePath ?? repositoryTopology.siteRepository?.checkoutPath ?? 'capacity provider volume'),
		notes: esc('Filesystem worktree for agent code edits and site deployment workflows.'),
	},
	...(repositoryTopology.projectRepository ? [{
		id: 'project',
		location: '<strong>Project repository</strong><span>Optional parent/root repository</span>',
		access: esc(repositoryTopology.projectRepository.accessMode ?? 'filesystem'),
		source: esc(repositoryTopology.projectRepository.url ?? repositoryTopology.projectRepository.name ?? 'parent project'),
		workspace: esc(repositoryTopology.projectRepository.volumePath ?? repositoryTopology.projectRepository.checkoutPath ?? 'capacity provider volume'),
		notes: esc(repositoryTopology.projectRepository.siteSubmodulePath ? `Site submodule: ${repositoryTopology.projectRepository.siteSubmodulePath}` : 'Filesystem worktree for parent project edits.'),
	}] : []),
] : [];
const pageJson = JSON.stringify({
	projectId: project?.id ?? null,
	hostRequirements: requirementsView.hosts,
}).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title="Project hosts" description="Operate one project's template host bindings." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{projectEntry && details ? (
		<section class="ts-control-page" aria-label="Project hosts">
			<ProjectControlNav projectId={project.id} current="hosts" />
			<Panel eyebrow="Project hosts" title="Template host bindings" description="Inspect, audit, resync, replace, or rotate the hosts selected for this project's template requirements.">
				<div class="ts-requirement-summary">
					<strong>{template?.title ?? sourceRef}</strong>
					<span>{hostView.summary.total} requirements · {hostView.summary.warnings} warnings · {hostView.summary.blocked} blocked</span>
				</div>
				<ul class="ts-host-diagnostics">
					<li>Secret-bearing operations use client-encrypted escrow, GitHub Actions secret targets, explicit host env injection, or metadata-only re-entry states.</li>
					<li>Admin never sends the unlock passphrase to project host operations; re-enter or migrate the selected host secret before rotate/resync when a server-side unlock would be required.</li>
					<li>GitHub-backed secret use requires GitHub App grants, protected refs, protected environments, and allowlisted workflow operations.</li>
				</ul>
				<div class="ts-host-setup-grid" data-project-host-bindings>
					{hostView.requirements.map((requirement) => {
						const choices = (requirementChoicesByKey.get(requirement.requirementKey) ?? [])
							.filter((choice: any) => choice.mode !== 'new' && !String(choice.value ?? '').startsWith('new:'));
						const selectedValue = choices.find((choice: any) => {
							const binding = requirement.binding;
							if (!binding) return choice.mode === 'none';
							if (binding.managedHostKey) return choice.managedHostKey === binding.managedHostKey || choice.hostId === binding.managedHostKey;
							if (binding.hostId) return choice.hostId === binding.hostId;
							return choice.mode === binding.mode;
						})?.value ?? choices.find((choice: any) => choice.selected)?.value ?? choices[0]?.value ?? '';
						return (
							<section class="ts-inline-host-card ts-template-host-requirement" data-project-host-card data-requirement-key={requirement.requirementKey} data-requirement-type={requirement.type}>
								<div class="ts-inline-host-card__header">
									<strong>{requirement.displayName}</strong>
									<span>{requirement.purpose}</span>
								</div>
								<div class="ts-requirement-meta">
									<span>{requirement.required ? 'Required' : 'Optional'}</span>
									<span>{hostTypeLabel(requirement.type)}</span>
									<span>{requirement.audit.status}</span>
								</div>
								<div class="ts-host-binding-current">
									<strong>{esc(requirement.binding?.displayName ?? 'No host selected')}</strong>
									<span>{providerLabel(requirement.binding?.provider)} · {ownershipLabel(requirement.binding?.ownership ?? requirement.binding?.mode)} · {esc(requirement.audit.marketHostId ?? 'no Market host id')}</span>
								</div>
								<label class="ts-field">
									<span class="ts-field__label">Replacement host</span>
									<select name={`host-${requirement.requirementKey}`} data-host-replacement-select>
										{choices.map((choice: any) => (
											<option
												value={choice.value}
												selected={choice.value === selectedValue}
												data-mode={choice.mode}
												data-host-id={choice.hostId ?? ''}
												data-managed-host-key={choice.managedHostKey ?? ''}
												data-provider={choice.provider ?? ''}
												data-host-type={choice.type ?? ''}
												data-readiness={choice.readiness ?? ''}
											>{choice.label}</option>
										))}
									</select>
								</label>
								<div class="ts-requirement-preview">
									<div>
										<strong>Config</strong>
										<span>{requirement.configWrites.length > 0 ? requirement.configWrites.map((write) => `${write.target}:${write.path}`).join(' · ') : 'No config writes declared'}</span>
									</div>
									<div>
										<strong>Secrets</strong>
										<span>{requirement.secretTargets.length > 0 ? requirement.secretTargets.map((item) => `${item.env} -> ${item.targets.join(', ')}`).join(' · ') : 'No secret targets declared'}</span>
									</div>
									<div>
										<strong>Boundary</strong>
										<span>{requirement.secretTargets.length > 0 ? 'client-encrypted escrow -> GitHub Actions or explicit host injection' : 'metadata-only'}</span>
									</div>
								</div>
								{requirement.audit.diagnostics.length > 0 ? (
									<ul class="ts-host-diagnostics">
										{requirement.audit.diagnostics.map((diagnostic) => <li>{diagnostic.message}</li>)}
									</ul>
								) : null}
								<div class="ts-project-host-actions">
									<button class="ts-button-secondary" type="button" data-host-action="audit">Audit</button>
									<button class="ts-button-secondary" type="button" data-host-action="resync">Resync</button>
									<button class="ts-button-secondary" type="button" data-host-action="replace">Replace</button>
									<button class="ts-button-secondary" type="button" data-host-action="rotate">Rotate</button>
								</div>
							</section>
						);
					})}
				</div>
				<p class="ts-subtle" id="project-host-operation-message" role="status"></p>
			</Panel>
			<Panel eyebrow="Project architecture" title="Repository, site, and content bindings" description="Projects are logical repository bindings with root/site/content paths, runtime content source, and local materialization policy. Submodules are optional workspace mechanics, not the canonical model.">
				<PlainTable columns={[
					{ key: 'location', label: 'Location' },
					{ key: 'access', label: 'Access' },
					{ key: 'source', label: 'Source' },
					{ key: 'workspace', label: 'Runner workspace' },
					{ key: 'notes', label: 'Notes' },
				]} rows={topologyRows} emptyTitle="No project architecture" emptyDescription="Import or seed this project with rootPath, sitePath, contentPath, contentRuntimeSource, and localContentMaterialization." />
			</Panel>
			<Panel eyebrow="Audit" title="Recent host operations" description="Governed host operations record the Market host id and planned repository config changes.">
				<div class="ts-table-wrap">
					<table class="ts-plain-table">
						<thead><tr><th>Operation</th><th>Requirement</th><th>Status</th><th>Queued</th></tr></thead>
						<tbody>
							{operationRows.length > 0 ? operationRows.map((operation: any) => (
								<tr><td>{operation.kind ?? operation.id}</td><td>{operation.requirementKey ?? 'all'}</td><td>{operation.status ?? 'queued'}</td><td>{operation.queuedAt ?? ''}</td></tr>
							)) : <tr><td colspan="4">No project host operations recorded yet.</td></tr>}
						</tbody>
					</table>
				</div>
			</Panel>
			<script is:inline type="application/json" id="project-hosts-data" set:html={pageJson}></script>
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>

<script>
	import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

	function initProjectHostsPage() {
		const dataElement = document.getElementById('project-hosts-data');
		const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : {};
		const statusElement = document.getElementById('project-host-operation-message');
		if (!pageData.projectId || document.body.dataset.projectHostsBound === 'true') return;
		document.body.dataset.projectHostsBound = 'true';
		const requirements = new Map((pageData.hostRequirements ?? []).map((requirement: any) => [requirement.key, requirement]));
		function setStatus(message: string) {
			if (statusElement) statusElement.textContent = message;
		}
		function selectedChoice(card: HTMLElement) {
			const select = card.querySelector<HTMLSelectElement>('[data-host-replacement-select]');
			const option = select?.selectedOptions?.[0] ?? null;
			return {
				value: option?.value ?? '',
				mode: option?.dataset.mode ?? String(option?.value ?? '').split(':')[0],
				hostId: option?.dataset.hostId ?? '',
				managedHostKey: option?.dataset.managedHostKey ?? '',
				provider: option?.dataset.provider ?? '',
				type: option?.dataset.hostType ?? '',
				readiness: option?.dataset.readiness ?? '',
			};
		}
		function bindingForCard(card: HTMLElement) {
			const key = card.dataset.requirementKey ?? '';
			const requirement: any = requirements.get(key) ?? {};
			const choice = selectedChoice(card);
			const mode = choice.mode || 'none';
			const isNone = mode === 'none';
			const isManaged = mode === 'treeseed_managed';
			return {
				requirementKey: key,
				requirementKind: 'host',
				type: requirement.type ?? choice.type,
				provider: choice.provider || requirement.compatibleProviders?.[0] || '',
				hostId: isNone ? null : isManaged && requirement.type !== 'repository' ? null : choice.hostId || null,
				managedHostKey: isNone ? null : isManaged ? choice.managedHostKey || choice.hostId || null : null,
				mode,
				environmentScopes: requirement.environmentScopes ?? ['staging', 'prod'],
				selectedBy: isNone ? 'user' : isManaged ? 'managed-default' : 'user',
			};
		}
		function hostOperationWouldNeedServerUnlock(action: string, card: HTMLElement) {
			const choice = selectedChoice(card);
			return action === 'rotate' || action === 'resync' || choice.mode === 'team_owned';
		}
		async function submit(card: HTMLElement, action: string) {
			const key = card.dataset.requirementKey ?? '';
			if (hostOperationWouldNeedServerUnlock(action, card)) {
				setStatus(`${action} for ${key} needs secret re-entry or migration first. Admin no longer sends unlock passphrases to project host operations.`);
				return;
			}
			const body: any = {};
			if (action === 'replace') body.hostBinding = bindingForCard(card);
			setStatus(`${action} queued for ${key}...`);
			const url = action === 'audit'
				? `/v1/projects/${encodeURIComponent(pageData.projectId)}/hosts/audit`
				: `/v1/projects/${encodeURIComponent(pageData.projectId)}/hosts/${encodeURIComponent(key)}/${action}`;
			await submitPlatformOperationForm({
				url,
				body,
				statusElement,
				initialMessage: `${action} queued for ${key}...`,
				fallbackHref: `/app/projects/${encodeURIComponent(pageData.projectId)}/hosts`,
				timeoutMs: 180_000,
			});
		}
		for (const button of document.querySelectorAll<HTMLButtonElement>('[data-host-action]')) {
			button.addEventListener('click', async () => {
				const card = button.closest<HTMLElement>('[data-project-host-card]');
				if (!card) return;
				try {
					await submit(card, button.dataset.hostAction ?? 'audit');
				} catch (error) {
					setStatus(error instanceof Error ? error.message : String(error));
				}
			});
		}
	}
	(window as any).treeseedInitProjectHostsPage = initProjectHostsPage;
	initProjectHostsPage();
</script>

<script is:inline data-astro-rerun>
	window.treeseedInitProjectHostsPage?.();
</script>
