---
import ReaderTemplate from '@treeseed/ui/components/astro/templates/ReaderTemplate.astro';
import PublishedContentBody from '@treeseed/ui/components/astro/site/PublishedContentBody.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { loadPrivateKnowledgePageViewModel } from '../../../../../view-models/private-knowledge.vm.ts';

const projectId = String(Astro.params.projectId ?? '');
const slug = String(Astro.params.slug ?? '');
if (!Astro.locals.auth?.principal) {
	const returnTo = `${Astro.url.pathname}${Astro.url.search}`;
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(returnTo)}`);
}

const vm = await loadPrivateKnowledgePageViewModel(Astro, projectId, slug);
Astro.response.status = vm.statusCode;
for (const [name, value] of Object.entries(vm.reader.cache.headers)) Astro.response.headers.set(name, value);
---

<TreeseedAppLayout
	title={vm.reader.title}
	description={vm.reader.description}
	currentPath={`/app/projects/${encodeURIComponent(projectId)}/knowledge/${slug}`}
	teams={vm.teams}
	activeTeam={vm.activeTeam}
>
	<ReaderTemplate
		title={vm.reader.title}
		description={vm.reader.description}
		actions={vm.reader.actions}
		navGroups={vm.reader.navGroups}
	>
		{vm.reader.status === 'ready' && vm.reader.publishedHtml ? (
			<PublishedContentBody html={vm.reader.publishedHtml} />
		) : (
			<EmptyState
				title={vm.reader.errorTitle ?? vm.reader.title}
				description={vm.reader.errorDescription ?? vm.reader.description}
				actions={[{ label: 'Back to project', href: `/app/projects/${encodeURIComponent(projectId)}` }]}
			/>
		)}
	</ReaderTemplate>
</TreeseedAppLayout>
