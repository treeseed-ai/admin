---
import { getCollection, render } from 'astro:content';
import Badge from '@treeseed/ui/components/astro/data/Badge.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import KeyValueList from '@treeseed/ui/components/astro/data/KeyValueList.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../../view-models/app-access.js';

const projectParam = String(Astro.params.projectId ?? '');
const agentSlug = String(Astro.params.agentSlug ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const resolvedProject = await resolveAppProject(context, projectParam);
const project = resolvedProject.resource;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
const [agentEntries, summary] = project ? await Promise.all([
	getCollection('agents' as any, ({ data }: any) => data?.enabled !== false).catch(() => []),
	context.store && typeof context.store.getProjectAgentsSummary === 'function' ? context.store.getProjectAgentsSummary(project.id, context.principal).catch(() => null) : null,
]) : [[], null];
const entry = agentEntries.find((candidate: any) => String(candidate.data?.slug ?? candidate.id ?? '') === agentSlug || String(candidate.data?.id ?? '').replace(/^agent:/u, '') === agentSlug) ?? null;
const runtime = (summary?.agents ?? []).find((agent: any) => String(agent.agentSlug ?? agent.slug ?? '') === agentSlug) ?? null;
if (!project || (!entry && !runtime)) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
const rendered = entry ? await render(entry) : null;
const Content = rendered?.Content;
const data = entry?.data ?? {};
const operationData = JSON.stringify({ projectId: project?.id ?? '', agentSlug }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={data.name ?? data.title ?? agentSlug} description={data.description ?? runtime?.lastMessage ?? ''} currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{project && (entry || runtime) ? (
		<section class="ts-control-page" aria-label="Agent detail">
			<ProjectControlNav projectId={project.id} current="agents" />
			<Panel eyebrow="Agent" title={data.name ?? data.title ?? agentSlug} description={data.summary ?? data.description ?? runtime?.lastMessage ?? ''}>
				<Badge slot="actions" tone={String(runtime?.status ?? data.runtimeStatus ?? '') === 'active' ? 'success' : 'default'}>{runtime?.status ?? data.runtimeStatus ?? 'configured'}</Badge>
				<KeyValueList items={[
					{ key: 'Slug', value: agentSlug },
					{ key: 'Handler', value: data.handler ?? runtime?.handler ?? 'not recorded' },
					{ key: 'Current task', value: runtime?.currentTask ?? 'none' },
					{ key: 'Last run', value: runtime?.lastRunAt ?? 'not recorded' },
				]} />
				<FormActions align="start">
					<button class="ts-button" data-size="sm" type="button" id="run-agent-button">Run</button>
					<button class="ts-button" data-size="sm" data-variant="secondary" type="button" id="pause-agent-button">Pause</button>
					<button class="ts-button" data-size="sm" data-variant="secondary" type="button" id="resume-agent-button">Resume</button>
					<span class="ts-subtle" id="agent-action-status" role="status"></span>
				</FormActions>
			</Panel>
			<Panel eyebrow="Agent" title="Definition body" description="Human-readable description from the local agent content file.">
				<article class="ts-prose">{Content ? <Content /> : null}</article>
			</Panel>
			{entry ? (
				<Panel eyebrow="Edit" title="Edit agent summary" description="Update the plain-language agent definition fields. Advanced permissions remain managed in the source file.">
					<form id="agent-edit-form" class="ts-form-stack">
						<div class="ts-form-grid">
							<Field label="Name" name="title" required><TextInput name="title" required value={data.name ?? data.title ?? agentSlug} /></Field>
							<Field label="Handler" name="handler"><TextInput name="handler" value={data.handler ?? 'planner'} /></Field>
							<Field label="Runtime status" name="runtimeStatus"><Select name="runtimeStatus" value={data.runtimeStatus ?? 'active'} options={[{ label: 'Active', value: 'active' }, { label: 'Experimental', value: 'experimental' }, { label: 'Dormant', value: 'dormant' }]} /></Field>
						</div>
						<Field label="Description" name="description" required><Textarea name="description" rows={3} required value={data.description ?? ''} /></Field>
						<Field label="Summary" name="summary"><Textarea name="summary" rows={3} value={data.summary ?? ''} /></Field>
						<Field label="System prompt" name="systemPrompt"><Textarea name="systemPrompt" rows={7} value={data.systemPrompt ?? ''} /></Field>
						<Field label="Body" name="body"><Textarea name="body" rows={6} value="Update this agent role, operating boundaries, and expected outputs." /></Field>
						<FormActions align="start"><Button type="submit">Save summary</Button><span class="ts-subtle" id="agent-edit-status" role="status"></span></FormActions>
					</form>
				</Panel>
			) : null}
		</section>
	) : (
		<EmptyState title="Agent not found" description="This agent is not available for the selected project." actions={[{ label: 'Back to Agents', href: project ? `/app/projects/${project.id}/agents` : '/app/projects' }]} />
	)}
	<script is:inline type="application/json" id="agent-operation-data" set:html={operationData}></script>
</TreeseedAppLayout>

<script>
	import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

	const operationDataElement = document.getElementById('agent-operation-data');
	const operationData = operationDataElement?.textContent ? JSON.parse(operationDataElement.textContent) : {};
	const actionStatus = document.getElementById('agent-action-status');
	async function postAgentAction(action: string) {
		if (actionStatus) actionStatus.textContent = `${action} requested...`;
		const response = await fetch(`/v1/projects/${encodeURIComponent(operationData.projectId)}/agents/${encodeURIComponent(operationData.agentSlug)}/${action}`, {
			method: 'POST',
			headers: { 'content-type': 'application/json' },
			body: JSON.stringify({ environment: 'local', reason: `${action} requested from agent page`, payload: { source: 'project_agent_page' } }),
		});
		const payload = await response.json().catch(() => null);
		if (!response.ok || payload?.ok === false) {
			if (actionStatus) actionStatus.textContent = payload?.error ?? `${action} could not be requested.`;
			return;
		}
		if (actionStatus) actionStatus.textContent = `${action} request recorded.`;
	}
	document.getElementById('run-agent-button')?.addEventListener('click', () => postAgentAction('run'));
	document.getElementById('pause-agent-button')?.addEventListener('click', () => postAgentAction('pause'));
	document.getElementById('resume-agent-button')?.addEventListener('click', () => postAgentAction('resume'));

	const editForm = document.getElementById('agent-edit-form') as HTMLFormElement | null;
	const editStatus = document.getElementById('agent-edit-status');
	editForm?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const body: Record<string, any> = Object.fromEntries(new FormData(editForm).entries());
		body.slug = operationData.agentSlug;
		body.overwrite = true;
		try {
			await submitPlatformOperationForm({
				url: `/v1/projects/${encodeURIComponent(operationData.projectId)}/local-content/agents`,
				body,
				statusElement: editStatus,
				fallbackHref: `${window.location.pathname}?saved=${Date.now()}`,
				initialMessage: 'Queuing agent save operation...',
			});
		} catch (error) {
			if (editStatus) editStatus.textContent = error instanceof Error ? error.message : 'Agent could not be saved.';
		}
	});
</script>
