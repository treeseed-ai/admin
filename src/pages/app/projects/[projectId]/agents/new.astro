---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../../view-models/app-access.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const resolvedProject = await resolveAppProject(context, projectParam);
const project = resolvedProject.resource;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
if (!project) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
const operationData = JSON.stringify({ projectId: project?.id ?? '' }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title="New agent" description="Create a local agent definition." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{project ? (
		<section class="ts-control-page" aria-label="New agent">
			<ProjectControlNav projectId={project.id} current="agents" />
			<Panel eyebrow="Agents" title="Create agent" description="This writes a canonical local agent definition under src/content/agents.">
				<form id="agent-create-form" class="ts-form-stack">
					<div class="ts-form-grid">
						<Field label="Name" name="title" required><TextInput name="title" required /></Field>
						<Field label="Slug" name="slug"><TextInput name="slug" placeholder="Generated from name if empty" /></Field>
						<Field label="Handler" name="handler"><TextInput name="handler" value="planner" /></Field>
						<Field label="Runtime status" name="runtimeStatus"><Select name="runtimeStatus" options={[{ label: 'Active', value: 'active' }, { label: 'Experimental', value: 'experimental' }, { label: 'Dormant', value: 'dormant' }]} /></Field>
					</div>
					<Field label="Description" name="description" required><Textarea name="description" rows={3} required /></Field>
					<Field label="Summary" name="summary"><Textarea name="summary" rows={3} /></Field>
					<Field label="System prompt" name="systemPrompt"><Textarea name="systemPrompt" rows={7} /></Field>
					<Field label="Body" name="body"><Textarea name="body" rows={6} /></Field>
					<FormActions align="start"><Button type="submit">Create agent</Button><Button href={`/app/projects/${project.id}/agents`} variant="secondary">Cancel</Button><span class="ts-subtle" id="agent-create-status" role="status"></span></FormActions>
				</form>
			</Panel>
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
	<script is:inline type="application/json" id="agent-create-data" set:html={operationData}></script>
</TreeseedAppLayout>

<script>
	import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

	const dataElement = document.getElementById('agent-create-data');
	const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : {};
	const form = document.getElementById('agent-create-form') as HTMLFormElement | null;
	const status = document.getElementById('agent-create-status');
	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const body: Record<string, any> = Object.fromEntries(new FormData(form).entries());
		try {
			await submitPlatformOperationForm({
				url: `/v1/projects/${encodeURIComponent(pageData.projectId)}/local-content/agents`,
				body,
				statusElement: status,
				fallbackHref: `/app/projects/${encodeURIComponent(pageData.projectId)}/agents`,
				initialMessage: 'Queuing agent operation...',
			});
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'Agent could not be created.';
		}
	});
</script>
