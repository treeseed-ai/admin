---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../view-models/app-access.js';
import { loadWorkContentEntries, workContentEntriesFor, workContentRelationSummary } from '../../../../view-models/work-content.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const [context, contentEntries] = await Promise.all([
	loadAppContext(Astro),
	loadWorkContentEntries(),
]);
const resolvedProject = await resolveAppProject(context, projectParam);
const project = resolvedProject.resource;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
if (!project) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;

function rowFor(entry: any, label: string) {
	const detail = label.startsWith('objective')
		? entry.description || entry.summary
		: entry.summary || entry.description;
	return {
		id: `${label}-${esc(entry.id)}`,
		name: `<strong>${esc(entry.title)}</strong><span>${esc(detail)}</span>`,
		type: esc(entry.type),
		state: esc(entry.status),
		related: esc(workContentRelationSummary(entry)),
		action: `<a class="ts-link-button" href="${esc(entry.href)}">Open</a>`,
	};
}

const objectives = workContentEntriesFor(contentEntries, 'objectives');
const core = objectives.find((entry: any) => entry.id === 'core' || entry.id === 'objective:core' || entry.title.toLowerCase().includes('core treeseed objective')) ?? null;
const coreStatement = core?.description || core?.summary || '';
const coreMeta = core
	? [
			{ label: 'Status', value: core.status },
			{ label: 'Horizon', value: core.type },
			{ label: 'Updated', value: core.date },
		].filter((item) => item.value)
	: [];
const objectiveRows = [
	...(core ? [rowFor(core, 'objective-core')] : []),
	...objectives.filter((entry: any) => entry !== core).map((entry: any) => rowFor(entry, 'objective')),
];
const questionRows = workContentEntriesFor(contentEntries, 'questions').map((entry: any) => rowFor(entry, 'question'));
const noteRows = workContentEntriesFor(contentEntries, 'notes').map((entry: any) => rowFor(entry, 'note'));
const activeTabParam = String(Astro.url.searchParams.get('tab') ?? 'objectives');
const activeTab = ['objectives', 'questions', 'notes'].includes(activeTabParam) ? activeTabParam : 'objectives';
const tabBase = `/app/projects/${encodeURIComponent(project?.id ?? projectParam)}/guidance`;
const guidanceTabs = [
	{ key: 'objectives', label: 'Objectives', count: objectiveRows.length, href: `${tabBase}?tab=objectives` },
	{ key: 'questions', label: 'Questions', count: questionRows.length, href: `${tabBase}?tab=questions` },
	{ key: 'notes', label: 'Notes', count: noteRows.length, href: `${tabBase}?tab=notes` },
];
---

<TreeseedAppLayout title="Project guidance" description="Manage the objectives, questions, and notes that steer project work." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{project ? (
		<section class="ts-control-page" aria-label="Project guidance">
			<ProjectControlNav projectId={project.id} current="guidance" />
			<Panel
				eyebrow="Core objective"
				title={core?.title ?? 'Core objective'}
				description="The top-level goal used to orient project guidance and the first context given to agents."
			>
				{core ? <Button slot="actions" href={core.href} size="sm">Edit core objective</Button> : null}
				{core ? (
					<div class="ts-core-objective">
						<section class="ts-core-objective__statement" aria-label="Objective statement">
							<p class="ts-core-objective__label">Objective statement</p>
							<p>{coreStatement}</p>
						</section>
						{coreMeta.length > 0 ? (
							<dl class="ts-core-objective__meta" aria-label="Core objective metadata">
								{coreMeta.map((item) => (
									<div>
										<dt>{item.label}</dt>
										<dd>{item.value}</dd>
									</div>
								))}
							</dl>
						) : null}
					</div>
				) : (
					<EmptyState title="Core objective missing" description="Create src/content/objectives/core.md so project guidance has a stable top-level goal." />
				)}
			</Panel>
			<nav class="ts-tabs" aria-label="Guidance content sections">
				{guidanceTabs.map((tab) => (
					<a class="ts-tab" href={tab.href} aria-current={activeTab === tab.key ? 'page' : undefined}>
						{tab.label}
						<span class="ts-tab__count">{tab.count}</span>
					</a>
				))}
			</nav>
			{activeTab === 'objectives' ? (
				<Panel eyebrow="Guidance" title="Objectives" description="Durable project goals. The core objective stays first.">
					<Button slot="actions" href={`/app/work/objectives/new?projectId=${encodeURIComponent(project.id)}`} size="sm">New objective</Button>
					<PlainTable
						columns={[{ key: 'name', label: 'Objective' }, { key: 'type', label: 'Horizon' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]}
						rows={objectiveRows}
						emptyTitle="No objectives yet"
						emptyDescription="Create the core objective and the first project objective."
						interactive={true}
						pageSize={10}
						searchLabel="Filter objectives"
					/>
				</Panel>
			) : null}
			{activeTab === 'questions' ? (
				<Panel eyebrow="Guidance" title="Questions" description="Open questions that focus research, planning, and agent work.">
					<Button slot="actions" href={`/app/work/questions/new?projectId=${encodeURIComponent(project.id)}`} size="sm">New question</Button>
					<PlainTable
						columns={[{ key: 'name', label: 'Question' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]}
						rows={questionRows}
						emptyTitle="No questions yet"
						emptyDescription="Create a question to focus research or implementation discovery."
						interactive={true}
						pageSize={10}
						searchLabel="Filter questions"
					/>
				</Panel>
			) : null}
			{activeTab === 'notes' ? (
				<Panel eyebrow="Guidance" title="Notes" description="Reusable context and evidence that should stay visible while the project evolves.">
					<Button slot="actions" href={`/app/work/notes/new?projectId=${encodeURIComponent(project.id)}`} size="sm">New note</Button>
					<PlainTable
						columns={[{ key: 'name', label: 'Note' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Links' }, { key: 'action', label: 'Action' }]}
						rows={noteRows}
						emptyTitle="No notes yet"
						emptyDescription="Create a note to preserve useful project context."
						interactive={true}
						pageSize={10}
						searchLabel="Filter notes"
					/>
				</Panel>
			) : null}
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>
