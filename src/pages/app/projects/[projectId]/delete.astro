---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../view-models/app-access.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const resolvedProject = await resolveAppProject(context, projectParam);
const project = resolvedProject.resource;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
const blockers = project && context.store ? await context.store.evaluateProjectDeletionBlockers(project.id).catch(() => null) : null;
if (!project) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
const blockerRows = Object.entries(blockers ?? {}).filter(([, value]) => Array.isArray(value) ? value.length > 0 : Number(value) > 0).map(([key, value]) => ({ name: esc(key), value: esc(Array.isArray(value) ? value.length : value) }));
const hasDeletionBlockers = blockerRows.length > 0;
const confirmation = project ? `DELETE ${project.slug}` : '';
---

<TreeseedAppLayout title="Delete project" description="Delete one project." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam} showSensitiveUnlock>
	{project ? (
		<section class="ts-control-page" aria-label="Delete project">
			<ProjectControlNav projectId={project.id} current="delete" />
			<Panel eyebrow="Projects" title={`Delete ${project.name ?? project.slug}`} description="This starts an infrastructure deletion run. Repositories, deployment resources, and DNS records created for this project are cleaned up before the project is marked deleted.">
				<PlainTable columns={[{ key: 'name', label: 'Blocker' }, { key: 'value', label: 'Count' }]} rows={blockerRows} emptyTitle="No blockers found" emptyDescription="This project can be deleted after confirmation." />
				<form id="project-delete-form" class="ts-form-stack ts-stack-top">
					<Field label={`Type ${confirmation}`} name="confirmation" required><TextInput name="confirmation" required /></Field>
					<p class="ts-attention-note">
						Use the sensitive data unlock before deleting. The API needs the team passphrase only for this run so it can unlock host credentials and remove external infrastructure.
					</p>
					<FormActions align="start">
						<Button id="project-delete-submit" type="submit" variant="danger" disabled>Delete project and infrastructure</Button>
						<Button href="/app/projects" variant="secondary">Cancel</Button>
						<span class="ts-subtle" id="project-delete-status" role="status"></span>
					</FormActions>
				</form>
			</Panel>
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>

<script is:inline define:vars={{ projectId: project?.id ?? '', requiredConfirmation: confirmation, hasDeletionBlockers }}>
	const form = document.getElementById('project-delete-form');
	const status = document.getElementById('project-delete-status');
	const submitButton = document.getElementById('project-delete-submit');
	const confirmationInput = form?.querySelector('input[name="confirmation"]');

	function currentConfirmation() {
		return String(new FormData(form).get('confirmation') ?? '').trim();
	}

	function syncDeleteSubmitState() {
		const confirmationMatches = currentConfirmation() === requiredConfirmation;
		const canSubmit = !hasDeletionBlockers && confirmationMatches;
		if (submitButton) {
			submitButton.disabled = !canSubmit;
			submitButton.setAttribute('aria-disabled', canSubmit ? 'false' : 'true');
			submitButton.title = hasDeletionBlockers
				? 'Resolve deletion blockers before deleting this project.'
				: confirmationMatches
					? ''
					: 'Enter the exact confirmation text to enable deletion.';
		}
		if (status && hasDeletionBlockers) {
			status.textContent = 'Resolve blockers before deleting this project.';
		}
	}

	confirmationInput?.addEventListener('input', syncDeleteSubmitState);
	syncDeleteSubmitState();

	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		syncDeleteSubmitState();
		if (submitButton?.disabled) return;
		if (status) status.textContent = 'Project deletion needs secret re-entry or migration first. Admin no longer sends unlock passphrases to the API.';
	});
</script>
