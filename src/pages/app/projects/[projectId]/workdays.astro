---
import CollectionTemplate from '@treeseed/ui/components/astro/templates/CollectionTemplate.astro';
import WorkQueueSummary from '@treeseed/ui/components/astro/operating/WorkQueueSummary.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadProjectWorkdayCollection } from '../../../../view-models/operating-loop.vm.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadProjectWorkdayCollection(Astro, projectParam, Astro.url);
if (!vm.project) Astro.response.status = vm.resolution.status === 'forbidden' ? 403 : 404;
const pageJson = JSON.stringify({ projectId: vm.project?.id ?? '', requestType: 'one_off_run', reason: 'Requested from project workdays', source: 'project_workdays_ui' }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={vm.collection.title} description={vm.collection.description} currentPath="/app/projects" teams={vm.context.teams} activeTeam={vm.resolution.team ?? vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.project ? (
		<CollectionTemplate viewModel={vm.collection} actions={vm.actions}>
			<WorkQueueSummary viewModel={vm.queue} />
			<button class="ts-button" data-size="sm" type="button" id="request-workday-button">Request local workday</button>
			<span class="ts-subtle" id="workday-request-status" role="status"></span>
		</CollectionTemplate>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
	<script is:inline type="application/json" id="workday-request-data" set:html={pageJson}></script>
</TreeseedAppLayout>

<script>
	import { bindWorkdayRequest } from '../../../../lib/market/operating-loop-client';

	bindWorkdayRequest({ dataId: 'workday-request-data', buttonId: 'request-workday-button', statusId: 'workday-request-status' });
</script>
