---
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import ProjectControlNav from '@treeseed/ui/components/astro/app/controls/ProjectControlNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { loadKnowledgeViewModel } from '../../../../view-models/knowledge.vm.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppProject } from '../../../../view-models/app-access.js';

const projectParam = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const resolvedProject = await resolveAppProject(context, projectParam);
const project = resolvedProject.resource;
const layoutActiveTeam = resolvedProject.team ?? context.activeTeam;
if (resolvedProject.team?.id && resolvedProject.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, resolvedProject.team);
const releases = project && context.store && typeof context.store.getProjectReleasesSummary === 'function'
	? await context.store.getProjectReleasesSummary(project.id, context.principal).catch(() => null)
	: null;
const knowledgeVm = await loadKnowledgeViewModel(Astro).catch(() => null);
if (!project) Astro.response.status = resolvedProject.status === 'forbidden' ? 403 : 404;
const projectArtifacts = (knowledgeVm?.artifacts ?? []).filter((artifact: any) => artifact.metadata?.projectId === project?.id || artifact.originatingProject?.id === project?.id || artifact.projectId === project?.id);
const artifactRows = projectArtifacts.map((artifact: any) => ({
	id: `artifact-${esc(artifact.id ?? artifact.slug)}`,
	name: `<strong>${esc(artifact.title)}</strong><span>${esc(artifact.description ?? artifact.type ?? '')}</span>`,
	state: esc(artifact.state ?? 'generated'),
	action: `<a class="ts-link-button" href="${esc(artifact.href ?? '/app/knowledge/artifacts')}">Review</a>`,
}));
const releaseRows = [
	...(Array.isArray(releases?.releases) ? releases.releases : []),
	...(Array.isArray(releases?.recentReleases) ? releases.recentReleases : []),
].map((release: any, index: number) => ({
	id: `release-${esc(release.id ?? release.releaseTag ?? index)}`,
	name: `<strong>${esc(release.releaseTag ?? release.version ?? release.title ?? 'Release')}</strong><span>${esc(release.environment ?? release.summary ?? '')}</span>`,
	state: esc(release.status ?? release.state ?? 'recorded'),
}));
---

<TreeseedAppLayout title="Project artifacts" description="Package, publish, or share one project's artifacts." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{project ? (
		<section class="ts-control-page" aria-label="Project artifacts">
			<ProjectControlNav projectId={project.id} current="artifacts" />
			<Panel eyebrow="Projects" title="Artifact actions" description="Send an export, template, knowledge pack, or publish request to the project runtime.">
				<div class="ts-share-actions">
					<button class="ts-button" type="button" data-share-action="export">Export bundle</button>
					<button class="ts-button" data-variant="secondary" type="button" data-share-action="package-template">Package template</button>
					<button class="ts-button" data-variant="secondary" type="button" data-share-action="package-knowledge-pack">Package knowledge pack</button>
					<button class="ts-button" data-variant="secondary" type="button" data-share-action="publish">Publish</button>
					<span class="ts-subtle" id="share-action-status" role="status"></span>
				</div>
			</Panel>
			<Panel eyebrow="Projects" title="Artifacts" description="Generated outputs linked to this project.">
				<PlainTable columns={[{ key: 'name', label: 'Artifact' }, { key: 'state', label: 'State' }, { key: 'action', label: 'Action' }]} rows={artifactRows} emptyTitle="No artifacts yet" emptyDescription="Generated reports and knowledge outputs appear here." />
			</Panel>
			<Panel eyebrow="Projects" title="Releases" description="Release records linked to this project.">
				<PlainTable columns={[{ key: 'name', label: 'Release' }, { key: 'state', label: 'State' }]} rows={releaseRows} emptyTitle="No releases yet" emptyDescription="Release records appear after publish activity." />
			</Panel>
		</section>
	) : (
		<EmptyState title="Project not found" description="This project is not available." actions={[{ label: 'Back to Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>

<script is:inline define:vars={{ projectId: project?.id ?? '' }}>
	const status = document.getElementById('share-action-status');
	async function submitJson(url) {
		const response = await fetch(url, { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({}) });
		const payload = await response.json().catch(() => null);
		if (!response.ok || payload?.ok === false) throw new Error(payload?.error ?? 'Request failed.');
		return payload.payload;
	}
	document.querySelectorAll('[data-share-action]').forEach((button) => {
		button.addEventListener('click', async () => {
			const action = button.getAttribute('data-share-action') ?? '';
			const endpoint = action === 'export' ? 'share/export' : action === 'publish' ? 'share/publish' : `share/${action}`;
			if (status) status.textContent = 'Submitting...';
			try {
				await submitJson(`/v1/projects/${encodeURIComponent(projectId)}/${endpoint}`);
				if (status) status.textContent = 'Request submitted.';
			} catch (error) {
				if (status) status.textContent = error instanceof Error ? error.message : 'Request failed.';
			}
		});
	});
</script>
