---
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import StatusPill from '@treeseed/ui/components/astro/data/StatusPill.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext, persistActiveTeamSelection, resolveAppDeployment } from '../../../../view-models/app-access.js';

const deploymentId = Astro.params.id ?? '';
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname + Astro.url.search)}`);
}
const context = await loadAppContext(Astro);
const deploymentResolution = deploymentId ? await resolveAppDeployment(context, deploymentId) : null;
const deploymentAccessible = Boolean(deploymentId && deploymentResolution?.status === 'found');
const layoutActiveTeam = deploymentResolution?.team ?? context.activeTeam;
if (deploymentResolution?.team?.id && deploymentResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, deploymentResolution.team);
if (deploymentId && !deploymentAccessible) {
	Astro.response.status = deploymentResolution?.status === 'forbidden' ? 403 : 404;
}
---

<TreeseedAppLayout title="Project deployment" description="Follow project deployment progress, warnings, and support logs." currentPath="/app/projects" teams={context.teams} activeTeam={layoutActiveTeam}>
	{deploymentAccessible ? (
		<section class="ts-control-page ts-deployment-status-page" aria-label="Project deployment status" data-deployment-page data-deployment-id={deploymentId} data-status="loading">
			<Panel eyebrow="Deployment" title="Project deployment status" description="Follow bootstrap, provider setup, runner work, and acceptance checks from durable deployment records.">
				<div class="ts-launch-console">
					<div class="ts-launch-console__header">
						<div>
							<span class="ts-launch-console__label">Current state</span>
							<h2 data-deployment-title>Loading deployment</h2>
							<p data-deployment-subtitle>Reading durable deployment state.</p>
						</div>
						<StatusPill tone="warning" label="Loading" />
					</div>
					<div class="ts-launch-progress" aria-label="Deployment progress">
						<div class="ts-launch-progress__track"><span data-deployment-progress-bar style="width: 6%;"></span></div>
						<div class="ts-launch-progress__meta">
							<strong data-deployment-progress-label>6%</strong>
							<span data-deployment-progress-note>Loading deployment record</span>
						</div>
					</div>
					<ol class="ts-launch-stepper" aria-label="Project deployment steps">
						<li data-deployment-step="record" data-state="running"><span></span><div><strong>Record created</strong><small>Durable deployment exists.</small></div></li>
						<li data-deployment-step="credential_bootstrap" data-state="pending"><span></span><div><strong>Credential bootstrap</strong><small>Unlock host credentials in API memory.</small></div></li>
						<li data-deployment-step="hosting_readiness_audit" data-state="pending"><span></span><div><strong>Hosting audit</strong><small>Validate repository, web, email, and platform readiness.</small></div></li>
						<li data-deployment-step="provider_bootstrap" data-state="pending"><span></span><div><strong>Provider setup</strong><small>Create repositories and configure hosting resources.</small></div></li>
						<li data-deployment-step="runner" data-state="pending"><span></span><div><strong>Runner work</strong><small>Track any queued backend work.</small></div></li>
						<li data-deployment-step="acceptance" data-state="pending"><span></span><div><strong>Acceptance checks</strong><small>Confirm live environments are ready.</small></div></li>
					</ol>
				</div>
			</Panel>

			<div class="ts-grid-2">
				<Panel eyebrow="Blockers" title="Warnings and errors" description="Actionable deployment issues appear here as soon as they are recorded.">
					<div class="ts-launch-audit" data-deployment-issues><p class="ts-empty-inline">No blockers recorded yet.</p></div>
				</Panel>
				<Panel eyebrow="Actions" title="Support tools" description="Copy all visible status and log details for troubleshooting.">
					<div class="ts-launch-actions">
						<a class="ts-link-button ts-link-button--primary" href="/app/projects" data-project-link hidden>Open deployment overview</a>
						<button class="ts-link-button ts-launch-copy-button" type="button" data-copy-report aria-label="Copy deployment troubleshooting report">
							<svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
								<path d="M8 7a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v8a3 3 0 0 1-3 3h-1v-2h1a1 1 0 0 0 1-1V7a1 1 0 0 0-1-1h-6a1 1 0 0 0-1 1v1H8V7Zm-4 4a3 3 0 0 1 3-3h6a3 3 0 0 1 3 3v6a3 3 0 0 1-3 3H7a3 3 0 0 1-3-3v-6Zm3-1a1 1 0 0 0-1 1v6a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-6a1 1 0 0 0-1-1H7Z" />
							</svg>
							<span>Copy troubleshooting report</span>
						</button>
						<p class="ts-subtle" data-copy-status role="status" aria-live="polite"></p>
					</div>
				</Panel>
			</div>

			<Panel eyebrow="Logs" title="Deployment log" description="Events are grouped by deployment phase and can be copied as one support report.">
				<div class="ts-launch-log-shell" data-log-sections></div>
				<textarea class="ts-launch-log-copy ts-launch-log-copy--hidden" data-report-buffer readonly tabindex="-1" aria-hidden="true" aria-label="Copyable deployment log"></textarea>
			</Panel>
		</section>
	) : deploymentId ? (
		<EmptyState title="Deployment not available" description="This deployment is not available to your current account." actions={[{ label: 'Projects', href: '/app/projects' }]} />
	) : (
		<EmptyState title="No deployment selected" description="Open a deployment from a project launch or deployment history." actions={[{ label: 'Projects', href: '/app/projects' }]} />
	)}
</TreeseedAppLayout>

<script>
	const page = document.querySelector('[data-deployment-page]') as HTMLElement | null;
	const deploymentId = page?.dataset.deploymentId ?? '';
	const title = document.querySelector('[data-deployment-title]') as HTMLElement | null;
	const subtitle = document.querySelector('[data-deployment-subtitle]') as HTMLElement | null;
	const progressBar = document.querySelector('[data-deployment-progress-bar]') as HTMLElement | null;
	const progressLabel = document.querySelector('[data-deployment-progress-label]') as HTMLElement | null;
	const progressNote = document.querySelector('[data-deployment-progress-note]') as HTMLElement | null;
	const statePill = document.querySelector('.ts-launch-console__header .ts-status-pill') as HTMLElement | null;
	const issuesElement = document.querySelector('[data-deployment-issues]') as HTMLElement | null;
	const logSections = document.querySelector('[data-log-sections]') as HTMLElement | null;
	const reportBuffer = document.querySelector('[data-report-buffer]') as HTMLTextAreaElement | null;
	const copyButton = document.querySelector('[data-copy-report]') as HTMLButtonElement | null;
	const copyStatus = document.querySelector('[data-copy-status]') as HTMLElement | null;
	const projectLink = document.querySelector('[data-project-link]') as HTMLAnchorElement | null;
	const STEP_LABELS: Record<string, string> = {
		record: 'Record created',
		credential_bootstrap: 'Credential bootstrap',
		hosting_readiness_audit: 'Hosting audit',
		provider_bootstrap: 'Provider setup',
		runner: 'Runner work',
		acceptance: 'Acceptance checks',
	};
	const TERMINAL = new Set(['succeeded', 'failed', 'cancelled', 'timed_out', 'completed']);
	let latestPayload: any = null;
	function text(value: unknown, fallback = '') {
		return typeof value === 'string' && value.trim() ? value.trim() : fallback;
	}
	function setProgress(percent: number, note: string) {
		const normalized = Math.max(0, Math.min(100, Math.round(percent)));
		if (progressBar) progressBar.style.width = `${normalized}%`;
		if (progressLabel) progressLabel.textContent = `${normalized}%`;
		if (progressNote) progressNote.textContent = note;
	}
	function setPill(label: string, tone: string) {
		if (!statePill) return;
		statePill.dataset.tone = tone;
		const labelElement = statePill.querySelector('span:last-child');
		if (labelElement) labelElement.textContent = label;
	}
	function setStep(step: string, state: string) {
		const item = document.querySelector(`[data-deployment-step="${step}"]`) as HTMLElement | null;
		if (item) item.dataset.state = state;
	}
	function eventPhase(event: any) {
		const payload = event?.payload && typeof event.payload === 'object' ? event.payload : {};
		const data = payload.data && typeof payload.data === 'object' ? payload.data : {};
		const phase = text(payload.phase) || text(data.phase) || text(event?.kind).replace(/^launch\./u, '');
		if (/audit/u.test(phase)) return 'hosting_readiness_audit';
		if (/credential|unlock/u.test(phase)) return 'credential_bootstrap';
		if (/provider|repo|cloudflare|runtime|config|workflow/u.test(phase)) return 'provider_bootstrap';
		if (/runner|job/u.test(phase)) return 'runner';
		if (/accept|complete|succeed/u.test(phase)) return 'acceptance';
		return 'record';
	}
	function eventPayload(event: any) {
		return event?.payload && typeof event.payload === 'object' ? event.payload : {};
	}
	function issueMessages(event: any) {
		const payload = eventPayload(event);
		const data = payload.data && typeof payload.data === 'object' ? payload.data : {};
		const candidates = [
			payload.blockers,
			payload.errors,
			payload.issues,
			data.blockers,
			data.errors,
			data.issues,
		].filter(Array.isArray).flat();
		const messages = candidates.map((issue: any) => (
			text(issue?.message)
			|| text(issue?.summary)
			|| text(issue?.description)
			|| text(issue?.code)
			|| (typeof issue === 'string' ? issue : '')
		)).filter(Boolean);
		if ((event.severity === 'error' || event.status === 'failed') && messages.length === 0) {
			messages.push(text(event.message, text(event.kind, 'Deployment issue')));
		}
		return messages;
	}
	function renderIssues(events: any[]) {
		const issues = events.flatMap((event) => issueMessages(event).map((message) => ({ event, message })));
		if (!issuesElement) return;
		issuesElement.replaceChildren();
		if (issues.length === 0) {
			const empty = document.createElement('p');
			empty.className = 'ts-empty-inline';
			empty.textContent = 'No blockers recorded yet.';
			issuesElement.append(empty);
			return;
		}
		const list = document.createElement('ul');
		for (const issue of issues) {
			const item = document.createElement('li');
			item.dataset.state = issue.event.status === 'failed' || issue.event.severity === 'error' ? 'failed' : 'warning';
			const phase = STEP_LABELS[eventPhase(issue.event)] ?? 'Deployment';
			item.textContent = `${phase}: ${issue.message}`;
			list.append(item);
		}
		issuesElement.append(list);
	}
	function renderLogs(events: any[]) {
		if (!logSections) return;
		logSections.replaceChildren();
		for (const [step, label] of Object.entries(STEP_LABELS)) {
			const entries = events.filter((event) => eventPhase(event) === step);
			const details = document.createElement('details');
			details.open = entries.length > 0 && !['record'].includes(step);
			details.className = 'ts-launch-log-section';
			const hasFailure = entries.some((event) => event.status === 'failed' || event.severity === 'error');
			const hasWarning = entries.some((event) => event.status === 'warning' || event.severity === 'warning');
			details.dataset.state = hasFailure ? 'failed' : hasWarning ? 'warning' : entries.length > 0 ? 'running' : 'empty';
			const summary = document.createElement('summary');
			summary.textContent = `${label} (${entries.length})`;
			details.append(summary);
			const list = document.createElement('ol');
			list.className = 'ts-launch-log';
			for (const event of entries) {
				const item = document.createElement('li');
				item.dataset.state = event.status === 'failed' || event.severity === 'error'
					? 'failed'
					: event.status === 'warning' || event.severity === 'warning'
						? 'warning'
						: 'default';
				const timestamp = text(event.createdAt);
				item.textContent = `${timestamp ? `${timestamp} ` : ''}${text(event.kind, 'event')}: ${text(event.message, text(event.status))}`;
				list.append(item);
			}
			if (entries.length === 0) {
				const empty = document.createElement('p');
				empty.className = 'ts-empty-inline';
				empty.textContent = 'No events recorded for this step yet.';
				details.append(empty);
			} else {
				details.append(list);
			}
			logSections.append(details);
		}
	}
	function updateSteps(deployment: any, events: any[]) {
		for (const step of Object.keys(STEP_LABELS)) setStep(step, 'pending');
		setStep('record', 'complete');
		for (const event of events) {
			const phase = eventPhase(event);
			setStep(phase, event.status === 'failed' ? 'failed' : 'complete');
		}
		const status = text(deployment?.status, 'running');
		if (status === 'running') {
			const latest = events.at(-1);
			setStep(eventPhase(latest), 'running');
		}
		if (status === 'succeeded') {
			for (const step of Object.keys(STEP_LABELS)) setStep(step, 'complete');
		}
		if (status === 'failed') {
			setStep(eventPhase(events.at(-1)), 'failed');
		}
	}
	function supportReport() {
		const deployment = latestPayload?.deployment ?? {};
		const project = latestPayload?.project ?? null;
		const job = latestPayload?.job ?? null;
		const launch = latestPayload?.launch ?? null;
		const events = Array.isArray(latestPayload?.events) ? latestPayload.events : [];
		const groupedEvents = Object.entries(STEP_LABELS).flatMap(([step, label]) => {
			const entries = events.filter((event: any) => eventPhase(event) === step);
			return [
				`### ${label}`,
				entries.length ? entries.map((event: any) => {
					const issues = issueMessages(event);
					const line = `- ${event.createdAt ?? ''} ${event.kind ?? 'event'} [${event.status ?? 'unknown'}${event.severity ? `/${event.severity}` : ''}]: ${event.message ?? ''}`;
					return issues.length ? `${line}\n  Issues: ${issues.join('; ')}` : line;
				}).join('\n') : '- No events recorded.',
				'',
			];
		});
		return [
			'# TreeSeed project deployment troubleshooting report',
			`Generated: ${new Date().toISOString()}`,
			`URL: ${window.location.href}`,
			`Deployment: ${deployment.id ?? deploymentId}`,
			`Project: ${deployment.projectId ?? 'unknown'}`,
			`Status: ${deployment.status ?? 'unknown'}`,
			'',
			'## Summary',
			JSON.stringify({ deployment, project, job, launch }, null, 2),
			'',
			'## Events By Step',
			...groupedEvents,
			'## Raw Durable Events',
			JSON.stringify(events, null, 2),
		].join('\n');
	}
	function refreshReport() {
		if (reportBuffer) reportBuffer.value = supportReport();
	}
	async function readJson(response: Response) {
		return await response.json().catch(() => null);
	}
	async function loadDeployment() {
		const response = await fetch(`/v1/project-deployments/${encodeURIComponent(deploymentId)}?limit=200`);
		const payload = await readJson(response);
		if (!response.ok || payload?.ok === false) throw new Error(payload?.error ?? 'Unable to load deployment.');
		latestPayload = payload.payload;
		const deployment = latestPayload.deployment;
		const events = Array.isArray(latestPayload.events) ? latestPayload.events : [];
		const status = text(deployment.status, 'running');
		if (page) page.dataset.status = status;
		if (title) title.textContent = `${text(deployment.action, 'Deployment').replaceAll('_', ' ')} ${status.replaceAll('_', ' ')}`;
		if (subtitle) subtitle.textContent = `${text(deployment.environment, 'environment')} deployment ${deployment.id}`;
		const tone = status === 'succeeded' ? 'success' : status === 'failed' ? 'danger' : status === 'running' ? 'info' : 'warning';
		setPill(status.replaceAll('_', ' '), tone);
		setProgress(status === 'succeeded' ? 100 : status === 'failed' ? 100 : Math.min(92, 18 + events.length * 9), events.at(-1)?.message ?? 'Deployment is running.');
		if (projectLink && deployment.projectId) {
			projectLink.href = `/app/projects/${encodeURIComponent(deployment.projectId)}/deploy`;
			projectLink.hidden = false;
		}
		updateSteps(deployment, events);
		renderIssues(events);
		renderLogs(events);
		refreshReport();
		return TERMINAL.has(status);
	}
	copyButton?.addEventListener('click', async () => {
		refreshReport();
		try {
			await navigator.clipboard.writeText(reportBuffer?.value ?? supportReport());
			if (copyStatus) copyStatus.textContent = 'Troubleshooting report copied.';
		} catch {
			reportBuffer?.focus();
			reportBuffer?.select();
			document.execCommand('copy');
			if (copyStatus) copyStatus.textContent = 'Troubleshooting report copied.';
		}
	});
	if (deploymentId) {
		(async () => {
			for (let attempt = 0; attempt < 240; attempt += 1) {
				try {
					const done = await loadDeployment();
					if (done) break;
				} catch (error) {
					if (title) title.textContent = 'Unable to load deployment';
					if (subtitle) subtitle.textContent = error instanceof Error ? error.message : String(error);
					setPill('Error', 'danger');
					if (page) page.dataset.status = 'failed';
					break;
				}
				await new Promise((resolve) => window.setTimeout(resolve, 3000));
			}
		})();
	}
</script>
