---
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../lib/market/control-ui.js';
import { loadAppContext } from '../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/')}`);
}

const context = await loadAppContext(Astro);
const rows = [
	{ step: '1', name: '<strong>Hosts</strong><span>Add repository, web, processing, email, and AI host credentials.</span>', action: '<a class="ts-link-button" href="/app/hosts">Open Hosts</a>' },
	{ step: '2', name: '<strong>Projects</strong><span>Create hosted projects and manage their settings.</span>', action: '<a class="ts-link-button" href="/app/projects">Open Projects</a>' },
	{ step: '3', name: '<strong>Capacity</strong><span>Manage capacity providers, lifecycle state, and key rotation.</span>', action: '<a class="ts-link-button" href="/app/capacity/providers">Open Capacity</a>' },
	{ step: '4', name: '<strong>Work</strong><span>Review objectives, questions, notes, proposals, and decisions.</span>', action: '<a class="ts-link-button" href="/app/work/objectives">Open Work</a>' },
	{ step: '5', name: '<strong>Knowledge</strong><span>Review, package, publish, and share artifacts.</span>', action: '<a class="ts-link-button" href="/app/knowledge/artifacts">Open Knowledge</a>' },
];
---

<TreeseedAppLayout
	title="Start"
	description="Follow the setup path. Each page has one job."
	currentPath={Astro.url.pathname}
	teams={context.teams}
	activeTeam={context.activeTeam}
>
	<section class="ts-control-page" aria-label="Start">
		<Panel eyebrow="Start" title="Choose the next control" description={context.activeTeam ? `Active team: ${esc(context.activeTeam.displayName ?? context.activeTeam.name)}` : 'Create a team first.'}>
			<PlainTable columns={[
				{ key: 'step', label: 'Step' },
				{ key: 'name', label: 'Control' },
				{ key: 'action', label: 'Action' },
			]} rows={rows} />
		</Panel>
	</section>
</TreeseedAppLayout>
