---
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import CommonsDecisionTimeline from '@treeseed/ui/components/astro/governance/CommonsDecisionTimeline.astro';
import CommonsProposalCard from '@treeseed/ui/components/astro/governance/CommonsProposalCard.astro';
import '@treeseed/ui/styles/governance.css';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../lib/market/api-client';
import { loadAppContext } from '../../../view-models/app-access.js';
import { loadCommonsGovernanceDashboard } from '../../../view-models/ecommerce-governance.vm.js';

const context = await loadAppContext(Astro);
const api = new ApiClientFacade(Astro);

if (Astro.request.method === 'POST') {
	const form = await Astro.request.formData();
	if (String(form.get('action') ?? '') === 'backfill') {
		await api.backfillCommonsParticipants();
		return Astro.redirect('/app/commons?saved=backfilled', 303);
	}
}

const vm = await loadCommonsGovernanceDashboard(Astro, context);
---

<TreeseedAppLayout title={vm.dashboard.title} description={vm.dashboard.description} currentPath="/app/commons" teams={context.teams} activeTeam={context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	<DashboardTemplate viewModel={vm.dashboard} actions={vm.actions}>
		<form slot="beforeContent" class="ts-governance-actions" method="post">
			<button class="ts-governance-button" type="submit" name="action" value="backfill">Backfill participants</button>
			<a class="ts-governance-button" data-variant="secondary" href="/app/commons/participants">Participants</a>
		</form>
		{vm.proposals.length ? (
			<div class="ts-governance-grid">
				{vm.proposals.map((proposal: any) => (
					<CommonsProposalCard proposal={proposal} href={`/app/commons/proposals/${encodeURIComponent(proposal.id)}`} />
				))}
			</div>
		) : null}
		<CommonsDecisionTimeline events={vm.events} />
	</DashboardTemplate>
</TreeseedAppLayout>
