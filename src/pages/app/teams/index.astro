---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/teams')}`);
}

const context = await loadAppContext(Astro);
const manageableRoles = new Set(['team_owner', 'project_lead']);
const teamAccess = new Map(await Promise.all(context.teams.map(async (team: any) => {
	const access = context.store && typeof context.store.getTeamAccessSummary === 'function'
		? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
		: null;
	return [team.id, access] as const;
})));
const rows = context.teams.map((team: any) => ({
	id: `team-${esc(team.id)}`,
	sceneId: `team.card.${team.name ?? team.slug ?? team.id}`,
	name: `<strong>${esc(team.displayName ?? team.name)}</strong><span>${esc(team.profileSummary ?? team.slug ?? team.id)}</span>`,
	state: team.id === context.activeTeam?.id ? 'Active' : 'Available',
	actions: [
		`<a class="ts-link-button" href="/t/${encodeURIComponent(team.name ?? team.slug ?? team.id)}">Profile</a>`,
		...(teamAccess.get(team.id)?.roles?.some((role: string) => manageableRoles.has(role)) ? [
			`<a class="ts-link-button" href="/app/teams/${encodeURIComponent(team.id)}/edit">Edit</a>`,
			`<a class="ts-link-button" href="/app/teams/${encodeURIComponent(team.id)}/members">Members</a>`,
			`<a class="ts-link-button" href="/app/teams/${encodeURIComponent(team.id)}/delete">Delete</a>`,
		] : []),
	].join(' '),
}));
---

<TreeseedAppLayout title="Team" description="Create, switch, edit, invite, or remove teams." currentPath={Astro.url.pathname} teams={context.teams} activeTeam={context.activeTeam}>
	<section class="ts-control-page" aria-label="Teams">
		<Panel eyebrow="Team" title="Teams" description="Manage and display your teams">
			<Button slot="actions" href="/app/teams/new" size="sm">New team</Button>
			{rows.length > 0 ? (
				<PlainTable columns={[
					{ key: 'name', label: 'Team' },
					{ key: 'state', label: 'State' },
					{ key: 'actions', label: 'Actions' },
				]} rows={rows} />
			) : (
				<EmptyState title="No teams yet" description="Create a team to start configuring hosts and projects." actions={[{ label: 'New team', href: '/app/teams/new' }]} />
			)}
		</Panel>
	</section>
</TreeseedAppLayout>
