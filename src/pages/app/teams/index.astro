---
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext } from '../../../view-models/app-access.js';
import { buildTeamDashboard } from '../../../view-models/contextual-dashboard.vm.js';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/teams')}`);
}

const context = await loadAppContext(Astro);
const dashboard = await buildTeamDashboard(context, Astro.url);
---

<TreeseedAppLayout
	title={dashboard.viewModel.title}
	description={dashboard.viewModel.description}
	currentPath={Astro.url.pathname}
	teams={context.teams}
	activeTeam={context.activeTeam}
	helpContext={dashboard.helpContext}
	feedbackContext={dashboard.feedbackContext}
>
	<DashboardTemplate viewModel={dashboard.viewModel} actions={dashboard.actions} />
</TreeseedAppLayout>
