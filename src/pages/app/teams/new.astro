---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../lib/market/api-client';
import { loadAppContext } from '../../../view-models/app-access.js';
import { ensureCsrfToken, requireCsrf } from '../../../lib/auth/csrf';

if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/teams/new')}`);
}

let formError = '';
const csrfToken = ensureCsrfToken(Astro);
let formValues = {
	name: '',
	displayName: '',
	logoUrl: '',
	profileSummary: '',
};

if (Astro.request.method === 'POST') {
	const data = await Astro.request.formData();
	requireCsrf(Astro, data.get('csrfToken'));
	formValues = {
		name: String(data.get('name') ?? '').trim(),
		displayName: String(data.get('displayName') ?? '').trim(),
		logoUrl: String(data.get('logoUrl') ?? '').trim(),
		profileSummary: String(data.get('profileSummary') ?? '').trim(),
	};

	if (!formValues.name) {
		formError = 'Name is required.';
	} else {
		try {
			const team = await new ApiClientFacade(Astro).request<any>('POST', '/v1/teams', {
				body: formValues,
			});
			Astro.cookies.set('treeseed_active_team', team.id, {
				path: '/app',
				sameSite: 'lax',
				secure: Astro.url.protocol === 'https:',
				maxAge: 31_536_000,
			});
			return Astro.redirect('/app/teams', 303);
		} catch (error) {
			formError = error instanceof Error ? error.message : 'Team could not be created.';
		}
	}
}

const context = await loadAppContext(Astro);
---

<TreeseedAppLayout title="New team" description="Create one team." currentPath="/app/teams" teams={context.teams} activeTeam={context.activeTeam}>
	<section class="ts-control-page" aria-label="New team">
		<Panel eyebrow="Team" title="Create team" description="Teams own hosts, projects, capacity, work, and knowledge.">
			<form id="team-create-form" class="ts-form-stack" method="POST" action="/app/teams/new">
				<input type="hidden" name="csrfToken" value={csrfToken} />
				{formError && <p class="ts-form-error" role="alert">{formError}</p>}
				<div class="ts-form-grid">
					<Field label="Name" name="name" required>
						<TextInput name="name" required placeholder="acme-ops" pattern="[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?" value={formValues.name} />
					</Field>
					<Field label="Display name" name="displayName">
						<TextInput name="displayName" placeholder="Acme Operations" value={formValues.displayName} />
					</Field>
					<Field label="Logo URL" name="logoUrl" class="ts-field--full">
						<TextInput name="logoUrl" type="url" placeholder="https://example.com/logo.svg" value={formValues.logoUrl} />
					</Field>
					<Field label="Profile summary" name="profileSummary" class="ts-field--full">
						<Textarea name="profileSummary" rows={4} placeholder="What this team builds or manages." value={formValues.profileSummary} />
					</Field>
				</div>
				<FormActions align="start">
					<Button type="submit">Create team</Button>
					<Button href="/app/teams" variant="secondary">Cancel</Button>
				</FormActions>
			</form>
		</Panel>
	</section>
</TreeseedAppLayout>
