---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../view-models/app-access.js';

const teamParam = String(Astro.params.teamId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}
const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamParam);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);
const manageableRoles = new Set(['team_owner', 'project_lead']);
const access = team && context.store && typeof context.store.getTeamAccessSummary === 'function'
	? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
	: null;
const canManageTeam = Boolean(access?.roles?.some((role: string) => manageableRoles.has(role)));
const members = team && canManageTeam && context.store ? await context.store.listTeamMembers(team.id).catch(() => []) : [];
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;
else if (!canManageTeam) Astro.response.status = 403;
const roleOptions = [
	{ label: 'Contributor', value: 'contributor' },
	{ label: 'Reviewer', value: 'reviewer' },
	{ label: 'Project lead', value: 'project_lead' },
	{ label: 'Market steward', value: 'market_steward' },
	{ label: 'Finance', value: 'finance' },
	{ label: 'Owner', value: 'team_owner' },
];
function roleSelectOptions(roleKey: string) {
	return roleOptions.map((option) => `<option value="${esc(option.value)}" ${roleKey === option.value ? 'selected' : ''}>${esc(option.label)}</option>`).join('');
}
const rows = members.map((member: any) => ({
	id: `member-${esc(member.id ?? member.userId)}`,
	name: `<strong>${esc(member.displayName ?? member.email ?? member.userId ?? 'Member')}</strong><span>${esc(member.email ?? member.userId ?? '')}</span>`,
	role: esc(roleOptions.find((option) => option.value === (member.roleKey ?? member.role))?.label ?? member.roleKey ?? member.role ?? 'member'),
	actions: `<form class="ts-inline-form" data-member-form="${esc(member.id)}"><select class="ts-control" name="roleKey">${roleSelectOptions(String(member.roleKey ?? member.role ?? 'contributor'))}</select><button class="ts-link-button" type="submit">Save</button><button class="ts-link-button" type="button" data-remove-member="${esc(member.id)}">Remove</button></form>`,
}));
---

<TreeseedAppLayout title={team ? `${team.displayName ?? team.name} members` : 'Team not found'} description="Invite and manage team members." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam}>
	{team && canManageTeam ? (
		<section class="ts-control-page" aria-label="Team members">
			<Panel eyebrow="Team" title="Invite member" description="Send an invitation to this team.">
				<form id="invite-form" class="ts-form-stack">
					<div class="ts-form-grid">
						<Field label="Email" name="email" required>
							<TextInput name="email" type="email" required />
						</Field>
						<Field label="Role" name="roleKey" required>
							<Select name="roleKey" required options={[
								{ label: 'Contributor', value: 'contributor' },
								{ label: 'Reviewer', value: 'reviewer' },
								{ label: 'Project lead', value: 'project_lead' },
								{ label: 'Market steward', value: 'market_steward' },
								{ label: 'Finance', value: 'finance' },
								{ label: 'Owner', value: 'team_owner' },
							]} />
						</Field>
					</div>
					<FormActions align="start">
						<Button type="submit">Invite member</Button>
						<Button href="/app/teams" variant="secondary">Back</Button>
						<span class="ts-subtle" id="member-status" role="status"></span>
					</FormActions>
				</form>
			</Panel>
			<Panel eyebrow="Team" title="Members" description="Update roles or remove members.">
				<PlainTable columns={[
					{ key: 'name', label: 'Member' },
					{ key: 'role', label: 'Role' },
					{ key: 'actions', label: 'Actions' },
				]} rows={rows} emptyTitle="No members listed" emptyDescription="Invite the first member above." />
			</Panel>
		</section>
	) : team ? (
		<EmptyState title="Team controls unavailable" description="Team editing, member management, and deletion require the team owner or project lead role." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	) : (
		<EmptyState title="Team not found" description="This team is not available." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	)}
</TreeseedAppLayout>

<script is:inline define:vars={{ teamId: team?.id ?? '' }}>
	const status = document.getElementById('member-status');
	const inviteForm = document.getElementById('invite-form');
	async function send(url, method, body) {
		const response = await fetch(url, { method, headers: { 'content-type': 'application/json' }, body: body ? JSON.stringify(body) : undefined });
		const payload = await response.json().catch(() => null);
		if (!response.ok || payload?.ok === false) throw new Error(payload?.error ?? 'Request failed.');
		return payload.payload;
	}
	inviteForm?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const form = new FormData(inviteForm);
		if (status) status.textContent = 'Inviting...';
		try {
			await send(`/v1/teams/${encodeURIComponent(teamId)}/invites`, 'POST', {
				email: String(form.get('email') ?? '').trim(),
				roleKey: String(form.get('roleKey') ?? 'contributor'),
			});
			window.location.href = `${window.location.pathname}?updated=${Date.now()}`;
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'Invite failed.';
		}
	});
	document.querySelectorAll('[data-member-form]').forEach((form) => {
		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			const membershipId = form.getAttribute('data-member-form') ?? '';
			const roleKey = String(new FormData(form).get('roleKey') ?? 'contributor');
			try {
				await send(`/v1/teams/${encodeURIComponent(teamId)}/members/${encodeURIComponent(membershipId)}`, 'PATCH', { roleKey });
				window.location.href = `${window.location.pathname}?updated=${Date.now()}`;
			} catch (error) {
				if (status) status.textContent = error instanceof Error ? error.message : 'Role update failed.';
			}
		});
	});
	document.querySelectorAll('[data-remove-member]').forEach((button) => {
		button.addEventListener('click', async () => {
			const membershipId = button.getAttribute('data-remove-member') ?? '';
			try {
				await send(`/v1/teams/${encodeURIComponent(teamId)}/members/${encodeURIComponent(membershipId)}`, 'DELETE');
				window.location.href = `${window.location.pathname}?removed=${Date.now()}`;
			} catch (error) {
				if (status) status.textContent = error instanceof Error ? error.message : 'Remove failed.';
			}
		});
	});
</script>
