---
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import SellerCommerceMonitor from '@treeseed/ui/components/astro/commerce/SellerCommerceMonitor.astro';
import '@treeseed/ui/styles/commerce.css';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../../lib/market/api-client';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../view-models/app-access.js';
import { buildTeamCommerceDashboard, canManageTeamCommerce } from '../../../../view-models/ecommerce-governance.vm.js';

const teamId = String(Astro.params.teamId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamId);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);

const access = team && context.store && typeof context.store.getTeamAccessSummary === 'function'
	? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
	: null;
const canManageTeam = canManageTeamCommerce(access);
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;

const api = new ApiClientFacade(Astro);
let formError = '';
let statusMessage = '';

if (Astro.request.method === 'POST' && team && canManageTeam) {
	const data = await Astro.request.formData();
	const action = String(data.get('action') ?? '');
	try {
		if (action === 'request-vendor') {
			await api.requestCommerceVendor(team.id, {
				displayName: team.displayName ?? team.name ?? 'Commerce Vendor',
				slug: team.slug ?? team.name ?? team.id,
				reason: 'Team requested marketplace seller capability from Admin commerce settings.',
			});
			return Astro.redirect(`/app/teams/${encodeURIComponent(team.id)}/commerce?saved=vendor-requested`, 303);
		}
		if (action === 'connect-stripe') {
			const result = await api.startCommerceVendorStripeOnboarding(team.id, {});
			if (result?.onboardingUrl) return Astro.redirect(result.onboardingUrl, 303);
			throw new Error('Stripe onboarding URL was not returned.');
		}
		if (action === 'open-dashboard') {
			const result = await api.createCommerceVendorStripeLoginLink(team.id);
			if (result?.loginUrl) return Astro.redirect(result.loginUrl, 303);
			throw new Error('Stripe dashboard URL was not returned.');
		}
		if (action === 'refresh-status') {
			await api.getCommerceVendorStripeStatus(team.id, true);
			return Astro.redirect(`/app/teams/${encodeURIComponent(team.id)}/commerce?saved=status-refreshed`, 303);
		}
	} catch (error) {
		formError = error instanceof Error ? error.message : 'Commerce settings action failed.';
	}
}

if (team && canManageTeam && Astro.request.method === 'GET') {
	const stripeMarker = Astro.url.searchParams.get('stripe');
	if (stripeMarker === 'returned') {
		await api.markCommerceVendorStripeReturn(team.id).catch((error) => {
			formError = error instanceof Error ? error.message : 'Stripe return status could not be recorded.';
		});
		statusMessage = formError ? '' : 'Stripe onboarding return recorded. Status refreshed from Stripe when configured.';
	} else if (stripeMarker === 'refresh') {
		await api.getCommerceVendorStripeStatus(team.id, true).catch((error) => {
			formError = error instanceof Error ? error.message : 'Stripe status could not be refreshed.';
		});
		statusMessage = formError ? '' : 'Stripe onboarding link refreshed. Continue onboarding from this page.';
	}
}

const saved = Astro.url.searchParams.get('saved');
if (saved === 'vendor-requested') statusMessage = 'Seller capability request submitted.';
if (saved === 'status-refreshed') statusMessage = 'Stripe status refreshed.';

const vendor = team ? await api.getCommerceVendor(team.id).catch(() => null) : null;
const stripeAccount = team ? await api.getCommerceVendorStripeStatus(team.id).catch(() => null) : null;
const commerceMonitor = team ? await api.getCommerceVendorMonitoring(team.id).catch(() => null) : null;
const vm = team ? buildTeamCommerceDashboard({
	path: `/app/teams/${encodeURIComponent(team.id)}/commerce`,
	team,
	vendor,
	stripeAccount,
	commerceMonitor,
	canManageTeam,
	formError,
	statusMessage,
}) : null;
---

<TreeseedAppLayout title={team ? 'Commerce settings' : 'Team not found'} description="Manage seller readiness and marketplace governance." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam} helpContext={vm?.helpContext} feedbackContext={vm?.feedbackContext}>
	{team && vm ? (
		<DashboardTemplate viewModel={vm.dashboard} actions={vm.actions}>
			{canManageTeam ? (
				<form slot="beforeContent" class="ts-commerce-actions" method="post" action={`/app/teams/${encodeURIComponent(team.id)}/commerce`}>
					{!vendor ? (
						<button class="ts-commerce-button" type="submit" name="action" value="request-vendor">Request seller capability</button>
					) : vendor.status === 'approved' ? (
						<>
							<button class="ts-commerce-button" type="submit" name="action" value="connect-stripe">{stripeAccount?.accountStatus === 'enabled' ? 'Update Stripe' : 'Connect Stripe'}</button>
							<button class="ts-commerce-button" data-variant="secondary" type="submit" name="action" value="refresh-status">Refresh status</button>
							{stripeAccount ? <button class="ts-commerce-button" data-variant="secondary" type="submit" name="action" value="open-dashboard">Open Stripe dashboard</button> : null}
						</>
					) : (
						<a class="ts-commerce-button" data-variant="secondary" href="/app/teams">Back to teams</a>
					)}
				</form>
			) : null}
			<SellerCommerceMonitor monitor={vm.commerceMonitor} />
		</DashboardTemplate>
	) : (
		<EmptyState title="Team not found" description="This team is not available." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	)}
</TreeseedAppLayout>
