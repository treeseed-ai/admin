---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../../lib/market/api-client';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../view-models/app-access.js';
import { ensureCsrfToken, requireCsrf } from '../../../../lib/auth/csrf';

const teamId = String(Astro.params.teamId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}
const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamId);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);
const manageableRoles = new Set(['team_owner', 'project_lead']);
const access = team && context.store && typeof context.store.getTeamAccessSummary === 'function'
	? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
	: null;
const canManageTeam = Boolean(access?.roles?.some((role: string) => manageableRoles.has(role)));
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;
else if (!canManageTeam) Astro.response.status = 403;

let formError = '';
const csrfToken = ensureCsrfToken(Astro);
const saved = Astro.url.searchParams.get('saved') === '1';
const formValues = {
	name: team?.name ?? '',
	displayName: team?.displayName ?? '',
	logoUrl: team?.logoUrl ?? '',
	profileSummary: team?.profileSummary ?? '',
};

if (Astro.request.method === 'POST' && team && canManageTeam) {
	const data = await Astro.request.formData();
	requireCsrf(Astro, data.get('csrfToken'));
	const body = {
		name: String(data.get('name') ?? '').trim(),
		displayName: String(data.get('displayName') ?? '').trim(),
		logoUrl: String(data.get('logoUrl') ?? '').trim(),
		profileSummary: String(data.get('profileSummary') ?? '').trim(),
	};

	if (!body.name) {
		formError = 'Name is required.';
		Object.assign(formValues, body);
	} else {
		try {
			await new ApiClientFacade(Astro).request<any>('PATCH', `/v1/teams/${encodeURIComponent(team.id)}`, { body });
			return Astro.redirect(`/app/teams/${encodeURIComponent(team.id)}/edit?saved=1`, 303);
		} catch (error) {
			formError = error instanceof Error ? error.message : 'Team could not be saved.';
			Object.assign(formValues, body);
		}
	}
}
---

<TreeseedAppLayout title={team ? `Edit ${team.displayName ?? team.name}` : 'Team not found'} description="Edit one team." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam}>
	{team && canManageTeam ? (
		<section class="ts-control-page" aria-label="Edit team">
			<Panel eyebrow="Team" title="Edit team" description="Update the team fields.">
				<form id="team-edit-form" class="ts-form-stack" method="POST" action={`/app/teams/${encodeURIComponent(team.id)}/edit`}>
					<input type="hidden" name="csrfToken" value={csrfToken} />
					{formError && <p class="ts-form-error" role="alert">{formError}</p>}
					{saved && !formError && <p class="ts-subtle" role="status">Saved.</p>}
					<div class="ts-form-grid">
						<Field label="Name" name="name" required>
							<TextInput name="name" required value={formValues.name} pattern="[a-z0-9](?:[a-z0-9-]{0,61}[a-z0-9])?" />
						</Field>
						<Field label="Display name" name="displayName">
							<TextInput name="displayName" value={formValues.displayName} />
						</Field>
						<Field label="Logo URL" name="logoUrl" class="ts-field--full">
							<TextInput name="logoUrl" type="url" value={formValues.logoUrl} />
						</Field>
						<Field label="Profile summary" name="profileSummary" class="ts-field--full">
							<Textarea name="profileSummary" rows={4} value={formValues.profileSummary} />
						</Field>
					</div>
					<FormActions align="start">
						<Button type="submit">Save team</Button>
						<Button href="/app/teams" variant="secondary">Back</Button>
					</FormActions>
				</form>
			</Panel>
		</section>
	) : team ? (
		<EmptyState title="Team controls unavailable" description="Team editing, member management, and deletion require the team owner or project lead role." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	) : (
		<EmptyState title="Team not found" description="This team is not available." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	)}
</TreeseedAppLayout>
