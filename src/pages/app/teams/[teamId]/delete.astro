---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { ApiClientFacade } from '../../../../lib/market/api-client';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../view-models/app-access.js';
import { ensureCsrfToken, requireCsrf } from '../../../../lib/auth/csrf';

const teamParam = String(Astro.params.teamId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}
const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamParam);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);
const manageableRoles = new Set(['team_owner', 'project_lead']);
const access = team && context.store && typeof context.store.getTeamAccessSummary === 'function'
	? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
	: null;
const canManageTeam = Boolean(access?.roles?.some((role: string) => manageableRoles.has(role)));
const blockers = team && canManageTeam && context.store ? await context.store.evaluateTeamDeletionBlockers(team.id).catch(() => null) : null;
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;
else if (!canManageTeam) Astro.response.status = 403;
const blockerRows = Object.entries(blockers ?? {})
	.filter(([, value]) => Array.isArray(value) ? value.length > 0 : Number(value) > 0)
	.map(([key, value]) => ({ name: esc(key), value: esc(Array.isArray(value) ? value.length : value) }));
const hasDeletionBlockers = blockerRows.length > 0;
const confirmation = team ? `DELETE ${team.name}` : '';
let formError = '';
const csrfToken = ensureCsrfToken(Astro);
let confirmationValue = '';

if (Astro.request.method === 'POST' && team && canManageTeam) {
	const data = await Astro.request.formData();
	requireCsrf(Astro, data.get('csrfToken'));
	confirmationValue = String(data.get('confirmation') ?? '');
	if (hasDeletionBlockers) {
		formError = 'Blocking records must be removed before this team can be deleted.';
	} else if (confirmationValue !== confirmation) {
		formError = `Type "${confirmation}" to delete this team.`;
	} else {
	try {
		await new ApiClientFacade(Astro).request<any>('DELETE', `/v1/teams/${encodeURIComponent(team.id)}`, {
			body: { confirmation: confirmationValue },
		});
		Astro.cookies.delete('treeseed_active_team', {
			path: '/app',
			secure: Astro.url.protocol === 'https:',
		});
		return Astro.redirect('/app/teams', 303);
	} catch (error) {
		formError = error instanceof Error ? error.message : 'Team could not be deleted.';
	}
	}
}
---

<TreeseedAppLayout title={team ? `Delete ${team.displayName ?? team.name}` : 'Team not found'} description="Remove one team when it has no blocking records." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam}>
	{team && canManageTeam ? (
		<section class="ts-control-page" aria-label="Delete team">
			<Panel eyebrow="Team" title="Delete team" description="This action is permanent. Blocking records must be removed first.">
				<PlainTable columns={[{ key: 'name', label: 'Blocker' }, { key: 'value', label: 'Count' }]} rows={blockerRows} emptyTitle="No blockers found" emptyDescription="This team can be deleted after confirmation." />
				<form id="team-delete-form" class="ts-form-stack ts-stack-top" method="POST" action={`/app/teams/${encodeURIComponent(team.id)}/delete`}>
					<input type="hidden" name="csrfToken" value={csrfToken} />
					{formError && <p class="ts-form-error" role="alert">{formError}</p>}
					<Field label={`Type "${confirmation}"`} name="confirmation" required>
						<TextInput name="confirmation" required value={confirmationValue} data-confirmation-input />
					</Field>
					<FormActions align="start">
						<Button type="submit" variant="danger" disabled={hasDeletionBlockers || confirmationValue !== confirmation}>Delete team</Button>
						<Button href="/app/teams" variant="secondary">Cancel</Button>
					</FormActions>
				</form>
			</Panel>
		</section>
	) : team ? (
		<EmptyState title="Team controls unavailable" description="Team editing, member management, and deletion require the team owner or project lead role." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	) : (
		<EmptyState title="Team not found" description="This team is not available." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	)}
</TreeseedAppLayout>

<script is:inline define:vars={{ confirmation, hasDeletionBlockers }}>
	const form = document.getElementById('team-delete-form');
	const input = form?.querySelector('[data-confirmation-input]');
	const button = form?.querySelector('button[type="submit"]');
	function updateDeleteState() {
		if (!button || !input) return;
		button.disabled = Boolean(hasDeletionBlockers) || input.value !== confirmation;
	}
	input?.addEventListener('input', updateDeleteState);
	updateDeleteState();
</script>
