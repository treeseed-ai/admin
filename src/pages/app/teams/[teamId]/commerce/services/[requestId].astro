---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../../../../lib/market/api-client';
import { escapeHtml as esc } from '../../../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../../../view-models/app-access.js';

const teamId = String(Astro.params.teamId ?? '');
const requestId = String(Astro.params.requestId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamId);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);

const manageableRoles = new Set(['team_owner', 'project_lead']);
const access = team && context.store && typeof context.store.getTeamAccessSummary === 'function'
	? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
	: null;
const canManageTeam = Boolean(access?.roles?.some((role: string) => manageableRoles.has(role)));
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;

const api = new ApiClientFacade(Astro);
let formError = '';

if (Astro.request.method === 'POST' && team && canManageTeam) {
	const data = await Astro.request.formData();
	const action = String(data.get('action') ?? '');
	try {
		if (action === 'start-scoping') {
			await api.startCommerceServiceScoping(requestId, { reason: String(data.get('reason') ?? '').trim() || null });
			return Astro.redirect(Astro.url.pathname, 303);
		}
		if (action === 'update-request') {
			await api.updateCommerceServiceRequest(requestId, {
				approvedScope: String(data.get('approvedScope') ?? '').trim() || null,
				buyerVisibleSummary: String(data.get('buyerVisibleSummary') ?? '').trim() || null,
				vendorPrivateNotes: String(data.get('vendorPrivateNotes') ?? '').trim() || null,
			});
			return Astro.redirect(Astro.url.pathname, 303);
		}
		if (action === 'create-quote') {
			await api.createCommerceServiceQuote(requestId, {
				title: String(data.get('title') ?? '').trim(),
				scopeSummary: String(data.get('scopeSummary') ?? '').trim(),
				amount: Number(data.get('amount') ?? 0),
				currency: String(data.get('currency') ?? 'usd').trim().toLowerCase(),
				expiresAt: String(data.get('expiresAt') ?? '').trim() || null,
			});
			return Astro.redirect(Astro.url.pathname, 303);
		}
		if (action === 'submit-quote') {
			await api.submitCommerceServiceQuote(String(data.get('quoteId') ?? ''), {});
			return Astro.redirect(Astro.url.pathname, 303);
		}
		if (action === 'vendor-approve-quote') {
			await api.vendorApproveCommerceServiceQuote(String(data.get('quoteId') ?? ''), {});
			return Astro.redirect(Astro.url.pathname, 303);
		}
		if (action === 'link-work') {
			await api.linkCommerceServiceContractWork(String(data.get('contractId') ?? ''), {
				relatedProjectId: String(data.get('relatedProjectId') ?? '').trim() || null,
				relatedWorkdayId: String(data.get('relatedWorkdayId') ?? '').trim() || null,
			});
			return Astro.redirect(Astro.url.pathname, 303);
		}
		if (action === 'fulfill-contract') {
			await api.fulfillCommerceServiceContract(String(data.get('contractId') ?? ''), {
				summary: String(data.get('summary') ?? '').trim() || null,
			});
			return Astro.redirect(Astro.url.pathname, 303);
		}
		if (action === 'cancel-request') {
			await api.cancelCommerceServiceRequest(requestId, { reason: String(data.get('reason') ?? '').trim() || null });
			return Astro.redirect(`/app/teams/${encodeURIComponent(team.id)}/commerce/services`, 303);
		}
	} catch (error) {
		formError = error instanceof Error ? error.message : 'Service operation failed.';
	}
}

const request = team ? await api.getCommerceServiceRequest(requestId).catch(() => null) : null;
const quotes = request ? await api.listCommerceServiceQuotes(request.id).catch(() => []) : [];
const contract = request?.contractId ? await api.getCommerceServiceContract(request.contractId).catch(() => null) : null;
const events = request ? await api.listCommerceServiceEvents({ requestId: request.id }).catch(() => []) : [];

function money(amount: unknown, currency: unknown) {
	const value = Number(amount ?? 0) / 100;
	const code = typeof currency === 'string' && currency ? currency.toUpperCase() : 'USD';
	return `${code} ${value.toFixed(2)}`;
}

const quoteRows = quotes.map((quote: any) => ({
	id: quote.id,
	version: esc(String(quote.quoteVersion)),
	status: esc(quote.status),
	title: esc(quote.title),
	amount: esc(money(quote.amount, quote.currency)),
	expires: esc(quote.expiresAt ?? ''),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="quoteId" value="${esc(quote.id)}" /><button type="submit" name="action" value="submit-quote">Submit</button><button type="submit" name="action" value="vendor-approve-quote">Vendor approve</button></form>` : '',
}));

const eventRows = events.map((event: any) => ({
	id: event.id,
	event: esc(event.eventType),
	prior: esc(event.priorState ?? ''),
	next: esc(event.nextState ?? ''),
	created: esc(event.createdAt ?? ''),
}));
---

<TreeseedAppLayout title={request ? 'Service request' : 'Service request not found'} description="Manage scoped service scoping, quote, contract, and fulfillment state." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam}>
	{team && request ? (
		<section class="ts-control-page" aria-label="Service request detail">
			<Panel eyebrow="Scoped service" title={request.id} description="This workflow separates buyer inquiry, seller scoping, quote approval, contract activation, fulfillment, and cooperative ownership evidence.">
				{formError && <p class="ts-form-error" role="alert">{formError}</p>}
				<p class="ts-subtle">Status: <strong>{request.status}</strong></p>
				<p class="ts-subtle">Product: <strong>{request.productId}</strong> Offer: <strong>{request.offerId}</strong></p>
				<p>{request.buyerVisibleSummary ?? request.requestedScope}</p>
				<div slot="actions" class="ts-inline-actions">
					<Button href={`/app/teams/${encodeURIComponent(team.id)}/commerce/services`} variant="secondary" size="sm">All services</Button>
					{contract?.status === 'pending_checkout' ? <Button href={`/services/${encodeURIComponent(request.id)}/checkout`} variant="secondary" size="sm">Buyer checkout link</Button> : null}
				</div>
			</Panel>

			{canManageTeam ? (
				<Panel eyebrow="Seller actions" title="Scope and quote" description="Seller updates remain operational controls; buyer payment stays in the hosted market flow.">
					<div class="ts-form-grid">
						<form method="POST" class="ts-stack">
							<input type="hidden" name="action" value="start-scoping" />
							<input name="reason" placeholder="scoping note" />
							<Button type="submit" size="sm">Start scoping</Button>
						</form>
						<form method="POST" class="ts-stack">
							<input type="hidden" name="action" value="update-request" />
							<textarea name="approvedScope" placeholder="approved scope">{request.approvedScope ?? ''}</textarea>
							<input name="buyerVisibleSummary" value={request.buyerVisibleSummary ?? ''} placeholder="buyer-visible summary" />
							<input name="vendorPrivateNotes" value={request.vendorPrivateNotes ?? ''} placeholder="seller notes" />
							<Button type="submit" size="sm">Update scope</Button>
						</form>
						<form method="POST" class="ts-stack">
							<input type="hidden" name="action" value="create-quote" />
							<input name="title" placeholder="quote title" required />
							<textarea name="scopeSummary" placeholder="scope summary" required></textarea>
							<input name="amount" inputmode="numeric" placeholder="amount in cents" required />
							<input name="currency" value="usd" maxlength="3" required />
							<input name="expiresAt" placeholder="expires at" />
							<Button type="submit" size="sm">Create quote</Button>
						</form>
					</div>
				</Panel>
			) : null}

			<Panel eyebrow="Quotes" title="Quote versions" description="Quote revisions are immutable rows with their own approval state.">
				<PlainTable columns={[
					{ key: 'version', label: 'Version' },
					{ key: 'status', label: 'Status' },
					{ key: 'title', label: 'Title' },
					{ key: 'amount', label: 'Amount' },
					{ key: 'expires', label: 'Expires' },
					{ key: 'action', label: 'Action' },
				]} rows={quoteRows} emptyTitle="No quotes" emptyDescription="Create a quote after the seller has scoped the work." />
			</Panel>

			<Panel eyebrow="Contract" title="Contract state" description="Accepted quotes create pending service contracts; payment and entitlement activation stay in backend commerce records.">
				<p class="ts-subtle">Contract: <strong>{contract?.id ?? 'none'}</strong></p>
				<p class="ts-subtle">Status: <strong>{contract?.status ?? 'none'}</strong></p>
				<p class="ts-subtle">Order: <strong>{contract?.orderId ?? 'none'}</strong></p>
				{canManageTeam && contract ? (
					<div slot="actions" class="ts-inline-actions">
						<form method="POST" class="ts-inline-actions">
							<input type="hidden" name="action" value="link-work" />
							<input type="hidden" name="contractId" value={contract.id} />
							<input name="relatedProjectId" placeholder="project id" />
							<input name="relatedWorkdayId" placeholder="workday id" />
							<Button type="submit" size="sm">Link work</Button>
						</form>
						<form method="POST" class="ts-inline-actions">
							<input type="hidden" name="action" value="fulfill-contract" />
							<input type="hidden" name="contractId" value={contract.id} />
							<input name="summary" placeholder="fulfillment summary" />
							<Button type="submit" size="sm">Fulfill</Button>
						</form>
					</div>
				) : null}
			</Panel>

			<Panel eyebrow="Governance" title="Service timeline" description="Events capture request, scope, quote, approval, contract, work-link, and fulfillment transitions.">
				<PlainTable columns={[
					{ key: 'event', label: 'Event' },
					{ key: 'prior', label: 'Prior' },
					{ key: 'next', label: 'Next' },
					{ key: 'created', label: 'Created' },
				]} rows={eventRows} emptyTitle="No events" emptyDescription="Timeline entries appear after service workflow transitions." />
			</Panel>
		</section>
	) : (
		<EmptyState title="Service request not found" description="This service request is not available." actions={[{ label: 'Back to services', href: team ? `/app/teams/${encodeURIComponent(team.id)}/commerce/services` : '/app/teams' }]} />
	)}
</TreeseedAppLayout>
