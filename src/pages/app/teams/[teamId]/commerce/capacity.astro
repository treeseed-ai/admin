---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../../../lib/market/api-client';
import { escapeHtml as esc } from '../../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../../view-models/app-access.js';

const teamId = String(Astro.params.teamId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamId);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;

const api = new ApiClientFacade(Astro);
const vendor = team ? await api.getCommerceVendor(team.id).catch(() => null) : null;
const listings = team ? await api.listCommerceCapacityListings({ sellerTeamId: team.id }).catch(() => []) : [];
const inquiries = team ? await api.listCommerceCapacityListingInquiries({ sellerTeamId: team.id }).catch(() => []) : [];

const listingRows = listings.map((listing: any) => ({
	id: listing.id,
	listing: `<a href="/app/teams/${encodeURIComponent(team?.id ?? '')}/commerce/capacity/${encodeURIComponent(listing.id)}">${esc(listing.id)}</a>`,
	status: esc(listing.status),
	access: esc(listing.accessLevel),
	runtime: esc(listing.runtimeIsolationLevel),
	involvement: esc([listing.aiInvolvementLevel, listing.humanInvolvementLevel].filter(Boolean).join(' / ')),
	data: esc([listing.dataAccessLevel, listing.secretAccessLevel].filter(Boolean).join(' / ')),
	updated: esc(listing.updatedAt ?? ''),
}));

const inquiryRows = inquiries.slice(0, 10).map((inquiry: any) => ({
	id: inquiry.id,
	inquiry: esc(inquiry.id),
	status: esc(inquiry.status),
	buyer: esc(inquiry.buyerTeamId ?? inquiry.buyerUserId ?? 'redacted'),
	service: esc(inquiry.requestedServiceType ?? ''),
	scope: esc(inquiry.requestedScope ?? ''),
	updated: esc(inquiry.updatedAt ?? ''),
}));
---

<TreeseedAppLayout title={team ? 'Capacity listings' : 'Team not found'} description="Manage trust-gated marketplace capacity listings and inquiries." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam}>
	{team ? (
		<section class="ts-control-page" aria-label="Capacity listings">
			<Panel eyebrow="Commerce" title="Capacity marketplace foundation" description="Capacity listings disclose seller capability, readiness, and governance context without creating execution, billing, grants, or reservations.">
				<p class="ts-subtle">Vendor status: <strong>{vendor?.status ?? 'not requested'}</strong> · Trust: <strong>{vendor?.trustLevel ?? 'unreviewed'}</strong> · Capacity listings: <strong>{vendor?.capacityListingsEnabled ? 'enabled' : 'disabled'}</strong></p>
				<div slot="actions" class="ts-inline-actions">
					<Button href={`/app/teams/${encodeURIComponent(team.id)}/commerce`} variant="secondary" size="sm">Seller readiness</Button>
					<Button href={`/app/teams/${encodeURIComponent(team.id)}/commerce/services`} variant="secondary" size="sm">Services</Button>
				</div>
				<PlainTable columns={[
					{ key: 'listing', label: 'Listing' },
					{ key: 'status', label: 'Status' },
					{ key: 'access', label: 'Access' },
					{ key: 'runtime', label: 'Runtime' },
					{ key: 'involvement', label: 'AI / human' },
					{ key: 'data', label: 'Data / secret' },
					{ key: 'updated', label: 'Updated' },
				]} rows={listingRows} emptyTitle="No capacity listings" emptyDescription="Trust-gated listings appear here after a capacity product is created." />
			</Panel>
			<Panel eyebrow="Inquiries" title="Recent buyer interest" description="Inquiry approval means approved for scoping conversation only. It does not grant capacity or create execution work.">
				<PlainTable columns={[
					{ key: 'inquiry', label: 'Inquiry' },
					{ key: 'status', label: 'Status' },
					{ key: 'buyer', label: 'Buyer' },
					{ key: 'service', label: 'Service type' },
					{ key: 'scope', label: 'Scope' },
					{ key: 'updated', label: 'Updated' },
				]} rows={inquiryRows} emptyTitle="No capacity inquiries" emptyDescription="Buyer inquiries appear after approved public listings receive interest." />
			</Panel>
		</section>
	) : (
		<EmptyState title="Team not found" description="This team is not available." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	)}
</TreeseedAppLayout>
