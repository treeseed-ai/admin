---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../../../../../lib/market/api-client';
import { escapeHtml as esc } from '../../../../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../../../../view-models/app-access.js';

const teamId = String(Astro.params.teamId ?? '');
const productId = String(Astro.params.productId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamId);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);

const manageableRoles = new Set(['team_owner', 'project_lead']);
const access = team && context.store && typeof context.store.getTeamAccessSummary === 'function'
	? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
	: null;
const canManageTeam = Boolean(access?.roles?.some((role: string) => manageableRoles.has(role)));
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;

const api = new ApiClientFacade(Astro);
let formError = '';
let statusMessage = '';

if (Astro.request.method === 'POST' && team && canManageTeam) {
	const data = await Astro.request.formData();
	const action = String(data.get('action') ?? '');
	try {
		if (action === 'update-ownership') {
			await api.updateCommerceOwnershipRecord(productId, String(data.get('ownershipRecordId') ?? ''), {
				publicSummary: String(data.get('publicSummary') ?? '').trim() || null,
				buyerVisible: data.get('buyerVisible') === 'on',
				reason: String(data.get('reason') ?? '').trim() || 'Ownership summary updated.',
			});
			return Astro.redirect(Astro.url.pathname + '?saved=ownership', 303);
		}
		if (action === 'update-steward') {
			await api.updateCommerceStewardshipAssignment(productId, String(data.get('assignmentId') ?? ''), {
				displayName: String(data.get('displayName') ?? '').trim() || null,
				responsibilities: String(data.get('responsibilities') ?? '').split(',').map((value) => value.trim()).filter(Boolean),
				visibleToBuyers: data.get('visibleToBuyers') === 'on',
				reason: String(data.get('reason') ?? '').trim() || 'Stewardship assignment updated.',
			});
			return Astro.redirect(Astro.url.pathname + '?saved=steward', 303);
		}
		if (action === 'end-steward') {
			await api.endCommerceStewardshipAssignment(productId, String(data.get('assignmentId') ?? ''), {
				reason: String(data.get('reason') ?? '').trim() || 'Stewardship assignment ended.',
			});
			return Astro.redirect(Astro.url.pathname + '?saved=steward-ended', 303);
		}
		if (action === 'update-contribution') {
			await api.updateCommerceContribution(productId, String(data.get('contributionId') ?? ''), {
				summary: String(data.get('summary') ?? '').trim() || null,
				attributionVisibility: String(data.get('attributionVisibility') ?? '').trim() || 'public',
				benefitWeight: Number(String(data.get('benefitWeight') ?? '0')),
				reason: String(data.get('reason') ?? '').trim() || 'Contribution updated.',
			});
			return Astro.redirect(Astro.url.pathname + '?saved=contribution', 303);
		}
		if (action === 'update-policy') {
			await api.updateCommerceGovernancePolicy(productId, String(data.get('policyId') ?? ''), {
				title: String(data.get('title') ?? '').trim(),
				buyerVisibleSummary: String(data.get('buyerVisibleSummary') ?? '').trim() || null,
				status: String(data.get('status') ?? '').trim() || 'active',
				reason: String(data.get('reason') ?? '').trim() || 'Governance policy updated.',
			});
			return Astro.redirect(Astro.url.pathname + '?saved=policy', 303);
		}
		if (action === 'transfer-decision') {
			const transferId = String(data.get('transferId') ?? '');
			const decision = String(data.get('decision') ?? '');
			const body = { reason: String(data.get('reason') ?? '').trim() || `Ownership transfer ${decision}.` };
			if (decision === 'submit') await api.submitCommerceOwnershipTransfer(productId, transferId, body);
			if (decision === 'approve') await api.approveCommerceOwnershipTransfer(productId, transferId, body);
			if (decision === 'reject') await api.rejectCommerceOwnershipTransfer(productId, transferId, body);
			if (decision === 'cancel') await api.cancelCommerceOwnershipTransfer(productId, transferId, body);
			return Astro.redirect(Astro.url.pathname + '?saved=transfer', 303);
		}
		if (action === 'create-succession') {
			await api.createCommerceSuccessionEvent(productId, {
				successorType: String(data.get('successorType') ?? '').trim() || 'team',
				successorId: String(data.get('successorId') ?? '').trim() || team.id,
				eventType: String(data.get('eventType') ?? '').trim() || 'successor_named',
				reason: String(data.get('reason') ?? '').trim() || 'Succession event recorded.',
			});
			return Astro.redirect(Astro.url.pathname + '?saved=succession', 303);
		}
	} catch (error) {
		formError = error instanceof Error ? error.message : 'Governance operation failed.';
	}
}

const saved = Astro.url.searchParams.get('saved');
if (saved) statusMessage = 'Governance workflow updated.';

const product = productId ? await api.getCommerceProduct(productId).catch(() => null) : null;
const workflow = productId ? await api.getCommerceOwnershipWorkflow(productId).catch(() => null) : null;
const ownershipRows = (workflow?.buyerVisibleOwnershipRecords ?? []).map((record: any) => ({
	id: record.id,
	model: esc(record.model),
	owner: esc(record.canonicalOwnerId ?? record.canonicalOwnerType),
	summary: esc(record.publicSummary ?? ''),
	effective: esc(record.effectiveAt ?? ''),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="update-ownership" /><input type="hidden" name="ownershipRecordId" value="${esc(record.id)}" /><input name="publicSummary" value="${esc(record.publicSummary ?? '')}" /><label><input type="checkbox" name="buyerVisible" ${record.buyerVisible ? 'checked' : ''} /> Buyer visible</label><button type="submit">Update</button></form>` : '',
}));
const stewardRows = (workflow?.stewardshipAssignments ?? []).map((steward: any) => ({
	id: steward.id,
	role: esc(steward.role),
	assignee: esc(steward.displayName ?? steward.assigneeId ?? steward.assigneeType),
	visible: steward.visibleToBuyers ? 'yes' : 'no',
	ends: esc(steward.endsAt ?? ''),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="update-steward" /><input type="hidden" name="assignmentId" value="${esc(steward.id)}" /><input name="displayName" value="${esc(steward.displayName ?? '')}" /><input name="responsibilities" value="${esc((steward.responsibilities ?? []).join(', '))}" /><label><input type="checkbox" name="visibleToBuyers" ${steward.visibleToBuyers ? 'checked' : ''} /> Visible</label><button type="submit">Update</button></form><form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="end-steward" /><input type="hidden" name="assignmentId" value="${esc(steward.id)}" /><button type="submit">End</button></form>` : '',
}));
const contributionRows = (workflow?.contributions ?? []).map((contribution: any) => ({
	id: contribution.id,
	role: esc(contribution.role),
	contributor: esc(contribution.displayName ?? contribution.contributorId ?? contribution.contributorType),
	visibility: esc(contribution.attributionVisibility),
	weight: esc(String(contribution.benefitWeight ?? '')),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="update-contribution" /><input type="hidden" name="contributionId" value="${esc(contribution.id)}" /><input name="summary" value="${esc(contribution.summary ?? '')}" /><input name="attributionVisibility" value="${esc(contribution.attributionVisibility)}" /><input name="benefitWeight" value="${esc(String(contribution.benefitWeight ?? ''))}" /><button type="submit">Update</button></form>` : '',
}));
const policyRows = (workflow?.governancePolicies ?? []).map((policy: any) => ({
	id: policy.id,
	title: esc(policy.title),
	kind: esc(policy.policyKind),
	status: esc(policy.status),
	summary: esc(policy.buyerVisibleSummary ?? ''),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="update-policy" /><input type="hidden" name="policyId" value="${esc(policy.id)}" /><input name="title" value="${esc(policy.title)}" /><input name="buyerVisibleSummary" value="${esc(policy.buyerVisibleSummary ?? '')}" /><input name="status" value="${esc(policy.status)}" /><button type="submit">Update</button></form>` : '',
}));
const transferRows = (workflow?.pendingTransfers ?? []).map((transfer: any) => ({
	id: transfer.id,
	status: esc(transfer.status),
	from: esc(transfer.fromOwnershipRecordId),
	to: esc(transfer.toOwnershipRecordId),
	reason: esc(transfer.reason ?? ''),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="transfer-decision" /><input type="hidden" name="transferId" value="${esc(transfer.id)}" /><select name="decision"><option value="submit">Submit</option><option value="approve">Approve</option><option value="reject">Reject</option><option value="cancel">Cancel</option></select><input name="reason" placeholder="reason" /><button type="submit">Apply</button></form>` : '',
}));
const successionRows = (workflow?.successionEvents ?? []).map((event: any) => ({
	id: event.id,
	event: esc(event.eventType),
	successor: esc(`${event.successorType}:${event.successorId}`),
	status: esc(event.status),
	reason: esc(event.reason ?? ''),
}));
---

<TreeseedAppLayout title={product ? `${product.title} governance` : 'Product governance'} description="Manage cooperative ownership, stewardship, attribution, transfer, and succession state." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam}>
	{team && product ? (
		<section class="ts-control-page" aria-label="Product governance">
			<Panel eyebrow="Commerce" title={product.title} description="Current and future ownership decisions are governed here. Purchase-time order and entitlement snapshots remain immutable.">
				{formError && <p class="ts-form-error" role="alert">{formError}</p>}
				{statusMessage && !formError && <p class="ts-subtle" role="status">{statusMessage}</p>}
				<p class="ts-subtle">Product status: <strong>{product.status}</strong> · Ownership model: <strong>{product.ownershipModel}</strong></p>
				<div slot="actions" class="ts-inline-actions">
					<Button href={`/app/teams/${encodeURIComponent(team.id)}/commerce/products`} variant="secondary" size="sm">Products</Button>
					<Button href={`/app/teams/${encodeURIComponent(team.id)}/commerce/sales`} variant="secondary" size="sm">Sales</Button>
				</div>
			</Panel>

			<Panel eyebrow="Ownership" title="Buyer-visible ownership" description="Ownership records identify governance authority. They are not payout rules.">
				<PlainTable columns={[
					{ key: 'model', label: 'Model' },
					{ key: 'owner', label: 'Owner' },
					{ key: 'summary', label: 'Summary' },
					{ key: 'effective', label: 'Effective' },
					{ key: 'action', label: 'Action' },
				]} rows={ownershipRows} emptyTitle="No buyer-visible ownership" emptyDescription="Buyer-visible ownership records appear after product setup." />
			</Panel>

			<Panel eyebrow="Stewardship" title="Stewards" description="Steward roles describe governance, maintenance, support, and succession responsibility.">
				<PlainTable columns={[
					{ key: 'role', label: 'Role' },
					{ key: 'assignee', label: 'Assignee' },
					{ key: 'visible', label: 'Visible' },
					{ key: 'ends', label: 'Ends' },
					{ key: 'action', label: 'Action' },
				]} rows={stewardRows} emptyTitle="No stewards" emptyDescription="Stewardship assignments appear after governance setup." />
			</Panel>

			<Panel eyebrow="Attribution" title="Contributions" description="Benefit weights support future recognition and governance. They are not payout allocations.">
				<PlainTable columns={[
					{ key: 'role', label: 'Role' },
					{ key: 'contributor', label: 'Contributor' },
					{ key: 'visibility', label: 'Visibility' },
					{ key: 'weight', label: 'Weight' },
					{ key: 'action', label: 'Action' },
				]} rows={contributionRows} emptyTitle="No contributions" emptyDescription="Contribution records appear after attribution setup." />
			</Panel>

			<Panel eyebrow="Policy" title="Governance policies" description="Policies describe approval and quorum expectations for cooperative decisions.">
				<PlainTable columns={[
					{ key: 'title', label: 'Policy' },
					{ key: 'kind', label: 'Kind' },
					{ key: 'status', label: 'Status' },
					{ key: 'summary', label: 'Buyer summary' },
					{ key: 'action', label: 'Action' },
				]} rows={policyRows} emptyTitle="No governance policies" emptyDescription="Policies appear after cooperative governance setup." />
			</Panel>

			<Panel eyebrow="Transfer" title="Ownership transfers" description="Transfers require an explicit decision before current ownership changes.">
				<PlainTable columns={[
					{ key: 'status', label: 'Status' },
					{ key: 'from', label: 'From' },
					{ key: 'to', label: 'To' },
					{ key: 'reason', label: 'Reason' },
					{ key: 'action', label: 'Action' },
				]} rows={transferRows} emptyTitle="No transfers" emptyDescription="Transfer records appear after a governed transfer is proposed." />
			</Panel>

			<Panel eyebrow="Succession" title="Succession events" description="Succession records are governance evidence and do not automatically rewrite ownership.">
				{canManageTeam ? (
					<form slot="actions" class="ts-inline-actions" method="POST">
						<input type="hidden" name="action" value="create-succession" />
						<input name="successorType" value="team" />
						<input name="successorId" value={team.id} />
						<select name="eventType">
							<option value="successor_named">Successor named</option>
							<option value="successor_accepted">Successor accepted</option>
							<option value="succession_triggered">Succession triggered</option>
							<option value="succession_completed">Succession completed</option>
							<option value="succession_canceled">Succession canceled</option>
						</select>
						<input name="reason" placeholder="reason" />
						<Button type="submit" size="sm">Record</Button>
					</form>
				) : null}
				<PlainTable columns={[
					{ key: 'event', label: 'Event' },
					{ key: 'successor', label: 'Successor' },
					{ key: 'status', label: 'Status' },
					{ key: 'reason', label: 'Reason' },
				]} rows={successionRows} emptyTitle="No succession events" emptyDescription="Succession events appear after successor governance actions." />
			</Panel>
		</section>
	) : (
		<EmptyState title="Product not found" description="This commerce product is not available." actions={[{ label: 'Back to products', href: team ? `/app/teams/${encodeURIComponent(team.id)}/commerce/products` : '/app/teams' }]} />
	)}
</TreeseedAppLayout>
