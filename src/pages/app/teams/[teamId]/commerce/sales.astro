---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { ApiClientFacade } from '../../../../../lib/market/api-client';
import { escapeHtml as esc } from '../../../../../lib/market/control-ui.js';
import { loadAppContext, persistActiveTeamSelection, resolveAppTeam } from '../../../../../view-models/app-access.js';

const teamId = String(Astro.params.teamId ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const context = await loadAppContext(Astro);
const teamResolution = resolveAppTeam(context, teamId);
const team = teamResolution.resource;
if (teamResolution.team?.id && teamResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, teamResolution.team);

const manageableRoles = new Set(['team_owner', 'project_lead']);
const access = team && context.store && typeof context.store.getTeamAccessSummary === 'function'
	? await context.store.getTeamAccessSummary(team.id, context.principal).catch(() => null)
	: null;
const canManageTeam = Boolean(access?.roles?.some((role: string) => manageableRoles.has(role)));
if (!team) Astro.response.status = teamResolution.status === 'forbidden' ? 403 : 404;

const api = new ApiClientFacade(Astro);
let formError = '';
let statusMessage = '';

if (Astro.request.method === 'POST' && team && canManageTeam) {
	const data = await Astro.request.formData();
	const action = String(data.get('action') ?? '');
	try {
		if (action === 'refund-order') {
			const orderId = String(data.get('orderId') ?? '');
			const amountRaw = String(data.get('amount') ?? '').trim();
			await api.createCommerceOrderRefund(orderId, {
				amount: amountRaw ? Number(amountRaw) : null,
				reason: String(data.get('reason') ?? '').trim() || null,
			});
			return Astro.redirect(`/app/teams/${encodeURIComponent(team.id)}/commerce/sales?saved=refund`, 303);
		}
		if (action === 'fulfill-artifact') {
			const orderItemId = String(data.get('orderItemId') ?? '');
			await api.fulfillCommerceOrderItemArtifact(orderItemId, {
				catalogArtifactVersionId: String(data.get('catalogArtifactVersionId') ?? '').trim() || null,
				message: String(data.get('message') ?? '').trim() || null,
			});
			return Astro.redirect(`/app/teams/${encodeURIComponent(team.id)}/commerce/sales?saved=fulfilled`, 303);
		}
		if (action === 'revoke-entitlement') {
			const entitlementId = String(data.get('entitlementId') ?? '');
			await api.revokeCommerceEntitlement(entitlementId, {
				reason: String(data.get('reason') ?? '').trim() || 'Revoked from seller operations.',
			});
			return Astro.redirect(`/app/teams/${encodeURIComponent(team.id)}/commerce/sales?saved=revoked`, 303);
		}
	} catch (error) {
		formError = error instanceof Error ? error.message : 'Seller operation failed.';
	}
}

const saved = Astro.url.searchParams.get('saved');
if (saved === 'refund') statusMessage = 'Refund recorded.';
if (saved === 'fulfilled') statusMessage = 'Artifact fulfillment recorded.';
if (saved === 'revoked') statusMessage = 'Entitlement revoked.';

const vendor = team ? await api.getCommerceVendor(team.id).catch(() => null) : null;
const summary = team ? await api.getCommerceVendorSalesSummary(team.id).catch(() => null) : null;
const orders = team ? await api.listCommerceVendorSalesOrders(team.id).catch(() => []) : [];
const subscriptions = team ? await api.listCommerceVendorSalesSubscriptions(team.id).catch(() => []) : [];
const entitlements = team ? await api.listCommerceVendorSalesEntitlements(team.id).catch(() => []) : [];
const refunds = team ? await api.listCommerceVendorSalesRefunds(team.id).catch(() => []) : [];
const fulfillmentEvents = team ? await api.listCommerceVendorFulfillmentEvents(team.id).catch(() => []) : [];

function money(amount: unknown, currency: unknown) {
	const value = Number(amount ?? 0) / 100;
	const code = typeof currency === 'string' && currency ? currency.toUpperCase() : 'USD';
	return `${code} ${value.toFixed(2)}`;
}

const summaryRows = summary ? [
	{ id: 'gross', metric: 'Gross paid', value: esc(money(summary.grossPaidAmount, summary.currency)) },
	{ id: 'refunded', metric: 'Refunded', value: esc(money(summary.refundedAmount, summary.currency)) },
	{ id: 'net', metric: 'Net paid', value: esc(money(summary.netPaidAmount, summary.currency)) },
	{ id: 'orders', metric: 'Paid orders', value: esc(String(summary.paidOrderCount ?? 0)) },
	{ id: 'subscriptions', metric: 'Active subscriptions', value: esc(String(summary.activeSubscriptionCount ?? 0)) },
	{ id: 'entitlements', metric: 'Active entitlements', value: esc(String(summary.activeEntitlementCount ?? 0)) },
] : [];

const orderRows = orders.map((order: any) => ({
	id: order.id,
	order: esc(order.id),
	status: esc(order.status),
	total: esc(money(order.totalAmount, order.currency)),
	refunded: esc(money(order.refundedAmount, order.currency)),
	buyer: esc(order.buyerDisplayName ?? order.buyerTeamId ?? order.buyerUserIdRedacted ?? 'redacted'),
	created: esc(order.createdAt ?? ''),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="refund-order" /><input type="hidden" name="orderId" value="${esc(order.id)}" /><input name="amount" inputmode="numeric" placeholder="remaining" /><input name="reason" placeholder="reason" /><button type="submit">Refund</button></form>` : '',
}));

const subscriptionRows = subscriptions.map((subscription: any) => ({
	id: subscription.id,
	subscription: esc(subscription.id),
	status: esc(subscription.status),
	renewal: esc(subscription.renewalState ?? ''),
	periodEnd: esc(subscription.currentPeriodEnd ?? ''),
}));

const entitlementRows = entitlements.map((entitlement: any) => ({
	id: entitlement.id,
	entitlement: esc(entitlement.id),
	product: esc(entitlement.productId),
	status: esc(entitlement.status),
	artifacts: esc(String(entitlement.fulfillmentArtifactRefs?.length ?? 0)),
	action: canManageTeam ? `<form method="POST" class="ts-inline-actions"><input type="hidden" name="action" value="revoke-entitlement" /><input type="hidden" name="entitlementId" value="${esc(entitlement.id)}" /><input name="reason" placeholder="reason" /><button type="submit">Revoke</button></form>` : '',
}));

const refundRows = refunds.map((refund: any) => ({
	id: refund.id,
	refund: esc(refund.id),
	order: esc(refund.orderId),
	status: esc(refund.status),
	amount: esc(money(refund.amount, refund.currency)),
	reason: esc(refund.reason ?? ''),
}));

const fulfillmentRows = fulfillmentEvents.map((event: any) => ({
	id: event.id,
	event: esc(event.eventType),
	status: esc(event.status),
	order: esc(event.orderId),
	product: esc(event.productId),
	created: esc(event.createdAt ?? ''),
}));
---

<TreeseedAppLayout title={team ? 'Seller operations' : 'Team not found'} description="Review sales, fulfillment, and governance state for one seller team." currentPath="/app/teams" teams={context.teams} activeTeam={team ?? context.activeTeam}>
	{team ? (
		<section class="ts-control-page" aria-label="Seller operations">
			<Panel eyebrow="Commerce" title="Sales summary" description="Seller operations are tied to TreeSeed orders, entitlements, fulfillment records, and cooperative ownership snapshots.">
				{formError && <p class="ts-form-error" role="alert">{formError}</p>}
				{statusMessage && !formError && <p class="ts-subtle" role="status">{statusMessage}</p>}
				<p class="ts-subtle">Vendor status: <strong>{vendor?.status ?? 'not requested'}</strong></p>
				<PlainTable columns={[
					{ key: 'metric', label: 'Metric' },
					{ key: 'value', label: 'Value' },
				]} rows={summaryRows} emptyTitle="No sales summary" emptyDescription="Sales metrics appear after orders are recorded." />
				<div slot="actions" class="ts-inline-actions">
					<Button href={`/app/teams/${encodeURIComponent(team.id)}/commerce`} variant="secondary" size="sm">Seller readiness</Button>
				</div>
			</Panel>

			<Panel eyebrow="Orders" title="Recent orders" description="Buyer details are intentionally limited in seller views.">
				<PlainTable columns={[
					{ key: 'order', label: 'Order' },
					{ key: 'status', label: 'Status' },
					{ key: 'total', label: 'Total' },
					{ key: 'refunded', label: 'Refunded' },
					{ key: 'buyer', label: 'Buyer' },
					{ key: 'created', label: 'Created' },
					{ key: 'action', label: 'Action' },
				]} rows={orderRows} emptyTitle="No orders" emptyDescription="Orders appear after buyers complete purchases." />
			</Panel>

			<Panel eyebrow="Access" title="Entitlements" description="Access records preserve the purchase-time ownership and stewardship context.">
				<PlainTable columns={[
					{ key: 'entitlement', label: 'Entitlement' },
					{ key: 'product', label: 'Product' },
					{ key: 'status', label: 'Status' },
					{ key: 'artifacts', label: 'Artifacts' },
					{ key: 'action', label: 'Action' },
				]} rows={entitlementRows} emptyTitle="No entitlements" emptyDescription="Entitlements appear after access is granted." />
			</Panel>

			<Panel eyebrow="Subscriptions" title="Renewals" description="Recurring access state is tracked separately from product ownership.">
				<PlainTable columns={[
					{ key: 'subscription', label: 'Subscription' },
					{ key: 'status', label: 'Status' },
					{ key: 'renewal', label: 'Renewal' },
					{ key: 'periodEnd', label: 'Period end' },
				]} rows={subscriptionRows} emptyTitle="No subscriptions" emptyDescription="Subscriptions appear after recurring purchases." />
			</Panel>

			<Panel eyebrow="Refunds" title="Refund records" description="Refund state is operational evidence and not a payout ledger.">
				<PlainTable columns={[
					{ key: 'refund', label: 'Refund' },
					{ key: 'order', label: 'Order' },
					{ key: 'status', label: 'Status' },
					{ key: 'amount', label: 'Amount' },
					{ key: 'reason', label: 'Reason' },
				]} rows={refundRows} emptyTitle="No refunds" emptyDescription="Refunds appear after seller actions." />
			</Panel>

			<Panel eyebrow="Fulfillment" title="Artifact events" description="Artifact delivery records connect orders and entitlements to released catalog artifacts.">
				{canManageTeam ? (
					<form slot="actions" class="ts-inline-actions" method="POST">
						<input type="hidden" name="action" value="fulfill-artifact" />
						<input name="orderItemId" placeholder="order item id" />
						<input name="catalogArtifactVersionId" placeholder="artifact version id" />
						<input name="message" placeholder="message" />
						<Button type="submit" size="sm">Record artifact</Button>
					</form>
				) : null}
				<PlainTable columns={[
					{ key: 'event', label: 'Event' },
					{ key: 'status', label: 'Status' },
					{ key: 'order', label: 'Order' },
					{ key: 'product', label: 'Product' },
					{ key: 'created', label: 'Created' },
				]} rows={fulfillmentRows} emptyTitle="No fulfillment events" emptyDescription="Fulfillment records appear after delivery." />
			</Panel>
		</section>
	) : (
		<EmptyState title="Team not found" description="This team is not available." actions={[{ label: 'Back to teams', href: '/app/teams' }]} />
	)}
</TreeseedAppLayout>
