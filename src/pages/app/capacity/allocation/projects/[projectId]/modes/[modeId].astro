---
import DetailTemplate from '@treeseed/ui/components/astro/templates/DetailTemplate.astro';
import AllocationPanel from '@treeseed/ui/components/astro/operating/AllocationPanel.astro';
import TreeseedAppLayout from '../../../../../../../layouts/TreeseedAppLayout.astro';
import { loadAllocationDashboard } from '../../../../../../../view-models/operating-loop.vm.js';

const projectId = String(Astro.params.projectId ?? '');
const modeId = String(Astro.params.modeId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadAllocationDashboard(Astro, Astro.url, projectId);
---

<TreeseedAppLayout title={`${modeId} allocation`} description="Workstream and mode allocation drilldown." currentPath="/app/capacity/allocation" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	<DetailTemplate title={`${modeId} mode allocation`} description="Inherited project allocation, reservations, active assignments, and actual usage." eyebrow="Allocation" actions={vm.actions} metadata={[{ key: 'Project', value: projectId }, { key: 'Mode', value: modeId }]}>
		<AllocationPanel viewModel={vm.allocation} />
	</DetailTemplate>
</TreeseedAppLayout>
