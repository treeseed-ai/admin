---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import AllocationPanel from '@treeseed/ui/components/astro/operating/AllocationPanel.astro';
import { DynamicPieAllocationInput } from '@treeseed/ui/react';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { loadAllocationDashboard } from '../../../../../view-models/operating-loop.vm.js';

const projectId = String(Astro.params.projectId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadAllocationDashboard(Astro, Astro.url, projectId);
const slices = vm.portfolio?.slices ?? vm.allocation.items.map((item) => ({ id: item.id, name: item.label, percentage: Number.parseFloat(String(item.desired ?? '0')) || 0 }));
const pageJson = JSON.stringify({ teamId: vm.context.activeTeam?.id ?? null, projectId, canManage: vm.canManage }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={vm.allocation.title} description={vm.allocation.description} currentPath="/app/capacity/allocation" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	<DashboardTemplate viewModel={vm.dashboard} actions={vm.actions}>
		<AllocationPanel viewModel={vm.allocation} />
		<form class="ts-form-stack" data-allocation-form="project" data-project-id={projectId}>
			<DynamicPieAllocationInput client:load name="allocations" initialValue={slices} minSlicePercentage={0} precision={1} disabled={!vm.canManage} ariaLabel="Project agent class capacity allocation" />
			<FormActions align="start">
				<Button type="submit" disabled={!vm.canManage}>Save project allocation</Button>
				<Button href="/app/capacity/allocation" variant="secondary">Back to portfolio</Button>
				<span class="ts-subtle" data-allocation-status role="status"></span>
			</FormActions>
		</form>
	</DashboardTemplate>
	<script is:inline type="application/json" id="allocation-page-data" set:html={pageJson}></script>
</TreeseedAppLayout>

<script>
	import { bindAllocationForm } from '../../../../../lib/market/operating-loop-client';

	bindAllocationForm({ dataId: 'allocation-page-data' });
</script>
