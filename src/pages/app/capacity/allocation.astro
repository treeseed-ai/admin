---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import AllocationPanel from '@treeseed/ui/components/astro/operating/AllocationPanel.astro';
import { DynamicPieAllocationInput } from '@treeseed/ui/react';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { loadAllocationDashboard } from '../../../view-models/operating-loop.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/capacity/allocation')}`);
const vm = await loadAllocationDashboard(Astro, Astro.url);
const projects = vm.portfolio?.projects ?? vm.context.projects ?? [];
const providers = vm.portfolio?.providers ?? [];
const providerOptions = providers.map((provider: any) => ({ label: provider.name ?? provider.id, value: provider.id }));
const slices = vm.portfolio?.slices?.length ? vm.portfolio.slices : projects.map((project: any) => ({ id: project.id, name: project.name ?? project.slug, percentage: projects.length ? Math.round((100 / projects.length) * 10) / 10 : 100 }));
const pageJson = JSON.stringify({ teamId: vm.context.activeTeam?.id ?? null, canManage: vm.canManage, defaultProviderId: providerOptions[0]?.value ?? '' }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={vm.dashboard.title} description={vm.dashboard.description} currentPath="/app/capacity/allocation" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.context.activeTeam ? (
		<DashboardTemplate viewModel={vm.dashboard} actions={vm.actions}>
			<AllocationPanel viewModel={vm.allocation} />
			{providers.length === 0 ? (
				<EmptyState title="No capacity provider" description="Create a provider before saving portfolio allocation." actions={[{ label: 'Create provider', href: '/app/capacity/providers/new' }]} />
			) : projects.length === 0 ? (
				<EmptyState title="No projects" description="Create projects from starters before allocating provider capacity." actions={[{ label: 'Create project', href: '/app/projects/new' }]} />
			) : (
				<form class="ts-form-stack" data-allocation-form="portfolio">
					<Field label="Capacity provider" name="capacityProviderId">
						<Select name="capacityProviderId" options={providerOptions} disabled={!vm.canManage} />
					</Field>
					<DynamicPieAllocationInput client:load name="allocations" initialValue={slices} minSlicePercentage={0} precision={1} disabled={!vm.canManage} ariaLabel="Team project portfolio capacity allocation" />
					<FormActions align="start">
						<Button type="submit" disabled={!vm.canManage}>Save portfolio allocation</Button>
						<span class="ts-subtle" data-allocation-status role="status"></span>
					</FormActions>
				</form>
			)}
		</DashboardTemplate>
	) : (
		<EmptyState title="No active team" description="Create or switch to a team before allocating capacity." actions={[{ label: 'Create team', href: '/app/teams/new' }]} />
	)}
	<script is:inline type="application/json" id="allocation-page-data" set:html={pageJson}></script>
</TreeseedAppLayout>

<script>
	import { bindAllocationForm } from '../../../lib/market/operating-loop-client';

	bindAllocationForm({ dataId: 'allocation-page-data' });
</script>
