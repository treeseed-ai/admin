---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import CollectionTemplate from '@treeseed/ui/components/astro/templates/CollectionTemplate.astro';
import WorkQueueSummary from '@treeseed/ui/components/astro/operating/WorkQueueSummary.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadWorkdayRunCollection } from '../../../../view-models/operating-loop.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/capacity/workday-runs')}`);
const vm = await loadWorkdayRunCollection(Astro, Astro.url);
const pageJson = JSON.stringify({ teamId: vm.context.activeTeam?.id ?? '' }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={vm.collection.title} description={vm.collection.description} currentPath="/app/capacity/workday-runs" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.context.activeTeam ? (
		<CollectionTemplate viewModel={vm.collection} actions={vm.actions}>
			<form class="ts-grid-form" data-workday-run-form>
				<Field label="Projects" name="projects"><TextInput name="projects" value="all" autocomplete="off" /></Field>
				<Field label="Provider" name="providerId"><TextInput name="providerId" value="local" autocomplete="off" /></Field>
				<Field label="Workdays" name="workdays"><TextInput name="workdays" value="1" inputmode="numeric" autocomplete="off" /></Field>
				<Field label="Duration seconds" name="durationSeconds"><TextInput name="durationSeconds" value="900" inputmode="numeric" autocomplete="off" /></Field>
				<Field label="Max assignments" name="maxAssignments"><TextInput name="maxAssignments" value="162" inputmode="numeric" autocomplete="off" /></Field>
				<FormActions align="start">
					<Button type="submit">Create workday run</Button>
					<span class="ts-subtle" data-workday-run-status role="status"></span>
				</FormActions>
			</form>
			<WorkQueueSummary viewModel={vm.queue} />
		</CollectionTemplate>
	) : (
		<EmptyState title="No active team" description="Create or switch to a team before running workdays." actions={[{ label: 'Create team', href: '/app/teams/new' }]} />
	)}
	<script is:inline type="application/json" id="workday-run-data" set:html={pageJson}></script>
</TreeseedAppLayout>

<script>
	import { bindWorkdayRunForm } from '../../../../lib/market/operating-loop-client';

	bindWorkdayRunForm({ dataId: 'workday-run-data' });
</script>
