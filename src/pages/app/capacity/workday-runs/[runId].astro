---
import WorkspaceTemplate from '@treeseed/ui/components/astro/templates/WorkspaceTemplate.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadWorkdayRunWorkspace } from '../../../../view-models/operating-loop.vm.js';

const runId = String(Astro.params.runId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadWorkdayRunWorkspace(Astro, runId, Astro.url);
if (!vm.workspace) Astro.response.status = 404;
---

<TreeseedAppLayout title={vm.workspace?.title ?? 'Workday run'} description={vm.workspace?.description} currentPath="/app/capacity/workday-runs" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.workspace ? (
		<WorkspaceTemplate viewModel={vm.workspace} actions={vm.actions} />
	) : (
		<EmptyState title="Workday run not found" description="This workday run is not available for the selected team." actions={[{ label: 'Back to runs', href: '/app/capacity/workday-runs' }]} />
	)}
</TreeseedAppLayout>
