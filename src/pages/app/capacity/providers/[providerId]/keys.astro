---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext, persistActiveTeamSelection, resolveAppCapacityProvider } from '../../../../../view-models/app-access.js';

const providerId = String(Astro.params.providerId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const providerResolution = await resolveAppCapacityProvider(context, providerId);
const team = providerResolution.team ?? context.activeTeam;
const provider = providerResolution.resource;
if (providerResolution.team?.id && providerResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, providerResolution.team);
if (!provider) Astro.response.status = providerResolution.status === 'forbidden' ? 403 : 404;
---

<TreeseedAppLayout title="Provider keys" description="Rotate provider API keys." currentPath="/app/capacity/providers" teams={context.teams} activeTeam={team}>
	{provider ? (
		<section class="ts-control-page" aria-label="Provider keys">
			<Panel eyebrow="Capacity" title={`Rotate key for ${provider.name}`} description="Rotation revokes the old key immediately and reveals the new key once.">
				<p class="ts-subtle">Restart the capacity provider after rotation. The old key stops working immediately, and the new key is displayed only once.</p>
				<FormActions align="start"><button class="ts-button" type="button" id="rotate-key-button">Rotate API key</button><button class="ts-button-secondary" type="button" id="copy-key-button" hidden>Copy key</button><Button href="/app/capacity/providers" variant="secondary">Back</Button><span class="ts-subtle" id="key-status" role="status"></span></FormActions>
				<pre id="key-display" class="ts-code-block" hidden></pre>
			</Panel>
		</section>
	) : (
		<EmptyState title="Provider not found" description="This provider is not available." actions={[{ label: 'Back to Capacity', href: '/app/capacity/providers' }]} />
	)}
</TreeseedAppLayout>

<script is:inline define:vars={{ teamId: team?.id ?? '', providerId: provider?.id ?? '' }}>
	const status = document.getElementById('key-status');
	const rotate = document.getElementById('rotate-key-button');
	const copy = document.getElementById('copy-key-button');
	const keyDisplay = document.getElementById('key-display');
	let revealedKey = '';
	async function post(path) {
		const response = await fetch(path, { method: 'POST', headers: { 'content-type': 'application/json' }, body: JSON.stringify({}) });
		const payload = await response.json().catch(() => null);
		if (!response.ok || payload?.ok === false) throw new Error(payload?.error ?? 'Request failed.');
		return payload;
	}
	copy?.addEventListener('click', async () => {
		if (!revealedKey) return;
		try {
			await navigator.clipboard.writeText(revealedKey);
			if (status) status.textContent = 'Copied. Restart the capacity provider with this key.';
		} catch {
			if (status) status.textContent = 'Copy failed. Select the key text manually.';
		}
	});
	rotate?.addEventListener('click', async () => {
		if (status) status.textContent = 'Rotating...';
		try {
			const result = await post(`/v1/teams/${encodeURIComponent(teamId)}/capacity-providers/${encodeURIComponent(providerId)}/keys/rotate`);
			revealedKey = String(result?.apiKey?.plaintext ?? '');
			if (status) status.textContent = 'Key rotated. Restart the capacity provider with this key. The old key no longer works.';
			if (keyDisplay) {
				keyDisplay.hidden = false;
				keyDisplay.textContent = `TREESEED_CAPACITY_PROVIDER_API_KEY=${revealedKey}`;
			}
			if (copy) copy.hidden = false;
		} catch (error) { if (status) status.textContent = error instanceof Error ? error.message : 'Rotate failed.'; }
	});
</script>
