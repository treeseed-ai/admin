---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import RadioGroup from '@treeseed/ui/components/astro/forms/RadioGroup.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import HostCredentialPermissionNote from '@treeseed/ui/components/astro/app/controls/HostCredentialPermissionNote.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { hostPurposeFor } from '../../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/capacity/providers/new')}`);
const context = await loadAppContext(Astro);
const team = context.activeTeam;
const capacityProviderHosts = team && context.store
	? await context.store.listTeamWebHosts(team.id).then((hosts: any[]) => hosts.filter((host: any) => host.provider === 'railway' && host.metadata?.hostType === 'capacity_provider')).catch(() => [])
	: [];
const pageJson = JSON.stringify({ teamId: team?.id ?? null, capacityProviderHosts }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title="New capacity provider" description="Create one capacity provider." currentPath="/app/capacity/providers" teams={context.teams} activeTeam={team}>
	{team ? (
		<section class="ts-control-page" aria-label="New capacity provider">
			<Panel eyebrow="Capacity" title="Create provider" description="Create a provider from native limits that operators can forecast. TreeSeed derives credits after usage samples are available.">
				<form id="provider-form" class="ts-form-stack">
					<div class="ts-form-grid">
						<Field label="Name" name="name" required><TextInput name="name" required /></Field>
						<Field label="Launch mode" name="launchMode"><Select name="launchMode" options={[{ label: 'Self-host', value: 'self_hosted' }, { label: 'Managed Market host', value: 'managed_market_host' }, { label: 'Connected host', value: 'connected_host' }]} /></Field>
					</div>
					<section class="ts-inline-host-card" data-connected-host-card hidden>
						<div class="ts-inline-host-card__header">
							<strong>Connected capacity provider host</strong>
							<span>{hostPurposeFor('capacity-provider')}</span>
						</div>
						<Field label="Railway host" name="capacityProviderHostChoice">
							<Select name="capacityProviderHostChoice" options={[]} />
						</Field>
						<div class="ts-inline-host-fields" data-inline-host="capacity-provider" hidden>
							<div class="ts-form-grid">
								<Field label="Host display name" name="capacityHostNewName" required help="A friendly name shown in TreeSeed when people choose this capacity host."><TextInput name="capacityHostNewName" required disabled data-inline-control placeholder="Railway capacity connection" /></Field>
								<Field label="Connected account" name="capacityHostNewAccountLabel" help="Optional label for the Railway account or workspace behind this host."><TextInput name="capacityHostNewAccountLabel" disabled data-inline-control placeholder="Capacity Railway workspace" /></Field>
								<Field label="Railway API token" name="capacityHostNewRailwayToken" required><TextInput name="capacityHostNewRailwayToken" type="password" required disabled data-inline-control autocomplete="new-password" /></Field>
								<Field label="Railway workspace" name="capacityHostNewRailwayWorkspace"><TextInput name="capacityHostNewRailwayWorkspace" disabled data-inline-control /></Field>
							</div>
							<HostCredentialPermissionNote hostType="capacity-provider" />
						</div>
						<div class="ts-form-note" id="capacity-host-sensitive-notice" hidden>
							<strong>Sensitive data unlock required.</strong>
							<span>Connected deployments need an unlocked Railway host credential session.</span>
						</div>
					</section>
					<RadioGroup
						name="budgetMode"
						legend="Budget mode"
						value="derived"
						options={[
							{ label: 'Derived from native capacity', value: 'derived', help: 'Recommended. Enter minutes, USD, tokens, concurrency, reset windows, and buffers.' },
							{ label: 'Hybrid compatibility', value: 'hybrid', help: 'Use native facts with existing static credit governance when legacy grants already exist.' },
							{ label: 'Static compatibility', value: 'static', help: 'Legacy mode. No native execution provider is created from this setup form.' },
						]}
					/>
					<div class="ts-form-grid" id="native-capacity-fields">
						<Field label="Execution provider name" name="executionProviderName" required><TextInput name="executionProviderName" required value="Primary native capacity" /></Field>
						<Field label="Provider kind" name="providerKind" required>
							<Select name="providerKind" required options={[
								{ label: 'Codex subscription', value: 'codex_subscription' },
								{ label: 'OpenRouter', value: 'openrouter' },
								{ label: 'Custom native provider', value: 'custom' },
							]} />
						</Field>
						<Field label="Native unit" name="nativeUnit" required>
							<Select name="nativeUnit" required options={[
								{ label: 'Wall minutes', value: 'wall_minute' },
								{ label: 'Quota minutes', value: 'quota_minute' },
								{ label: 'USD', value: 'usd' },
								{ label: 'Tokens', value: 'token' },
							]} />
						</Field>
						<Field label="Native limit" name="limitAmount" required help="Enter the amount the provider can supply in the selected reset window."><TextInput name="limitAmount" type="number" min="0" step="0.01" required inputmode="decimal" /></Field>
						<Field label="Reset window" name="limitScope"><Select name="limitScope" options={[{ label: 'Daily', value: 'daily' }, { label: 'Weekly', value: 'weekly' }, { label: 'Monthly', value: 'monthly' }, { label: 'Work window', value: 'work_window' }]} /></Field>
						<Field label="Reset cadence" name="resetCadence"><Select name="resetCadence" options={[{ label: 'Daily', value: 'daily' }, { label: 'Weekly', value: 'weekly' }, { label: 'Monthly', value: 'monthly' }, { label: 'Manual', value: 'manual' }]} /></Field>
						<Field label="Quota visibility" name="quotaVisibility"><Select name="quotaVisibility" options={[{ label: 'Opaque', value: 'opaque' }, { label: 'Remaining visible', value: 'remaining_visible' }, { label: 'Exact usage visible', value: 'exact_usage' }]} /></Field>
						<Field label="Reserve buffer percent" name="reserveBufferPercent" help="Keep this much native capacity out of scheduling."><TextInput name="reserveBufferPercent" type="number" min="0" max="100" step="1" value="20" inputmode="decimal" /></Field>
						<Field label="Concurrent workers" name="maxConcurrentWorkers" help="Use seats, runners, or safe parallel jobs."><TextInput name="maxConcurrentWorkers" type="number" min="1" step="1" value="1" inputmode="numeric" /></Field>
					</div>
					<details class="ts-stack-sm">
						<summary>Advanced static compatibility</summary>
						<p class="ts-subtle">Legacy TreeSeed credit inventory is not part of native setup. Existing static or hybrid grants can still cap derived capacity after the provider is created.</p>
					</details>
					<FormActions align="start"><Button type="submit">Create provider</Button><Button href="/app/capacity/providers" variant="secondary">Cancel</Button><span class="ts-subtle" id="provider-status" role="status"></span></FormActions>
				</form>
			</Panel>
			<Panel eyebrow="One-time reveal" title="Launch credentials" description="The provider API key is shown once. Store it through trsd config and restart the provider with the new value." >
				<FormActions align="start">
					<button class="ts-button-secondary" type="button" id="copy-provider-key" hidden>Copy key</button>
					<span class="ts-subtle" id="copy-status" role="status"></span>
				</FormActions>
				<pre id="provider-key" class="ts-code-block" hidden></pre>
			</Panel>
			<Panel eyebrow="Self-host" title="Instructions" description="Use these redacted values with trsd config. Do not write plaintext provider keys into env files.">
				<pre id="provider-instructions" class="ts-code-block" hidden></pre>
			</Panel>
		</section>
	) : (
		<EmptyState title="No active team" description="Create or switch to a team before adding capacity." actions={[{ label: 'Open Team', href: '/app/teams' }]} />
	)}
	<script is:inline type="application/json" id="provider-create-data" set:html={pageJson}></script>
</TreeseedAppLayout>

<script>
	import { encryptHostConfig } from '../../../../lib/host-crypto.ts';
	const dataElement = document.getElementById('provider-create-data');
	const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : { teamId: '', capacityProviderHosts: [] };
	const form = document.getElementById('provider-form') as HTMLFormElement | null;
	const status = document.getElementById('provider-status');
	const keyDisplay = document.getElementById('provider-key');
	const instructions = document.getElementById('provider-instructions');
	const copyButton = document.getElementById('copy-provider-key') as HTMLButtonElement | null;
	const copyStatus = document.getElementById('copy-status');
	const nativeFields = document.getElementById('native-capacity-fields');
	const connectedHostCard = document.querySelector('[data-connected-host-card]') as HTMLElement | null;
	const connectedHostFields = document.querySelector('[data-inline-host="capacity-provider"]') as HTMLElement | null;
	const capacityHostSelect = form?.querySelector('[name="capacityProviderHostChoice"]') as HTMLSelectElement | null;
	const capacityHostSensitiveNotice = document.getElementById('capacity-host-sensitive-notice');
	let revealedKey = '';
	function value(data: FormData, key: string) {
		return String(data.get(key) ?? '').trim();
	}
	function hostLabel(host: any) {
		const account = host.accountLabel || host.metadata?.workspace || host.provider || 'team-owned';
		return `${host.name || 'Railway capacity provider host'} (${account})`;
	}
	function selectedLaunchMode() {
		if (!form) return 'self_hosted';
		return String(new FormData(form).get('launchMode') ?? 'self_hosted');
	}
	function selectedCapacityHostMode() {
		return String(capacityHostSelect?.value ?? '').split(':')[0] || '';
	}
	function selectedCapacityHostId() {
		return String(capacityHostSelect?.value ?? '').split(':').slice(1).join(':');
	}
	function refreshCapacityHostChoices() {
		if (!capacityHostSelect) return;
		capacityHostSelect.replaceChildren();
		for (const host of pageData.capacityProviderHosts ?? []) {
			capacityHostSelect.append(new Option(hostLabel(host), `team_owned:${host.id}`));
		}
		capacityHostSelect.append(new Option('Create new Railway capacity provider host...', 'new:capacity-provider'));
	}
	function selectedBudgetMode() {
		if (!form) return 'derived';
		return String(new FormData(form).get('budgetMode') ?? 'derived');
	}
	function syncNativeFields() {
		const staticMode = selectedBudgetMode() === 'static';
		if (nativeFields) nativeFields.hidden = staticMode;
		for (const control of nativeFields?.querySelectorAll<HTMLInputElement | HTMLSelectElement>('input, select') ?? []) {
			control.disabled = staticMode;
		}
	}
	function syncConnectedHostFields() {
		const connected = selectedLaunchMode() === 'connected_host';
		if (connectedHostCard) connectedHostCard.hidden = !connected;
		if (capacityHostSelect) capacityHostSelect.disabled = !connected;
		const creatingHost = connected && selectedCapacityHostMode() === 'new';
		if (connectedHostFields) connectedHostFields.hidden = !creatingHost;
		for (const control of connectedHostFields?.querySelectorAll<HTMLInputElement>('[data-inline-control]') ?? []) {
			control.disabled = !creatingHost;
		}
		if (capacityHostSensitiveNotice) capacityHostSensitiveNotice.hidden = !connected;
	}
	form?.addEventListener('change', () => {
		syncNativeFields();
		syncConnectedHostFields();
	});
	refreshCapacityHostChoices();
	syncNativeFields();
	syncConnectedHostFields();
	copyButton?.addEventListener('click', async () => {
		if (!revealedKey) return;
		try {
			await navigator.clipboard.writeText(revealedKey);
			if (copyStatus) copyStatus.textContent = 'Copied.';
		} catch {
			if (copyStatus) copyStatus.textContent = 'Copy failed. Select the key text manually.';
		}
	});
	async function submitJson(url: string, method: string, body: any) {
		const response = await fetch(url, { method, headers: { 'content-type': 'application/json' }, body: JSON.stringify(body) });
		const payload = await response.json().catch(() => null);
		if (!response.ok || payload?.ok === false) throw new Error(payload?.error ?? 'Request failed.');
		return payload.payload ?? payload;
	}
	async function createCapacityProviderHost(data: FormData, passphrase: string) {
		const encryptedPayload = await encryptHostConfig({
			RAILWAY_API_TOKEN: value(data, 'capacityHostNewRailwayToken'),
			TREESEED_RAILWAY_WORKSPACE: value(data, 'capacityHostNewRailwayWorkspace'),
		}, passphrase);
		return submitJson(`/v1/teams/${encodeURIComponent(pageData.teamId)}/hosts`, 'POST', {
			name: value(data, 'capacityHostNewName') || 'Railway capacity provider host',
			accountLabel: value(data, 'capacityHostNewAccountLabel'),
			provider: 'railway',
			ownership: 'team_owned',
			status: 'active',
			metadata: { hostType: 'capacity_provider', createdFrom: 'capacity_provider_setup_ui' },
			encryptedPayload,
		});
	}
	async function createCredentialSession(hostId: string, passphrase: string) {
		const session = await submitJson(`/v1/teams/${encodeURIComponent(pageData.teamId)}/provider-credential-sessions`, 'POST', {
			hostKind: 'capacity_provider_host',
			hostId,
			passphrase,
			purpose: 'deploy_capacity_provider',
			expiresInSeconds: 900,
		});
		return session.id;
	}
	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		if (!form) return;
		const data = new FormData(form);
		if (status) status.textContent = 'Creating...';
		try {
			const launchMode = selectedLaunchMode();
			const connected = launchMode === 'connected_host';
			let connectedHostId = selectedCapacityHostMode() === 'team_owned' ? selectedCapacityHostId() : '';
			let capacityProviderHostSession = '';
			if (connected) {
				const unlock = (window as any).treeseedSensitiveUnlock;
				const passphrase = (await unlock?.requestPassphrase?.()) ?? unlock?.requirePassphrase?.();
				if (!passphrase) throw new Error('Unlock sensitive data before deploying with a connected capacity provider host.');
				if (selectedCapacityHostMode() === 'new') {
					const host = await createCapacityProviderHost(data, String(passphrase));
					connectedHostId = host.id;
				}
				if (!connectedHostId) throw new Error('Choose or create a Railway capacity provider host.');
				capacityProviderHostSession = await createCredentialSession(connectedHostId, String(passphrase));
			}
			const payload = await submitJson(`/v1/teams/${encodeURIComponent(pageData.teamId)}/capacity-providers`, 'POST', {
				name: value(data, 'name'),
				launchMode,
				creditBudgetMode: String(data.get('budgetMode') ?? 'derived'),
			});
			const providerId = String(payload?.provider?.id ?? '');
			const budgetMode = String(data.get('budgetMode') ?? 'derived');
			if (providerId && budgetMode !== 'static') {
				const nativeLimitAmount = Number(data.get('limitAmount') ?? 0);
				await submitJson(`/v1/teams/${encodeURIComponent(pageData.teamId)}/capacity-providers/${encodeURIComponent(providerId)}/execution-providers`, 'POST', {
					name: value(data, 'executionProviderName') || 'Primary native capacity',
					kind: String(data.get('providerKind') ?? 'codex_subscription'),
					nativeUnit: String(data.get('nativeUnit') ?? 'wall_minute'),
					quotaVisibility: String(data.get('quotaVisibility') ?? 'opaque'),
					maxConcurrentWorkers: Number(data.get('maxConcurrentWorkers') ?? 1) || 1,
					resetCadence: String(data.get('resetCadence') ?? 'daily'),
					nativeLimits: [{
						scope: String(data.get('limitScope') ?? 'daily'),
						nativeUnit: String(data.get('nativeUnit') ?? 'wall_minute'),
						limitAmount: Number.isFinite(nativeLimitAmount) ? nativeLimitAmount : 0,
						reserveBufferPercent: Number(data.get('reserveBufferPercent') ?? 0) || 0,
						confidence: 'estimated',
						source: 'configured',
						metadata: { setupMode: budgetMode },
					}],
					metadata: { setupMode: budgetMode, configuredFrom: 'provider_setup_ui' },
				});
			}
			revealedKey = String(payload?.apiKey?.plaintext ?? '');
			if (keyDisplay) {
				keyDisplay.hidden = false;
				keyDisplay.textContent = `TREESEED_CAPACITY_PROVIDER_API_KEY=${revealedKey}`;
			}
			if (copyButton) copyButton.hidden = false;
			if (connected && providerId) {
				if (status) status.textContent = 'Provider created. Deploying connected Railway services...';
				const deployment = await submitJson(`/v1/teams/${encodeURIComponent(pageData.teamId)}/capacity-providers/${encodeURIComponent(providerId)}/deployments`, 'POST', {
					launchMode: 'connected_host',
					hostId: connectedHostId,
					credentialSessions: { capacityProviderHost: capacityProviderHostSession },
				});
				if (status) status.textContent = `Provider created and connected deployment ${deployment.deployment?.status ?? 'started'}. Store the revealed provider key for emergency rotation only.`;
				if (instructions) {
					instructions.hidden = false;
					instructions.textContent = JSON.stringify(deployment.deployment ?? deployment, null, 2);
				}
				return;
			}
			if (status) status.textContent = budgetMode === 'static'
				? 'Provider created in static compatibility mode. Store the revealed key and restart or launch the provider with it.'
				: 'Provider and native capacity created. Store the revealed key and restart or launch the provider with it.';
			if (instructions) {
				const redactedEnv = payload?.selfHosting?.redactedEnv ?? payload?.selfHosting?.env ?? {};
				const envLines = Object.entries(redactedEnv).map(([key, value]) => `${key}=${value}`);
				instructions.hidden = false;
				instructions.textContent = [
					...envLines,
					'',
					...(payload?.selfHosting?.commands ?? []),
				].join('\n').trim();
			}
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'Provider could not be created.';
		}
	});
</script>
