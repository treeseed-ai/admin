---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../../lib/market/control-ui.js';
import { createApiFacade } from '../../../../lib/market/api-client';
import { loadAppContext } from '../../../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/capacity/providers')}`);
const context = await loadAppContext(Astro);
const team = context.activeTeam;
const api = createApiFacade(Astro);
const providers = team ? await api.listTeamCapacityProviders(team.id).catch(() => []) : [];
const nativeCapacityEntries = team
	? await Promise.all(providers.map(async (provider: any) => [
			provider.id,
			await api.listExecutionProviders(team.id, provider.id).catch(() => []),
		]))
	: [];
const nativeCapacityByProvider = new Map(nativeCapacityEntries as Array<[string, any[]]>);
const grantEntries = team
	? await Promise.all(providers.map(async (provider: any) => [
			provider.id,
			await api.listCapacityGrants(team.id, { providerId: provider.id }).catch(() => []),
		]))
	: [];
const grantsByProvider = new Map(grantEntries as Array<[string, any[]]>);

function summarizeCapabilities(provider: any) {
	const runtimes = Array.isArray(provider.capabilities?.runtimes) ? provider.capabilities.runtimes : [];
	const handlers = Array.isArray(provider.capabilities?.handlers) ? provider.capabilities.handlers : [];
	const labels = [...runtimes, ...handlers]
		.map((entry) => typeof entry === 'string' ? entry : entry?.name ?? entry?.id ?? '')
		.filter(Boolean);
	return labels.length > 0 ? labels.slice(0, 3).join(', ') + (labels.length > 3 ? ` +${labels.length - 3}` : '') : 'not reported';
}

function summarizeCompatibilityBudget(provider: any) {
	const budgets = provider.budgets ?? {};
	const daily = budgets.dailyCreditBudget ?? budgets.dailyTaskCreditBudget ?? provider.dailyCreditBudget ?? 0;
	const monthly = budgets.monthlyCreditBudget ?? provider.monthlyCreditBudget ?? 0;
	const mode = provider.creditBudgetMode ?? 'derived';
	if (mode === 'derived' && !daily && !monthly) return 'native-derived, no static credits';
	return mode === 'static'
		? `legacy static compatibility: ${daily} daily / ${monthly} monthly`
		: `${mode} compatibility: ${daily} daily / ${monthly} monthly`;
}

function summarizeNativeCapacity(executionProviders: any[]) {
	if (!executionProviders.length) return 'not reported';
	const labels = executionProviders.slice(0, 2).map((entry) => {
		const limit = Array.isArray(entry.nativeLimits) ? entry.nativeLimits[0] : null;
		const amount = limit?.limitAmount ?? 'unbounded';
		const unit = limit?.nativeUnit ?? entry.nativeUnit ?? 'native units';
		const scope = limit?.scope ? `/${limit.scope}` : '';
		const buffer = limit?.reserveBufferPercent != null ? `, ${limit.reserveBufferPercent}% buffer` : '';
		const workers = entry.maxConcurrentWorkers != null ? `, ${entry.maxConcurrentWorkers} worker${entry.maxConcurrentWorkers === 1 ? '' : 's'}` : '';
		const visibility = entry.quotaVisibility ? `, ${entry.quotaVisibility}` : '';
		return `${entry.kind ?? 'provider'}: ${amount} ${unit}${scope}${buffer}${workers}${visibility}`;
	});
	return labels.join(' | ') + (executionProviders.length > 2 ? ` +${executionProviders.length - 2}` : '');
}

function summarizeDerivedCapacity(provider: any) {
	const entries = Array.isArray(provider.derivedCapacity?.entries) ? provider.derivedCapacity.entries : [];
	const first = entries.find((entry: any) => entry?.nativeUnit) ?? null;
	if (!first) return (provider.creditBudgetMode ?? 'derived') === 'derived' ? 'learning native conversion' : 'not derived';
	const credits = first.derivedAvailableCredits == null ? 'learning' : `${first.derivedAvailableCredits} credits`;
	const native = `${first.availableNativeAmount ?? 0} ${first.nativeUnit}`;
	const confidence = first.confidence ? `, ${first.confidence}` : '';
	const warning = first.derivedAvailableCredits == null || first.confidence === 'low' ? ', learning' : '';
	return `${credits} from ${native}${confidence}${warning}`;
}

function summarizePortfolioAllocation(grants: any[]) {
	const active = grants.filter((grant: any) => grant.state === 'active');
	if (active.length === 0) return 'no active allocation';
	const labels = active.slice(0, 2).map((grant: any) => {
		const scope = grant.projectId ? `project ${grant.projectId}` : grant.grantScope ?? 'team';
		const percent = grant.portfolioAllocationPercent == null ? 'unbounded' : `${grant.portfolioAllocationPercent}%`;
		const reserve = grant.reservePoolPercent == null ? '' : `, ${grant.reservePoolPercent}% reserve`;
		const daily = grant.maxDailyProjectCredits == null ? '' : `, max ${grant.maxDailyProjectCredits}/day`;
		return `${scope}: ${percent}${reserve}${daily}`;
	});
	return labels.join(' | ') + (active.length > 2 ? ` +${active.length - 2}` : '');
}

function summarizeDeployment(provider: any) {
	const deployment = provider.deployment ?? (Array.isArray(provider.deployments) ? provider.deployments[0] : null);
	return deployment?.status ?? deployment?.state ?? provider.launchMode ?? 'not started';
}

function summarizeProviderWork(provider: any) {
	const report = provider.metadata?.latestProviderReport;
	const workday = provider.metadata?.latestProviderWorkday;
	return report?.status ?? report?.summary ?? workday?.workDayId ?? 'not reported';
}

const rows = providers.map((provider: any) => ({
	id: `provider-${esc(provider.id)}`,
	name: `<strong>${esc(provider.name)}</strong><span>${esc(provider.launchMode ?? 'self_hosted')}</span>`,
	health: esc(`${provider.connectionState ?? provider.metadata?.connectionState ?? 'waiting_for_provider'} · heartbeat ${provider.lastSeenAt ?? provider.metadata?.lastSeenAt ?? 'never'}`),
	hosting: esc(`${summarizeDeployment(provider)} · ${provider.launchMode ?? provider.metadata?.launchMode ?? 'self_hosted'}`),
	capacity: esc(`${summarizeNativeCapacity(nativeCapacityByProvider.get(provider.id) ?? [])} · ${summarizeDerivedCapacity(provider)}`),
	allocation: esc(summarizePortfolioAllocation(grantsByProvider.get(provider.id) ?? [])),
	operations: esc(`key ${provider.activeKeyPrefix ?? provider.metadata?.apiKey?.activeKeyPrefix ?? 'none'} · ${summarizeCapabilities(provider)} · ${summarizeProviderWork(provider)}`),
	compatibility: esc(summarizeCompatibilityBudget(provider)),
	actions: `<a class="ts-link-button" href="/app/capacity/providers/${encodeURIComponent(provider.id)}/edit">Open</a> <a class="ts-link-button" href="/app/capacity/providers/${encodeURIComponent(provider.id)}/keys">Rotate key</a>`,
}));
---

<TreeseedAppLayout title="Capacity providers" description="Manage provider lifecycle and runtime state." currentPath="/app/capacity/providers" teams={context.teams} activeTeam={team}>
	<section class="ts-control-page" aria-label="Capacity providers">
		<Panel eyebrow="Capacity" title="Providers" description={team ? 'Create providers from native limits, then review derived availability and portfolio allocation.' : 'Create a team before adding capacity.'}>
			<FormActions slot="actions" align="end">
				<Button href="/app/capacity/runtime" variant="secondary" size="sm">Runtime</Button>
				<Button href="/app/capacity/workday-runs" variant="secondary" size="sm">Workday runs</Button>
				<Button href="/app/capacity/providers/new" size="sm">New provider</Button>
			</FormActions>
			{team ? (
				<PlainTable columns={[
					{ key: 'name', label: 'Provider' },
					{ key: 'health', label: 'Connection' },
					{ key: 'hosting', label: 'Host and deployment' },
					{ key: 'capacity', label: 'Capacity' },
					{ key: 'allocation', label: 'Portfolio allocation' },
					{ key: 'operations', label: 'Operations' },
					{ key: 'compatibility', label: 'Compatibility credits' },
					{ key: 'actions', label: 'Actions' },
				]} rows={rows} emptyTitle="No providers yet" emptyDescription="Create a provider to make capacity available." />
			) : (
				<EmptyState title="No team selected" description="Create or switch to a team first." actions={[{ label: 'Open Team', href: '/app/teams' }]} />
			)}
		</Panel>
	</section>
</TreeseedAppLayout>
