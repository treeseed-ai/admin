---
import CollectionTemplate from '@treeseed/ui/components/astro/templates/CollectionTemplate.astro';
import ReadinessSummary from '@treeseed/ui/components/astro/service/ReadinessSummary.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext } from '../../../../view-models/app-access.js';
import { buildProviderCollection, buildServicesDashboard, loadServiceInventory } from '../../../../view-models/service-readiness.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/capacity/providers')}`);

const context = await loadAppContext(Astro);
const runtime = (Astro.locals as any).runtime ?? Astro.locals;
const inventory = await loadServiceInventory(context, runtime);
const services = buildServicesDashboard(context, inventory, Astro.url);
const collection = buildProviderCollection(inventory);
const actions = [
	{ id: 'capacity.provider.create', label: 'New provider', state: context.activeTeam ? 'allowed' : 'requiresSetup', href: '/app/capacity/providers/new', reason: context.activeTeam ? undefined : 'Create or select a team first.' },
	{ id: 'capacity.runtime', label: 'Runtime diagnostics', state: 'allowed', href: '/app/capacity/runtime' },
	{ id: 'services.open', label: 'Services', state: 'allowed', href: '/app/services' },
] as const;
---

<TreeseedAppLayout
	title="Capacity providers"
	description="Capacity provider readiness, credentials, native limits, and diagnostics."
	currentPath="/app/capacity/providers"
	teams={context.teams}
	activeTeam={context.activeTeam}
	helpContext={services.helpContext}
	feedbackContext={services.feedbackContext}
>
	{context.activeTeam ? (
		<CollectionTemplate viewModel={collection} actions={actions}>
			<ReadinessSummary viewModel={services.readiness} />
		</CollectionTemplate>
	) : (
		<EmptyState title="No team selected" description="Create or switch to a team before adding capacity providers." actions={[{ label: 'Open teams', href: '/app/teams' }]} />
	)}
</TreeseedAppLayout>
