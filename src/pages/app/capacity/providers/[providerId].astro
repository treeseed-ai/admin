---
import DetailTemplate from '@treeseed/ui/components/astro/templates/DetailTemplate.astro';
import ReadinessSummary from '@treeseed/ui/components/astro/service/ReadinessSummary.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { createApiFacade } from '../../../../lib/market/api-client';
import { loadAppContext, persistActiveTeamSelection, resolveAppCapacityProvider } from '../../../../view-models/app-access.js';
import { providerMetadata } from '../../../../view-models/service-readiness.vm.js';

const providerId = String(Astro.params.providerId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);

const context = await loadAppContext(Astro);
const api = createApiFacade(Astro);
const providerResolution = await resolveAppCapacityProvider(context, providerId);
const team = providerResolution.team ?? context.activeTeam;
const provider = providerResolution.resource;
if (providerResolution.team?.id && providerResolution.team.id !== context.activeTeam?.id) persistActiveTeamSelection(Astro, providerResolution.team);
if (!provider) Astro.response.status = providerResolution.status === 'forbidden' ? 403 : 404;
const executionProviders = provider && team ? await api.listExecutionProviders(team.id, provider.id).catch(() => []) : [];
const grants = provider && team ? await api.listCapacityGrants(team.id, { providerId: provider.id }).catch(() => []) : [];
const title = provider?.name ?? 'Capacity provider';
const connection = provider?.connectionState ?? provider?.metadata?.connectionState ?? provider?.status ?? 'waiting_for_provider';
const readiness = {
	title: 'Provider readiness',
	description: 'Connection, native capacity, allocation, and credential state.',
	items: [
		{ id: 'connection', label: 'Connection', status: connection === 'active' || connection === 'connected' ? 'ready' : 'warning', message: `Connection is ${String(connection).replaceAll('_', ' ')}.` },
		{ id: 'native-capacity', label: 'Native capacity', status: executionProviders.length > 0 ? 'ready' : 'warning', message: `${executionProviders.length} native provider records reported.`, href: `/app/capacity/providers/${encodeURIComponent(providerId)}/settings` },
		{ id: 'allocation', label: 'Allocation', status: grants.length > 0 ? 'ready' : 'warning', message: `${grants.length} allocation grants configured.`, href: `/app/capacity/providers/${encodeURIComponent(providerId)}/settings` },
		{ id: 'keys', label: 'Credential rotation', status: provider?.activeKeyPrefix ? 'ready' : 'warning', message: 'Rotate provider keys from the sensitive credentials route.', href: `/app/capacity/providers/${encodeURIComponent(providerId)}/keys`, advanced: true },
	],
} as const;
const actions = [
	{ id: 'provider.settings', label: 'Settings', state: 'allowed', href: `/app/capacity/providers/${encodeURIComponent(providerId)}/settings` },
	{ id: 'provider.keys', label: 'Rotate key', state: 'allowed', href: `/app/capacity/providers/${encodeURIComponent(providerId)}/keys` },
	{ id: 'services.open', label: 'Services', state: 'allowed', href: '/app/services' },
] as const;
---

<TreeseedAppLayout title={provider ? title : 'Provider not found'} description="Capacity provider readiness and service details." currentPath="/app/capacity/providers" teams={context.teams} activeTeam={team}>
	{provider ? (
		<DetailTemplate title={title} description="Capacity provider readiness, native capacity, and credentials." eyebrow="Capacity provider" actions={actions} metadata={providerMetadata(provider, executionProviders, grants)}>
			<ReadinessSummary viewModel={readiness} showAdvanced />
			<Panel title="Advanced diagnostics" description="Runtime diagnostics are available without turning this detail page into a scheduler.">
				<p><a class="ts-link-button" href="/app/capacity/runtime">Open runtime diagnostics</a></p>
			</Panel>
		</DetailTemplate>
	) : (
		<EmptyState title="Provider not found" description="This capacity provider is not available." actions={[{ label: 'Back to providers', href: '/app/capacity/providers' }]} />
	)}
</TreeseedAppLayout>
