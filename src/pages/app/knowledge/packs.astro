---
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../lib/market/control-ui.js';
import { loadKnowledgeViewModel } from '../../../view-models/knowledge.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/knowledge/packs')}`);
const vm = await loadKnowledgeViewModel(Astro);
const rows = [...(vm.imports ?? []), ...(vm.artifacts ?? [])]
	.filter((item: any) => String(`${item.type} ${item.category} ${item.kind}`).toLowerCase().includes('pack'))
	.map((item: any) => ({ name: `<strong>${esc(item.title ?? item.name)}</strong><span>${esc(item.description ?? item.summary ?? '')}</span>`, state: esc(item.state ?? item.status ?? 'available'), action: item.href ? `<a class="ts-link-button" href="${esc(item.href)}">Open</a>` : '' }));
---

<TreeseedAppLayout title="Knowledge packs" description="Review packaged knowledge packs." currentPath="/app/knowledge/artifacts" teams={vm.context.teams} activeTeam={vm.context.activeTeam}>
	<section class="ts-control-page" aria-label="Knowledge packs">
		<Panel eyebrow="Knowledge" title="Knowledge packs" description="Knowledge packs created or imported for this team.">
			{rows.length > 0 ? <PlainTable columns={[{ key: 'name', label: 'Knowledge pack' }, { key: 'state', label: 'State' }, { key: 'action', label: 'Action' }]} rows={rows} /> : <EmptyState title="No knowledge packs yet" description="Package a knowledge pack from a project artifact page." />}
		</Panel>
	</section>
</TreeseedAppLayout>
