---
import Badge from '@treeseed/ui/components/astro/data/Badge.astro';
import KeyValueList from '@treeseed/ui/components/astro/data/KeyValueList.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadKnowledgeArtifactViewModel } from '../../../../view-models/knowledge.vm.js';

const slug = String(Astro.params.slug ?? '');
if (!Astro.locals.auth?.principal) {
	return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
}

const vm = await loadKnowledgeArtifactViewModel(Astro, slug);
if (!vm.artifact) {
	Astro.response.status = 404;
}

const artifact = vm.artifact;
const artifactProjectId = artifact ? (artifact.projectId ?? '') : '';
const esc = (value: unknown) => String(value ?? '')
	.replaceAll('&', '&amp;')
	.replaceAll('<', '&lt;')
	.replaceAll('>', '&gt;')
	.replaceAll('"', '&quot;');
const relatedRows = artifact ? [
	...artifact.relationships.workdays.map((workday: any) => ({
		id: `work-${esc(workday.workDayId ?? workday.id)}`,
		name: `<strong>${esc(workday.summary?.objective ?? workday.summary?.title ?? workday.workDayId ?? workday.id)}</strong><span>${esc(workday.state ?? 'Project work')}</span>`,
		type: 'Project work',
		action: artifactProjectId ? `<a class="ts-link-button" href="/app/projects/${encodeURIComponent(artifactProjectId)}#development">Open project</a>` : '',
	})),
	...artifact.relationships.approvals.map((approval: any) => ({
		id: `approval-${esc(approval.id)}`,
		name: `<strong>${esc(approval.title ?? 'Decision')}</strong><span>${esc(approval.summary ?? approval.kind ?? '')}</span>`,
		type: 'Decision',
		action: approval.id ? `<a class="ts-link-button" href="/app/work/decisions/${encodeURIComponent(approval.id)}">Review</a>` : '',
	})),
	...artifact.relationships.releases.map((release: any) => ({
		id: `release-${esc(release.id ?? release.releaseTag)}`,
		name: `<strong>${esc(release.releaseTag ?? release.tag ?? release.id ?? 'Release')}</strong><span>${esc(release.status ?? release.environment ?? '')}</span>`,
		type: 'Release',
		action: '',
	})),
	...artifact.relationships.relatedDecisions.map((decision: any) => ({
		id: `decision-${esc(decision.id ?? decision.title)}`,
		name: `<strong>${esc(decision.title)}</strong><span>${esc(decision.description ?? '')}</span>`,
		type: 'Decision',
		action: decision.href ? `<a class="ts-link-button" href="${esc(String(decision.href).replace(`/app/${'governance'}`, '/app/work/decisions').replace(`/app/${'decisions'}`, '/app/work/decisions'))}">Open</a>` : '',
	})),
	...artifact.relationships.relatedReports.map((report: any) => ({
		id: `report-${esc(report.id ?? report.title)}`,
		name: `<strong>${esc(report.title)}</strong><span>${esc(report.description ?? '')}</span>`,
		type: 'Report',
		action: report.href ? `<a class="ts-link-button" href="${esc(report.href)}">Open</a>` : '',
	})),
] : [];
const repositoryRows = artifact ? artifact.relationships.repositories.map((repository: any, index: number) => ({
	id: `repository-${esc(repository.id ?? index)}`,
	name: `<strong>${esc(repository.name ?? repository.label ?? repository.repository ?? 'Repository')}</strong><span>${esc(repository.description ?? repository.href ?? '')}</span>`,
	state: esc(repository.state ?? repository.status ?? 'referenced'),
})) : [];
---

<TreeseedAppLayout
	title={artifact?.title ?? 'Artifact not found'}
	description="Review the artifact, its project, and related decisions."
	currentPath="/app/knowledge/artifacts"
	teams={vm.context.teams}
	activeTeam={vm.context.activeTeam}
>
	{artifact ? (
		<section class="ts-control-page" aria-label="Knowledge artifact">
			<Panel eyebrow={artifact.category} title={artifact.title} description={artifact.description}>
				<Badge slot="actions" tone={artifact.tone ?? 'default'}>{artifact.state}</Badge>
				<KeyValueList items={[
					{ key: 'Type', value: artifact.type },
					{ key: 'Produced During', value: artifact.metadata.producedDuring ?? 'not linked' },
					{ key: 'Generated By', value: artifact.metadata.generatedBy ?? 'project work' },
					{ key: 'Approved By', value: artifact.metadata.approvedBy ?? 'not recorded' },
					{ key: 'Approval Status', value: artifact.metadata.approvalStatus ?? 'not attached' },
					{ key: 'Project', value: artifact.metadata.projectName ?? 'not linked' },
					{ key: 'Created', value: artifact.metadata.createdAt ?? 'not recorded' },
				]} />
			</Panel>
			<Panel eyebrow="Knowledge" title="Relationships">
				<PlainTable columns={[
					{ key: 'name', label: 'Related item' },
					{ key: 'type', label: 'Type' },
					{ key: 'action', label: 'Action' },
				]} rows={relatedRows} emptyTitle="No related records" emptyDescription="Related project work, decisions, reports, and releases appear here when available." />
			</Panel>
			<Panel eyebrow="Knowledge" title="Repositories">
				<PlainTable columns={[
					{ key: 'name', label: 'Repository' },
					{ key: 'state', label: 'State' },
				]} rows={repositoryRows} emptyTitle="No repositories linked" emptyDescription="Repository references appear when the artifact is connected to project work." />
			</Panel>
		</section>
	) : (
		<EmptyState title="Artifact not found" description="This artifact is not available to the active team." actions={[{ label: 'Back to Artifacts', href: '/app/knowledge/artifacts' }]} />
	)}
</TreeseedAppLayout>
