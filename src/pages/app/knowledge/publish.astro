---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import DistributionSummary from '@treeseed/ui/components/astro/distribution/DistributionSummary.astro';
import SettingsTemplate from '@treeseed/ui/components/astro/templates/SettingsTemplate.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { loadKnowledgePublishSettings } from '../../../view-models/knowledge-distribution.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/knowledge/publish')}`);
const vm = await loadKnowledgePublishSettings(Astro);
---

<TreeseedAppLayout title={vm.title} description={vm.description} currentPath="/app/knowledge" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	<SettingsTemplate title={vm.title} description={vm.description} actions={vm.actions} sections={[{ label: 'Publish', href: '/app/knowledge/publish', current: true }, { label: 'Releases', href: '/app/knowledge/releases' }, { label: 'Imports', href: '/app/knowledge/imports' }]}>
		<DistributionSummary viewModel={vm.distribution} />
		{vm.projects.length > 0 ? (
			<form id="publish-form" class="ts-form-stack">
				<Field label="Project" name="projectId" required><Select name="projectId" required options={vm.projects.map((project) => ({ label: project.label, value: project.id }))} /></Field>
				<Field label="Action" name="action" required><Select name="action" required options={[
					{ label: 'Export bundle', value: 'share/export' },
					{ label: 'Package workflow import', value: 'share/package-template' },
					{ label: 'Package knowledge import', value: 'share/package-knowledge-pack' },
					{ label: 'Publish release', value: 'share/publish' },
				]} /></Field>
				<FormActions align="start"><Button type="submit">Submit action</Button><Button href="/app/knowledge" variant="secondary">Cancel</Button><span class="ts-subtle" id="publish-status" role="status"></span></FormActions>
			</form>
		) : (
			<EmptyState title="No projects" description="Create a project before publishing artifacts." actions={[{ label: 'New project', href: '/app/projects/new' }]} />
		)}
	</SettingsTemplate>
</TreeseedAppLayout>

<script>
	import { submitKnowledgeDistributionAction } from '../../../lib/knowledge-distribution/publish-client.ts';
	const form = document.getElementById('publish-form') as HTMLFormElement | null;
	const status = document.getElementById('publish-status');
	form?.addEventListener('submit', (event) => {
		event.preventDefault();
		void submitKnowledgeDistributionAction(form, status);
	});
</script>
