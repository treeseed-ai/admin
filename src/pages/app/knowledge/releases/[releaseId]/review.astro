---
import SettingsTemplate from '@treeseed/ui/components/astro/templates/SettingsTemplate.astro';
import DistributionSummary from '@treeseed/ui/components/astro/distribution/DistributionSummary.astro';
import OverlayStatus from '@treeseed/ui/components/astro/distribution/OverlayStatus.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../../layouts/TreeseedAppLayout.astro';
import { loadKnowledgeDistributionDetail } from '../../../../../view-models/knowledge-distribution.vm.js';

const releaseId = String(Astro.params.releaseId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadKnowledgeDistributionDetail(Astro, 'releases', releaseId);
if (!vm.found) Astro.response.status = 404;
---

<TreeseedAppLayout title={`Review ${vm.title}`} description={vm.description} currentPath="/app/knowledge" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.found ? (
		<SettingsTemplate title={`Review ${vm.title}`} description="Resolve release review state before public or entitlement-gated delivery." actions={vm.actions} sections={[{ label: 'Release', href: `/app/knowledge/releases/${releaseId}` }, { label: 'Review', href: Astro.url.pathname, current: true }]}>
			<DistributionSummary viewModel={vm.distribution} />
			<OverlayStatus viewModel={vm.overlayStatus} />
		</SettingsTemplate>
	) : (
		<EmptyState title="Release not found" description="This release cannot be reviewed by the active team." actions={[{ label: 'Back to releases', href: '/app/knowledge/releases' }]} />
	)}
</TreeseedAppLayout>
