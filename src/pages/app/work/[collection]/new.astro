---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import MarkdownField from '@treeseed/ui/components/astro/app/controls/MarkdownField.astro';
import WorkContentNav from '@treeseed/ui/components/astro/app/controls/WorkContentNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext } from '../../../../view-models/app-access.js';

const collection = String(Astro.params.collection ?? '');
const config: Record<string, any> = {
	objectives: { singular: 'objective', current: 'objectives', typeLabel: 'Horizon', typeName: 'timeHorizon', options: [{ label: 'Near-term', value: 'near-term' }, { label: 'Mid-term', value: 'mid-term' }, { label: 'Long-term', value: 'long-term' }] },
	questions: { singular: 'question', current: 'questions', typeLabel: 'Question type', typeName: 'questionType', options: [{ label: 'Strategy', value: 'strategy' }, { label: 'Implementation', value: 'implementation' }, { label: 'Research', value: 'research' }, { label: 'Evaluation', value: 'evaluation' }] },
	notes: { singular: 'note', current: 'notes' },
	proposals: { singular: 'proposal', current: 'proposals', typeLabel: 'Proposal type', typeName: 'proposalType', options: [{ label: 'Implementation', value: 'implementation' }, { label: 'Strategy', value: 'strategy' }, { label: 'Policy', value: 'policy' }, { label: 'Research', value: 'research' }] },
	decisions: { singular: 'decision', current: 'decisions', typeLabel: 'Decision type', typeName: 'decisionType', options: [{ label: 'Approved', value: 'approved' }, { label: 'Rejected', value: 'rejected' }, { label: 'Deferred', value: 'deferred' }, { label: 'Request changes', value: 'request_changes' }, { label: 'Superseded', value: 'superseded' }] },
};
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
const item = config[collection] ?? null;
if (!item) Astro.response.status = 404;
const selectedProjectId = String(Astro.url.searchParams.get('projectId') ?? context.projects[0]?.id ?? '');
const title = item ? `New ${item.singular}` : 'Unsupported content type';
const data = JSON.stringify({ collection, selectedProjectId }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={title} description="Create a local TreeSeed content record." currentPath={`/app/work/${collection}`} teams={context.teams} activeTeam={context.activeTeam}>
	{item ? (
		<section class="ts-control-page" aria-label={title}>
			<WorkContentNav current={item.current} />
			<Panel eyebrow="Work content" title={title} description="This writes a canonical local content file under src/content.">
				<form id="content-create-form" class="ts-form-stack">
					<div class="ts-form-grid">
						<Field label="Project" name="projectId" required>
							<Select name="projectId" required value={selectedProjectId} options={context.projects.map((project: any) => ({ label: project.name ?? project.slug, value: project.id }))} />
						</Field>
						<Field label="Title" name="title" required><TextInput name="title" required /></Field>
						<Field label="Slug" name="slug"><TextInput name="slug" placeholder="Generated from title if empty" /></Field>
						<Field label="Status" name="status"><Select name="status" options={[{ label: 'Planned', value: 'planned' }, { label: 'Live', value: 'live' }, { label: 'In progress', value: 'in progress' }, { label: 'Exploratory', value: 'exploratory' }, { label: 'Speculative', value: 'speculative' }]} /></Field>
						{item.options ? (
							<Field label={item.typeLabel} name={item.typeName}><Select name={item.typeName} options={item.options} /></Field>
						) : null}
						{collection === 'decisions' ? (
							<Field label="Authority" name="authority"><TextInput name="authority" value="TreeSeed Market Team" /></Field>
						) : null}
					</div>
					<MarkdownField label="Description" name="description" rows={3} required />
					<MarkdownField label="Summary" name="summary" rows={3} />
					<MarkdownField label={collection === 'decisions' ? 'Rationale' : 'Motivation'} name={collection === 'decisions' ? 'rationale' : 'motivation'} rows={4} />
					{collection === 'decisions' ? (
						<Field label="Related proposals" name="relatedProposals"><Textarea name="relatedProposals" rows={3} placeholder="One proposal id per line or comma separated" /></Field>
					) : null}
					{collection === 'proposals' ? (
						<div class="ts-form-grid">
							<Field label="Related objectives" name="relatedObjectives"><Textarea name="relatedObjectives" rows={3} /></Field>
							<Field label="Related questions" name="relatedQuestions"><Textarea name="relatedQuestions" rows={3} /></Field>
							<Field label="Related notes" name="relatedNotes"><Textarea name="relatedNotes" rows={3} /></Field>
						</div>
					) : null}
					<MarkdownField label="Body" name="body" rows={8} />
					<FormActions align="start"><Button type="submit">Create {item.singular}</Button><Button href={`/app/work/${collection}`} variant="secondary">Cancel</Button><span class="ts-subtle" id="content-create-status" role="status"></span></FormActions>
				</form>
			</Panel>
		</section>
	) : (
		<EmptyState title="Unsupported content type" description="Choose objectives, questions, notes, proposals, or decisions." actions={[{ label: 'Back to Work', href: '/app/work/objectives' }]} />
	)}
	<script is:inline type="application/json" id="content-create-data" set:html={data}></script>
</TreeseedAppLayout>

<script>
	import '@treeseed/ui/lib/app/markdown-field';
	import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

	const dataElement = document.getElementById('content-create-data');
	const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : {};
	const form = document.getElementById('content-create-form') as HTMLFormElement | null;
	const status = document.getElementById('content-create-status');
	function value(formData: FormData, key: string) { return String(formData.get(key) ?? '').trim(); }
	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const formData = new FormData(form);
		const projectId = value(formData, 'projectId') || pageData.selectedProjectId;
		const body: any = Object.fromEntries(formData.entries());
		try {
			await submitPlatformOperationForm({
				url: `/v1/projects/${encodeURIComponent(projectId)}/local-content/${encodeURIComponent(pageData.collection)}`,
				body,
				statusElement: status,
				fallbackHref: `/app/work/${pageData.collection}`,
				initialMessage: 'Queuing content operation...',
			});
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'Content could not be created.';
		}
	});
</script>
