---
import { getCollection } from 'astro:content';
import Badge from '@treeseed/ui/components/astro/data/Badge.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import Textarea from '@treeseed/ui/components/astro/forms/Textarea.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import ContentFieldHelp from '@treeseed/ui/components/astro/app/controls/ContentFieldHelp.astro';
import MarkdownField from '@treeseed/ui/components/astro/app/controls/MarkdownField.astro';
import WorkContentNav from '@treeseed/ui/components/astro/app/controls/WorkContentNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { allowedRelatedCollections, contentRelationPolicy, WORK_CONTENT_LABELS } from '../../../../lib/market/content-relations.js';
import { contentFieldHelp } from '../../../../lib/market/content-form-help.js';
import { loadAppContext } from '../../../../view-models/app-access.js';
import { loadWorkContentEntries } from '../../../../view-models/work-content.js';

const collection = String(Astro.params.collection ?? '');
const slug = String(Astro.params.slug ?? '');
const validCollections = new Set(['objectives', 'questions', 'notes', 'proposals', 'decisions']);
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const context = await loadAppContext(Astro);
let entry: any = null;
if (validCollections.has(collection)) {
	const entries = await getCollection(collection as any, ({ data }: any) => !data?.draft).catch(() => []);
	entry = entries.find((candidate: any) => {
		const id = String(candidate.id ?? '').replace(/\.(mdx|md)$/u, '');
		const dataId = String(candidate.data?.id ?? '');
		return id === slug || dataId === slug || dataId.replace(/^[^:]+:/u, '') === slug;
	}) ?? null;
}
if (!entry) Astro.response.status = 404;
const data = entry?.data ?? {};
const title = data.title ?? 'Content not found';
const entrySlug = String(entry?.id ?? slug).replace(/\.(mdx|md)$/u, '');
const selectedProjectId = String(Astro.url.searchParams.get('projectId') ?? context.projects[0]?.id ?? '');
const contentLabels = WORK_CONTENT_LABELS as Record<string, { singular: string; plural: string; title: string }>;
const typeLabel = contentLabels[collection]?.title ?? 'Content';
const typeSingular = contentLabels[collection]?.singular ?? 'content';
const workEntries = await loadWorkContentEntries();
const entryLookup = new Map(workEntries.map((item) => [`${item.collection}:${item.id.replace(/\.(mdx|md)$/u, '')}`, item]));
const principalPermissions = new Set((Astro.locals.auth?.principal?.permissions ?? []) as string[]);
const canManageProject = ['*', '*:*:*', 'projects:*:team', 'projects:manage:team'].some((permission) => principalPermissions.has(permission));
const relatedActions = canManageProject
	? allowedRelatedCollections(collection).map((targetCollection) => ({
		collection: targetCollection,
		label: `Create related ${contentLabels[targetCollection]?.singular ?? 'record'}`,
	}))
	: [];
const relationCollections: Record<string, string> = {
	relatedObjectives: 'objectives',
	relatedQuestions: 'questions',
	relatedNotes: 'notes',
	relatedProposals: 'proposals',
	decision: 'decisions',
};
const relationFieldLabels: Record<string, string> = {
	relatedObjectives: 'Related objectives',
	relatedQuestions: 'Related questions',
	relatedNotes: 'Related notes',
	relatedProposals: 'Related proposals',
	decision: 'Decision',
};
const supportedRelationFields = Array.from(new Set([
	...allowedRelatedCollections(collection)
		.map((targetCollection) => contentRelationPolicy(collection, targetCollection)?.sourceField)
		.filter(Boolean),
	...Object.keys(relationCollections).filter((field) => relationValues(data[field]).length > 0),
]));
function plainValue(value: unknown, fallback = ''): string {
	if (typeof value === 'string' && value.trim()) return value.trim();
	if (typeof value === 'number' || typeof value === 'boolean') return String(value);
	if (value && typeof value === 'object') {
		const record = value as Record<string, unknown>;
		for (const key of ['name', 'title', 'label', 'displayName', 'slug', 'id']) {
			const candidate = record[key];
			if (typeof candidate === 'string' && candidate.trim()) return candidate.trim();
		}
	}
	return fallback;
}
function relationValues(value: unknown): string[] {
	if (Array.isArray(value)) return value.map((item) => plainValue(item)).filter(Boolean);
	const single = plainValue(value);
	return single ? [single] : [];
}
function joinedValue(value: unknown): string {
	return relationValues(value).join('\n');
}
function help(name: string) {
	return contentFieldHelp(name) ?? { label: name, purpose: '' };
}
function resolvedRelation(field: string, value: string) {
	const targetCollection = relationCollections[field] ?? '';
	const clean = value.replace(/^[^:]+:/u, '').replace(/\.(mdx|md)$/u, '');
	const found = entryLookup.get(`${targetCollection}:${clean}`);
	return {
		collection: targetCollection,
		slug: clean,
		title: found?.title ?? clean.replace(/[-_]+/gu, ' '),
		href: found?.href ?? `/app/work/${targetCollection}/${encodeURIComponent(clean)}`,
	};
}
const contributor = collection === 'notes' ? plainValue(data.author, 'not recorded') : plainValue(data.primaryContributor ?? data.author, 'not recorded');
const metadata = [
	{ key: 'Date', value: data.date instanceof Date ? data.date.toISOString().slice(0, 10) : String(data.date ?? ''), help: help('date') },
	{ key: 'Content id', value: String(data.id ?? entry?.id ?? ''), help: help('contentId') },
	{ key: 'Source slug', value: entrySlug, help: help('sourceSlug') },
].filter((item) => item.value);
const statusOptions = [
	{ label: 'Planned', value: 'planned' },
	{ label: 'Live', value: 'live' },
	{ label: 'In progress', value: 'in progress' },
	{ label: 'Exploratory', value: 'exploratory' },
	{ label: 'Speculative', value: 'speculative' },
];
const typeOptions: Record<string, Array<{ label: string; value: string }>> = {
	objectives: [{ label: 'Near-term', value: 'near-term' }, { label: 'Mid-term', value: 'mid-term' }, { label: 'Long-term', value: 'long-term' }],
	questions: [{ label: 'Strategy', value: 'strategy' }, { label: 'Implementation', value: 'implementation' }, { label: 'Research', value: 'research' }, { label: 'Evaluation', value: 'evaluation' }],
	proposals: [{ label: 'Implementation', value: 'implementation' }, { label: 'Strategy', value: 'strategy' }, { label: 'Policy', value: 'policy' }, { label: 'Research', value: 'research' }],
	decisions: [{ label: 'Approved', value: 'approved' }, { label: 'Rejected', value: 'rejected' }, { label: 'Deferred', value: 'deferred' }, { label: 'Request changes', value: 'request_changes' }, { label: 'Superseded', value: 'superseded' }],
};
const typeField: Record<string, { name: string; label: string }> = {
	objectives: { name: 'timeHorizon', label: 'Horizon' },
	questions: { name: 'questionType', label: 'Question type' },
	proposals: { name: 'proposalType', label: 'Proposal type' },
	decisions: { name: 'decisionType', label: 'Decision type' },
};
const editData = JSON.stringify({ collection, projectId: selectedProjectId }).replace(/</gu, '\\u003c');
---

<TreeseedAppLayout title={title} description={data.description ?? ''} currentPath={`/app/work/${collection}`} teams={context.teams} activeTeam={context.activeTeam}>
	{entry ? (
		<section class="ts-control-page" aria-label={`${typeLabel} content`}>
			<WorkContentNav current={collection as any} />
			<Panel eyebrow={typeLabel} title={`Edit ${title}`} description="Edit the canonical local content file. Relation panels below keep the graph readable while still allowing raw reference edits.">
				<Badge slot="actions" tone={String(data.status ?? '') === 'live' ? 'success' : 'warning'}>{data.status ?? 'recorded'}</Badge>
				<form id="content-edit-form" class="ts-form-stack">
					<input type="hidden" name="slug" value={entrySlug} />
					<input type="hidden" name="id" value={data.id ?? `${typeSingular}:${entrySlug}`} />
					<input type="hidden" name="overwrite" value="true" />
					<div class="ts-form-grid">
						<Field label="Project" name="projectId" required>
							<div class="ts-help-row">
								<Select name="projectId" required value={selectedProjectId} options={context.projects.map((project: any) => ({ label: project.name ?? project.slug, value: project.id }))} />
								<ContentFieldHelp {...help('projectId')} />
							</div>
						</Field>
						<Field label="Title" name="title" required>
							<div class="ts-help-row">
								<TextInput name="title" required value={data.title ?? ''} />
								<ContentFieldHelp {...help('title')} />
							</div>
						</Field>
						<Field label="Status" name="status">
							<div class="ts-help-row">
								<Select name="status" value={data.status ?? 'recorded'} options={[{ label: 'Recorded', value: 'recorded' }, { label: 'Planned', value: 'planned' }, { label: 'Live', value: 'live' }, { label: 'In progress', value: 'in progress' }, { label: 'Exploratory', value: 'exploratory' }, { label: 'Speculative', value: 'speculative' }]} />
								<ContentFieldHelp {...help('status')} />
							</div>
						</Field>
						{collection === 'objectives' ? <Field label="Horizon" name="timeHorizon"><div class="ts-help-row"><Select name="timeHorizon" value={data.timeHorizon ?? 'near-term'} options={[{ label: 'Near-term', value: 'near-term' }, { label: 'Mid-term', value: 'mid-term' }, { label: 'Long-term', value: 'long-term' }]} /><ContentFieldHelp {...help('timeHorizon')} /></div></Field> : null}
						{collection === 'questions' ? <Field label="Question type" name="questionType"><div class="ts-help-row"><Select name="questionType" value={data.questionType ?? 'strategy'} options={[{ label: 'Strategy', value: 'strategy' }, { label: 'Implementation', value: 'implementation' }, { label: 'Research', value: 'research' }, { label: 'Evaluation', value: 'evaluation' }]} /><ContentFieldHelp {...help('questionType')} /></div></Field> : null}
						{collection === 'proposals' ? <Field label="Proposal type" name="proposalType"><div class="ts-help-row"><Select name="proposalType" value={data.proposalType ?? 'implementation'} options={[{ label: 'Implementation', value: 'implementation' }, { label: 'Strategy', value: 'strategy' }, { label: 'Policy', value: 'policy' }, { label: 'Research', value: 'research' }]} /><ContentFieldHelp {...help('proposalType')} /></div></Field> : null}
						{collection === 'decisions' ? <Field label="Decision type" name="decisionType"><div class="ts-help-row"><Select name="decisionType" value={data.decisionType ?? 'approved'} options={typeOptions.decisions} /><ContentFieldHelp {...help('decisionType')} /></div></Field> : null}
						{collection === 'decisions' ? <Field label="Authority" name="authority"><div class="ts-help-row"><TextInput name="authority" value={plainValue(data.authority, 'TreeSeed Market Team')} /><ContentFieldHelp {...help('authority')} /></div></Field> : null}
					</div>
					<MarkdownField label="Description" name="description" rows={3} required value={data.description ?? ''} help={help('description').purpose} />
					<MarkdownField label="Summary" name="summary" rows={3} value={data.summary ?? ''} help={help('summary').purpose} />
					<Field label={collection === 'notes' ? 'Author' : 'Contributor'} name={collection === 'notes' ? 'author' : 'primaryContributor'}>
						<div class="ts-help-row">
							<TextInput name={collection === 'notes' ? 'author' : 'primaryContributor'} value={contributor === 'not recorded' ? '' : contributor} />
							<ContentFieldHelp {...help(collection === 'notes' ? 'author' : 'primaryContributor')} />
						</div>
					</Field>
					{collection === 'decisions' ? (
						<MarkdownField label="Rationale" name="rationale" rows={4} value={data.rationale ?? ''} help={help('rationale').purpose} />
					) : collection !== 'notes' ? (
						<MarkdownField label="Motivation" name="motivation" rows={4} value={data.motivation ?? ''} help={help('motivation').purpose} />
					) : null}
					<MarkdownField label="Body" name="body" rows={12} value={entry.body ?? ''} help={help('body').purpose} />
					{supportedRelationFields.length > 0 ? (
						<section class="ts-relation-grid" aria-label="Content relations">
							{supportedRelationFields.map((field) => {
								const values = relationValues(data[field]);
								const targetCollection = relationCollections[field] ?? '';
								const targetLabel = contentLabels[targetCollection]?.plural ?? 'records';
								return (
									<div class="ts-relation-panel">
										<div class="ts-relation-panel__header">
											<div>
												<h3>{relationFieldLabels[field] ?? field}</h3>
												<p>{help(field).purpose}</p>
											</div>
											<ContentFieldHelp {...help(field)} />
										</div>
										{values.length > 0 ? (
											<ul class="ts-relation-list">
												{values.map((value) => {
													const relation = resolvedRelation(field, value);
													return (
														<li>
															<span>{contentLabels[relation.collection]?.title ?? 'Record'}</span>
															<a href={relation.href}>{relation.title}</a>
														</li>
													);
												})}
											</ul>
										) : (
											<p class="ts-empty-inline">No {targetLabel} linked yet.</p>
										)}
										<details class="ts-advanced-references">
											<summary>Advanced edit raw references</summary>
											<Field label={`${relationFieldLabels[field] ?? field} slugs`} name={field}>
												<Textarea name={field} rows={3} value={joinedValue(data[field])} />
											</Field>
										</details>
									</div>
								);
							})}
						</section>
					) : null}
					{relatedActions.length > 0 ? (
						<section class="ts-related-create" aria-label="Create related content" data-related-create>
							<div class="ts-related-create__header">
								<div>
									<p class="ts-section__eyebrow">Related content</p>
									<h2>Create while viewing this record</h2>
									<p>Add linked content without leaving <strong>{title}</strong>. TreeSeed saves the relation on both records.</p>
								</div>
								<div class="ts-related-create__actions">
									{relatedActions.map((action) => (
										<Button type="button" variant="secondary" size="sm" class="ts-related-create__button" ariaLabel={action.label}>
											<span data-related-create-open={action.collection}>{action.label}</span>
										</Button>
									))}
								</div>
							</div>
							<script is:inline type="application/json" id="related-content-data" set:html={JSON.stringify({ projectId: selectedProjectId, parentCollection: collection, parentSlug: entrySlug }).replace(/</gu, '\\u003c')}></script>
						</section>
					) : null}
					<FormActions align="start"><Button type="submit">Save {typeSingular}</Button><span class="ts-subtle" id="content-edit-status" role="status"></span></FormActions>
				</form>
				{relatedActions.length > 0 ? (
					<div class="ts-related-float" data-related-float hidden>
						<div class="ts-related-float__window" data-related-window style="left: 22rem; top: 7rem; width: min(44rem, calc(100vw - 3rem)); height: min(42rem, calc(100vh - 4rem));">
							<header class="ts-related-float__bar" data-related-drag-handle>
								<div>
									<p class="ts-section__eyebrow">Create related content</p>
									<h2 data-related-title>New related content</h2>
								</div>
								<button class="ts-icon-button" type="button" data-related-close aria-label="Cancel related content creation">Cancel</button>
							</header>
							<div class="ts-related-float__body">
								{relatedActions.map((action) => {
									const label = contentLabels[action.collection]?.singular ?? 'record';
									const type = typeField[action.collection];
									return (
										<form class="ts-form-stack ts-related-form" data-related-form={action.collection} hidden>
											<input type="hidden" name="targetCollection" value={action.collection} />
											<input type="hidden" name="parentCollection" value={collection} />
											<input type="hidden" name="parentSlug" value={entrySlug} />
											<div class="ts-form-grid">
												<Field label="Title" name={`related-${action.collection}-title`} required>
													<div class="ts-help-row">
														<TextInput name="title" required />
														<ContentFieldHelp {...help('title')} />
													</div>
												</Field>
												<Field label="Slug" name={`related-${action.collection}-slug`}>
													<div class="ts-help-row">
														<TextInput name="slug" placeholder="Generated from title if empty" />
														<ContentFieldHelp {...help('slug')} />
													</div>
												</Field>
												<Field label="Status" name={`related-${action.collection}-status`}>
													<div class="ts-help-row">
														<Select name="status" options={statusOptions} />
														<ContentFieldHelp {...help('status')} />
													</div>
												</Field>
												{type ? (
													<Field label={type.label} name={`related-${action.collection}-${type.name}`}>
														<div class="ts-help-row">
															<Select name={type.name} options={typeOptions[action.collection] ?? []} />
															<ContentFieldHelp {...help(type.name)} />
														</div>
													</Field>
												) : null}
											</div>
											<MarkdownField label="Description" name="description" rows={3} required help={help('description').purpose} />
											<MarkdownField label="Summary" name="summary" rows={3} help={help('summary').purpose} />
											{action.collection === 'decisions' ? (
												<MarkdownField label="Rationale" name="rationale" rows={4} help={help('rationale').purpose} />
											) : action.collection !== 'notes' ? (
												<MarkdownField label="Motivation" name="motivation" rows={4} help={help('motivation').purpose} />
											) : (
												<Field label="Author" name={`related-${action.collection}-author`}>
													<div class="ts-help-row">
														<TextInput name="author" value="market-steward" />
														<ContentFieldHelp {...help('author')} />
													</div>
												</Field>
											)}
											<MarkdownField label="Body" name="body" rows={8} help={help('body').purpose} />
											<FormActions align="start">
												<Button type="submit">Create related {label}</Button>
												<Button type="button" variant="secondary" class="ts-related-cancel">Cancel</Button>
												<span class="ts-subtle" data-related-status role="status"></span>
											</FormActions>
										</form>
									);
								})}
							</div>
						</div>
					</div>
				) : null}
			</Panel>
			<Panel eyebrow="System" title="Content metadata" description="Generated fields that identify the source record.">
				<dl class="ts-metadata-list">
					{metadata.map((item) => (
						<div class="ts-metadata-list__row">
							<dt>{item.key}</dt>
							<dd>{item.value}</dd>
							<ContentFieldHelp {...item.help} />
						</div>
					))}
				</dl>
			</Panel>
			<script is:inline type="application/json" id="content-edit-data" set:html={editData}></script>
		</section>
	) : (
		<EmptyState title="Content not found" description="This content record is not available." actions={[{ label: 'Back to Work', href: `/app/work/${collection}` }]} />
	)}
</TreeseedAppLayout>

<style>
	.ts-help-row {
		align-items: center;
		display: grid;
		gap: 0.45rem;
		grid-template-columns: minmax(0, 1fr) auto;
	}

	.ts-related-create {
		background: var(--ts-color-surface);
		border: 1px solid var(--ts-color-border);
		border-radius: var(--ts-radius-lg);
		display: grid;
		gap: var(--ts-space-2);
		padding: var(--ts-space-3);
	}

	.ts-related-create__header {
		align-items: flex-start;
		display: flex;
		gap: var(--ts-space-3);
		justify-content: space-between;
	}

	.ts-related-create h2,
	.ts-related-create p {
		margin: 0;
	}

	.ts-related-create__actions {
		display: flex;
		flex-wrap: wrap;
		gap: var(--ts-space-2);
		justify-content: flex-end;
	}

	.ts-related-create__button span {
		pointer-events: none;
	}

	.ts-related-float {
		inset: 0;
		pointer-events: none;
		position: fixed;
		z-index: 80;
	}

	.ts-related-float__window {
		background: var(--ts-color-surface-overlay, var(--ts-color-surface));
		border: 1px solid var(--ts-color-border);
		border-radius: var(--ts-radius-lg);
		box-shadow: var(--ts-shadow-lg, 0 24px 60px rgb(15 23 42 / 20%));
		display: grid;
		grid-template-rows: auto minmax(0, 1fr);
		min-height: 24rem;
		min-width: min(26rem, calc(100vw - 2rem));
		overflow: hidden;
		pointer-events: auto;
		position: fixed;
		resize: both;
	}

	.ts-related-float__bar {
		align-items: center;
		background: color-mix(in srgb, var(--ts-color-canvas-subtle) 72%, var(--ts-color-surface));
		border-bottom: 1px solid var(--ts-color-border);
		cursor: move;
		display: flex;
		gap: var(--ts-space-3);
		justify-content: space-between;
		padding: var(--ts-space-2) var(--ts-space-3);
	}

	.ts-related-float__bar h2 {
		font-size: 1rem;
		margin: 0;
	}

	.ts-related-float__body {
		overflow: auto;
		padding: var(--ts-space-3);
	}

	.ts-relation-grid {
		display: grid;
		gap: var(--ts-space-3);
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 22rem), 1fr));
	}

	.ts-relation-panel {
		background: color-mix(in srgb, var(--ts-color-surface, #fff) 94%, var(--ts-color-border, #d8dee4));
		border: 1px solid var(--ts-color-border, #d8dee4);
		border-radius: 10px;
		display: grid;
		gap: 0.8rem;
		padding: var(--ts-space-3);
	}

	.ts-relation-panel__header {
		align-items: flex-start;
		display: grid;
		gap: 0.6rem;
		grid-template-columns: minmax(0, 1fr) auto;
	}

	.ts-relation-panel h3,
	.ts-relation-panel p {
		margin: 0;
	}

	.ts-relation-panel h3 {
		font-size: 0.98rem;
	}

	.ts-relation-list {
		display: grid;
		gap: 0.5rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}

	.ts-relation-list li {
		align-items: center;
		background: var(--ts-color-surface, #fff);
		border: 1px solid color-mix(in srgb, var(--ts-color-border, #d8dee4) 82%, transparent);
		border-radius: 8px;
		display: flex;
		gap: 0.65rem;
		justify-content: space-between;
		padding: 0.55rem 0.65rem;
	}

	.ts-relation-list span {
		color: var(--ts-color-text-muted, #57606a);
		font-size: 0.75rem;
		font-weight: 750;
		text-transform: uppercase;
	}

	.ts-relation-list a {
		font-weight: 700;
		text-align: right;
	}

	.ts-advanced-references {
		border-top: 1px solid color-mix(in srgb, var(--ts-color-border, #d8dee4) 70%, transparent);
		padding-top: 0.7rem;
	}

	.ts-advanced-references summary {
		color: var(--ts-color-text-muted, #57606a);
		cursor: pointer;
		font-size: 0.84rem;
		font-weight: 700;
	}

	.ts-metadata-list {
		display: grid;
		gap: 0;
		margin: 0;
	}

	.ts-metadata-list__row {
		align-items: center;
		border-bottom: 1px solid var(--ts-color-border, #d8dee4);
		display: grid;
		gap: 0.75rem;
		grid-template-columns: minmax(8rem, 0.45fr) minmax(0, 1fr) auto;
		padding: 0.75rem 0;
	}

	.ts-metadata-list__row:last-child {
		border-bottom: 0;
	}

	.ts-metadata-list dt {
		color: var(--ts-color-text-muted, #57606a);
		font-weight: 750;
	}

	.ts-metadata-list dd {
		margin: 0;
		min-width: 0;
		overflow-wrap: anywhere;
	}

	@media (max-width: 44rem) {
		.ts-related-create__header {
			display: grid;
		}

		.ts-related-float__window {
			inset: 1rem !important;
			width: auto !important;
		}
	}
</style>

<script>
	import '@treeseed/ui/lib/app/markdown-field';
	import '@treeseed/ui/lib/app/related-content-creator';
	import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

	const dataElement = document.getElementById('content-edit-data');
	const pageData = dataElement?.textContent ? JSON.parse(dataElement.textContent) : {};
	const form = document.getElementById('content-edit-form') as HTMLFormElement | null;
	const status = document.getElementById('content-edit-status');
	function formValue(formData: FormData, key: string) { return String(formData.get(key) ?? '').trim(); }
	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const formData = new FormData(form);
		const projectId = formValue(formData, 'projectId') || pageData.projectId;
		const body: any = Object.fromEntries(formData.entries());
		body.overwrite = true;
		try {
			await submitPlatformOperationForm({
				url: `/v1/projects/${encodeURIComponent(projectId)}/local-content/${encodeURIComponent(pageData.collection)}`,
				body,
				statusElement: status,
				fallbackHref: `${window.location.pathname}?saved=${Date.now()}`,
				initialMessage: 'Queuing save operation...',
			});
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'Content could not be saved.';
		}
	});
</script>
