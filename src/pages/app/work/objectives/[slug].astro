---
import DetailTemplate from '@treeseed/ui/components/astro/templates/DetailTemplate.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadDirectionDetail } from '../../../../view-models/operating-loop.vm.js';

const slug = String(Astro.params.slug ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadDirectionDetail(Astro, 'objectives', slug, Astro.url);
if (!vm.entry) Astro.response.status = 404;
const data = vm.entry?.data ?? {};
---

<TreeseedAppLayout title={data.title ?? 'Objective not found'} description={data.description ?? ''} currentPath="/app/work/objectives" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.entry ? (
		<DetailTemplate title={data.title} description={data.description ?? data.summary} eyebrow="Objective" actions={vm.actions} metadata={vm.metadata}>
			{data.summary ? <p>{data.summary}</p> : null}
			{vm.form?.body ? <pre class="ts-preformatted-content">{vm.form.body}</pre> : null}
		</DetailTemplate>
	) : (
		<EmptyState title="Objective not found" description="The requested objective is not available." actions={[{ label: 'Back to objectives', href: '/app/work/objectives' }]} />
	)}
</TreeseedAppLayout>
