---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Field from '@treeseed/ui/components/astro/forms/Field.astro';
import FormActions from '@treeseed/ui/components/astro/forms/FormActions.astro';
import Select from '@treeseed/ui/components/astro/forms/Select.astro';
import TextInput from '@treeseed/ui/components/astro/forms/TextInput.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import MarkdownField from '@treeseed/ui/components/astro/app/controls/MarkdownField.astro';
import WorkContentNav from '@treeseed/ui/components/astro/app/controls/WorkContentNav.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext } from '../../../../view-models/app-access.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/work/objectives/new')}`);
const context = await loadAppContext(Astro);
const selectedProjectId = String(Astro.url.searchParams.get('projectId') ?? context.projects[0]?.id ?? '');
---

<TreeseedAppLayout title="New objective" description="Create one local project objective." currentPath="/app/work/objectives" teams={context.teams} activeTeam={context.activeTeam}>
	{context.projects.length > 0 ? (
		<section class="ts-control-page" aria-label="New objective">
			<WorkContentNav current="objectives" />
			<Panel eyebrow="Work content" title="Create objective" description="This writes a canonical local objective under src/content/objectives.">
				<form id="objective-form" class="ts-form-stack">
					<div class="ts-form-grid">
						<Field label="Project" name="projectId" required><Select name="projectId" required value={selectedProjectId} options={context.projects.map((project: any) => ({ label: project.name ?? project.slug, value: project.id }))} /></Field>
						<Field label="Title" name="title" required><TextInput name="title" required /></Field>
						<Field label="Slug" name="slug"><TextInput name="slug" placeholder="Generated from title if empty" /></Field>
						<Field label="Horizon" name="timeHorizon"><Select name="timeHorizon" options={[{ label: 'Near-term', value: 'near-term' }, { label: 'Mid-term', value: 'mid-term' }, { label: 'Long-term', value: 'long-term' }]} /></Field>
					</div>
					<MarkdownField label="Description" name="description" rows={3} required />
					<MarkdownField label="Summary" name="summary" rows={3} />
					<MarkdownField label="Motivation" name="motivation" rows={4} />
					<MarkdownField label="Body" name="body" rows={8} />
					<FormActions align="start"><Button type="submit">Create objective</Button><Button href="/app/work/objectives" variant="secondary">Cancel</Button><span class="ts-subtle" id="objective-status" role="status"></span></FormActions>
				</form>
			</Panel>
		</section>
	) : (
		<EmptyState title="No projects" description="Create a project before creating objectives." actions={[{ label: 'New project', href: '/app/projects/new' }]} />
	)}
</TreeseedAppLayout>

<script>
	import '@treeseed/ui/lib/app/markdown-field';
	import { submitPlatformOperationForm } from '@treeseed/ui/lib/app/platform-operation-status';

	const form = document.getElementById('objective-form') as HTMLFormElement | null;
	const status = document.getElementById('objective-status');
	form?.addEventListener('submit', async (event) => {
		event.preventDefault();
		const formData = new FormData(form);
		const projectId = String(formData.get('projectId') ?? '');
		try {
			await submitPlatformOperationForm({
				url: `/v1/projects/${encodeURIComponent(projectId)}/local-content/objectives`,
				body: Object.fromEntries(formData.entries()),
				statusElement: status,
				fallbackHref: '/app/work/objectives',
				initialMessage: 'Queuing objective operation...',
			});
		} catch (error) {
			if (status) status.textContent = error instanceof Error ? error.message : 'Objective could not be created.';
		}
	});
</script>
