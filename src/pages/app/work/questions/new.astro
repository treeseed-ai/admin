---
import PermissionBoundary from '@treeseed/ui/components/astro/patterns/PermissionBoundary.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import SettingsTemplate from '@treeseed/ui/components/astro/templates/SettingsTemplate.astro';
import WorkContentNav from '@treeseed/ui/components/astro/app/controls/WorkContentNav.astro';
import QuestionForm from '../../../../components/work/QuestionForm.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadAppContext } from '../../../../view-models/app-access.js';
import { buildQuestionFormViewModel } from '../../../../view-models/ui-foundation/questions.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/work/questions/new')}`);
const context = await loadAppContext(Astro);
const pageViewModel = buildQuestionFormViewModel({
	context,
	question: null,
	url: Astro.url,
	mode: 'create',
});
---

<TreeseedAppLayout
	title={pageViewModel.title}
	description={pageViewModel.description}
	currentPath="/app/work/questions"
	teams={context.teams}
	activeTeam={context.activeTeam}
	helpContext={pageViewModel.help}
	feedbackContext={pageViewModel.feedback}
>
	<section class="ts-control-page" aria-label="New question">
		<WorkContentNav current="questions" />
		<PermissionBoundary
			state={pageViewModel.permissions['question.create'] ?? 'requiresSetup'}
			title="Question creation unavailable"
			description="Create or select a team and project before adding questions."
			remediation={pageViewModel.policy.remediation}
		>
			<SettingsTemplate title={pageViewModel.title} description={pageViewModel.description} actions={pageViewModel.actions}>
				<Panel eyebrow="Work content" title="Question fields" description="This writes a canonical local question content file under src/content/questions.">
					<QuestionForm viewModel={pageViewModel} />
				</Panel>
			</SettingsTemplate>
		</PermissionBoundary>
	</section>
</TreeseedAppLayout>
