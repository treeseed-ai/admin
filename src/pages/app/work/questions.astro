---
import DataTable from '@treeseed/ui/components/astro/data/DataTable.astro';
import PermissionBoundary from '@treeseed/ui/components/astro/patterns/PermissionBoundary.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import CollectionTemplate from '@treeseed/ui/components/astro/templates/CollectionTemplate.astro';
import WorkContentNav from '@treeseed/ui/components/astro/app/controls/WorkContentNav.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { loadGovernanceViewModel } from '../../../view-models/governance.vm.js';
import { loadKnowledgeViewModel } from '../../../view-models/knowledge.vm.js';
import { buildQuestionsPageViewModel } from '../../../view-models/ui-foundation/questions.vm.js';
import { loadWorkContentEntries, workContentEntriesFor } from '../../../view-models/work-content.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/work/questions')}`);
const [governance, knowledge, contentEntries] = await Promise.all([
	loadGovernanceViewModel(Astro),
	loadKnowledgeViewModel(Astro).catch(() => null),
	loadWorkContentEntries(),
]);
const questionEntries = workContentEntriesFor(contentEntries, 'questions');
const approvalQuestions = governance.reviewQueue.filter((item: any) => String(item.kind ?? item.title ?? '').toLowerCase().includes('question'));
const artifactQuestions = (knowledge?.artifacts ?? []).filter((artifact: any) => String(`${artifact.category} ${artifact.type} ${artifact.title}`).toLowerCase().includes('question'));
const pageViewModel = buildQuestionsPageViewModel({
	governance,
	knowledge,
	questionEntries,
	approvalQuestions,
	artifactQuestions,
	url: Astro.url,
});
---

<TreeseedAppLayout
	title={pageViewModel.title}
	description={pageViewModel.description}
	currentPath="/app/work/questions"
	teams={governance.context.teams}
	activeTeam={governance.context.activeTeam}
	helpContext={pageViewModel.help}
	feedbackContext={pageViewModel.feedback}
>
	<section class="ts-control-page" aria-label="Questions">
		<WorkContentNav current="questions" />
		<PermissionBoundary
			state={pageViewModel.permissions['question.read'] ?? 'requiresSetup'}
			title="Questions unavailable"
			description="Select or create a team before viewing workspace questions."
			remediation={pageViewModel.policy.remediation}
		>
			<CollectionTemplate viewModel={pageViewModel.collection} actions={pageViewModel.actions} mode="cards">
				<Panel
					eyebrow="Operational work"
					title={pageViewModel.operationalCollection.title}
					description={pageViewModel.operationalCollection.description}
				>
					<DataTable
						columns={pageViewModel.operationalCollection.columns}
						rows={pageViewModel.operationalCollection.rows}
						emptyLabel={pageViewModel.operationalCollection.emptyDescription}
					/>
				</Panel>
			</CollectionTemplate>
		</PermissionBoundary>
	</section>
</TreeseedAppLayout>
