---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import WorkContentNav from '@treeseed/ui/components/astro/app/controls/WorkContentNav.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../view-models/app-access.js';
import { loadWorkContentEntries, workContentEntriesFor, workContentRelationSummary } from '../../../view-models/work-content.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/work/notes')}`);
const [context, contentEntries] = await Promise.all([
	loadAppContext(Astro),
	loadWorkContentEntries(),
]);
const noteEntries = workContentEntriesFor(contentEntries, 'notes');
const rows = noteEntries.map((entry: any) => ({
	id: `note-content-${esc(entry.id)}`,
	name: `<strong>${esc(entry.title)}</strong><span>${esc(entry.summary || entry.description)}</span>`,
	updated: esc(entry.date),
	state: esc(entry.status),
	related: esc(workContentRelationSummary(entry)),
	action: `<a class="ts-link-button" href="${esc(entry.href)}">Open</a>`,
}));
---

<TreeseedAppLayout title="Notes" description="Review working notes in the TreeSeed content workspace." currentPath="/app/work/notes" teams={context.teams} activeTeam={context.activeTeam}>
	<section class="ts-control-page" aria-label="Notes">
		<WorkContentNav current="notes" />
		<Panel eyebrow="Work content" title="Note records" description="Source content notes from the active TreeSeed workspace.">
			<Button slot="actions" href="/app/work/notes/new" size="sm">New note</Button>
			<PlainTable columns={[{ key: 'name', label: 'Note' }, { key: 'updated', label: 'Date' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Related' }, { key: 'action', label: 'Action' }]} rows={rows} emptyTitle="No note content yet" emptyDescription="Note records appear from src/content/notes." />
		</Panel>
	</section>
</TreeseedAppLayout>
