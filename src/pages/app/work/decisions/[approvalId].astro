---
import { getCollection, render } from 'astro:content';
import KeyValueList from '@treeseed/ui/components/astro/data/KeyValueList.astro';
import Badge from '@treeseed/ui/components/astro/data/Badge.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import GovernanceDecisionPanel from '@treeseed/ui/components/astro/app/operations/GovernanceDecisionPanel.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadGovernanceApprovalViewModel } from '../../../../view-models/governance.vm.js';

async function loadProposalContent(approval: any) {
	const candidates = proposalCandidates(approval);
	if (candidates.size === 0) return null;
	const proposals = await getCollection('proposals', (entry: any) => !entry.data?.draft).catch(() => []);
	const entry = proposals.find((proposal: any) => {
		const id = String(proposal?.data?.id ?? proposal?.id ?? '');
		const slug = String(proposal?.slug ?? proposal?.id ?? '');
		return candidates.has(id) || candidates.has(slug) || candidates.has(`proposal:${slug}`) || candidates.has(id.replace(/^proposal:/u, ''));
	});
	if (!entry) return null;
	const rendered = await render(entry);
	return {
		entry,
		Content: rendered.Content,
	};
}

async function loadDecisionContent(slug: string) {
	const decisions = await getCollection('decisions', (entry: any) => !entry.data?.draft).catch(() => []);
	const entry = decisions.find((decision: any) => {
		const id = String(decision?.data?.id ?? decision?.id ?? '');
		const fileId = String(decision?.id ?? '');
		return fileId === slug || id === slug || id.replace(/^decision:/u, '') === slug;
	});
	if (!entry) return null;
	const rendered = await render(entry);
	return { entry, Content: rendered.Content };
}

function proposalCandidates(approval: any) {
	const metadata = approval?.metadata && typeof approval.metadata === 'object' ? approval.metadata : {};
	const recommendation = approval?.recommendation && typeof approval.recommendation === 'object' ? approval.recommendation : {};
	const approvalId = String(approval?.approvalId ?? approval?.id ?? '');
	const fromApprovalId = approvalId.replace(/^approval:/u, '').replace(/^proposal:/u, '');
	return new Set([
		metadata.proposalId,
		metadata.contentId,
		metadata.content_id,
		metadata.contentProposalId,
		recommendation.proposalId,
		recommendation.contentId,
		approvalId,
		approvalId.replace(/^approval:/u, ''),
		fromApprovalId ? `proposal:${fromApprovalId}` : '',
		fromApprovalId,
	].filter((value): value is string => typeof value === 'string' && value.trim().length > 0));
}

const approvalId = String(Astro.params.approvalId ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const vm = await loadGovernanceApprovalViewModel(Astro, approvalId);
const detail = vm.detail;
const decisionContent = detail ? null : await loadDecisionContent(approvalId);
if (!detail && !decisionContent) Astro.response.status = 404;
const proposalContent = detail ? await loadProposalContent(detail.approval) : null;
const ProposalContent = proposalContent?.Content;
const DecisionContent = decisionContent?.Content;
---

<TreeseedAppLayout title={detail?.approval.title ?? decisionContent?.entry.data.title ?? 'Decision not found'} description="Review and decide one request." currentPath="/app/work/decisions" teams={vm.context.teams} activeTeam={vm.context.activeTeam}>
	{detail ? (
		<section class="ts-control-page" aria-label="Decision">
			<Panel eyebrow="Work" title={detail.approval.title} description={detail.approval.description}>
				<Badge slot="actions" tone={detail.approval.tone ?? 'default'}>{detail.approval.state}</Badge>
				<KeyValueList items={[
					{ key: 'Severity', value: detail.approval.severity },
					{ key: 'Kind', value: detail.approval.kind },
					{ key: 'Project', value: detail.approval.projectName ?? 'Team' },
					{ key: 'Requested', value: detail.approval.requestedAt ?? 'not recorded' },
					{ key: 'Expires', value: detail.approval.expiresAt ?? 'not recorded' },
				]} />
			</Panel>
			{ProposalContent ? (
				<Panel eyebrow="Proposal" title={proposalContent.entry.data.title ?? detail.approval.title} description={proposalContent.entry.data.summary ?? proposalContent.entry.data.description ?? ''}>
					<article class="ts-prose">
						<ProposalContent />
					</article>
				</Panel>
			) : null}
			<GovernanceDecisionPanel approval={detail.approval} options={detail.decisionOptions} action={`/v1/ui/governance/${encodeURIComponent(detail.approval.approvalId)}/decision`} />
		</section>
	) : decisionContent ? (
		<section class="ts-control-page" aria-label="Decision content">
			<Panel eyebrow="Decision" title={decisionContent.entry.data.title} description={decisionContent.entry.data.summary ?? decisionContent.entry.data.description ?? ''}>
				<Badge slot="actions" tone={decisionContent.entry.data.status === 'live' ? 'success' : 'warning'}>{decisionContent.entry.data.status}</Badge>
				<KeyValueList items={[
					{ key: 'Type', value: decisionContent.entry.data.decisionType ?? 'decision' },
					{ key: 'Authority', value: decisionContent.entry.data.authority ?? 'not recorded' },
					{ key: 'Date', value: decisionContent.entry.data.date instanceof Date ? decisionContent.entry.data.date.toISOString().slice(0, 10) : String(decisionContent.entry.data.date ?? '') },
					{ key: 'Related proposals', value: Array.isArray(decisionContent.entry.data.relatedProposals) ? decisionContent.entry.data.relatedProposals.join(', ') : 'none' },
				]} />
			</Panel>
			<Panel eyebrow="Content" title="Decision record">
				<article class="ts-prose">{DecisionContent ? <DecisionContent /> : null}</article>
			</Panel>
		</section>
	) : (
		<EmptyState title="Decision not found" description="This decision is not available." actions={[{ label: 'Back to Decisions', href: '/app/work/decisions' }]} />
	)}
</TreeseedAppLayout>
