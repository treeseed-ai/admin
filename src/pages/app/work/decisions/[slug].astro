---
import DetailTemplate from '@treeseed/ui/components/astro/templates/DetailTemplate.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import TreeseedAppLayout from '../../../../layouts/TreeseedAppLayout.astro';
import { loadDirectionDetail } from '../../../../view-models/operating-loop.vm.js';

const slug = String(Astro.params.slug ?? '');
if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent(Astro.url.pathname)}`);
const decisionVm = await loadDirectionDetail(Astro, 'decisions', slug, Astro.url).catch(() => null);
const data = decisionVm?.entry?.data ?? {};
if (!decisionVm?.entry) Astro.response.status = 404;
---

<TreeseedAppLayout title={data.title ?? 'Decision not found'} description={data.description ?? ''} currentPath="/app/work/decisions" teams={decisionVm?.context.teams ?? []} activeTeam={decisionVm?.context.activeTeam} helpContext={decisionVm?.helpContext} feedbackContext={decisionVm?.feedbackContext}>
	{decisionVm?.entry ? (
		<DetailTemplate title={data.title} description={data.description ?? data.summary} eyebrow={data.immutable ? 'Immutable decision' : 'Decision'} actions={data.immutable ? [] : decisionVm.actions} metadata={decisionVm.metadata}>
			{data.summary ? <p>{data.summary}</p> : null}
			{data.immutable ? (
				<section class="ts-detail-section" aria-label="Governance evidence">
					<h2>Governance evidence</h2>
					<dl class="ts-metadata-list">
						{data.sourceProposalGovernanceId ? <><dt>Source proposal</dt><dd>{data.sourceProposalGovernanceId}</dd></> : null}
						{data.sourceProposalVersion ? <><dt>Proposal version</dt><dd>{data.sourceProposalVersion}</dd></> : null}
						{data.sourceProposalHash ? <><dt>Proposal hash</dt><dd>{data.sourceProposalHash}</dd></> : null}
						{data.governanceProviderId ? <><dt>Governance provider</dt><dd>{data.governanceProviderId}</dd></> : null}
					</dl>
				</section>
			) : null}
			{decisionVm.form?.body ? <pre class="ts-preformatted-content">{decisionVm.form.body}</pre> : null}
		</DetailTemplate>
	) : (
		<EmptyState title="Decision not found" description="The requested decision is not available." actions={[{ label: 'Back to decisions', href: '/app/work/decisions' }]} />
	)}
</TreeseedAppLayout>
