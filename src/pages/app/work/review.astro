---
import CollectionTemplate from '@treeseed/ui/components/astro/templates/CollectionTemplate.astro';
import ActivityTimeline from '@treeseed/ui/components/astro/operating/ActivityTimeline.astro';
import WorkQueueSummary from '@treeseed/ui/components/astro/operating/WorkQueueSummary.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { loadReviewQueue } from '../../../view-models/operating-loop.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/work/review')}`);
const vm = await loadReviewQueue(Astro, Astro.url);
---

<TreeseedAppLayout title={vm.collection.title} description={vm.collection.description} currentPath="/app/work/review" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	<CollectionTemplate viewModel={vm.collection} actions={vm.actions}>
		<div class="ts-workspace-grid">
			<WorkQueueSummary viewModel={vm.queue} />
			<ActivityTimeline viewModel={vm.timeline} />
		</div>
	</CollectionTemplate>
</TreeseedAppLayout>
