---
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import PlainTable from '@treeseed/ui/components/astro/app/controls/PlainTable.astro';
import WorkContentNav from '@treeseed/ui/components/astro/app/controls/WorkContentNav.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { escapeHtml as esc } from '../../../lib/market/control-ui.js';
import { loadAppContext } from '../../../view-models/app-access.js';
import { loadWorkContentEntries, workContentEntriesFor, workContentRelationSummary } from '../../../view-models/work-content.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/work/proposals')}`);
const [context, contentEntries] = await Promise.all([
	loadAppContext(Astro),
	loadWorkContentEntries(),
]);
const proposalEntries = workContentEntriesFor(contentEntries, 'proposals');
const rows = proposalEntries.map((entry: any) => ({
	id: `proposal-content-${esc(entry.id)}`,
	name: `<strong>${esc(entry.title)}</strong><span>${esc(entry.summary || entry.description)}</span>`,
	type: esc(entry.type),
	state: esc(entry.status),
	related: esc(workContentRelationSummary(entry)),
	action: `<a class="ts-link-button" href="${esc(entry.href)}">Open</a>`,
}));
---

<TreeseedAppLayout title="Proposals" description="Review proposed changes in the TreeSeed content workspace." currentPath="/app/work/proposals" teams={context.teams} activeTeam={context.activeTeam}>
	<section class="ts-control-page" aria-label="Proposals">
		<WorkContentNav current="proposals" />
		<Panel eyebrow="Work content" title="Proposal records" description="Source content proposals from the active TreeSeed workspace.">
			<Button slot="actions" href="/app/work/proposals/new" size="sm">New proposal</Button>
			<PlainTable columns={[{ key: 'name', label: 'Proposal' }, { key: 'type', label: 'Type' }, { key: 'state', label: 'State' }, { key: 'related', label: 'Related' }, { key: 'action', label: 'Action' }]} rows={rows} emptyTitle="No proposal content yet" emptyDescription="Proposal records appear from src/content/proposals." />
		</Panel>
	</section>
</TreeseedAppLayout>
