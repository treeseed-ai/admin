---
import CollectionTemplate from '@treeseed/ui/components/astro/templates/CollectionTemplate.astro';
import TreeseedAppLayout from '../../../layouts/TreeseedAppLayout.astro';
import { loadDirectionCollection } from '../../../view-models/operating-loop.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/work/proposals')}`);
const vm = await loadDirectionCollection(Astro, 'proposals', Astro.url);
---

<TreeseedAppLayout title={vm.collection.title} description={vm.collection.description} currentPath="/app/work/proposals" teams={vm.context.teams} activeTeam={vm.context.activeTeam} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	<CollectionTemplate viewModel={vm.collection} actions={vm.actions} />
</TreeseedAppLayout>
