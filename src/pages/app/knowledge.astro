---
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import DistributionSummary from '@treeseed/ui/components/astro/distribution/DistributionSummary.astro';
import OverlayStatus from '@treeseed/ui/components/astro/distribution/OverlayStatus.astro';
import TreeseedAppLayout from '../../layouts/TreeseedAppLayout.astro';
import { loadKnowledgeDistributionDashboard } from '../../view-models/knowledge-distribution.vm.js';

if (!Astro.locals.auth?.principal) return Astro.redirect(`/auth/sign-in?returnTo=${encodeURIComponent('/app/knowledge')}`);
const vm = await loadKnowledgeDistributionDashboard(Astro);
---

<TreeseedAppLayout
	title={vm.dashboard.title}
	description={vm.dashboard.description}
	currentPath="/app/knowledge"
	teams={vm.context.teams}
	activeTeam={vm.context.activeTeam}
	helpContext={vm.helpContext}
	feedbackContext={vm.feedbackContext}
>
	<DashboardTemplate viewModel={vm.dashboard} actions={vm.actions}>
		<DistributionSummary viewModel={vm.distribution} />
		<OverlayStatus viewModel={vm.overlayStatus} />
	</DashboardTemplate>
</TreeseedAppLayout>
