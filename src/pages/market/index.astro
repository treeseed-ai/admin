---
import DashboardTemplate from '@treeseed/ui/components/astro/templates/DashboardTemplate.astro';
import TreeseedPublicLayout from '../../layouts/TreeseedPublicLayout.astro';
import { listMarketplaceKnowledgePacks, listMarketplaceSiteTemplates, loadMarketplaceContext } from '../../lib/market/public-access.js';
import { buildMarketDashboard } from '../../view-models/contextual-dashboard.vm.js';

const templateListing = await listMarketplaceSiteTemplates(Astro);
const knowledgePacks = await listMarketplaceKnowledgePacks(Astro);
const marketContext = loadMarketplaceContext(Astro);
const dashboard = buildMarketDashboard({
	url: Astro.url,
	templates: templateListing.items,
	knowledgePacks,
	principal: marketContext.principal,
});
---

<TreeseedPublicLayout
	title={dashboard.viewModel.title}
	description={dashboard.viewModel.description}
	currentPath={Astro.url.pathname}
	helpContext={dashboard.helpContext}
	feedbackContext={dashboard.feedbackContext}
>
	<DashboardTemplate viewModel={dashboard.viewModel} actions={dashboard.actions} />
</TreeseedPublicLayout>
