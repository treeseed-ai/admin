---
import TreeseedPublicLayout from '../../layouts/TreeseedPublicLayout.astro';
import MarketProductCard from '@treeseed/ui/components/astro/market/ProductCard.astro';
import Button from '@treeseed/ui/components/astro/forms/Button.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import { listMarketplaceKnowledgePacks, listMarketplaceSiteTemplates } from '../../lib/market/public-access.js';

const templateListing = await listMarketplaceSiteTemplates(Astro);
const knowledgePacks = await listMarketplaceKnowledgePacks(Astro);
---

<TreeseedPublicLayout
	title="TreeSeed Operational Resources"
	description="Browse reusable workflows, imports, and operational assets inside TreeSeed."
	currentPath={Astro.url.pathname}
>
	<Panel
		eyebrow="Operational Resources"
		title="Reusable workflows, imports, and operational assets"
		description="Resources provide working operational baselines, reusable source material, and governed context for future workdays."
	/>

	<section class="ts-section-grid ts-stack-top">
		<Panel title="Workflow imports" description="Start operational contexts with a proven baseline.">
			<Button slot="actions" href="/market/templates/" variant="secondary" size="sm">Browse imports</Button>
			<div class="ts-card-list">
				{templateListing.items.map((entry) => (
					<MarketProductCard
						href={`/market/templates/${entry.slug}/`}
						slug={entry.slug}
						title={entry.title}
						summary={entry.summary}
						category={entry.category}
						featured={entry.featured}
						publisherName={entry.publisherName}
						templateVersion={entry.templateVersion}
						priceModel={entry.priceModel}
					/>
				))}
			</div>
		</Panel>
		<Panel title="Knowledge imports" description="Reusable knowledge sets with install and trust context attached.">
			<Button slot="actions" href="/market/knowledge-packs/" variant="secondary" size="sm">Browse imports</Button>
			<div class="ts-card-list">
				{knowledgePacks.length > 0 ? knowledgePacks.map((entry: any) => (
					<MarketProductCard
						href={`/market/knowledge-packs/${entry.slug}/`}
						slug={entry.slug}
						title={entry.name}
						summary={entry.summary ?? 'Reusable source material and market-packaged knowledge assets.'}
						category="Knowledge import"
						publisherName="TreeSeed"
						badges={[entry.visibility, entry.installStrategy]}
					/>
				)) : <EmptyState title="No public knowledge packs" description="No public knowledge packs are published yet." />}
			</div>
		</Panel>
	</section>
</TreeseedPublicLayout>
