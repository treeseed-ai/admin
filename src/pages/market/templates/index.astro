---
import CollectionTemplate from '@treeseed/ui/components/astro/templates/CollectionTemplate.astro';
import DistributionSummary from '@treeseed/ui/components/astro/distribution/DistributionSummary.astro';
import TreeseedPublicLayout from '../../../layouts/TreeseedPublicLayout.astro';
import { loadPublicMarketplaceCollection } from '../../../view-models/knowledge-distribution.vm.js';

const vm = await loadPublicMarketplaceCollection(Astro, 'templates');
---

<TreeseedPublicLayout title="TreeSeed Workflow Imports" description="Reusable workflow foundations for operational TreeSeed contexts." currentPath={Astro.url.pathname} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	<CollectionTemplate viewModel={vm.collection} actions={vm.actions} mode="cards">
		<DistributionSummary viewModel={vm.distribution} />
	</CollectionTemplate>
</TreeseedPublicLayout>
