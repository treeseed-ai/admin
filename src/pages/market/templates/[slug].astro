---
import { render } from 'astro:content';
import TreeseedPublicLayout from '../../../layouts/TreeseedPublicLayout.astro';
import Badge from '@treeseed/ui/components/astro/data/Badge.astro';
import KeyValueList from '@treeseed/ui/components/astro/data/KeyValueList.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import { resolveMarketplaceSiteTemplate } from '../../../lib/market/public-access.js';

const slug = Astro.params.slug ?? '';
const template = await resolveMarketplaceSiteTemplate(Astro, slug);
if (!template.rendered || !template.item) {
	Astro.response.status = 404;
}
const contentRender = template.item?.contentEntry ? await render(template.item.contentEntry) : null;
const Content = contentRender?.Content;
---

<TreeseedPublicLayout
	title={`${template.item?.title ?? 'Workflow import'} | TreeSeed`}
	description={template.item?.description ?? 'TreeSeed workflow import detail'}
	currentPath={Astro.url.pathname}
>
	<Panel
		eyebrow="Workflow Import"
		title={template.item?.title ?? 'Unknown workflow import'}
		description={template.item?.description ?? 'This workflow import could not be resolved.'}
	>
		<div class="ts-badges">
			<Badge tone="muted">{template.item?.category ?? 'Workflow import'}</Badge>
			{template.item?.compatibility.templateVersion ? <Badge tone="muted">v{template.item.compatibility.templateVersion}</Badge> : null}
			{template.item?.priceModel ? <Badge tone="muted">{template.item.priceModel.replaceAll('_', ' ')}</Badge> : null}
		</div>
	</Panel>

	{template.item ? (
		<section class="ts-section-grid ts-stack-top">
			<Panel title="Compatibility" description="Version and runtime expectations for this workflow import.">
				<KeyValueList items={[
					{ key: 'Import version', value: template.item.compatibility.templateVersion ?? 'unknown' },
					{ key: 'Import API', value: template.item.compatibility.templateApiVersion ?? 'unknown' },
					{ key: 'Minimum CLI', value: template.item.compatibility.minCliVersion ?? 'unknown' },
					{ key: 'Minimum core', value: template.item.compatibility.minCoreVersion ?? 'unknown' },
				]} />
			</Panel>
			<Panel title="Fulfillment" description="Where this workflow import comes from and how it should be installed.">
				<KeyValueList items={[
					{ key: 'Mode', value: template.item.fulfillment.mode ?? 'unknown' },
					{ key: 'Source', value: template.item.fulfillment.sourceLabel ?? 'unknown' },
					...(template.item.fulfillment.repoUrl ? [{ key: 'Repository', value: template.item.fulfillment.repoUrl }] : []),
					...(template.item.fulfillment.directory ? [{ key: 'Directory', value: template.item.fulfillment.directory }] : []),
					...(template.item.fulfillment.ref ? [{ key: 'Ref', value: template.item.fulfillment.ref }] : []),
					...(template.item.fulfillment.manifestKey ? [{ key: 'Manifest key', value: template.item.fulfillment.manifestKey }] : []),
				]} />
			</Panel>
		</section>
	) : null}

	{Content ? (
		<Panel class="ts-stack-top">
			<Content />
		</Panel>
	) : null}
</TreeseedPublicLayout>
