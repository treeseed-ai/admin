---
import { render } from 'astro:content';
import DetailTemplate from '@treeseed/ui/components/astro/templates/DetailTemplate.astro';
import DistributionSummary from '@treeseed/ui/components/astro/distribution/DistributionSummary.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import TreeseedPublicLayout from '../../../layouts/TreeseedPublicLayout.astro';
import { loadPublicMarketplaceDetail } from '../../../view-models/knowledge-distribution.vm.js';

const slug = String(Astro.params.slug ?? '');
const vm = await loadPublicMarketplaceDetail(Astro, 'templates', slug);
if (!vm.found) Astro.response.status = 404;
const contentRender = vm.templateItem?.contentEntry ? await render(vm.templateItem.contentEntry) : null;
const Content = contentRender?.Content;
---

<TreeseedPublicLayout title={`${vm.title} | TreeSeed`} description={vm.description} currentPath={Astro.url.pathname} helpContext={vm.helpContext} feedbackContext={vm.feedbackContext}>
	{vm.found ? (
		<DetailTemplate title={vm.title} description={vm.description} eyebrow={vm.eyebrow} metadata={vm.metadata} actions={vm.actions}>
			<DistributionSummary viewModel={vm.distribution} />
			{Content ? <Panel><Content /></Panel> : null}
		</DetailTemplate>
	) : (
		<EmptyState title="Workflow import not found" description="This marketplace listing could not be resolved." actions={[{ label: 'Back to Workflow Imports', href: '/market/templates' }]} />
	)}
</TreeseedPublicLayout>
