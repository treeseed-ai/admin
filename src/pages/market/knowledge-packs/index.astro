---
import TreeseedPublicLayout from '../../../layouts/TreeseedPublicLayout.astro';
import MarketProductCard from '@treeseed/ui/components/astro/market/ProductCard.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import EmptyState from '@treeseed/ui/components/astro/surface/EmptyState.astro';
import { listMarketplaceKnowledgePacks } from '../../../lib/market/public-access.js';

const knowledgePacks = await listMarketplaceKnowledgePacks(Astro);
---

<TreeseedPublicLayout
	title="TreeSeed Knowledge Imports"
	description="Packaged operational knowledge assets for TreeSeed."
	currentPath={Astro.url.pathname}
>
	<Panel
		eyebrow="Knowledge Imports"
		title="Reusable direction, context, and source material"
		description="Knowledge imports carry audience, install strategy, trust posture, and reusable operational artifacts."
	/>

	<section class="ts-market-grid ts-stack-top">
		{knowledgePacks.length > 0 ? knowledgePacks.map((entry: any) => (
			<MarketProductCard
				href={`/market/knowledge-packs/${entry.slug}/`}
				slug={entry.slug}
				title={entry.name}
				summary={entry.summary ?? 'Reusable packaged knowledge for teams and agents.'}
				category="Knowledge import"
				publisherName="TreeSeed"
				badges={[entry.visibility, entry.installStrategy, entry.sourceKind]}
			/>
		)) : <EmptyState title="No public knowledge packs" description="No public knowledge packs are available yet." />}
	</section>
</TreeseedPublicLayout>
