---
import TreeseedPublicLayout from '../../../layouts/TreeseedPublicLayout.astro';
import Badge from '@treeseed/ui/components/astro/data/Badge.astro';
import KeyValueList from '@treeseed/ui/components/astro/data/KeyValueList.astro';
import ActionList from '@treeseed/ui/components/astro/data/ActionList.astro';
import Panel from '@treeseed/ui/components/astro/surface/Panel.astro';
import { resolveMarketplaceCatalogItem } from '../../../lib/market/public-access.js';

const slug = Astro.params.slug ?? '';
const { entry, artifacts } = await resolveMarketplaceCatalogItem(Astro, 'knowledge_pack', slug);

if (!entry) {
	Astro.response.status = 404;
}
---

<TreeseedPublicLayout
	title={`${entry?.title ?? 'Knowledge import'} | TreeSeed`}
	description={entry?.summary ?? 'Knowledge import detail'}
	currentPath={Astro.url.pathname}
>
	<Panel
		eyebrow="Knowledge Import"
		title={entry?.title ?? 'Unknown knowledge import'}
		description={entry?.summary ?? 'This knowledge import could not be resolved.'}
	>
		<div class="ts-badges">
			{entry ? <Badge tone="muted">{entry.visibility}</Badge> : null}
			{entry?.offerMode ? <Badge tone="muted">{entry.offerMode.replaceAll('_', ' ')}</Badge> : null}
			{entry?.metadata?.installStrategy ? <Badge tone="muted">{String(entry.metadata.installStrategy)}</Badge> : null}
		</div>
	</Panel>

	<section class="ts-section-grid ts-stack-top">
		<Panel title="Trust and packaging" description="Visibility, source, and publication context carried in the catalog entry.">
			<KeyValueList items={[
				{ key: 'Visibility', value: entry?.visibility ?? 'unknown' },
				{ key: 'Offer mode', value: entry?.offerMode?.replaceAll('_', ' ') ?? 'unknown' },
				{ key: 'Source kind', value: String(entry?.metadata?.sourceKind ?? 'market_import') },
				{ key: 'Install strategy', value: String(entry?.metadata?.installStrategy ?? 'import_export') },
			]} />
		</Panel>
		<Panel title="Published artifacts" description="Artifact versions packaged for this knowledge import.">
			<ActionList
				items={artifacts.map((artifact: any) => ({
					title: artifact.version,
					description: `${artifact.kind} · ${artifact.publishedAt}`,
				}))}
			>
				<div class="ts-empty-inline">No published artifacts are attached yet.</div>
			</ActionList>
		</Panel>
	</section>
</TreeseedPublicLayout>
