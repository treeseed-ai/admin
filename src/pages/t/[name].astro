---
import TreeseedPublicLayout from '../../layouts/TreeseedPublicLayout.astro';
import PublicProfileHeader from '@treeseed/ui/components/astro/public/PublicProfileHeader.astro';
import PublicSection from '@treeseed/ui/components/astro/public/PublicSection.astro';
import PublicStack from '@treeseed/ui/components/astro/public/PublicStack.astro';
import { resolvePublicTeamProfile } from '../../lib/market/public-access.js';

export const prerender = false;

const requestedName = String(Astro.params.name ?? '');
const normalizedName = requestedName.trim().toLowerCase().replace(/[^a-z0-9-]+/gu, '-').replace(/^-+|-+$/gu, '').slice(0, 63);
if (requestedName !== normalizedName && normalizedName) return Astro.redirect(`/t/${normalizedName}`, 301);

const profile: any = await resolvePublicTeamProfile(Astro, normalizedName);
if (!profile?.team) return new Response('Not found', { status: 404 });

const team = profile.team;
const displayName = team.displayName ?? team.name;
const createdDate = team.createdAt
	? new Date(team.createdAt).toLocaleDateString('en', { month: 'long', year: 'numeric' })
	: null;
---

<TreeseedPublicLayout
	title={`${displayName} (@${team.name}) | TreeSeed`}
	description={team.profileSummary ?? `Public TreeSeed team identity for @${team.name}.`}
	currentPath={`/t/${team.name}`}
>
	<PublicStack>
		<PublicProfileHeader
			eyebrow="Team identity"
			name={displayName}
			handle={`@${team.name}`}
			imageSrc={team.logoUrl}
			meta={createdDate ? `Created ${createdDate}` : undefined}
			description={team.profileSummary}
		/>
		<PublicSection title="TreeSeed team" eyebrow="Public identity">
			<p>This profile confirms the public name and identity of a TreeSeed team.</p>
		</PublicSection>
	</PublicStack>
</TreeseedPublicLayout>
