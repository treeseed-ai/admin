---
import TreeseedPublicLayout from '../../layouts/TreeseedPublicLayout.astro';
import { resolveMarketplaceTeamProfile } from '../../lib/market/public-access.js';

export const prerender = false;

const requestedName = String(Astro.params.name ?? '');
const normalizedName = requestedName.trim().toLowerCase().replace(/[^a-z0-9-]+/gu, '-').replace(/^-+|-+$/gu, '').slice(0, 63);
if (requestedName !== normalizedName && normalizedName) {
	return Astro.redirect(`/t/${normalizedName}`, 301);
}

const profile = await resolveMarketplaceTeamProfile(Astro, normalizedName);
if (!profile) {
	return new Response('Not found', { status: 404 });
}

const team = profile.team;
const displayName = team.displayName ?? team.name;
const joinedDate = new Date(team.createdAt).toLocaleDateString('en', { month: 'long', year: 'numeric' });
const visibleCount = profile.activity.projects.length + profile.activity.catalogItems.length + profile.activity.knowledgePacks.length;
---

<TreeseedPublicLayout
	title={`${displayName} (@${team.name}) | TreeSeed`}
	description={team.profileSummary ?? `Public TreeSeed profile for @${team.name}.`}
	currentPath={`/t/${team.name}`}
>
	<main class="ts-section">
		<section class="ts-user-profile">
			<div class="ts-user-profile__avatar" aria-hidden="true">
				{team.logoUrl ? <img src={team.logoUrl} alt="" loading="lazy" /> : <span>{displayName.slice(0, 1).toUpperCase()}</span>}
			</div>
			<div>
				<p class="ts-section__eyebrow">Team profile</p>
				<h1>{displayName}</h1>
				<p class="ts-user-profile__handle">@{team.name}</p>
				<p class="ts-user-profile__meta">Created {joinedDate}</p>
				{team.profileSummary ? <p>{team.profileSummary}</p> : null}
			</div>
		</section>

		<section class="ts-grid-2 ts-profile-activity" aria-label="Team activity">
			<div class="ts-panel">
				<div class="ts-panel__header">
					<h2>Projects</h2>
					<span class="ts-badge">{profile.activity.projects.length}</span>
				</div>
				<div class="ts-list">
					{profile.activity.projects.length > 0 ? profile.activity.projects.map((project: any) => (
						<div class="ts-list-item">
							<strong>{project.name}</strong><br />
							<span>{project.description || project.slug}</span>
						</div>
					)) : <p>No visible projects.</p>}
				</div>
			</div>

			<div class="ts-panel">
				<div class="ts-panel__header">
					<h2>Catalog listings</h2>
					<span class="ts-badge">{profile.activity.catalogItems.length}</span>
				</div>
				<div class="ts-list">
					{profile.activity.catalogItems.length > 0 ? profile.activity.catalogItems.map((item: any) => (
						<a class="ts-list-item" href={`/market/${item.kind === 'knowledge_pack' ? 'knowledge-packs' : 'templates'}/${item.slug}`}>
							<strong>{item.title}</strong><br />
							<span>{item.summary || item.kind}</span>
						</a>
					)) : <p>No visible listings.</p>}
				</div>
			</div>

			<div class="ts-panel">
				<div class="ts-panel__header">
					<h2>Knowledge packs</h2>
					<span class="ts-badge">{profile.activity.knowledgePacks.length}</span>
				</div>
				<div class="ts-list">
					{profile.activity.knowledgePacks.length > 0 ? profile.activity.knowledgePacks.map((pack: any) => (
						<a class="ts-list-item" href={`/market/knowledge-packs/${pack.slug}`}>
							<strong>{pack.name}</strong><br />
							<span>{pack.summary || pack.visibility}</span>
						</a>
					)) : <p>No visible knowledge packs.</p>}
				</div>
			</div>
		</section>
		{visibleCount === 0 ? <p class="ts-muted">No team activity is visible to you yet.</p> : null}
	</main>
	<style>
		.ts-user-profile {
			display: grid;
			grid-template-columns: auto 1fr;
			align-items: center;
			gap: 1rem;
			margin-bottom: 1.5rem;
		}
		.ts-user-profile__avatar {
			width: 5rem;
			height: 5rem;
			border-radius: 8px;
			overflow: hidden;
			display: grid;
			place-items: center;
			background: var(--ts-color-link);
			color: var(--ts-color-accent-text);
			font-weight: 900;
			font-size: 2rem;
		}
		.ts-user-profile__avatar img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
	</style>
</TreeseedPublicLayout>
