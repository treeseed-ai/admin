---
import TreeseedPublicLayout from '../../layouts/TreeseedPublicLayout.astro';
import PublicProfileHeader from '@treeseed/ui/components/astro/public/PublicProfileHeader.astro';
import PublicSection from '@treeseed/ui/components/astro/public/PublicSection.astro';
import PublicStack from '@treeseed/ui/components/astro/public/PublicStack.astro';
import { resolveMarketplaceProjectProfile } from '../../lib/market/public-access.js';

export const prerender = false;

const requestedProject = String(Astro.params.project ?? '');
const normalizedProject = requestedProject.trim().toLowerCase().replace(/[^a-z0-9-]+/gu, '-').replace(/^-+|-+$/gu, '').slice(0, 63);
if (requestedProject !== normalizedProject && normalizedProject) {
	return Astro.redirect(`/p/${normalizedProject}`, 301);
}

const profile = await resolveMarketplaceProjectProfile(Astro, normalizedProject);
if (!profile) {
	return new Response('Not found', { status: 404 });
}

const project = profile.project;
const team = profile.team;
const displayName = project.name ?? project.slug;
const teamName = team.displayName ?? team.name;
const createdDate = project.createdAt ? new Date(project.createdAt).toLocaleDateString('en', { month: 'long', year: 'numeric' }) : null;
---

<TreeseedPublicLayout
	title={`${displayName} | TreeSeed`}
	description={project.description ?? `Public TreeSeed project profile for ${displayName}.`}
	currentPath={`/p/${project.slug}`}
>
	<PublicStack>
		<PublicProfileHeader
			eyebrow="Project profile"
			name={displayName}
			handle={`/${project.slug}`}
			description={project.description}
			meta={createdDate ? `Created ${createdDate}` : undefined}
		/>
		<PublicSection
			eyebrow="Public team"
			title={teamName}
			description={team.profileSummary ?? `This project is published by @${team.name}.`}
			actions={[{ label: 'Open team profile', href: `/t/${team.name}` }]}
		/>
	</PublicStack>
</TreeseedPublicLayout>
