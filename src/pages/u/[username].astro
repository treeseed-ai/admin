---
import TreeseedPublicLayout from '../../layouts/TreeseedPublicLayout.astro';
import ProfileTemplate from '@treeseed/ui/components/astro/templates/ProfileTemplate.astro';
import { normalizeUsername, validateUsername } from '../../lib/auth/profile-validation';
import { resolvePublicUserProfile } from '../../lib/market/public-access.js';

export const prerender = false;

const requestedUsername = String(Astro.params.username ?? '');
const normalizedUsername = normalizeUsername(requestedUsername);
if (requestedUsername !== normalizedUsername && validateUsername(normalizedUsername).ok) {
	return Astro.redirect(`/u/${normalizedUsername}`, 301);
}
const profile: any = await resolvePublicUserProfile(Astro, normalizedUsername);
if (!profile?.user) return new Response('Not found', { status: 404 });

const user = profile.user;
const displayName = user.displayName || `@${user.username}`;
const joinedDate = user.joinedAt
	? new Date(user.joinedAt).toLocaleDateString('en', { month: 'long', year: 'numeric' })
	: null;
---

<TreeseedPublicLayout
	title={`${displayName} (@${user.username}) | TreeSeed`}
	description={`Public TreeSeed identity for @${user.username}.`}
	currentPath={`/u/${user.username}`}
>
	<ProfileTemplate title={displayName} description="Public TreeSeed account identity." handle={user.username} image={user.image} metadata={joinedDate ? [{ label: 'Joined', value: joinedDate }] : []}>
		<p>This profile confirms the public username and display identity associated with a TreeSeed account.</p>
	</ProfileTemplate>
</TreeseedPublicLayout>
