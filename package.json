{
  "name": "@treeseed/admin",
  "version": "0.12.59-dev.staging.20260716T154320Z",
  "description": "Treeseed administration portal framework built on @treeseed/core and @treeseed/ui.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/treeseed-ai/admin.git",
    "directory": "."
  },
  "homepage": "https://treeseed.ai",
  "bugs": {
    "url": "https://github.com/treeseed-ai/admin/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "README.md",
    "dist",
    "scripts/verify-driver.ts"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "check:file-lengths": "node --import tsx ./scripts/check-file-lengths.ts && npm run check:file-architecture",
    "check:file-architecture": "node --import tsx ./scripts/check-file-architecture.ts",
    "setup": "npm install",
    "setup:ci": "npm ci --workspaces=false",
    "build": "npm run build:dist",
    "build:dist": "node --import tsx ./scripts/build-dist.ts",
    "prepare": "node --import tsx ./scripts/prepare.ts",
    "prepack": "npm run build:dist",
    "check": "npm run check:file-lengths && npm run build:dist && tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "vitest run --config ./vitest.config.ts",
    "lint": "npm run check",
    "verify:direct": "npm run release:verify",
    "verify:local": "TREESEED_VERIFY_DRIVER=direct TMPDIR=/tmp node --import tsx ./scripts/verify-driver.ts",
    "verify:action": "TREESEED_VERIFY_DRIVER=act TMPDIR=/tmp node --import tsx ./scripts/verify-driver.ts",
    "verify": "TMPDIR=/tmp node --import tsx ./scripts/verify-driver.ts",
    "release:setup": "npm run setup:ci",
    "release:check-tag": "node --import tsx ./scripts/assert-release-tag-version.ts",
    "release:verify": "npm run check:file-lengths && npm run build:dist && npm run test:unit",
    "release:publish": "node --import tsx ./scripts/publish-package.ts"
  },
  "dependencies": {
    "@react-email/render": "^2.0.8",
    "@treeseed/core": "github:treeseed-ai/core#784c3b0f770a3f2252445d8da6006b884b2252b3",
    "@treeseed/sdk": "github:treeseed-ai/sdk#363356034d2717f401f4cdd0c54b22c16dffc60c",
    "@treeseed/ui": "github:treeseed-ai/ui#84b54513a13691dc55a5868ab2e97b3f14f83fd6",
    "react": "^19.2.5",
    "react-dom": "^19.2.6"
  },
  "peerDependencies": {
    "astro": "^5.0.0 || ^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.4.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./content-config": {
      "types": "./dist/content-config.d.ts",
      "default": "./dist/content-config.js"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "default": "./dist/plugin.js"
    },
    "./routes": {
      "types": "./dist/routes.d.ts",
      "default": "./dist/routes.js"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "default": "./dist/middleware.js"
    },
    "./commerce": {
      "types": "./dist/commerce.d.ts",
      "default": "./dist/commerce.js"
    },
    "./secret-managers": {
      "types": "./dist/secret-managers.d.ts",
      "default": "./dist/secret-managers.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "default": "./dist/lib/*.js"
    },
    "./view-models/*": {
      "types": "./dist/view-models/*.d.ts",
      "default": "./dist/view-models/*.js"
    },
    "./layouts/TreeseedAppLayout.astro": "./dist/layouts/TreeseedAppLayout.astro",
    "./layouts/TreeseedPublicLayout.astro": "./dist/layouts/TreeseedPublicLayout.astro"
  }
}
